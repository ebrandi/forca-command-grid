# =============================================================================
#  [FORCA] Command Grid — environment configuration template
# =============================================================================
# Copy this file to `.env` in the repository root and fill it in:
#
#     cp .env.example .env
#
# The production deploy script (deploy/deploy-ubuntu-26.04.sh) generates a `.env`
# with strong random secrets automatically — you only edit the EVE SSO + contact
# values afterward. This template documents EVERY variable the app reads so you
# can configure a self-hosted instance by hand if you prefer.
#
# NEVER commit a filled-in `.env` (it is git-ignored). Keep it mode 600.
#
# Legend:  [REQUIRED] must be set or the app refuses to boot in production.
#          [sensitive] a secret — treat like a password, never log or commit.
#          Everything else has a working default (shown) and is optional.
# =============================================================================


# -----------------------------------------------------------------------------
#  1. Django core
# -----------------------------------------------------------------------------
# Which settings module to load. Use config.settings.prod for a real deployment,
# config.settings.dev for local development.
DJANGO_SETTINGS_MODULE=config.settings.prod

# [REQUIRED] [sensitive] Django cryptographic secret. Boot fails in prod if this
# is missing or left at the insecure dev default. Generate:
#     openssl rand -base64 50
DJANGO_SECRET_KEY=change-me-generate-50-random-bytes

# Debug mode. MUST stay 0 in production (1 leaks stack traces + disables security).
DJANGO_DEBUG=0

# [REQUIRED] Comma-separated Host header allowlist. Boot fails in prod if unset.
# Use your public domain(s); include bare host for internal healthchecks.
DJANGO_ALLOWED_HOSTS=grid.example.com

# CSRF trusted origins (scheme + host). If left blank, prod derives https://<host>
# for each DJANGO_ALLOWED_HOSTS entry, which is correct for a standard TLS setup.
DJANGO_CSRF_TRUSTED_ORIGINS=https://grid.example.com

# Stock Django /admin is DISABLED by default in prod (the app uses its own
# role-gated console at /ops/). Set to 1 only as a deliberate break-glass.
DJANGO_ENABLE_ADMIN=0

# Session lifetimes (seconds). Defaults: 12h sliding idle, 7d absolute cap.
# DJANGO_SESSION_COOKIE_AGE=43200
# DJANGO_SESSION_ABSOLUTE_MAX_AGE=604800

# Root log level: DEBUG | INFO | WARNING | ERROR.
DJANGO_LOG_LEVEL=INFO

# Persistent DB connection lifetime (seconds). 0 disables connection reuse.
# DJANGO_CONN_MAX_AGE=60

# Director "view-as" (impersonation) auto-exit cap, in minutes. Clamped to 1..1440.
# IMPERSONATION_MAX_MINUTES=30

# Transport-security escape hatches. All default to the SECURE value; only relax
# them for an internal HTTP-only test box, NEVER for an internet-facing instance.
# Setting any of these to 0 exposes session/CSRF cookies over plaintext HTTP.
# DJANGO_SECURE_SSL_REDIRECT=1     # 0 = do not redirect http:// to https://
# DJANGO_SESSION_COOKIE_SECURE=1   # 0 = send the session cookie over HTTP
# DJANGO_CSRF_COOKIE_SECURE=1      # 0 = send the CSRF cookie over HTTP
# DJANGO_HSTS_SECONDS=31536000     # 0 = send no Strict-Transport-Security header
# The language cookie follows DJANGO_SESSION_COOKIE_SECURE unless set explicitly.
# DJANGO_LANGUAGE_COOKIE_SECURE=1  # 0 = send the language cookie over HTTP

# I18N_ENABLED is an ops HARD kill switch for localisation (default on); set 0 to
# short-circuit locale resolution and serve every page in English. Which languages
# the selector offers is a separate, leadership-set choice in the Admin Console
# (/ops/admin/i18n/) — a fresh install offers English only.
# I18N_ENABLED=1


# -----------------------------------------------------------------------------
#  2. Database (PostgreSQL 16)
# -----------------------------------------------------------------------------
# These POSTGRES_* values seed the postgres container AND must match DATABASE_URL.
POSTGRES_DB=forca
POSTGRES_USER=forca
# [sensitive] Generate:  openssl rand -base64 24 | tr -d '/+='
POSTGRES_PASSWORD=change-me

# [sensitive] Full connection URL the app uses. Host is the compose service name
# `postgres`. Keep the password identical to POSTGRES_PASSWORD above.
DATABASE_URL=postgres://forca:change-me@postgres:5432/forca


# -----------------------------------------------------------------------------
#  3. Redis (cache + Celery broker/result backend)
# -----------------------------------------------------------------------------
# [sensitive] Password for the redis container. Generate:
#     openssl rand -base64 24 | tr -d '/+='
REDIS_PASSWORD=change-me

# Connection URLs (host is the compose service name `redis`). The password must
# match REDIS_PASSWORD. DB 0 = cache, DB 1 = Celery broker (a common split).
REDIS_URL=redis://:change-me@redis:6379/0
CELERY_BROKER_URL=redis://:change-me@redis:6379/1
# Defaults to REDIS_URL; set only to store results somewhere else.
# CELERY_RESULT_BACKEND=


# -----------------------------------------------------------------------------
#  4. Token encryption at rest (OAuth refresh tokens, comms credentials)
# -----------------------------------------------------------------------------
# [REQUIRED] [sensitive] Fernet key — 32 url-safe base64 bytes WITH padding.
# Boot fails in prod if unset. LOSING THIS makes stored refresh tokens
# unrecoverable (members simply re-authorise). Back it up securely. Generate:
#     openssl rand -base64 32 | tr '+/' '-_'
TOKEN_ENCRYPTION_KEY=change-me-urlsafe-base64-32-bytes


# -----------------------------------------------------------------------------
#  5. EVE SSO / ESI  (register an app at https://developers.eveonline.com)
# -----------------------------------------------------------------------------
# Primary login application. Its redirect_uri MUST equal EVE_SSO_CALLBACK_URL.
EVE_SSO_CLIENT_ID=
# [sensitive]
EVE_SSO_CLIENT_SECRET=
EVE_SSO_CALLBACK_URL=https://grid.example.com/auth/eve/callback/

# Identify the app to CCP per ESI policy: app name/version + a contact CCP can
# reach. Set a REAL contact email — CCP may rate-limit or block a generic UA.
ESI_USER_AGENT=forca-command-grid/1.0 (you@example.com)

# Pin the ESI compatibility date; bump deliberately after testing.
ESI_COMPATIBILITY_DATE=2026-06-21

# Your home corporation's EVE id (numeric). Find it via zKillboard/EVE tools.
FORCA_HOME_CORP_ID=

# ESI scopes requested at login. The default is the minimum the app's features need.
# Only ADD a scope when you enable a feature that requires it — every extra scope is
# data your members hand over. Comma-separated.
# EVE_SSO_DEFAULT_SCOPES=publicData,esi-skills.read_skills.v1,...

# Canonical public base URL. Used to build ABSOLUTE links in messages sent
# off-site by background workers (Discord / EVE-mail), which have no request to
# derive a host from. Leave blank to fall back to relative links.
FORCA_SITE_URL=https://grid.example.com

# Corp display/branding name shown in the UI.
# FORCA_CORP_NAME=Forças Armadas

# ESI + image endpoints (defaults are correct; override only for testing).
# ESI_BASE_URL=https://esi.evetech.net           # must be https + esi.evetech.net
# EVE_IMAGE_BASE_URL=/eveimg                       # prod serves images locally via nginx
# EVE_IMAGE_SOURCE_URL=https://images.evetech.net  # source for mirror_type_images
# EVE_IMAGE_MIRROR_DIR=/app/eveimg                 # where mirror_type_images writes


# -----------------------------------------------------------------------------
#  6. Recruitment SSO  (OPTIONAL — a SECOND EVE application)
# -----------------------------------------------------------------------------
# Read-only candidate vetting: a separate registered EVE app with a dedicated,
# NON-login callback, used once per consenting candidate to read skills + corp
# roles (token never stored). Leave blank to keep recruitment public-evidence-only.
RECRUITMENT_SSO_CLIENT_ID=
# [sensitive]
RECRUITMENT_SSO_CLIENT_SECRET=
RECRUITMENT_SSO_CALLBACK_URL=https://grid.example.com/recruitment/oauth/callback/


# -----------------------------------------------------------------------------
#  7. Discord role sync (comms_access)  (OPTIONAL)
# -----------------------------------------------------------------------------
# The whole subsystem is configured in the Admin Console (/ops/admin/comms-access/);
# the bot token + OAuth secret are stored ENCRYPTED on a console row and a console
# value always wins. The vars below are an optional fallback for env-based setups.
# COMMS_ACCESS_ENABLED is an ops HARD kill switch (default on); set 0 to fully
# disable regardless of console state.
# COMMS_ACCESS_ENABLED=1
# DISCORD_BOT_TOKEN=                # [sensitive] bot with Manage Roles on your guild
# DISCORD_OAUTH_CLIENT_ID=
# DISCORD_OAUTH_CLIENT_SECRET=      # [sensitive]
# DISCORD_OAUTH_CALLBACK_URL=https://grid.example.com/comms/discord/callback/


# -----------------------------------------------------------------------------
#  8. LLM / Command Intelligence  (OPTIONAL — strategic AI features)
# -----------------------------------------------------------------------------
# Empty LLM_API_KEY disables the command_intel subsystem cleanly. If you set a
# fallback, you MUST set BOTH LLM_FALLBACK_API_KEY and LLM_FALLBACK_BASE_URL
# (a half-configured fallback makes the app refuse to boot). Any *_BASE_URL must
# be https and its host present in the matching *_ALLOWED_HOSTS list.
# LLM_PROVIDER=minimax
# LLM_API_KEY=                      # [sensitive]
# LLM_MODEL=MiniMax-M2.7
# LLM_BASE_URL=https://api.minimax.io/v1
# LLM_ALLOWED_HOSTS=api.minimax.io
# LLM_TIMEOUT=120
# LLM_FALLBACK_PROVIDER=minimax
# LLM_FALLBACK_API_KEY=             # [sensitive]
# LLM_FALLBACK_MODEL=
# LLM_FALLBACK_BASE_URL=
# LLM_FALLBACK_ALLOWED_HOSTS=


# -----------------------------------------------------------------------------
#  9. Pingboard alert channels  (OPTIONAL — Slack / Telegram / WhatsApp)
# -----------------------------------------------------------------------------
# Telegram + WhatsApp are configured 100% in the Admin Console (credentials stored
# encrypted per-channel); a console value always wins. The vars below are an
# optional fallback for older installs — leave blank on a new deployment.
# PINGBOARD_SLACK_BOT_TOKEN=        # [sensitive] xoxb-... enables workspace posts+DMs
# PINGBOARD_TELEGRAM_BOT_TOKEN=     # [sensitive]
# PINGBOARD_TELEGRAM_WEBHOOK_SECRET=  # [sensitive] only for pilot self-linking
# PINGBOARD_TELEGRAM_BOT_USERNAME=
# PINGBOARD_WHATSAPP_BACKEND=none   # none | meta | twilio
# PINGBOARD_WHATSAPP_META_TOKEN=    # [sensitive]
# PINGBOARD_WHATSAPP_META_PHONE_ID=
# PINGBOARD_WHATSAPP_META_API_VERSION=v21.0   # Meta Graph API version
# PINGBOARD_WHATSAPP_TWILIO_SID=    # [sensitive]
# PINGBOARD_WHATSAPP_TWILIO_TOKEN=  # [sensitive]
# PINGBOARD_WHATSAPP_TWILIO_FROM=

# SSRF guards: outbound provider calls are refused unless the target host is on these
# allowlists. The defaults are the real provider endpoints — widen them only if you
# front a provider with your own proxy, and never add an internal/RFC1918 host.
# PINGBOARD_SLACK_ALLOWED_HOSTS=slack.com,hooks.slack.com
# PINGBOARD_TELEGRAM_ALLOWED_HOSTS=api.telegram.org
# PINGBOARD_WHATSAPP_ALLOWED_HOSTS=graph.facebook.com,api.twilio.com


# -----------------------------------------------------------------------------
#  10. Host sizing  (OPTIONAL — only if your VM is bigger than the 4 GB minimum)
# -----------------------------------------------------------------------------
# The compose defaults are sized for the documented minimum host (2 vCPU / 4 GB
# RAM / 25 GB disk). Every value below is a docker-compose override — raise them
# here rather than editing docker-compose.prod.yml.
#
# Postgres. shared_buffers ~25% of RAM; effective_cache_size ~50-75% of RAM (a
# planner HINT, not an allocation — setting it above real RAM produces bad plans).
#    4 GB host -> 1GB / 2GB       8 GB host -> 2GB / 4GB
#   16 GB host -> 4GB / 8GB      32 GB host -> 8GB / 24GB
# POSTGRES_SHARED_BUFFERS=1GB
# POSTGRES_EFFECTIVE_CACHE_SIZE=2GB
# POSTGRES_WORK_MEM=8MB
# POSTGRES_MAINTENANCE_WORK_MEM=256MB
# POSTGRES_AUTOVACUUM_WORK_MEM=256MB  # per-autovacuum-worker cap, pinned apart from maintenance_work_mem
# POSTGRES_MAX_CONNECTIONS=100
# POSTGRES_PARALLEL_WORKERS=2
# POSTGRES_SHM_SIZE=512m          # /dev/shm for parallel-query and hash segments
# POSTGRES_MEM_LIMIT=2g           # keep well above shared_buffers + shm + work_mem
# Planner I/O costs default to SSD/NVMe. On a spinning-disk (HDD/RAID) host, raise them:
# POSTGRES_RANDOM_PAGE_COST=1.1        # HDD: ~4.0 (or 2.0-3.0 crediting a RAID + controller cache)
# POSTGRES_EFFECTIVE_IO_CONCURRENCY=200 # HDD: ~2-4 (roughly the spindle count); 200 suits SSD/NVMe

# Application concurrency. Rule of thumb: GUNICORN_WORKERS = 2 x vCPU + 1.
# GUNICORN_WORKERS=3
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=120            # worker request timeout (s); raise if heavy pages get SIGKILLed
# CELERY_CONCURRENCY=4
# CELERY_MAX_TASKS_PER_CHILD=100  # recycle each worker child after N tasks to bound RSS creep (0 = off)

# Container memory caps (backstops against a leak, not reservations).
# WEB_MEM_LIMIT=1g
# WORKER_MEM_LIMIT=1536m          # SDE/EveRef imports are the heaviest jobs
# BEAT_MEM_LIMIT=384m
# NGINX_MEM_LIMIT=192m
# REDIS_MEM_LIMIT=384m
# REDIS_MAXMEMORY=256mb           # cache eviction ceiling; keep under REDIS_MEM_LIMIT


# -----------------------------------------------------------------------------
#  11. Email  (OPTIONAL — leadership briefings / notifications)
# -----------------------------------------------------------------------------
# With no EMAIL_HOST, Django uses the console backend (emails are logged, not sent).
# Override the backend only for testing (e.g. django.core.mail.backends.dummy.EmailBackend).
# EMAIL_BACKEND=
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=              # [sensitive]
# EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=forca@grid.example.com
# FORCA_BRIEFING_EMAILS=           # comma-separated recipients of scheduled briefings


# -----------------------------------------------------------------------------
#  12. Combat Signatures  (OPTIONAL — banner render + rate-limit knobs)
# -----------------------------------------------------------------------------
# Pilot-authored public banner PNGs, pre-rendered off-request by the Celery beat and
# served off disk by nginx. The leadership-facing options (enable, quota, refresh
# interval, revoke-on-leave) live on the admin console; these are the operator knobs.
# Defaults suit a typical corp — tune only if you have a reason.
# SIGNATURE_RENDER_MAX_FAILURES=5   # park a render after N consecutive failures (until edit/regenerate)
# SIGNATURE_RENDER_MAX_PER_TICK=30  # max banners re-rendered per 10-min tick (worker-budget cap)
# SIGNATURE_PUBLIC_RATE=120         # per-IP req/min on the public delivery FALLBACK (nginx serves bypass this); 0 disables
# SIGNATURE_PREVIEW_RATE=10         # per-user req/min for the in-builder synchronous preview; 0 disables
# SIGNATURE_REGENERATE_RATE=5       # per-user req/min for the manual regenerate action; 0 disables
