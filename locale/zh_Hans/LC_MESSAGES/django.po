msgid "If set, the deadline tracks this many minutes before form-up."
msgstr "若设置，截止时间将设为集结前的这么多分钟。"

#: apps/operations/models.py
msgid "Organiser confirmed the op runs even if the minimum isn't met."
msgstr "组织者已确认即使未达到最低人数，行动也照常进行。"

#: apps/operations/models.py
msgid "Fleet commander / organiser."
msgstr "Fleet commander / 组织者。"

#: apps/operations/models.py
msgid "Pilots required on this ship."
msgstr "这艘舰船所需的飞行员数。"

#: apps/operations/models.py
msgid "Optional hard cap (blank = no cap)."
msgstr "可选的硬性上限（留空 = 无上限）。"

#: apps/operations/models.py
msgid "1 = most needed; shown first."
msgstr "1 = 最需要；优先显示。"

#: apps/operations/models.py
msgid "The doctrine fit this slot is for, if it's an official doctrine ship."
msgstr "此槽位对应的 doctrine 配装（如果它是官方 doctrine 舰船）。"

#: apps/operations/models.py
msgid "EFT for a non-doctrine (custom) ship."
msgstr "非 doctrine（自定义）舰船的 EFT。"

#: apps/operations/models.py templates/operations/detail.html
