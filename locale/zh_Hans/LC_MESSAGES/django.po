#, python-format
msgid "Audience role must be one of: %(roles)s."
msgstr "受众角色必须是以下之一：%(roles)s。"

#: apps/admin_audit/console_pingboard.py
msgid "Window must be at least 1 minute."
msgstr "时间窗口至少为 1 分钟。"

#: apps/admin_audit/console_pingboard.py
msgid "Cooldown can't be negative."
msgstr "冷却时间不能为负。"

#: apps/admin_audit/console_pingboard.py
msgid "Max per window can't be negative (0 = unlimited)."
msgstr "每个窗口的上限不能为负（0 = 不限）。"

#: apps/admin_audit/console_pingboard.py
msgid "Channels must be a JSON list of channel keys, e.g. [\"in_app\", \"discord\"]."
msgstr "频道必须是一个由频道键组成的 JSON 列表，例如 [\"in_app\", \"discord\"]。"

