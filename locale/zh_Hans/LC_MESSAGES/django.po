msgid "Only a Director can cancel a contest."
msgstr "只有总监才能取消抽奖活动。"

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Contest moved to %(status)s."
msgstr "抽奖活动已转为 %(status)s。"

#: apps/admin_audit/console_raffle.py
msgid "That status change isn't allowed from the current state."
msgstr "当前状态不允许进行该状态变更。"

