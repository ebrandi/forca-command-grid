#: apps/navigation/jump_service.py
#, python-format
msgid "Gate: %(origin)s (high-sec) → %(entry)s"
msgstr "星门：%(origin)s（high-sec）→ %(entry)s"

#: apps/navigation/jump_service.py
#, python-format
msgid "Jump: %(entry)s → %(dest)s"
msgstr "跳跃：%(entry)s → %(dest)s"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Gate out of %(origin)s to %(entry)s (%(security)s), light a cyno there, then "
"jump."
msgstr ""
"从 %(origin)s 走星门到 %(entry)s（%(security)s），在那里点亮 cyno，然后跳跃。"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Couldn't find a low-sec entry near %(origin)s that can jump to a low-sec "
"exit near %(dest)s. The high-sec pockets may be too far apart for this "
"hull's range."
msgstr ""
"找不到 %(origin)s 附近能跳跃到 %(dest)s 附近 low-sec 出口的 low-sec 入口。这"
"两片 high-sec 区域之间的距离可能超出了该船体的跳跃距离。"

#: apps/navigation/jump_service.py
msgid "No jump route between the chosen entry and exit systems."
msgstr "所选入口星系与出口星系之间没有跳跃路线。"

#: apps/navigation/jump_service.py
#, python-format
msgid "Jump: %(entry)s → %(exit)s"
msgstr "跳跃：%(entry)s → %(exit)s"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Two gate legs: out of %(origin)s to %(entry)s, and from %(exit)s into "
"%(dest)s. Fuel covers the jump between them only."
msgstr ""
"两段星门航程：从 %(origin)s 到 %(entry)s，以及从 %(exit)s 到 %(dest)s。燃料仅"
"覆盖两者之间的跳跃。"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Range %(range)s ly (%(ship)s, base %(base)s ly × JDC %(jdc)s). JDC affects "
"range only."
msgstr ""
"跳跃距离 %(range)s 光年（%(ship)s，基础 %(base)s 光年 × JDC %(jdc)s）。JDC 只"
"影响距离。"

#: apps/navigation/jump_service.py
#, python-format
msgid "Fuel %(base)s %(isotope)s/ly base, −10%%/level JFC (JFC %(jfc)s)."
msgstr ""
"燃料基础消耗 %(base)s 单位 %(isotope)s/光年，JFC 每级 −10%%（JFC %(jfc)s）。"

#: apps/navigation/jump_service.py
#, python-format
msgid "Jump Freighters skill saves a further −10%%/level (JF %(jf)s)."
msgstr "Jump Freighters 技能每级再节省 −10%%（JF %(jf)s）。"

#: apps/navigation/jump_service.py
#, python-format
msgid "%(rigs)s× Jump Drive Economizer rig fitted."
msgstr "已装配 %(rigs)s× Jump Drive Economizer 改装件。"

#: apps/navigation/jump_service.py
msgid ""
"Fuel is rounded up per jump (never under-fuel) and covers jump legs only — "
"gate legs burn no isotopes."
msgstr ""
"燃料按每次跳跃向上取整（绝不少装），且仅计入跳跃航段 —— 星门航段不消耗同位"
"素。"

#: apps/navigation/jump_service.py
#, python-format
msgid "Includes a %(pct)s%% fuel safety margin."
msgstr "已包含 %(pct)s%% 的燃料安全余量。"

#: apps/navigation/jump_service.py
msgid "No market price for the fuel isotope — ISK cost unavailable."
msgstr "燃料同位素没有市场价格 —— 无法计算 ISK 成本。"

