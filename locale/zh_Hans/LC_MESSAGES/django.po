msgid "ship_owned.type_ids must be a non-empty list."
msgstr "ship_owned.type_ids 必须是非空列表。"

#: apps/capsuleer/params.py
msgid "ship_owned.require_fitted must be a boolean."
msgstr "ship_owned.require_fitted 必须是布尔值。"

#: apps/capsuleer/params.py
msgid "contribution.baseline_count is system-managed, not author-supplied."
msgstr "contribution.baseline_count 由系统管理，不由作者提供。"

#: apps/capsuleer/params.py
