msgid "doctrine_ready.resolver must be 'category' or 'key'."
msgstr "doctrine_ready.resolver 必须是 'category' 或 'key'。"

#: apps/capsuleer/params.py
msgid "doctrine_ready.unresolved must be a boolean."
msgstr "doctrine_ready.unresolved 必须是布尔值。"

#: apps/capsuleer/params.py
