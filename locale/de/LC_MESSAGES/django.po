msgid "Mentor reviews your UI setup"
msgstr "Mentor überprüft dein UI-Setup"

#: apps/mentorship/tracks_i18n.py
msgid "Learn session-change timers & gate cloak"
msgstr "Lerne Session-Change-Timer & Gate-Cloak"

#: apps/mentorship/tracks_i18n.py
msgid "Learn to use directional scan"
msgstr "Lerne, den Directional Scan zu nutzen"

#: apps/mentorship/tracks_i18n.py
msgid "Create safe spots, tacticals & bookmarks"
msgstr "Erstelle Safespots, Tacticals & Bookmarks"

#: apps/mentorship/tracks_i18n.py
msgid "Complete a travel exercise with your mentor"
msgstr "Absolviere eine Reiseübung mit deinem Mentor"

#: apps/mentorship/tracks_i18n.py
msgid "Learn high/mid/low/rig/drone/cargo slots"
msgstr "Lerne High-/Mid-/Low-/Rig-/Drohnen-/Cargo-Slots"

#: apps/mentorship/tracks_i18n.py
msgid "Learn CPU/PG, cap, resists, tank, range & application"
msgstr "Lerne CPU/PG, Cap, Resists, Tank, Reichweite & Application"

#: apps/mentorship/tracks_i18n.py
msgid "Review a corp doctrine fit with your mentor"
msgstr "Geh mit deinem Mentor einen Corp-Doctrine-Fit durch"

#: apps/mentorship/tracks_i18n.py
msgid "Be able to fly a corp doctrine ship"
msgstr "Sei in der Lage, ein Corp-Doctrine-Schiff zu fliegen"

#: apps/mentorship/tracks_i18n.py
msgid "Create a skill plan toward a doctrine"
msgstr "Erstelle einen Skillplan Richtung Doctrine"

#: apps/mentorship/tracks_i18n.py
msgid "Learn safe ratting practice & aligning out"
msgstr "Lerne sicheres Ratting & das Aligning-Out"

#: apps/mentorship/tracks_i18n.py
msgid "Learn site selection & when to dock up"
msgstr "Lerne die Site-Auswahl & wann du docken solltest"

#: apps/mentorship/tracks_i18n.py
msgid "Run a ratting session with your mentor nearby"
msgstr "Absolviere eine Ratting-Session mit deinem Mentor in der Nähe"

#: apps/mentorship/tracks_i18n.py
msgid "Review a near-miss, loss or good tick"
msgstr "Besprich einen Beinahe-Verlust, einen Loss oder einen guten Tick"

#: apps/mentorship/tracks_i18n.py
msgid "Learn mining ship roles & compression"
msgstr "Lerne die Rollen der Mining-Schiffe & Komprimierung"

#: apps/mentorship/tracks_i18n.py
msgid "Learn the corp buyback flow"
msgstr "Lerne den Corp-Buyback-Ablauf"

#: apps/mentorship/tracks_i18n.py
msgid "Join a mining session"
msgstr "Nimm an einer Mining-Session teil"

#: apps/mentorship/tracks_i18n.py
msgid "Submit a buyback lot"
msgstr "Reiche ein Buyback-Los ein"

#: apps/mentorship/tracks_i18n.py
msgid "Learn probe scanning"
msgstr "Lerne das Probe-Scanning"

#: apps/mentorship/tracks_i18n.py
msgid "Learn the hacking minigame"
msgstr "Lerne das Hacking-Minispiel"

#: apps/mentorship/tracks_i18n.py
msgid "Learn wormhole safety basics"
msgstr "Lerne die Grundlagen der Wormhole-Sicherheit"

#: apps/mentorship/tracks_i18n.py
msgid "Complete an exploration practice run"
msgstr "Absolviere einen Exploration-Übungslauf"

#: apps/mentorship/tracks_i18n.py
msgid "Learn tackle: scram, web, point, prop & transversal"
msgstr "Lerne Tackle: scram, web, point, prop & transversal"

#: apps/mentorship/tracks_i18n.py
msgid "Learn to follow FC commands & broadcasts"
msgstr "Lerne, FC-Befehlen & Broadcasts zu folgen"

#: apps/mentorship/tracks_i18n.py
msgid "Join a training roam or home-defence fleet"
msgstr "Nimm an einem Trainings-Roam oder einer Home-Defence-Fleet teil"

#: apps/mentorship/tracks_i18n.py
msgid "Review a killmail or lossmail with your mentor"
msgstr "Besprich ein Killmail oder Lossmail mit deinem Mentor"

#: apps/mentorship/tracks_i18n.py
msgid "Learn fleet roles, anchoring & the watchlist"
msgstr "Lerne Fleet-Rollen, Anchoring & die Watchlist"

#: apps/mentorship/tracks_i18n.py
msgid "Demonstrate correct broadcast usage"
msgstr "Demonstriere die korrekte Broadcast-Nutzung"

#: apps/mentorship/tracks_i18n.py
msgid "Fly a real corp fleet op"
msgstr "Fliege einen echten Corp-Fleet-Op"

#: apps/mentorship/tracks_i18n.py
msgid "Complete a mentor debrief after the op"
msgstr "Absolviere nach dem Op ein Mentor-Debrief"

#: apps/mentorship/tracks_i18n.py
msgid "Learn how to request freight & how courier contracts work"
msgstr "Lerne, wie man Fracht anfordert & wie Courier-Contracts funktionieren"

#: apps/mentorship/tracks_i18n.py
msgid "Learn the corp buyback rules"
msgstr "Lerne die Corp-Buyback-Regeln"

#: apps/mentorship/tracks_i18n.py
msgid "Complete a courier contract (or example)"
msgstr "Schließe einen Courier-Contract (oder ein Beispiel) ab"

#: apps/mentorship/tracks_i18n.py
msgid "Mentor confirms you understand the flow"
msgstr "Mentor bestätigt, dass du den Ablauf verstehst"

#: apps/mentorship/tracks_i18n.py
msgid "Learn blueprint basics (BPO vs BPC)"
msgstr "Lerne die Blueprint-Grundlagen (BPO vs. BPC)"

#: apps/mentorship/tracks_i18n.py
msgid "Learn material & time efficiency"
msgstr "Lerne Material- & Zeiteffizienz"

#: apps/mentorship/tracks_i18n.py
msgid "Install a small industry job"
msgstr "Installiere einen kleinen Industrie-Job"

#: apps/mentorship/tracks_i18n.py
msgid "Review cost, materials & output with your mentor"
msgstr "Prüfe Kosten, Materialien & Output mit deinem Mentor"

#: apps/mentorship/tracks_i18n.py
msgid "Review your current skills with your mentor"
msgstr "Prüfe deine aktuellen Skills mit deinem Mentor"

#: apps/mentorship/tracks_i18n.py
msgid "Choose a short-term training goal"
msgstr "Wähle ein kurzfristiges Trainingsziel"

#: apps/mentorship/tracks_i18n.py
msgid "Create a doctrine-relevant skill plan"
msgstr "Erstelle einen Doctrine-relevanten Skillplan"

#: apps/mentorship/tracks_i18n.py
msgid "Re-check progress after a couple of weeks"
msgstr "Überprüfe den Fortschritt nach ein paar Wochen"

#: apps/mentorship/tracks_i18n.py
msgid "Read the corp rules and code of conduct end to end."
msgstr "Lies die Corp-Regeln und den Verhaltenskodex von Anfang bis Ende."

#: apps/mentorship/tracks_i18n.py
msgid "Install and log into the corp's comms tool and join the right channels."
msgstr ""
"Installiere das Comms-Tool der Corp, logge dich ein und tritt den richtigen "
"Kanälen bei."

#: apps/mentorship/tracks_i18n.py
msgid "Learn how to recognise officers, directors and fleet commanders."
msgstr "Lerne, Offiziere, Direktoren und Fleet Commander zu erkennen."

#: apps/mentorship/tracks_i18n.py
msgid ""
"Learn what SRP, buyback, freight and doctrines are and when to use them."
msgstr ""
"Lerne, was SRP, Buyback, Freight und Doctrines sind und wann man sie "
"einsetzt."

#: apps/mentorship/tracks_i18n.py
msgid "Link your main character so the tools can help you."
msgstr "Verknüpfe deinen Hauptcharakter, damit die Tools dir helfen können."

#: apps/mentorship/tracks_i18n.py
msgid "Sit down (on comms) with your mentor for a first proper chat."
msgstr ""
"Setz dich (auf Comms) mit deinem Mentor für ein erstes richtiges Gespräch "
"zusammen."

#: apps/mentorship/tracks_i18n.py
msgid "Set up a clean overview with the right tabs and columns."
msgstr "Richte ein sauberes Overview mit den richtigen Tabs und Spalten ein."

#: apps/mentorship/tracks_i18n.py
msgid "Tune brackets so grid is readable at a glance."
msgstr "Stelle die Brackets so ein, dass das Grid auf einen Blick lesbar ist."

#: apps/mentorship/tracks_i18n.py
msgid ""
"Dock the local, directional-scan and fleet windows where you can see them."
msgstr ""
"Docke das Local-, Directional-Scan- und Fleet-Fenster dort an, wo du sie "
"sehen kannst."

#: apps/mentorship/tracks_i18n.py
msgid "Share your screen (or a screenshot) so your mentor can review your UI."
msgstr ""
"Teile deinen Bildschirm (oder einen Screenshot), damit dein Mentor dein UI "
"prüfen kann."

#: apps/mentorship/tracks_i18n.py
msgid ""
"Understand session timers, gate cloak and the 'don't decloak into a camp' "
"rule."
msgstr ""
"Verstehe Session-Timer, Gate-Cloak und die Regel „Nicht in einen Camp "
"decloaken“."

#: apps/mentorship/tracks_i18n.py
msgid "Learn to read d-scan — angle, range, and what a probe on scan means."
msgstr ""
"Lerne, den D-Scan zu lesen — Winkel, Reichweite und was eine Probe auf dem "
"Scan bedeutet."

#: apps/mentorship/tracks_i18n.py
msgid "Make a few safes and tactical bookmarks in your home system."
msgstr "Setze ein paar Safes und taktische Bookmarks in deinem Heimatsystem."

#: apps/mentorship/tracks_i18n.py
msgid ""
"Fly a short route with your mentor, using safes and d-scan the whole way."
msgstr ""
"Fliege eine kurze Route mit deinem Mentor und nutze dabei durchgehend Safes "
"und D-Scan."

#: apps/mentorship/tracks_i18n.py
msgid "Learn what each slot type is for."
msgstr "Lerne, wofür jeder Slot-Typ da ist."

#: apps/mentorship/tracks_i18n.py
msgid "Understand the core fitting stats and the trade-offs between them."
msgstr ""
"Verstehe die wichtigsten Fitting-Werte und die Kompromisse zwischen ihnen."

#: apps/mentorship/tracks_i18n.py
msgid "Open a corp doctrine fit and go through every module with your mentor."
msgstr ""
"Öffne einen Corp-Doctrine-Fit und geh mit deinem Mentor jedes Modul durch."

#: apps/mentorship/tracks_i18n.py
msgid ""
"Train into (or confirm you can already fly) at least one active doctrine "
"ship."
msgstr ""
"Trainiere (oder bestätige, dass du es bereits fliegen kannst) mindestens ein "
"aktives Doctrine-Schiff."

#: apps/mentorship/tracks_i18n.py
msgid "Use the skills tool to build a plan toward a doctrine hull."
msgstr ""
"Nutze das Skills-Tool, um einen Plan Richtung Doctrine-Hull zu erstellen."

#: apps/mentorship/tracks_i18n.py
msgid "Learn to rat aligned, watch local/intel, and dock when it's spicy."
msgstr ""
"Lerne, aligned zu ratten, Local/Intel im Auge zu behalten und zu docken, "
"wenn's brenzlig wird."

#: apps/mentorship/tracks_i18n.py
msgid "Learn which sites to run and the triggers to stop."
msgstr "Lerne, welche Sites du machst und die Trigger zum Aufhören."

#: apps/mentorship/tracks_i18n.py
msgid "Run a ratting session while your mentor is on comms / nearby."
msgstr ""
"Absolviere eine Ratting-Session, während dein Mentor auf Comms / in der Nähe "
"ist."

#: apps/mentorship/tracks_i18n.py
msgid "Talk through what happened on a run — good or bad."
msgstr "Besprich, was bei einem Run passiert ist — gut oder schlecht."

#: apps/mentorship/tracks_i18n.py
msgid "Learn the mining hull roles and why compression matters."
msgstr "Lerne die Rollen der Mining-Hulls und warum Komprimierung wichtig ist."

#: apps/mentorship/tracks_i18n.py
msgid "Learn how to turn ore into ISK via corp buyback."
msgstr "Lerne, wie man Erz über den Corp-Buyback in ISK verwandelt."

#: apps/mentorship/tracks_i18n.py
msgid "Join a fleet mine (or mine near your mentor) and pull some ore."
msgstr ""
"Nimm an einem Fleet-Mining teil (oder mine in der Nähe deines Mentors) und "
"bau etwas Erz ab."

#: apps/mentorship/tracks_i18n.py
msgid "Submit a real buyback lot for your ore."
msgstr "Reiche einen echten buyback-Posten für dein Erz ein."

#: apps/mentorship/tracks_i18n.py
msgid "Learn to scan down cosmic signatures with probes."
msgstr "Lerne, kosmische Signaturen mit Probes einzuscannen."

#: apps/mentorship/tracks_i18n.py
msgid "Practice the data/relic hacking minigame."
msgstr "Übe das Data-/Relic-Hacking-Minispiel."

#: apps/mentorship/tracks_i18n.py
msgid "Learn the rules for entering and leaving wormholes safely."
msgstr "Lerne die Regeln, um Wormholes sicher zu betreten und zu verlassen."

#: apps/mentorship/tracks_i18n.py
msgid "Do a supervised exploration run and talk through each site."
msgstr ""
"Absolviere unter Aufsicht einen Exploration-Run und besprich jede Site durch."

#: apps/mentorship/tracks_i18n.py
msgid "Learn what scram/web/point do and how transversal keeps you alive."
msgstr ""
"Lerne, was scram/web/point bewirken und wie Transversal dich am Leben hält."

#: apps/mentorship/tracks_i18n.py
msgid "Learn the standard FC calls and how to use broadcasts."
msgstr "Lerne die Standard-FC-Ansagen und wie man Broadcasts nutzt."

#: apps/mentorship/tracks_i18n.py
msgid "Get on a killmail with the corp — a roam, gank or home defence."
msgstr ""
"Komm mit der Corp auf ein killmail — ein roam, gank oder eine "
"Heimatverteidigung."

#: apps/mentorship/tracks_i18n.py
msgid "Pull up a recent kill or loss and talk through what happened."
msgstr ""
"Ruf einen kürzlichen Kill oder Verlust auf und besprich, was passiert ist."

#: apps/mentorship/tracks_i18n.py
msgid "Learn wings/squads, anchoring, and what the watchlist is for."
msgstr "Lerne Wings/Squads, Anchoring und wofür die Watchlist da ist."

#: apps/mentorship/tracks_i18n.py
msgid "Show you can broadcast for reps/target/align correctly."
msgstr ""
"Zeige, dass du korrekt Broadcasts für Reps/Target/Align absetzen kannst."

#: apps/mentorship/tracks_i18n.py
msgid "Sign up for and fly a corp operation."
msgstr "Melde dich für eine Corp-Operation an und fliege sie mit."

#: apps/mentorship/tracks_i18n.py
msgid "Debrief the op with your mentor afterwards."
msgstr "Bespreche die Op danach mit deinem Mentor."

#: apps/mentorship/tracks_i18n.py
msgid "Learn to book a courier and what collateral/reward mean."
msgstr "Lerne, einen courier zu buchen und was collateral/reward bedeuten."

#: apps/mentorship/tracks_i18n.py
msgid "Learn what buyback pays and where."
msgstr "Lerne, was das buyback zahlt und wo."

#: apps/mentorship/tracks_i18n.py
msgid "Run a real courier contract through the freight service."
msgstr "Wickle einen echten courier-Contract über den Freight-Service ab."

#: apps/mentorship/tracks_i18n.py
msgid "Talk your mentor through the whole logistics flow."
msgstr "Führe deinen Mentor durch den gesamten Logistik-Ablauf."

#: apps/mentorship/tracks_i18n.py
msgid "Learn the difference between BPOs and BPCs."
msgstr "Lerne den Unterschied zwischen BPOs und BPCs."

#: apps/mentorship/tracks_i18n.py
msgid "Learn what ME/TE do and why they matter."
msgstr "Lerne, was ME/TE bewirken und warum sie wichtig sind."

#: apps/mentorship/tracks_i18n.py
msgid "Install a small manufacturing or research job."
msgstr "Starte einen kleinen Manufacturing- oder Research-Job."

#: apps/mentorship/tracks_i18n.py
msgid "Go over the BOM and margin of your job with your mentor."
msgstr "Geh die BOM und die Marge deines Jobs mit deinem Mentor durch."

#: apps/mentorship/tracks_i18n.py
msgid "Go through your current skills and gaps with your mentor."
msgstr "Geh deine aktuellen Skills und Lücken mit deinem Mentor durch."

#: apps/mentorship/tracks_i18n.py
msgid "Pick a concrete short-term skill goal."
msgstr "Wähle ein konkretes kurzfristiges Skill-Ziel."

#: apps/mentorship/tracks_i18n.py
msgid "Build a skill plan toward a corp doctrine."
msgstr "Erstelle einen Skill-Plan hin zu einer Corp-doctrine."

#: apps/mentorship/tracks_i18n.py
msgid "Come back to your mentor after ~2 weeks to review progress."
msgstr ""
"Komm nach ~2 Wochen zu deinem Mentor zurück, um den Fortschritt zu prüfen."

#: apps/mentorship/tracks_i18n.py
msgid "Point your cadet at the rules doc; answer any questions."
msgstr "Verweise deinen Cadet auf das Regel-Dokument; beantworte alle Fragen."

#: apps/mentorship/tracks_i18n.py
msgid "Confirm your cadet can hear and be heard on comms."
msgstr "Stelle sicher, dass dein Cadet auf Comms hören und gehört werden kann."

#: apps/mentorship/tracks_i18n.py
msgid "Walk through the org chart and who to ask for what."
msgstr "Geh das Organigramm durch und wer für was zuständig ist."

#: apps/mentorship/tracks_i18n.py
msgid "Give the tour of the corp's services and expectations."
msgstr "Gib eine Tour durch die Services und Erwartungen der Corp."

#: apps/mentorship/tracks_i18n.py
msgid "Confirm the cadet's character is linked and skills import."
msgstr ""
"Stelle sicher, dass der Charakter des Cadets verknüpft ist und die Skills "
"importiert werden."

#: apps/mentorship/tracks_i18n.py
msgid ""
"Have a relaxed first session — goals, timezones, what they want from EVE."
msgstr ""
"Führe eine entspannte erste Session — Ziele, Zeitzonen, was sie von EVE "
"wollen."

#: apps/mentorship/tracks_i18n.py
msgid "Review the cadet's overview live; fix obvious gaps."
msgstr "Geh das Overview des Cadets live durch; behebe offensichtliche Lücken."

#: apps/mentorship/tracks_i18n.py
msgid "Sanity-check bracket settings."
msgstr "Überprüfe die Bracket-Einstellungen."

#: apps/mentorship/tracks_i18n.py
msgid "Confirm the window layout works."
msgstr "Stelle sicher, dass das Fenster-Layout funktioniert."

#: apps/mentorship/tracks_i18n.py
msgid "Do a full pass over the cadet's UI and overview."
msgstr "Geh die UI und das Overview des Cadets komplett durch."

#: apps/mentorship/tracks_i18n.py
msgid "Explain session timers and cloak with real examples."
msgstr "Erkläre Session-Timer und Cloak anhand echter Beispiele."

#: apps/mentorship/tracks_i18n.py
msgid "Run a live d-scan drill with your cadet."
msgstr "Mach eine Live-d-scan-Übung mit deinem Cadet."

#: apps/mentorship/tracks_i18n.py
msgid "Verify the cadet's safes are actually safe (off-grid)."
msgstr "Prüfe, ob die Safes des Cadets wirklich sicher sind (off-grid)."

#: apps/mentorship/tracks_i18n.py
msgid "Take the cadet on a supervised travel run through a chokepoint."
msgstr ""
"Nimm den Cadet auf einen betreuten Reise-Run durch einen chokepoint mit."

#: apps/mentorship/tracks_i18n.py
msgid "Walk through slot layout on a real hull."
msgstr "Geh das Slot-Layout an einem echten Hull durch."

#: apps/mentorship/tracks_i18n.py
msgid "Explain the fitting stats with a doctrine fit open."
msgstr "Erkläre die Fitting-Werte mit einem offenen doctrine-Fit."

#: apps/mentorship/tracks_i18n.py
msgid "Explain why each module is on the doctrine fit."
msgstr "Erkläre, warum jedes Modul auf dem doctrine-Fit ist."

#: apps/mentorship/tracks_i18n.py
msgid "Help the cadet pick the fastest doctrine to get into."
msgstr "Hilf dem Cadet, die am schnellsten erreichbare doctrine zu wählen."

#: apps/mentorship/tracks_i18n.py
msgid "Help pick a sensible first doctrine skill goal."
msgstr "Hilf, ein sinnvolles erstes doctrine-Skill-Ziel zu wählen."

#: apps/mentorship/tracks_i18n.py
msgid "Explain ratting safety and the 'align out' habit."
msgstr "Erkläre die Sicherheit beim ratting und die 'align out'-Gewohnheit."

#: apps/mentorship/tracks_i18n.py
msgid "Cover site choice and bail triggers."
msgstr "Behandle die Site-Auswahl und Bail-Trigger."

#: apps/mentorship/tracks_i18n.py
msgid "Watch intel and coach while your cadet rats."
msgstr "Beobachte den Intel und coache, während dein Cadet rattet."

#: apps/mentorship/tracks_i18n.py
msgid "Debrief a real ratting moment with your cadet."
msgstr "Bespreche einen echten ratting-Moment mit deinem Cadet."

#: apps/mentorship/tracks_i18n.py
msgid "Explain mining ships, boosts and compression."
msgstr "Erkläre Mining-Schiffe, Boosts und Compression."

#: apps/mentorship/tracks_i18n.py
msgid "Walk through submitting a buyback lot."
msgstr "Geh das Einreichen eines buyback-Postens durch."

#: apps/mentorship/tracks_i18n.py
msgid "Get the cadet into a mining op and confirm they mined."
msgstr ""
"Bring den Cadet in eine Mining-Op und bestätige, dass er Mining betrieben "
"hat."

#: apps/mentorship/tracks_i18n.py
msgid "Confirm the cadet submitted a buyback lot."
msgstr "Bestätige, dass der Cadet einen buyback-Posten eingereicht hat."

#: apps/mentorship/tracks_i18n.py
msgid "Run a scanning drill with your cadet."
msgstr "Mach eine Scanning-Übung mit deinem Cadet."

#: apps/mentorship/tracks_i18n.py
msgid "Share hacking tips (node types, virus strength)."
msgstr "Teile Hacking-Tipps (Node-Typen, Virus-Stärke)."

#: apps/mentorship/tracks_i18n.py
msgid "Cover WH mass/time and the 'bookmark both sides' rule."
msgstr "Behandle WH-Masse/-Zeit und die 'bookmark both sides'-Regel."

#: apps/mentorship/tracks_i18n.py
msgid "Take the cadet on a low-risk exploration run."
msgstr "Nimm den Cadet auf einen risikoarmen Exploration-Run mit."

#: apps/mentorship/tracks_i18n.py
msgid "Explain tackle and range control with examples."
msgstr "Erkläre tackle und Range-Control anhand von Beispielen."

#: apps/mentorship/tracks_i18n.py
msgid "Run a quick comms/broadcast drill."
msgstr "Mach eine schnelle Comms-/Broadcast-Übung."

#: apps/mentorship/tracks_i18n.py
msgid "Bring your cadet on a low-stakes fleet and get them on a mail."
msgstr ""
"Nimm deinen Cadet auf eine risikoarme Fleet mit und bring ihn auf ein Mail."

#: apps/mentorship/tracks_i18n.py
msgid "Debrief a real mail — what went right, what to change."
msgstr "Bespreche ein echtes Mail — was gut lief, was zu ändern ist."

#: apps/mentorship/tracks_i18n.py
msgid "Explain fleet structure and anchoring."
msgstr "Erkläre die Fleet-Struktur und Anchoring."

#: apps/mentorship/tracks_i18n.py
msgid "Check the cadet broadcasts the right things at the right time."
msgstr ""
"Prüfe, dass der Cadet die richtigen Dinge zur richtigen Zeit broadcastet."

#: apps/mentorship/tracks_i18n.py
msgid "Get your cadet on a scheduled op and keep an eye on them."
msgstr "Bring deinen Cadet auf eine geplante Op und behalte ihn im Auge."

#: apps/mentorship/tracks_i18n.py
msgid "Run a short after-action with your cadet."
msgstr "Mach ein kurzes After-Action mit deinem Cadet."

#: apps/mentorship/tracks_i18n.py
msgid "Walk through booking a freight contract."
msgstr "Geh das Buchen eines Freight-Contracts durch."

#: apps/mentorship/tracks_i18n.py
msgid "Explain the buyback rates and locations."
msgstr "Erkläre die buyback-Raten und -Standorte."

#: apps/mentorship/tracks_i18n.py
msgid "Confirm the cadet completed (and ideally ESI-verified) a haul."
msgstr ""
"Bestätige, dass der Cadet einen Haul abgeschlossen (und idealerweise per ESI "
"verifiziert) hat."

#: apps/mentorship/tracks_i18n.py
msgid "Confirm the cadet understands collateral, reward and risk."
msgstr "Bestätige, dass der Cadet collateral, reward und Risiko versteht."

#: apps/mentorship/tracks_i18n.py
msgid "Explain blueprints and runs."
msgstr "Erkläre Blueprints und Runs."

#: apps/mentorship/tracks_i18n.py
msgid "Show ME/TE impact on a real build."
msgstr "Zeige den Einfluss von ME/TE an einem echten Build."

#: apps/mentorship/tracks_i18n.py
msgid "Help the cadet install their first job."
msgstr "Hilf dem Cadet, seinen ersten Job zu starten."

#: apps/mentorship/tracks_i18n.py
msgid "Review the economics of the cadet's job."
msgstr "Prüfe die Wirtschaftlichkeit des Cadet-Jobs."

#: apps/mentorship/tracks_i18n.py
msgid "Review the cadet's skills and obvious priorities."
msgstr "Prüfe die Skills des Cadets und offensichtliche Prioritäten."

#: apps/mentorship/tracks_i18n.py
msgid "Help pick a motivating first goal."
msgstr "Hilf, ein motivierendes erstes Ziel zu wählen."

#: apps/mentorship/tracks_i18n.py
msgid "Confirm the plan targets a doctrine the corp needs."
msgstr ""
"Bestätige, dass der Plan auf eine doctrine abzielt, die die Corp braucht."

#: apps/mentorship/tracks_i18n.py
msgid "Follow up on the cadet's training progress."
msgstr "Fasse beim Trainingsfortschritt des Cadets nach."

#: apps/mentorship/tracks_i18n.py
msgid "First Steps"
msgstr "Erste Schritte"

#: apps/mentorship/tracks_i18n.py
msgid "Navigator"
msgstr "Navigator"

#: apps/mentorship/tracks_i18n.py
msgid "Fleet Ready"
msgstr "Fleet-bereit"

#: apps/mentorship/tracks_i18n.py
msgid "Graduate"
msgstr "Absolvent"

#: apps/mentorship/tracks_i18n.py templates/mentorship/dashboard.html
msgid "Veteran Mentor"
msgstr "Veteranen-Mentor"

#: apps/mentorship/tracks_i18n.py
msgid "Cadet: completed onboarding"
msgstr "Cadet: Onboarding abgeschlossen"

#: apps/mentorship/tracks_i18n.py
msgid "Cadet: first corp fleet"
msgstr "Cadet: erste Corp-Fleet"

#: apps/mentorship/tracks_i18n.py
msgid "Cadet: first PvP kill"
msgstr "Cadet: erster PvP-Kill"

#: apps/mentorship/tracks_i18n.py
msgid "Cadet: first haul"
msgstr "Cadet: erster Haul"

#: apps/mentorship/tracks_i18n.py
msgid "Cadet: first industry job"
msgstr "Cadet: erster Industry-Job"

#: apps/mentorship/tracks_i18n.py
msgid "Cadet: programme graduation"
msgstr "Cadet: Programm-Abschluss"

#: apps/mentorship/tracks_i18n.py
msgid "Mentor: guided a cadet to graduation"
msgstr "Mentor: hat einen Cadet zum Abschluss geführt"

#: apps/mentorship/tracks_i18n.py
msgid "Mentor: 30 days active mentoring"
msgstr "Mentor: 30 Tage aktives Mentoring"

#: apps/mentorship/views.py
msgid "The Mentorship Program is currently paused."
msgstr "Das Mentoring-Programm ist derzeit pausiert."

#: apps/mentorship/views.py
msgid "Mentor registration submitted — pending leadership approval."
msgstr "Mentor-Registrierung eingereicht — Freigabe der Leitung ausstehend."

#: apps/mentorship/views.py
msgid "You're registered as a mentor. Thank you!"
msgstr "Du bist als Mentor registriert. Danke!"

#: apps/mentorship/views.py
msgid "Cadet registration submitted — pending leadership approval."
msgstr "Kadetten-Registrierung eingereicht — Freigabe der Leitung ausstehend."

#: apps/mentorship/views.py
msgid "You're registered as a cadet. Let's find you a mentor!"
msgstr "Du bist als Kadett registriert. Finden wir einen Mentor für dich!"

#: apps/mentorship/views.py
msgid "The mentor directory is not currently open."
msgstr "Das Mentorenverzeichnis ist derzeit nicht geöffnet."

#: apps/mentorship/views.py
msgid "You can't request a mentor right now."
msgstr "Du kannst gerade keinen Mentor anfragen."

#: apps/mentorship/views.py
msgid "That mentor is at capacity."
msgstr "Dieser Mentor ist ausgelastet."

#: apps/mentorship/views.py
msgid "You already have a pending or active pairing with that mentor."
msgstr ""
"Du hast bereits eine ausstehende oder aktive Paarung mit diesem Mentor."

#: apps/mentorship/views.py
#, python-format
msgid "Request sent to %(name)s."
msgstr "Anfrage an %(name)s gesendet."

#: apps/mentorship/views.py
msgid "You can't invite a cadet right now."
msgstr "Du kannst gerade keinen Kadetten einladen."

#: apps/mentorship/views.py
msgid "You're already at your mentee capacity."
msgstr "Du hast deine Mentee-Kapazität bereits erreicht."

#: apps/mentorship/views.py
msgid "You already have a pending or active pairing with that cadet."
msgstr ""
"Du hast bereits eine ausstehende oder aktive Paarung mit diesem Kadetten."

#: apps/mentorship/views.py
#, python-format
msgid "Invitation sent to %(name)s."
msgstr "Einladung an %(name)s gesendet."

#: apps/mentorship/views.py
msgid "That pairing can no longer be answered."
msgstr "Diese Paarung kann nicht mehr beantwortet werden."

#: apps/mentorship/views.py
msgid "The other pilot needs to accept this one."
msgstr "Der andere Pilot muss diese annehmen."

#: apps/mentorship/views.py
msgid "Accepted — now awaiting leadership approval."
msgstr "Angenommen — wartet nun auf die Freigabe der Leitung."

#: apps/mentorship/views.py
msgid "Mentorship is now active. Fair winds!"
msgstr "Das Mentoring ist jetzt aktiv. Fair winds!"

#: apps/mentorship/views.py
msgid "Pairing declined."
msgstr "Paarung abgelehnt."

#: apps/mentorship/views.py
#, python-format
msgid "%(count)d task(s) awaiting your sign-off."
msgstr "%(count)d Aufgabe(n) warten auf deine Bestätigung."

#: apps/mentorship/views.py
#, python-format
msgid "%(count)d field exercise(s) to work on."
msgstr "%(count)d Feldübung(en) zu bearbeiten."

#: apps/mentorship/views.py
msgid "Schedule your first mentoring session."
msgstr "Plane deine erste Mentoring-Sitzung."

#: apps/mentorship/views.py
msgid "This exercise needs an evidence link or note."
msgstr "Diese Übung benötigt einen Nachweis-Link oder eine Notiz."

#: apps/mentorship/views.py
msgid "Finish the prerequisite exercises first."
msgstr "Schließe zuerst die vorausgesetzten Übungen ab."

#: apps/mentorship/views.py
msgid "Exercise completed!"
msgstr "Übung abgeschlossen!"

#: apps/mentorship/views.py
msgid "Submitted for review."
msgstr "Zur Prüfung eingereicht."

#: apps/mentorship/views.py
msgid "Only the mentor can sign this off."
msgstr "Nur der Mentor kann dies bestätigen."

#: apps/mentorship/views.py
msgid "Exercise confirmed."
msgstr "Übung bestätigt."

#: apps/mentorship/views.py
msgid "Exercise sent back."
msgstr "Übung zurückgeschickt."

#: apps/mentorship/views.py
msgid "Opened another attempt."
msgstr "Weiterer Versuch geöffnet."

#: apps/mentorship/views.py
msgid "Can't repeat this exercise yet."
msgstr "Diese Übung kann noch nicht wiederholt werden."

#: apps/mentorship/views.py
msgid "That action isn't available."
msgstr "Diese Aktion ist nicht verfügbar."

#: apps/mentorship/views.py
msgid "Only the pair can schedule a session."
msgstr "Nur das Paar kann eine Sitzung planen."

#: apps/mentorship/views.py
msgid "Session scheduled."
msgstr "Sitzung geplant."

#: apps/mentorship/views.py
msgid "Session confirmed."
msgstr "Sitzung bestätigt."

#: apps/mentorship/views.py
msgid "Session cancelled."
msgstr "Sitzung abgesagt."

#: apps/mentorship/views.py
msgid "The pairing must be active to add tracks."
msgstr "Die Paarung muss aktiv sein, um Tracks hinzuzufügen."

#: apps/mentorship/views.py
#, python-format
msgid "Enrolled in “%(title)s”."
msgstr "In „%(title)s“ eingeschrieben."

#: apps/mentorship/views.py
msgid "Mentorship paused."
msgstr "Mentoring pausiert."

#: apps/mentorship/views.py
msgid "Mentorship resumed."
msgstr "Mentoring fortgesetzt."

#: apps/mentorship/views.py
msgid "Mentorship marked complete. Well done!"
msgstr "Mentoring als abgeschlossen markiert. Gut gemacht!"

#: apps/mentorship/views.py
msgid "Mentorship cancelled."
msgstr "Mentoring abgebrochen."

#: apps/mining/models.py
#, python-format
msgid "Observer %(observer_id)s"
msgstr "Observer %(observer_id)s"

#: apps/mining/models.py
msgid "By ISK value mined"
msgstr "Nach abgebautem ISK-Wert"

#: apps/mining/models.py
msgid "By quantity mined"
msgstr "Nach abgebauter Menge"

#: apps/mining/models.py
msgid "Split equally"
msgstr "Gleichmäßig aufteilen"

#: apps/mining/models.py
msgid "Finalised"
msgstr "Finalisiert"

#: apps/mining/views.py
#, python-format
msgid "Ledger synced — %(count)s entries."
msgstr "Ledger synchronisiert — %(count)s Einträge."

#: apps/mining/views.py
msgid "Ledger sync failed; try again later."
msgstr "Ledger-Synchronisierung fehlgeschlagen; versuche es später erneut."

#: apps/mining/views.py
msgid "Invalid tax rate."
msgstr "Ungültiger Steuersatz."

#: apps/mining/views.py
#, python-format
msgid "Mining tax set to %(rate)s."
msgstr "Mining-Steuer auf %(rate)s gesetzt."

#: apps/mining/views.py
msgid "A payout needs a name and a valid date range."
msgstr "Eine Auszahlung benötigt einen Namen und einen gültigen Datumsbereich."

