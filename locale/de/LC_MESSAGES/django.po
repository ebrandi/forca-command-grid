"loss value (market insurance)."
msgstr ""
"<span class=\"text-muted\">ISK — voller Verlustwert</span> — zahle ISK bis "
"zum Verlustwert (Marktversicherung)."

#: templates/srp/settings.html
msgid ""
"<span class=\"text-muted\">ISK — top up insurance</span> — pay only the gap "
"above the official in-game insurance."
msgstr ""
"<span class=\"text-muted\">ISK — Versicherung aufstocken</span> — zahle nur "
"die Differenz über der offiziellen Versicherung im Spiel."

#: templates/srp/settings.html
msgid "Loss valuation"
msgstr "Verlustbewertung"

#: templates/srp/settings.html
msgid ""
"<span class=\"text-muted\">Actual loss</span> — hull + the modules actually "
"destroyed, at market."
msgstr ""
"<span class=\"text-muted\">Tatsächlicher Verlust</span> — Hull + die "
"tatsächlich zerstörten Module, zum Marktpreis."

#: templates/srp/settings.html
msgid ""
"<span class=\"text-muted\">Doctrine fit</span> — the value of the doctrine's"
" standard fit."
msgstr ""
"<span class=\"text-muted\">Doctrine-Fit</span> — der Wert des Standard-Fits "
"der doctrine."

#: templates/srp/settings.html
msgid "<span class=\"text-muted\">Hull only</span> — modules are on the pilot."
msgstr ""
"<span class=\"text-muted\">Nur Hull</span> — Module gehen zu Lasten des "
"Piloten."

