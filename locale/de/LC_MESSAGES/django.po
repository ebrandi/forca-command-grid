msgid "Data-retention policy saved."
msgstr "Datenaufbewahrungsrichtlinie gespeichert."

#: apps/admin_audit/console.py
msgid "Couldn't read that expiry date."
msgstr "Dieses Ablaufdatum konnte nicht gelesen werden."

#: apps/admin_audit/console.py
msgid "Expiry must be in the future — leave it blank for a permanent grant."
msgstr ""
"Das Ablaufdatum muss in der Zukunft liegen — für eine dauerhafte Zuweisung "
"leer lassen."

#: apps/admin_audit/console.py
msgid "That role can't be managed here."
msgstr "Diese Rolle kann hier nicht verwaltet werden."

#: apps/admin_audit/console.py
#, python-format
msgid "A %(role)s grant for that pilot is already awaiting approval."
msgstr ""
"Eine %(role)s-Zuweisung für diesen Piloten wartet bereits auf Genehmigung."

#: apps/admin_audit/console.py
#, python-format
msgid "%(role)s grant requested — a second director must approve it."
msgstr ""
"%(role)s-Zuweisung angefordert — ein zweiter Director muss sie genehmigen."

#: apps/admin_audit/console.py
msgid "Can't remove the last Director — promote someone else first."
msgstr ""
"Der letzte Director kann nicht entfernt werden — befördere zuerst jemand "
"anderen."

#: apps/admin_audit/console.py
#, python-format
msgid "%(role)s %(action)s for %(name)s."
msgstr "%(role)s %(action)s für %(name)s."

#: apps/admin_audit/console.py
msgid "You can't approve your own role request — another director must."
msgstr ""
"Du kannst deine eigene Rollenanfrage nicht genehmigen — das muss ein anderer "
"Director tun."

#: apps/admin_audit/console.py
#, python-format
msgid "%(role)s grant %(outcome)s for %(name)s."
msgstr "%(role)s-Zuweisung %(outcome)s für %(name)s."

#: apps/admin_audit/console.py apps/admin_audit/console_doctrine_xml.py
msgid "Enter a whole number."
msgstr "Gib eine ganze Zahl ein."

#: apps/admin_audit/console.py
#, python-format
msgid "Page size set to %(clamped)s (kept within %(min)s–%(max)s)."
msgstr ""
"Seitengröße auf %(clamped)s gesetzt (innerhalb von %(min)s–%(max)s gehalten)."

#: apps/admin_audit/console.py
#, python-format
msgid "Page size set to %(clamped)s per page."
msgstr "Seitengröße auf %(clamped)s pro Seite gesetzt."

#: apps/admin_audit/console.py
msgid "Give the doctrine a name."
msgstr "Gib der Doctrine einen Namen."

#: apps/admin_audit/console.py
#, python-format
msgid "Doctrine “%(name)s” created — add a fit below."
msgstr "Doctrine „%(name)s“ erstellt — füge unten ein Fit hinzu."

#: apps/admin_audit/console.py
msgid "Doctrine updated."
msgstr "Doctrine aktualisiert."

#: apps/admin_audit/console.py
msgid "Doctrine deleted."
msgstr "Doctrine gelöscht."

#: apps/admin_audit/console.py
#, python-format
msgid "Couldn't parse the EFT: %(error)s"
msgstr "Das EFT konnte nicht verarbeitet werden: %(error)s"

#: apps/admin_audit/console.py
#, python-format
msgid "Unknown ship “%(ship)s” — check the EFT header."
msgstr "Unbekanntes Schiff „%(ship)s“ — prüfe den EFT-Header."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"Fit “%(name)s” added (%(count)s skill requirements derived). Unresolved "
"lines: %(lines)s."
msgstr ""
"Fit „%(name)s“ hinzugefügt (%(count)s Skill-Anforderungen abgeleitet). Nicht "
"aufgelöste Zeilen: %(lines)s."

#: apps/admin_audit/console.py
#, python-format
msgid "Fit “%(name)s” added (%(count)s skill requirements derived)."
msgstr "Fit „%(name)s“ hinzugefügt (%(count)s Skill-Anforderungen abgeleitet)."

#: apps/admin_audit/console.py
msgid "Fit removed."
msgstr "Fit entfernt."

#: apps/admin_audit/console.py
msgid "Pick a valid requirement type."
msgstr "Wähle einen gültigen Anforderungstyp."

#: apps/admin_audit/console.py
msgid "A note needs some text."
msgstr "Eine Notiz braucht etwas Text."

#: apps/admin_audit/console.py
msgid "This requirement needs a type id (or record it as a note)."
msgstr "Diese Anforderung braucht eine Type-ID (oder erfasse sie als Notiz)."

#: apps/admin_audit/console.py
msgid "Requirement added."
msgstr "Anforderung hinzugefügt."

#: apps/admin_audit/console.py
msgid "Requirement removed."
msgstr "Anforderung entfernt."

#: apps/admin_audit/console.py
msgid "Tick at least one fit to import."
msgstr "Markiere mindestens ein Fit zum Importieren."

#: apps/admin_audit/console.py
#, python-format
msgid "Imported %(count)d fit as new doctrines under IMPORTED."
msgid_plural "Imported %(count)d fits as new doctrines under IMPORTED."
msgstr[0] "%(count)d Fit als neue doctrines unter IMPORTED importiert."
msgstr[1] "%(count)d Fits als neue doctrines unter IMPORTED importiert."

#: apps/admin_audit/console.py
#, python-format
msgid "Already in the library (identical name and fit) — skipped: %(names)s."
msgstr ""
"Bereits in der Bibliothek (identischer Name und Fit) — übersprungen: "
"%(names)s."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"A doctrine with this name already exists but with a different fit — rename "
"it and import again: %(names)s."
msgstr ""
"Eine Doctrine mit diesem Namen existiert bereits, aber mit einem anderen Fit "
"— benenne sie um und importiere erneut: %(names)s."

#: apps/admin_audit/console.py
msgid "Nothing imported — the selected fits couldn't be read."
msgstr ""
"Nichts importiert — die ausgewählten Fits konnten nicht gelesen werden."

#: apps/admin_audit/console.py
#, python-format
msgid "Couldn't parse the fit: %(error)s"
msgstr "Das Fit konnte nicht verarbeitet werden: %(error)s"

#: apps/admin_audit/console.py
#, python-format
msgid "Unknown ship “%(ship)s” — check the first line."
msgstr "Unbekanntes Schiff „%(ship)s“ — prüfe die erste Zeile."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"Doctrine “%(name)s” created from killmail (%(count)s skills derived). "
"Unresolved: %(lines)s."
msgstr ""
"Doctrine „%(name)s“ aus einem Killmail erstellt (%(count)s Skills "
"abgeleitet). Nicht aufgelöst: %(lines)s."

#: apps/admin_audit/console.py
#, python-format
msgid "Doctrine “%(name)s” created from killmail (%(count)s skills derived)."
msgstr ""
"Doctrine „%(name)s“ aus einem Killmail erstellt (%(count)s Skills "
"abgeleitet)."

#: apps/admin_audit/console.py
#, python-format
msgid "Category “%(label)s” added."
msgstr "Kategorie „%(label)s“ hinzugefügt."

#: apps/admin_audit/console.py
msgid "Manual — pilot checks it off"
msgstr "Manuell — Pilot hakt es ab"

#: apps/admin_audit/console.py
msgid "Auto — a character is linked"
msgstr "Auto — ein Charakter ist verknüpft"

#: apps/admin_audit/console.py
msgid "Auto — verified corp member"
msgstr "Auto — verifiziertes Corp-Mitglied"

#: apps/admin_audit/console.py
msgid "Auto — skills imported"
msgstr "Auto — Skills importiert"

#: apps/admin_audit/console.py
msgid "Auto — ESI scopes granted"
msgstr "Auto — ESI-Scopes gewährt"

#: apps/admin_audit/console.py
msgid "Auto — skill trained to level"
msgstr "Auto — Skill auf Stufe trainiert"

#: apps/admin_audit/console.py
msgid "Auto — can fly a specific doctrine"
msgstr "Auto — kann eine bestimmte Doctrine fliegen"

#: apps/admin_audit/console.py
msgid "Auto — can fly ANY active doctrine"
msgstr "Auto — kann JEDE aktive Doctrine fliegen"

#: apps/admin_audit/console.py apps/campaigns/views.py
msgid "A milestone needs a title."
msgstr "Ein Meilenstein braucht einen Titel."

#: apps/admin_audit/console.py
msgid "Pick the doctrine this milestone checks."
msgstr "Wähle die Doctrine, die dieser Meilenstein prüft."

#: apps/admin_audit/console.py
msgid "That doctrine no longer exists."
msgstr "Diese Doctrine existiert nicht mehr."

#: apps/admin_audit/console.py
msgid "Skill milestones need a skill type id and a level (1–5)."
msgstr "Skill-Meilensteine brauchen eine Skill-Type-ID und eine Stufe (1–5)."

#: apps/admin_audit/console.py
msgid "List at least one ESI scope (comma-separated)."
msgstr "Liste mindestens einen ESI-Scope auf (durch Komma getrennt)."

#: apps/admin_audit/console.py
msgid "That milestone no longer exists."
msgstr "Dieser Meilenstein existiert nicht mehr."

#: apps/admin_audit/console.py
#, python-format
msgid "Milestone “%(title)s” saved."
msgstr "Meilenstein „%(title)s“ gespeichert."

