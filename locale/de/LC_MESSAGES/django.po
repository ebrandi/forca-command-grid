#: apps/admin_audit/console.py
#, python-format
msgid "Imported %(count)d fit as new doctrines under IMPORTED."
msgid_plural "Imported %(count)d fits as new doctrines under IMPORTED."
msgstr[0] "%(count)d Fit als neue doctrines unter IMPORTED importiert."
msgstr[1] "%(count)d Fits als neue doctrines unter IMPORTED importiert."

#: apps/admin_audit/console_access.py
msgid "Enter a valid alliance id."
msgstr "Gib eine gültige Allianz-ID ein."

#: apps/admin_audit/console_access.py
msgid "Partner alliance saved."
msgstr "Partner-Allianz gespeichert."

#: apps/admin_audit/console_access.py
msgid "Partner alliance removed."
msgstr "Partner-Allianz entfernt."

#: apps/admin_audit/console_access.py
msgid "Enter a valid corporation id."
msgstr "Gib eine gültige Corporation-ID ein."

#: apps/admin_audit/console_access.py
msgid "Friendly corporation saved."
msgstr "Befreundete Corporation gespeichert."

#: apps/admin_audit/console_access.py
msgid "Friendly corporation removed."
msgstr "Befreundete Corporation entfernt."

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings reset to defaults."
msgstr "Capsuleer-Path-Einstellungen auf Standard zurückgesetzt."

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings saved."
msgstr "Capsuleer-Path-Einstellungen gespeichert."

#: apps/admin_audit/console_combat.py
msgid "A rank title can't be empty."
msgstr "Ein Rang-Titel darf nicht leer sein."

#: apps/admin_audit/console_combat.py
msgid "Reward amount can't be negative."
msgstr "Der Belohnungsbetrag darf nicht negativ sein."

#: apps/admin_audit/console_combat.py
msgid "Another rank already uses this threshold for this metric."
msgstr ""
"Ein anderer Rang verwendet diesen Schwellenwert für diese Metrik bereits."

#: apps/admin_audit/console_combat.py
msgid ""
"Rewards apply to the all-time PvP kills track only — the support-role tracks"
" are recognition-only."
msgstr ""
"Belohnungen gelten nur für die All-Time-PvP-Kills-Wertung — die Support-"
"Rollen-Wertungen dienen nur der Anerkennung."

#: apps/admin_audit/console_combat.py
msgid "Choose a reward type, or untick “grants reward”."
msgstr "Wähle einen Belohnungstyp oder deaktiviere “gewährt Belohnung”."

#: apps/admin_audit/console_combat.py
msgid "An item reward needs an EVE type id."
msgstr "Eine Item-Belohnung benötigt eine EVE-Type-ID."

#: apps/admin_audit/console_combat.py
msgid "An ISK/PLEX reward needs a positive amount."
msgstr "Eine ISK/PLEX-Belohnung benötigt einen positiven Betrag."

#: apps/admin_audit/console_combat.py
msgid "Must be zero or positive."
msgstr "Muss null oder positiv sein."

#: apps/admin_audit/console_combat.py
msgid "Can't exceed 100%."
msgstr ""

#: apps/admin_audit/console_combat.py
msgid "Newbro settings saved."
msgstr "Newbro-Einstellungen gespeichert."

#: apps/admin_audit/console_combat.py
msgid "Please correct the newbro settings."
msgstr "Bitte korrigiere die Newbro-Einstellungen."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” saved."
msgstr "Rang “%(name)s” gespeichert."

#: apps/admin_audit/console_combat.py apps/admin_audit/console_corporation.py
#: apps/admin_audit/console_industry.py apps/admin_audit/console_mentorship.py
#: apps/admin_audit/console_navigation.py
#: apps/admin_audit/console_pingboard.py apps/admin_audit/console_planetary.py
#: apps/admin_audit/console_raffle.py
msgid "Please correct the errors below."
msgstr "Bitte korrigiere die untenstehenden Fehler."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” removed."
msgstr "Rang “%(name)s” entfernt."

#: apps/admin_audit/console_combat.py
msgid "Reward settings saved."
msgstr "Belohnungseinstellungen gespeichert."

#: apps/admin_audit/console_combat.py
#, python-format
msgid ""
"Rewards enabled. Baseline snapshotted for %(n)d pilot(s) — only ranks "
"reached from now on will create rewards."
msgstr ""
"Belohnungen aktiviert. Baseline für %(n)d Pilot(en) erfasst — nur ab jetzt "
"erreichte Ränge erzeugen Belohnungen."

#: apps/admin_audit/console_combat.py
msgid "Rewards disabled. No new reward events will be created."
msgstr ""
"Belohnungen deaktiviert. Es werden keine neuen Belohnungs-Events erstellt."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Baseline re-snapshotted for %(n)d pilot(s)."
msgstr "Baseline für %(n)d Pilot(en) neu erfasst."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward scan complete — %(n)d new reward event(s) created."
msgstr ""
"Belohnungs-Scan abgeschlossen — %(n)d neue(s) Belohnungs-Event(s) erstellt."

#: apps/admin_audit/console_combat.py apps/buyback/views.py
#: apps/logistics/views.py apps/stockpile/views.py apps/store/views.py
msgid "Unknown action."
msgstr "Unbekannte Aktion."

#: apps/admin_audit/console_combat.py
msgid "Only a Director can mark a reward paid."
msgstr "Nur ein Director kann eine Belohnung als bezahlt markieren."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward %(action)s — %(character)s · %(rank)s."
msgstr "Belohnung %(action)s — %(character)s · %(rank)s."

#: apps/admin_audit/console_command_intel.py
#, python-format
msgid "%(domain)s reset to defaults."
msgstr "%(domain)s auf Standard zurückgesetzt."

#: apps/admin_audit/console_command_intel.py
msgid "Provider & model settings saved."
msgstr "Provider- & Modell-Einstellungen gespeichert."

#: apps/admin_audit/console_command_intel.py
msgid "Critical ratio"
msgstr "Kritisches Verhältnis"

#: apps/admin_audit/console_command_intel.py
msgid "Headroom/demand at or below this colours a constraint critical."
msgstr ""
"Spielraum/Bedarf auf oder unter diesem Wert markiert eine Beschränkung als "
"kritisch."

#: apps/admin_audit/console_command_intel.py
msgid "High ratio"
msgstr "Hohes Verhältnis"

#: apps/admin_audit/console_command_intel.py
msgid "Above critical, at or below this colours it high."
msgstr "Über kritisch, auf oder unter diesem Wert wird sie als hoch markiert."

#: apps/admin_audit/console_command_intel.py
msgid "Watch ratio"
msgstr "Beobachtungs-Verhältnis"

#: apps/admin_audit/console_command_intel.py
msgid "Above high, at or below this colours it watch."
msgstr ""
"Über hoch, auf oder unter diesem Wert wird sie als Beobachten markiert."

#: apps/admin_audit/console_command_intel.py
msgid "Constraints & thresholds saved."
msgstr "Beschränkungen & Schwellenwerte gespeichert."

#: apps/admin_audit/console_command_intel.py
msgid "Classification settings saved."
msgstr "Klassifizierungs-Einstellungen gespeichert."

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Corporation Internal"
msgstr "Corporation-intern"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "High Command"
msgstr "Oberkommando"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Director — Eyes Only"
msgstr "Director — streng vertraulich"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Alliance Command"
msgstr "Allianz-Kommando"

#: apps/admin_audit/console_command_intel.py
msgid "Notification & delivery settings saved."
msgstr "Benachrichtigungs- & Zustellungs-Einstellungen gespeichert."

#: apps/admin_audit/console_command_intel.py
msgid "Autonomous proposal settings saved."
msgstr "Einstellungen für autonome Vorschläge gespeichert."

#: apps/admin_audit/console_command_intel.py
msgid "Auto-AAR settings saved."
msgstr "Auto-AAR-Einstellungen gespeichert."

#: apps/admin_audit/console_corporation.py
msgid "Low-fuel warning must be between 1 and 30 days."
msgstr ""
"Die Warnung bei niedrigem Treibstoff muss zwischen 1 und 30 Tagen liegen."

#: apps/admin_audit/console_corporation.py
msgid "ADM floor must be between 1.0 and 6.0."
msgstr "Der ADM-Mindestwert muss zwischen 1.0 und 6.0 liegen."

#: apps/admin_audit/console_corporation.py
msgid "Structure-alert thresholds saved."
msgstr "Schwellenwerte für Strukturwarnungen gespeichert."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import rejected: %(error)s"
msgstr "Import abgelehnt: %(error)s"

#: apps/admin_audit/console_doctrine_xml.py
msgid "XML import applied."
msgstr "XML-Import angewendet."

#: apps/admin_audit/console_doctrine_xml.py
msgid "Enter a whole number."
msgstr "Gib eine ganze Zahl ein."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Limit set to %(clamped)s (values are kept within 1–%(ceiling)s)."
msgstr ""
"Limit auf %(clamped)s gesetzt (Werte bleiben innerhalb von 1–%(ceiling)s)."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import limit set to %(clamped)s fittings."
msgstr "Import-Limit auf %(clamped)s Fittings gesetzt."

#: apps/admin_audit/console_industry.py
msgid "Industry & Economy settings saved."
msgstr "Einstellungen für Industrie & Wirtschaft gespeichert."

#: apps/admin_audit/console_mentorship.py
msgid "Mentorship Program settings saved."
msgstr "Einstellungen für das Mentorship-Programm gespeichert."

#: apps/admin_audit/console_mentorship.py
msgid "Cohort saved."
msgstr "Kohorte gespeichert."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the cohort — check the values."
msgstr "Kohorte konnte nicht gespeichert werden — überprüfe die Werte."

#: apps/admin_audit/console_mentorship.py
msgid "Cohort removed."
msgstr "Kohorte entfernt."

#: apps/admin_audit/console_mentorship.py
msgid "Track saved."
msgstr "Track gespeichert."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the track — check the values."
msgstr "Track konnte nicht gespeichert werden — überprüfe die Werte."

#: apps/admin_audit/console_mentorship.py
msgid "Track removed."
msgstr "Track entfernt."

#: apps/admin_audit/console_mentorship.py
msgid "Track cloned (as a draft)."
msgstr "Track geklont (als Entwurf)."

#: apps/admin_audit/console_mentorship.py
msgid ""
"Criteria must be a JSON object, e.g. {\"type\": \"skill_min\", "
"\"skill_type_id\": 3300, \"level\": 3}."
msgstr ""
"Kriterien müssen ein JSON-Objekt sein, z. B. {\"type\": \"skill_min\", "
"\"skill_type_id\": 3300, \"level\": 3}."

#: apps/admin_audit/console_mentorship.py
msgid "Field exercise saved."
msgstr "Feldübung gespeichert."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the exercise — check the values."
msgstr "Übung konnte nicht gespeichert werden — überprüfe die Werte."

#: apps/admin_audit/console_mentorship.py
msgid "Field exercise removed."
msgstr "Feldübung entfernt."

#: apps/admin_audit/console_mentorship.py
msgid "Reward rule saved."
msgstr "Belohnungsregel gespeichert."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the reward rule — check the values."
msgstr ""
"Belohnungsregel konnte nicht gespeichert werden — überprüfe die Werte."

#: apps/admin_audit/console_mentorship.py
msgid "Reward rule removed."
msgstr "Belohnungsregel entfernt."

#: apps/admin_audit/console_mentorship.py
msgid "Badge saved."
msgstr "Abzeichen gespeichert."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the badge — check the values."
msgstr "Abzeichen konnte nicht gespeichert werden — überprüfe die Werte."

#: apps/admin_audit/console_mentorship.py
msgid "Badge removed."
msgstr "Abzeichen entfernt."

#: apps/admin_audit/console_mentorship.py
msgid "Mentor application updated."
msgstr "Mentor-Bewerbung aktualisiert."

#: apps/admin_audit/console_mentorship.py
msgid "Cadet application updated."
msgstr "Kadetten-Bewerbung aktualisiert."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't activate — the mentor may be at capacity."
msgstr ""
"Aktivierung fehlgeschlagen — der Mentor ist möglicherweise ausgelastet."

#: apps/admin_audit/console_mentorship.py
msgid "Pairing updated."
msgstr "Zuordnung aktualisiert."

#: apps/admin_audit/console_mentorship.py
msgid "Those two already have an open pairing."
msgstr "Diese beiden haben bereits eine offene Zuordnung."

#: apps/admin_audit/console_mentorship.py
msgid "Pairing created."
msgstr "Zuordnung erstellt."

#: apps/admin_audit/console_mentorship.py
#, python-format
msgid "Generated %(count)s suggestion(s)."
msgstr "%(count)s Vorschläge generiert."

#: apps/admin_audit/console_mentorship.py
msgid "You can't decide your own reward — another officer must."
msgstr ""
"Du kannst nicht über deine eigene Belohnung entscheiden — das muss ein "
"anderer Offizier tun."

#: apps/admin_audit/console_mentorship.py
msgid "Reward updated."
msgstr "Belohnung aktualisiert."

#: apps/admin_audit/console_mentorship.py
msgid "You can't pay out your own reward — another officer must."
msgstr ""
"Du kannst deine eigene Belohnung nicht auszahlen — das muss ein anderer "
"Offizier tun."

#: apps/admin_audit/console_mentorship.py
msgid "Marked paid."
msgstr "Als bezahlt markiert."

#: apps/admin_audit/console_mentorship.py
msgid "That reward isn't ready to pay."
msgstr "Diese Belohnung ist noch nicht zur Auszahlung bereit."

#: apps/admin_audit/console_mentorship.py apps/admin_audit/console_raffle.py
msgid "Flag resolved."
msgstr "Meldung erledigt."

#: apps/admin_audit/console_navigation.py
msgid "Safety margin must be between 0 and 100%."
msgstr ""

#: apps/admin_audit/console_navigation.py
msgid "Jump Planner settings saved."
msgstr "Jump-Planner-Einstellungen gespeichert."

#: apps/admin_audit/console_notifications.py
msgid "Unknown form."
msgstr "Unbekanntes Formular."

#: apps/admin_audit/console_notifications.py
msgid "Leadership distribution saved."
msgstr "Führungsverteilung gespeichert."

#: apps/admin_audit/console_notifications.py
msgid "Notification settings saved."
msgstr "Benachrichtigungseinstellungen gespeichert."

#: apps/admin_audit/console_pingboard.py
msgid "General settings saved."
msgstr "Allgemeine Einstellungen gespeichert."

#: apps/admin_audit/console_pingboard.py
msgid "Anti-abuse settings saved."
msgstr "Anti-Missbrauch-Einstellungen gespeichert."

#: apps/admin_audit/console_pingboard.py
msgid "Calendar settings saved."
msgstr "Kalender-Einstellungen gespeichert."

#: apps/admin_audit/console_pingboard.py
msgid "Channel added."
msgstr "Kanal hinzugefügt."

#: apps/admin_audit/console_pingboard.py
msgid "Channel enabled."
msgstr "Kanal aktiviert."

#: apps/admin_audit/console_pingboard.py
msgid "Channel disabled."
msgstr "Kanal deaktiviert."

#: apps/admin_audit/console_pingboard.py
msgid "Channel deleted."
msgstr "Kanal gelöscht."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Channel “%(label)s” saved and ready to send."
msgstr "Kanal “%(label)s” gespeichert und sendebereit."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Channel “%(label)s” saved, but not operational yet: %(why)s"
msgstr "Kanal “%(label)s” gespeichert, aber noch nicht einsatzbereit: %(why)s"

#: apps/admin_audit/console_pingboard.py
msgid "no provider implementation for this channel kind"
msgstr "keine Provider-Implementierung für diesen Kanaltyp"

#: apps/admin_audit/console_pingboard.py
msgid "could not verify configuration"
msgstr "Konfiguration konnte nicht überprüft werden"

#: apps/admin_audit/console_pingboard.py
msgid "No provider implementation for this channel."
msgstr "Keine Provider-Implementierung für diesen Kanal."

#: apps/admin_audit/console_pingboard.py
msgid ""
"Can't send a test EVE-mail — your account has no linked character to receive"
" it. Link a character, or just send a real alert (delivery to the corp works"
" independently)."
msgstr ""
"Es kann keine Test-EVE-Mail gesendet werden — dein Account hat keinen "
"verknüpften Charakter, der sie empfangen könnte. Verknüpfe einen Charakter "
"oder sende einfach einen echten Alarm (die Zustellung an die Corp "
"funktioniert unabhängig davon)."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Test mail sent to %(recipient)s — check your in-game inbox."
msgstr ""
"Test-Mail an %(recipient)s gesendet — überprüfe deinen Posteingang im Spiel."

#: apps/admin_audit/console_pingboard.py
msgid "your character"
msgstr "dein Charakter"

#: apps/admin_audit/console_pingboard.py
msgid "Test message sent."
msgstr "Testnachricht gesendet."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Test failed: %(error)s"
msgstr "Test fehlgeschlagen: %(error)s"

#: apps/admin_audit/console_pingboard.py
msgid "unknown error"
msgstr "unbekannter Fehler"

#: apps/admin_audit/console_pingboard.py
msgid "— none (use title/body below) —"
msgstr "— keine (Titel/Text unten verwenden) —"

#: apps/admin_audit/console_pingboard.py
msgid "Condition must be a JSON object, e.g. {\"amount_gt\": 1000000000}."
msgstr "Bedingung muss ein JSON-Objekt sein, z. B. {\"amount_gt\": 1000000000}."

#: apps/admin_audit/console_pingboard.py
msgid "Audience must be a JSON object, e.g. {\"kind\": \"officer\"}."
msgstr "Zielgruppe muss ein JSON-Objekt sein, z. B. {\"kind\": \"officer\"}."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Unknown audience kind %(kind)r. Use one of: %(kinds)s."
msgstr "Unbekannter Zielgruppentyp %(kind)r. Verwende einen von: %(kinds)s."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Audience role must be one of: %(roles)s."
msgstr "Die Zielgruppenrolle muss eine von folgenden sein: %(roles)s."

#: apps/admin_audit/console_pingboard.py
msgid "Window must be at least 1 minute."
msgstr "Das Zeitfenster muss mindestens 1 Minute betragen."

#: apps/admin_audit/console_pingboard.py
msgid "Cooldown can't be negative."
msgstr "Der Cooldown darf nicht negativ sein."

#: apps/admin_audit/console_pingboard.py
msgid "Max per window can't be negative (0 = unlimited)."
msgstr "Max. pro Fenster darf nicht negativ sein (0 = unbegrenzt)."

#: apps/admin_audit/console_pingboard.py
msgid "Channels must be a JSON list of channel keys, e.g. [\"in_app\", \"discord\"]."
msgstr ""
"Kanäle müssen eine JSON-Liste von Kanal-Keys sein, z. B. [\"in_app\", "
"\"discord\"]."

#: apps/admin_audit/console_pingboard.py
msgid "Rule updated."
msgstr "Regel aktualisiert."

#: apps/admin_audit/console_pingboard.py
msgid "Rule created (disabled)."
msgstr "Regel erstellt (deaktiviert)."

#: apps/admin_audit/console_pingboard.py
msgid "Rule enabled."
msgstr "Regel aktiviert."

#: apps/admin_audit/console_pingboard.py
msgid "Rule disabled."
msgstr "Regel deaktiviert."

#: apps/admin_audit/console_pingboard.py
msgid "Rule deleted."
msgstr "Regel gelöscht."

#: apps/admin_audit/console_pingboard.py
msgid "Template created."
msgstr "Vorlage erstellt."

#: apps/admin_audit/console_pingboard.py
msgid "Template enabled."
msgstr "Vorlage aktiviert."

#: apps/admin_audit/console_pingboard.py
msgid "Template disabled."
msgstr "Vorlage deaktiviert."

#: apps/admin_audit/console_pingboard.py
msgid "Template deleted."
msgstr "Vorlage gelöscht."

#: apps/admin_audit/console_planetary.py
msgid "Planetary Industry settings saved."
msgstr "Planetary-Industry-Einstellungen gespeichert."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Contest “%(name)s” created as a draft."
msgstr "Wettbewerb “%(name)s” als Entwurf erstellt."

#: apps/admin_audit/console_raffle.py
msgid "Raffle settings saved."
msgstr "Verlosungseinstellungen gespeichert."

#: apps/admin_audit/console_raffle.py
msgid ""
"This contest has started accruing tickets (or is closed) — its schedule and "
"rules are locked; only the text/display fields were saved."
msgstr ""
"Dieser Wettbewerb sammelt bereits Tickets an (oder ist geschlossen) — sein "
"Zeitplan und seine Regeln sind gesperrt; nur die Text-/Anzeigefelder wurden "
"gespeichert."

#: apps/admin_audit/console_raffle.py
msgid "Contest updated."
msgstr "Wettbewerb aktualisiert."

#: apps/admin_audit/console_raffle.py
msgid "Only a Director can cancel a contest."
msgstr "Nur ein Director kann einen Wettbewerb abbrechen."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Contest moved to %(status)s."
msgstr "Wettbewerb auf %(status)s gesetzt."

#: apps/admin_audit/console_raffle.py
msgid "That status change isn't allowed from the current state."
msgstr "Diese Statusänderung ist aus dem aktuellen Zustand nicht zulässig."

#: apps/admin_audit/console_raffle.py
msgid "Templates can only be applied to a draft/scheduled contest."
msgstr ""
"Vorlagen können nur auf einen Wettbewerb im Status Entwurf/Geplant "
"angewendet werden."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Applied the “%(key)s” template."
msgstr "Vorlage “%(key)s” angewendet."

#: apps/admin_audit/console_raffle.py
msgid "Unknown template."
msgstr "Unbekannte Vorlage."

#: apps/admin_audit/console_raffle.py
msgid "Prize saved."
msgstr "Preis gespeichert."

#: apps/admin_audit/console_raffle.py
msgid "Prize removed."
msgstr "Preis entfernt."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "“%(source)s” source saved."
msgstr "Quelle “%(source)s” gespeichert."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Granted %(amount)s tickets to %(who)s."
msgstr "%(amount)s Tickets an %(who)s vergeben."

#: apps/admin_audit/console_raffle.py
msgid "Entry reversed (a correcting row was appended)."
msgstr "Eintrag storniert (eine Korrekturzeile wurde angehängt)."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Entry marked %(status)s."
msgstr "Eintrag als %(status)s markiert."

#: apps/admin_audit/console_raffle.py
msgid "Couldn't change that entry."
msgstr "Dieser Eintrag konnte nicht geändert werden."

#: apps/admin_audit/console_raffle.py
msgid ""
" Only the top 200 pilots by tickets were considered — run again for more."
msgstr ""
" Nur die Top 200 Piloten nach Tickets wurden berücksichtigt — für mehr "
"erneut ausführen."

#: apps/admin_audit/console_raffle.py
msgid "Enrolment outreach is turned off in the notification console."
msgstr ""
"Die Anmelde-Kontaktaufnahme ist in der Benachrichtigungskonsole deaktiviert."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid ""
"Sent %(sent)s enrolment nudge(s); skipped %(skipped)s (already nudged, opted"
