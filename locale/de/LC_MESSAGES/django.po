msgid "Milestone removed — pilots' progress rows went with it."
msgstr ""
"Meilenstein entfernt — die Fortschrittszeilen der Piloten wurden ebenfalls "
"entfernt."

#: apps/admin_audit/console.py
#, python-format
msgid "Glossary term “%(term)s” saved."
msgstr "Glossarbegriff „%(term)s“ gespeichert."

#: apps/admin_audit/console.py
msgid "Both term and definition are required."
msgstr "Sowohl Begriff als auch Definition sind erforderlich."

#: apps/admin_audit/console.py
msgid "Glossary term removed."
msgstr "Glossarbegriff entfernt."

#: apps/admin_audit/console.py
