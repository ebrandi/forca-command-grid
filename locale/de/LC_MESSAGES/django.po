#: apps/pingboard/messages.py
msgid "Milestone unlocked: First kill!"
msgstr "Meilenstein freigeschaltet: Erster Kill!"

#: apps/pingboard/messages.py
msgid "Congratulations on your first corp killmail! Welcome to the fight."
msgstr "Glückwunsch zu deinem ersten Corp-Killmail! Willkommen im Kampf."

#: apps/pingboard/messages.py
msgid "Milestone unlocked: First solo kill!"
msgstr "Meilenstein freigeschaltet: Erster Solo-Kill!"

#: apps/pingboard/messages.py
msgid "Your first solo kill — you took one down all on your own. Nice work."
msgstr "Dein erster Solo-Kill — ganz allein erledigt. Starke Arbeit."

#: apps/pingboard/messages.py
msgid "Milestone unlocked: First final blow!"
msgstr "Meilenstein freigeschaltet: Erster Final Blow!"

#: apps/pingboard/messages.py
msgid "You landed your first final blow. The killing shot is yours."
msgstr ""
"Du hast deinen ersten Final Blow gelandet. Der tödliche Schuss gehört dir."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Combat rank achieved: {rank_name}"
msgstr "Kampfrang erreicht: {rank_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Congratulations — you've reached the rank of {rank_name} ({kill_count} "
"lifetime kills recorded). Ranks update from the nightly combat rollup, so "
"this can reflect kills from the last day or two rather than the exact moment."
msgstr ""
"Glückwunsch — du hast den Rang {rank_name} erreicht ({kill_count} Kills "
"insgesamt erfasst). Ränge werden aus der nächtlichen Kampfauswertung "
"aktualisiert, daher können Kills der letzten ein bis zwei Tage einfließen "
"statt des exakten Zeitpunkts."

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Congratulations — you've reached the rank of {rank_name} ({kill_count} "
"lifetime kills recorded). A rank reward is pending leadership approval. "
"Ranks update from the nightly combat rollup, so this can reflect kills from "
"the last day or two rather than the exact moment."
msgstr ""
"Glückwunsch — du hast den Rang {rank_name} erreicht ({kill_count} Kills "
"insgesamt erfasst). Eine Rangbelohnung wartet auf die Freigabe der Führung. "
"Ränge werden aus der nächtlichen Kampfauswertung aktualisiert, dieser Stand "
"kann also Kills der letzten ein bis zwei Tage abbilden statt des exakten "
"Moments."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Watchlist tripwire: {entity_name}"
msgstr "Watchlist-Tripwire: {entity_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"⚠ Watched {entity_type} **{entity_name}** ({watchlist_name}) was on a "
"killmail in {system_name} ~{minutes}m ago. Risk indicator, not a guarantee — "
"verify before acting."
msgstr ""
"⚠ Beobachtet: {entity_type} **{entity_name}** ({watchlist_name}) tauchte vor "
"ca. {minutes} Min. auf einem Killmail in {system_name} auf. Risikohinweis, "
"keine Garantie — vor dem Handeln prüfen."

