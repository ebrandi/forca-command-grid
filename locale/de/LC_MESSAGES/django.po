msgid "Grace (minutes)"
msgstr "Karenzzeit (Minuten)"

#: templates/srp/settings.html
msgid "Slack before/after the op for form-up &amp; travel."
msgstr "Puffer vor/nach der Op für Form-up &amp; Anreise."

#: templates/srp/settings.html
msgid "Default op length (minutes)"
msgstr "Standard-Op-Länge (Minuten)"

#: templates/srp/settings.html
msgid "Used when an op has no explicit duration."
msgstr "Wird verwendet, wenn eine Op keine explizite Dauer hat."

#: templates/srp/settings.html
msgid "Require recorded attendance (PAP)"
msgstr "Erfasste Teilnahme erforderlich (PAP)"

#: templates/srp/settings.html
msgid "Auto-draft claims for eligible losses"
msgstr "Anträge für anspruchsberechtigte Verluste automatisch erstellen"

