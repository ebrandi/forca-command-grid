#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "PVP activity raffle"
msgstr "PVP-Aktivitäts-Verlosung"

#: apps/raffle/contest_templates.py
msgid ""
"Reward everyone who undocks and gets on kills. Solo 100 · final blow 10 · "
"participation 1."
msgstr ""
"Belohnt alle, die undocken und auf Kills kommen. Solo 100 · Final Blow 10 · "
"Teilnahme 1."

#: apps/raffle/contest_templates.py
msgid "Get pilots on more kills."
msgstr "Bring Piloten auf mehr Kills."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Solo kill challenge"
msgstr "Solo-Kill-Challenge"

#: apps/raffle/contest_templates.py
msgid ""
"Heavily reward solo PvP prowess — solo kills are worth 10× a normal kill."
msgstr ""
"Belohnt Solo-PvP-Können massiv — Solo-Kills zählen 10× so viel wie ein "
"normaler Kill."

#: apps/raffle/contest_templates.py
msgid "Crown the corp's best solo hunter."
msgstr "Kröne den besten Solo-Jäger der Corp."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Home defence contest"
msgstr "Heimatverteidigungs-Wettbewerb"

#: apps/raffle/contest_templates.py
msgid ""
"Reward kills defending home space. Set the home region/systems in the PVP "
"filters."
msgstr ""
"Belohnt Kills bei der Verteidigung des Heimat-Space. Setz die Heimatregion/-"
"systeme in den PVP-Filtern."

#: apps/raffle/contest_templates.py
msgid "Defend home — kills in our space earn tickets."
msgstr "Verteidige die Heimat — Kills in unserem Territorium bringen Tickets."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Mining month"
msgstr "Mining-Monat"

#: apps/raffle/contest_templates.py
msgid "Reward ore mined from the corp mining ledger (X tickets per m³)."
msgstr "Belohnt geschürftes Erz laut Corp-Mining-Ledger (X Tickets pro m³)."

#: apps/raffle/contest_templates.py
msgid "Fill the ore hangar — mine to earn tickets."
msgstr "Füll den Erz-Hangar — schürfe, um Tickets zu verdienen."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Industry production drive"
msgstr "Industrie-Produktionsoffensive"

#: apps/raffle/contest_templates.py
msgid ""
"Recognise builders. Industry has no reliable per-pilot feed, so awards are "
"officer-approved."
msgstr ""
"Würdigt die Builder. Für Industrie gibt es keinen verlässlichen Feed pro "
"Pilot, deshalb werden Vergaben von Offizieren freigegeben."

#: apps/raffle/contest_templates.py
msgid "Keep the production lines running."
msgstr "Halte die Produktionslinien am Laufen."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Logistics support campaign"
msgstr "Logistik-Support-Kampagne"

#: apps/raffle/contest_templates.py
msgid "Reward haulers for delivered courier contracts (officer-approved)."
msgstr ""
"Belohnt Hauler für gelieferte Kurierverträge (von Offizieren freigegeben)."

#: apps/raffle/contest_templates.py
msgid "Keep the supply lines moving."
msgstr "Halte die Nachschublinien in Bewegung."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Newbro support contest"
msgstr "Newbro-Support-Wettbewerb"

#: apps/raffle/contest_templates.py
msgid "Reward mentors and helpers. Mentorship completions + leadership grants."
msgstr ""
"Belohnt Mentoren und Helfer. Abgeschlossene Mentorships + Vergaben der "
"Führung."

#: apps/raffle/contest_templates.py
msgid "Help new pilots get flying."
msgstr "Hilf neuen Piloten beim Einstieg."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Alliance deployment raffle"
msgstr "Allianz-Deployment-Verlosung"

#: apps/raffle/contest_templates.py
msgid ""
"PVP + fleet attendance during a deployment. Admits alliance / friendly "
"pilots."
msgstr ""
"PVP + Flottenteilnahme während eines Deployments. Zugelassen sind Allianz- "
"und befreundete Piloten."

#: apps/raffle/contest_templates.py
msgid "Show up and fight the deployment."
msgstr "Sei dabei und kämpfe im Deployment."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Mixed activity engagement"
msgstr "Gemischte Aktivitäten"

#: apps/raffle/contest_templates.py
msgid ""
"A bit of everything — PVP, mining, fleet attendance and leadership grants."
msgstr ""
"Von allem etwas — PVP, Mining, Flottenteilnahme und Vergaben der Führung."

#: apps/raffle/contest_templates.py
msgid "Reward any way of contributing to the corp."
msgstr "Belohne jeden Beitrag zur Corp."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "ESI adoption campaign"
msgstr "ESI-Anbindungskampagne"

#: apps/raffle/contest_templates.py
msgid ""
"Drive app enrolment — everyone who connects ESI and flies earns; big CTA on "
"the dashboard."
msgstr ""
"Treibt die Anmeldung in der App voran — wer ESI verbindet und fliegt, "
"verdient; großer CTA auf dem Dashboard."

#: apps/raffle/contest_templates.py
msgid "Get the whole corp enrolled in FORCA Command Grid."
msgstr "Bring die ganze Corp dazu, sich bei FORCA Command Grid anzumelden."

#: apps/raffle/draw.py
msgid "draw not completed / seed not revealed"
msgstr "Ziehung nicht abgeschlossen / Seed nicht offengelegt"

#: apps/raffle/draw.py
msgid "no eligible tickets"
msgstr "keine berechtigten Tickets"

#: apps/raffle/eligibility.py
msgid "This pilot has no FORCA Command Grid account."
msgstr "Dieser Pilot hat kein FORCA Command Grid-Konto."

#: apps/raffle/eligibility.py
msgid "Ask them to sign in with EVE SSO to start earning tickets."
msgstr "Bitte ihn, sich mit EVE SSO anzumelden, um Tickets zu sammeln."

#: apps/raffle/eligibility.py
msgid "This character isn't linked to a FORCA account."
msgstr "Dieser Charakter ist mit keinem FORCA-Konto verknüpft."

#: apps/raffle/eligibility.py
msgid "Sign in with EVE SSO to enrol and start earning tickets."
msgstr "Melde dich mit EVE SSO an, um teilzunehmen und Tickets zu sammeln."

#: apps/raffle/eligibility.py
msgid "You've been excluded from this contest by leadership."
msgstr "Du wurdest von der Führung aus diesem Wettbewerb ausgeschlossen."

#: apps/raffle/eligibility.py
msgid "Contact a director if you believe this is a mistake."
msgstr ""
"Kontaktiere einen Director, falls du glaubst, dass dies ein Fehler ist."

#: apps/raffle/eligibility.py
msgid "You haven't connected an ESI token yet."
msgstr "Du hast noch kein ESI-Token verbunden."

#: apps/raffle/eligibility.py
msgid "Connect your ESI token to start earning raffle tickets."
msgstr "Verbinde dein ESI-Token, um Verlosungs-Tickets zu sammeln."

#: apps/raffle/eligibility.py
msgid "Your ESI token has expired or been revoked."
msgstr "Dein ESI-Token ist abgelaufen oder wurde widerrufen."

#: apps/raffle/eligibility.py
msgid "Reconnect your ESI token to keep earning tickets."
msgstr "Verbinde dein ESI-Token erneut, um weiter Tickets zu sammeln."

#: apps/raffle/eligibility.py
msgid "Your ESI token is missing a scope this contest needs."
msgstr "Deinem ESI-Token fehlt ein Scope, den dieser Wettbewerb benötigt."

#: apps/raffle/eligibility.py
msgid "Re-authorise with the required scopes to earn tickets."
msgstr ""
"Autorisiere erneut mit den erforderlichen Scopes, um Tickets zu sammeln."

#: apps/raffle/eligibility.py
msgid "Only recognised corporation pilots can take part."
msgstr "Nur anerkannte Corporation-Piloten können teilnehmen."

#: apps/raffle/eligibility.py
msgid "Make sure your main is in the corp and re-sync your affiliation."
msgstr ""
"Stelle sicher, dass dein Main in der Corp ist, und synchronisiere deine "
"Zugehörigkeit erneut."

#: apps/raffle/eligibility.py
msgid "You're eligible — fly, earn tickets and check your progress."
msgstr ""
"Du bist teilnahmeberechtigt — flieg, sammle Tickets und verfolge deinen "
"Fortschritt."

#: apps/raffle/eligibility.py
msgid "Sign in with EVE SSO to take part in the raffle."
msgstr "Melde dich mit EVE SSO an, um an der Verlosung teilzunehmen."

#: apps/raffle/eligibility.py
msgid "Sign in to enrol and start earning tickets."
msgstr "Melde dich an, um teilzunehmen und Tickets zu sammeln."

#: apps/raffle/eligibility.py
msgid "Your account has no linked EVE character yet."
msgstr "Deinem Konto ist noch kein EVE-Charakter zugeordnet."

#: apps/raffle/eligibility.py
msgid "Link a character with EVE SSO to earn tickets."
msgstr "Verknüpfe einen Charakter mit EVE SSO, um Tickets zu sammeln."

