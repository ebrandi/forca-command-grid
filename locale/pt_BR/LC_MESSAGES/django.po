#: apps/pingboard/messages.py
msgid "Milestone unlocked: First kill!"
msgstr "Marco desbloqueado: primeiro kill!"

#: apps/pingboard/messages.py
msgid "Congratulations on your first corp killmail! Welcome to the fight."
msgstr "Parabéns pelo seu primeiro killmail da corp! Bem-vindo à luta."

#: apps/pingboard/messages.py
msgid "Milestone unlocked: First solo kill!"
msgstr "Marco desbloqueado: primeiro kill solo!"

#: apps/pingboard/messages.py
msgid "Your first solo kill — you took one down all on your own. Nice work."
msgstr ""
"Seu primeiro kill solo — você derrubou um alvo sozinho. Belo trabalho."

#: apps/pingboard/messages.py
msgid "Milestone unlocked: First final blow!"
msgstr "Marco desbloqueado: primeiro final blow!"

#: apps/pingboard/messages.py
msgid "You landed your first final blow. The killing shot is yours."
msgstr "Você deu seu primeiro final blow. O tiro fatal é seu."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Combat rank achieved: {rank_name}"
msgstr "Patente de combate alcançada: {rank_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Congratulations — you've reached the rank of {rank_name} ({kill_count} "
"lifetime kills recorded). Ranks update from the nightly combat rollup, so "
"this can reflect kills from the last day or two rather than the exact "
"moment."
msgstr ""
"Parabéns — você alcançou a patente de {rank_name} ({kill_count} kills "
"registrados no total). As patentes são atualizadas pelo consolidado noturno "
"de combate, então isso pode refletir kills do último dia ou dois, e não o "
"momento exato."

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Congratulations — you've reached the rank of {rank_name} ({kill_count} "
"lifetime kills recorded). A rank reward is pending leadership approval. "
"Ranks update from the nightly combat rollup, so this can reflect kills from "
"the last day or two rather than the exact moment."
msgstr ""
"Parabéns — você alcançou a patente de {rank_name} ({kill_count} kills "
"registrados no total). Uma recompensa de patente está pendente de aprovação "
"da liderança. As patentes são atualizadas pelo consolidado noturno de "
"combate, então isso pode refletir kills do último dia ou dois, e não o "
"momento exato."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Watchlist tripwire: {entity_name}"
msgstr "Alarme de watchlist: {entity_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"⚠ Watched {entity_type} **{entity_name}** ({watchlist_name}) was on a "
"killmail in {system_name} ~{minutes}m ago. Risk indicator, not a guarantee —"
" verify before acting."
msgstr ""
"⚠ Alvo monitorado ({entity_type}) **{entity_name}** ({watchlist_name}) "
"apareceu em um killmail em {system_name} há ~{minutes}min. Indicador de "
"risco, não uma garantia — confirme antes de agir."

#: apps/pingboard/messages.py
msgid "Order update: Claimed"
msgstr "Pedido atualizado: Reivindicado"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "{ship_name} was claimed — a member is fulfilling it."
msgstr "O pedido de {ship_name} foi reivindicado — um membro está atendendo."

