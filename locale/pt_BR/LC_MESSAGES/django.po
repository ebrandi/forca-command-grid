msgstr ""
"Plano “%(name)s” criado — aqui estão sua configuração e estimativa de lucro."

#: apps/planetary/views.py
msgid "Plan updated and re-costed."
msgstr "Plano atualizado e com custos recalculados."

#: apps/planetary/views.py
msgid "Keep at least one planet on the plan."
msgstr "Mantenha pelo menos um planeta no plano."

#: apps/planetary/views.py
msgid "Re-costed with the latest market prices."
msgstr "Custos recalculados com os preços de mercado mais recentes."

#: apps/planetary/views.py
#, python-format
msgid "Duplicated as “%(name)s”."
msgstr "Duplicado como “%(name)s”."

#: apps/planetary/views.py
#, python-format
msgid "Status set to %(status)s."
msgstr "Status definido como %(status)s."

#: apps/planetary/views.py
#, python-format
msgid "“%(name)s” archived. Delete again to remove it permanently."
msgstr ""
"“%(name)s” arquivado. Exclua novamente para removê-lo permanentemente."

#: apps/planetary/views.py
#, python-format
