#: apps/admin_audit/console.py
#, python-format
msgid "Imported %(count)d fit as new doctrines under IMPORTED."
msgid_plural "Imported %(count)d fits as new doctrines under IMPORTED."
msgstr[0] "Importado %(count)d fit como novas doctrines em IMPORTED."
msgstr[1] "Importados %(count)d fits como novas doctrines em IMPORTED."

#: apps/admin_audit/console_access.py
msgid "Enter a valid alliance id."
msgstr "Informe um id de aliança válido."

#: apps/admin_audit/console_access.py
msgid "Partner alliance saved."
msgstr "Aliança parceira salva."

#: apps/admin_audit/console_access.py
msgid "Partner alliance removed."
msgstr "Aliança parceira removida."

#: apps/admin_audit/console_access.py
msgid "Enter a valid corporation id."
msgstr "Informe um id de corporação válido."

#: apps/admin_audit/console_access.py
msgid "Friendly corporation saved."
msgstr "Corporação amiga salva."

#: apps/admin_audit/console_access.py
msgid "Friendly corporation removed."
msgstr "Corporação amiga removida."

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings reset to defaults."
msgstr "Configurações de Capsuleer Path redefinidas para os padrões."

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings saved."
msgstr "Configurações de Capsuleer Path salvas."

#: apps/admin_audit/console_combat.py
msgid "A rank title can't be empty."
msgstr "O título de uma patente não pode ficar vazio."

#: apps/admin_audit/console_combat.py
msgid "Reward amount can't be negative."
msgstr "O valor da recompensa não pode ser negativo."

#: apps/admin_audit/console_combat.py
msgid "Another rank already uses this threshold for this metric."
msgstr "Outra patente já usa este limiar para esta métrica."

#: apps/admin_audit/console_combat.py
msgid ""
"Rewards apply to the all-time PvP kills track only — the support-role tracks"
" are recognition-only."
msgstr ""
"As recompensas se aplicam apenas à trilha de abates PvP de todos os tempos —"
" as trilhas de função de suporte são apenas de reconhecimento."

#: apps/admin_audit/console_combat.py
msgid "Choose a reward type, or untick “grants reward”."
msgstr "Escolha um tipo de recompensa ou desmarque “concede recompensa”."

#: apps/admin_audit/console_combat.py
msgid "An item reward needs an EVE type id."
msgstr "Uma recompensa de item precisa de um EVE type id."

#: apps/admin_audit/console_combat.py
msgid "An ISK/PLEX reward needs a positive amount."
msgstr "Uma recompensa em ISK/PLEX precisa de um valor positivo."

#: apps/admin_audit/console_combat.py
msgid "Must be zero or positive."
msgstr "Deve ser zero ou positivo."

#: apps/admin_audit/console_combat.py
msgid "Can't exceed 100%."
msgstr "Não pode exceder 100%."

#: apps/admin_audit/console_combat.py
msgid "Newbro settings saved."
msgstr "Configurações de Newbro salvas."

#: apps/admin_audit/console_combat.py
msgid "Please correct the newbro settings."
msgstr "Corrija as configurações de newbro."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” saved."
msgstr "Patente “%(name)s” salva."

#: apps/admin_audit/console_combat.py apps/admin_audit/console_corporation.py
#: apps/admin_audit/console_industry.py apps/admin_audit/console_mentorship.py
#: apps/admin_audit/console_navigation.py
#: apps/admin_audit/console_pingboard.py apps/admin_audit/console_planetary.py
#: apps/admin_audit/console_raffle.py
msgid "Please correct the errors below."
msgstr "Corrija os erros abaixo."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” removed."
msgstr "Patente “%(name)s” removida."

#: apps/admin_audit/console_combat.py
msgid "Reward settings saved."
msgstr "Configurações de recompensa salvas."

#: apps/admin_audit/console_combat.py
#, python-format
msgid ""
"Rewards enabled. Baseline snapshotted for %(n)d pilot(s) — only ranks "
"reached from now on will create rewards."
msgstr ""
"Recompensas ativadas. Linha de base capturada para %(n)d piloto(s) — apenas "
"patentes alcançadas de agora em diante criarão recompensas."

#: apps/admin_audit/console_combat.py
msgid "Rewards disabled. No new reward events will be created."
msgstr ""
"Recompensas desativadas. Nenhum novo evento de recompensa será criado."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Baseline re-snapshotted for %(n)d pilot(s)."
msgstr "Linha de base recapturada para %(n)d piloto(s)."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward scan complete — %(n)d new reward event(s) created."
msgstr ""
"Varredura de recompensas concluída — %(n)d novo(s) evento(s) de recompensa "
"criado(s)."

#: apps/admin_audit/console_combat.py apps/buyback/views.py
#: apps/logistics/views.py apps/stockpile/views.py apps/store/views.py
msgid "Unknown action."
msgstr "Ação desconhecida."

#: apps/admin_audit/console_combat.py
msgid "Only a Director can mark a reward paid."
msgstr "Apenas um Diretor pode marcar uma recompensa como paga."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward %(action)s — %(character)s · %(rank)s."
msgstr "Recompensa %(action)s — %(character)s · %(rank)s."

#: apps/admin_audit/console_command_intel.py
#, python-format
msgid "%(domain)s reset to defaults."
msgstr "%(domain)s redefinido para os padrões."

#: apps/admin_audit/console_command_intel.py
msgid "Provider & model settings saved."
msgstr "Configurações de provedor e modelo salvas."

#: apps/admin_audit/console_command_intel.py
msgid "Critical ratio"
msgstr "Razão crítica"

#: apps/admin_audit/console_command_intel.py
msgid "Headroom/demand at or below this colours a constraint critical."
msgstr ""
"Folga/demanda igual ou abaixo disto colore uma restrição como crítica."

#: apps/admin_audit/console_command_intel.py
msgid "High ratio"
msgstr "Razão alta"

#: apps/admin_audit/console_command_intel.py
msgid "Above critical, at or below this colours it high."
msgstr "Acima de crítico, igual ou abaixo disto colore-a como alta."

#: apps/admin_audit/console_command_intel.py
msgid "Watch ratio"
msgstr "Razão de atenção"

#: apps/admin_audit/console_command_intel.py
msgid "Above high, at or below this colours it watch."
msgstr "Acima de alto, igual ou abaixo disto colore-a como atenção."

#: apps/admin_audit/console_command_intel.py
msgid "Constraints & thresholds saved."
msgstr "Restrições e limiares salvos."

#: apps/admin_audit/console_command_intel.py
msgid "Classification settings saved."
msgstr "Configurações de classificação salvas."

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Corporation Internal"
msgstr "Interno da Corporação"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "High Command"
msgstr "Alto Comando"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Director — Eyes Only"
msgstr "Diretor — Apenas para os Olhos"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Alliance Command"
msgstr "Comando da Aliança"

#: apps/admin_audit/console_command_intel.py
msgid "Notification & delivery settings saved."
msgstr "Configurações de notificação e entrega salvas."

#: apps/admin_audit/console_command_intel.py
msgid "Autonomous proposal settings saved."
msgstr "Configurações de proposta autônoma salvas."

#: apps/admin_audit/console_command_intel.py
msgid "Auto-AAR settings saved."
msgstr "Configurações de Auto-AAR salvas."

#: apps/admin_audit/console_corporation.py
msgid "Low-fuel warning must be between 1 and 30 days."
msgstr "O aviso de combustível baixo deve estar entre 1 e 30 dias."

#: apps/admin_audit/console_corporation.py
msgid "ADM floor must be between 1.0 and 6.0."
msgstr "O piso de ADM deve estar entre 1.0 e 6.0."

#: apps/admin_audit/console_corporation.py
msgid "Structure-alert thresholds saved."
msgstr "Limiares de alerta de estrutura salvos."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import rejected: %(error)s"
msgstr "Importação rejeitada: %(error)s"

#: apps/admin_audit/console_doctrine_xml.py
msgid "XML import applied."
msgstr "Importação de XML aplicada."

#: apps/admin_audit/console_doctrine_xml.py
msgid "Enter a whole number."
msgstr "Informe um número inteiro."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Limit set to %(clamped)s (values are kept within 1–%(ceiling)s)."
msgstr ""
"Limite definido como %(clamped)s (os valores são mantidos entre "
"1–%(ceiling)s)."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import limit set to %(clamped)s fittings."
msgstr "Limite de importação definido como %(clamped)s fittings."

#: apps/admin_audit/console_industry.py
msgid "Industry & Economy settings saved."
msgstr "Configurações de Indústria e Economia salvas."

#: apps/admin_audit/console_mentorship.py
msgid "Mentorship Program settings saved."
msgstr "Configurações do Programa de Mentoria salvas."

#: apps/admin_audit/console_mentorship.py
msgid "Cohort saved."
msgstr "Coorte salva."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the cohort — check the values."
msgstr "Não foi possível salvar a coorte — verifique os valores."

#: apps/admin_audit/console_mentorship.py
msgid "Cohort removed."
msgstr "Coorte removida."

#: apps/admin_audit/console_mentorship.py
msgid "Track saved."
msgstr "Trilha salva."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the track — check the values."
msgstr "Não foi possível salvar a trilha — verifique os valores."

#: apps/admin_audit/console_mentorship.py
msgid "Track removed."
msgstr "Trilha removida."

#: apps/admin_audit/console_mentorship.py
msgid "Track cloned (as a draft)."
msgstr "Trilha clonada (como rascunho)."

#: apps/admin_audit/console_mentorship.py
msgid ""
"Criteria must be a JSON object, e.g. {\"type\": \"skill_min\", "
"\"skill_type_id\": 3300, \"level\": 3}."
msgstr ""
"Os critérios devem ser um objeto JSON, por exemplo {\"type\": \"skill_min\","
" \"skill_type_id\": 3300, \"level\": 3}."

#: apps/admin_audit/console_mentorship.py
msgid "Field exercise saved."
msgstr "Exercício de campo salvo."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the exercise — check the values."
msgstr "Não foi possível salvar o exercício — verifique os valores."

#: apps/admin_audit/console_mentorship.py
msgid "Field exercise removed."
msgstr "Exercício de campo removido."

#: apps/admin_audit/console_mentorship.py
msgid "Reward rule saved."
msgstr "Regra de recompensa salva."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the reward rule — check the values."
msgstr "Não foi possível salvar a regra de recompensa — verifique os valores."

#: apps/admin_audit/console_mentorship.py
msgid "Reward rule removed."
msgstr "Regra de recompensa removida."

#: apps/admin_audit/console_mentorship.py
msgid "Badge saved."
msgstr "Emblema salvo."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the badge — check the values."
msgstr "Não foi possível salvar o emblema — verifique os valores."

#: apps/admin_audit/console_mentorship.py
msgid "Badge removed."
msgstr "Emblema removido."

#: apps/admin_audit/console_mentorship.py
msgid "Mentor application updated."
msgstr "Candidatura de mentor atualizada."

#: apps/admin_audit/console_mentorship.py
msgid "Cadet application updated."
msgstr "Candidatura de cadete atualizada."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't activate — the mentor may be at capacity."
msgstr "Não foi possível ativar — o mentor pode estar na capacidade máxima."

#: apps/admin_audit/console_mentorship.py
msgid "Pairing updated."
msgstr "Emparelhamento atualizado."

#: apps/admin_audit/console_mentorship.py
msgid "Those two already have an open pairing."
msgstr "Esses dois já têm um emparelhamento aberto."

#: apps/admin_audit/console_mentorship.py
msgid "Pairing created."
msgstr "Emparelhamento criado."

#: apps/admin_audit/console_mentorship.py
#, python-format
msgid "Generated %(count)s suggestion(s)."
msgstr "%(count)s sugestão(ões) gerada(s)."

#: apps/admin_audit/console_mentorship.py
msgid "You can't decide your own reward — another officer must."
msgstr ""
"Você não pode decidir sua própria recompensa — outro oficial precisa fazê-"
"lo."

#: apps/admin_audit/console_mentorship.py
msgid "Reward updated."
msgstr "Recompensa atualizada."

#: apps/admin_audit/console_mentorship.py
msgid "You can't pay out your own reward — another officer must."
msgstr ""
"Você não pode pagar sua própria recompensa — outro oficial precisa fazê-lo."

#: apps/admin_audit/console_mentorship.py
msgid "Marked paid."
msgstr "Marcado como pago."

#: apps/admin_audit/console_mentorship.py
msgid "That reward isn't ready to pay."
msgstr "Essa recompensa não está pronta para pagamento."

#: apps/admin_audit/console_mentorship.py apps/admin_audit/console_raffle.py
msgid "Flag resolved."
msgstr "Sinalização resolvida."

#: apps/admin_audit/console_navigation.py
msgid "Safety margin must be between 0 and 100%."
msgstr "A margem de segurança deve estar entre 0 e 100%."

#: apps/admin_audit/console_navigation.py
msgid "Jump Planner settings saved."
msgstr "Configurações do Jump Planner salvas."

#: apps/admin_audit/console_notifications.py
msgid "Unknown form."
msgstr "Formulário desconhecido."

#: apps/admin_audit/console_notifications.py
msgid "Leadership distribution saved."
msgstr "Distribuição de liderança salva."

#: apps/admin_audit/console_notifications.py
msgid "Notification settings saved."
msgstr "Configurações de notificação salvas."

#: apps/admin_audit/console_pingboard.py
msgid "General settings saved."
msgstr "Configurações gerais salvas."

#: apps/admin_audit/console_pingboard.py
msgid "Anti-abuse settings saved."
msgstr "Configurações antiabuso salvas."

#: apps/admin_audit/console_pingboard.py
msgid "Calendar settings saved."
msgstr "Configurações de calendário salvas."

#: apps/admin_audit/console_pingboard.py
msgid "Channel added."
msgstr "Canal adicionado."

#: apps/admin_audit/console_pingboard.py
msgid "Channel enabled."
msgstr "Canal ativado."

#: apps/admin_audit/console_pingboard.py
msgid "Channel disabled."
msgstr "Canal desativado."

#: apps/admin_audit/console_pingboard.py
msgid "Channel deleted."
msgstr "Canal excluído."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Channel “%(label)s” saved and ready to send."
msgstr "Canal “%(label)s” salvo e pronto para enviar."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Channel “%(label)s” saved, but not operational yet: %(why)s"
msgstr "Canal “%(label)s” salvo, mas ainda não operacional: %(why)s"

#: apps/admin_audit/console_pingboard.py
msgid "no provider implementation for this channel kind"
msgstr "nenhuma implementação de provedor para este tipo de canal"

#: apps/admin_audit/console_pingboard.py
msgid "could not verify configuration"
msgstr "não foi possível verificar a configuração"

#: apps/admin_audit/console_pingboard.py
msgid "No provider implementation for this channel."
msgstr "Nenhuma implementação de provedor para este canal."

#: apps/admin_audit/console_pingboard.py
msgid ""
"Can't send a test EVE-mail — your account has no linked character to receive"
" it. Link a character, or just send a real alert (delivery to the corp works"
" independently)."
msgstr ""
"Não é possível enviar um EVE-mail de teste — sua conta não tem nenhum "
"personagem vinculado para recebê-lo. Vincule um personagem ou apenas envie "
"um alerta real (a entrega para a corp funciona de forma independente)."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Test mail sent to %(recipient)s — check your in-game inbox."
msgstr ""
"E-mail de teste enviado para %(recipient)s — verifique sua caixa de entrada "
"no jogo."

#: apps/admin_audit/console_pingboard.py
msgid "your character"
msgstr "seu personagem"

#: apps/admin_audit/console_pingboard.py
msgid "Test message sent."
msgstr "Mensagem de teste enviada."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Test failed: %(error)s"
msgstr "Teste falhou: %(error)s"

#: apps/admin_audit/console_pingboard.py
msgid "unknown error"
msgstr "erro desconhecido"

#: apps/admin_audit/console_pingboard.py
msgid "— none (use title/body below) —"
msgstr "— nenhum (use o título/corpo abaixo) —"

#: apps/admin_audit/console_pingboard.py
msgid "Condition must be a JSON object, e.g. {\"amount_gt\": 1000000000}."
msgstr ""
"A condição deve ser um objeto JSON, por exemplo {\"amount_gt\": 1000000000}."

#: apps/admin_audit/console_pingboard.py
msgid "Audience must be a JSON object, e.g. {\"kind\": \"officer\"}."
msgstr "O público deve ser um objeto JSON, por exemplo {\"kind\": \"officer\"}."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Unknown audience kind %(kind)r. Use one of: %(kinds)s."
msgstr "Tipo de público desconhecido %(kind)r. Use um destes: %(kinds)s."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Audience role must be one of: %(roles)s."
msgstr "O papel do público deve ser um destes: %(roles)s."

#: apps/admin_audit/console_pingboard.py
msgid "Window must be at least 1 minute."
msgstr "A janela deve ter pelo menos 1 minuto."

#: apps/admin_audit/console_pingboard.py
msgid "Cooldown can't be negative."
msgstr "O tempo de espera não pode ser negativo."

#: apps/admin_audit/console_pingboard.py
msgid "Max per window can't be negative (0 = unlimited)."
msgstr "O máximo por janela não pode ser negativo (0 = ilimitado)."

#: apps/admin_audit/console_pingboard.py
msgid "Channels must be a JSON list of channel keys, e.g. [\"in_app\", \"discord\"]."
msgstr ""
"Os canais devem ser uma lista JSON de chaves de canal, por exemplo "
"[\"in_app\", \"discord\"]."

#: apps/admin_audit/console_pingboard.py
msgid "Rule updated."
msgstr "Regra atualizada."

#: apps/admin_audit/console_pingboard.py
msgid "Rule created (disabled)."
msgstr "Regra criada (desativada)."

#: apps/admin_audit/console_pingboard.py
msgid "Rule enabled."
msgstr "Regra ativada."

#: apps/admin_audit/console_pingboard.py
msgid "Rule disabled."
msgstr "Regra desativada."

#: apps/admin_audit/console_pingboard.py
msgid "Rule deleted."
msgstr "Regra excluída."

#: apps/admin_audit/console_pingboard.py
msgid "Template created."
msgstr "Modelo criado."

#: apps/admin_audit/console_pingboard.py
msgid "Template enabled."
msgstr "Modelo ativado."

#: apps/admin_audit/console_pingboard.py
msgid "Template disabled."
msgstr "Modelo desativado."

#: apps/admin_audit/console_pingboard.py
msgid "Template deleted."
msgstr "Modelo excluído."

#: apps/admin_audit/console_planetary.py
msgid "Planetary Industry settings saved."
msgstr "Configurações de Planetary Industry salvas."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Contest “%(name)s” created as a draft."
msgstr "Concurso “%(name)s” criado como rascunho."

#: apps/admin_audit/console_raffle.py
msgid "Raffle settings saved."
msgstr "Configurações de rifa salvas."

#: apps/admin_audit/console_raffle.py
msgid ""
"This contest has started accruing tickets (or is closed) — its schedule and "
"rules are locked; only the text/display fields were saved."
msgstr ""
"Este concurso começou a acumular bilhetes (ou está encerrado) — seu "
"cronograma e suas regras estão bloqueados; apenas os campos de "
"texto/exibição foram salvos."

#: apps/admin_audit/console_raffle.py
msgid "Contest updated."
msgstr "Concurso atualizado."

#: apps/admin_audit/console_raffle.py
msgid "Only a Director can cancel a contest."
msgstr "Apenas um Diretor pode cancelar um concurso."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Contest moved to %(status)s."
msgstr "Concurso movido para %(status)s."

#: apps/admin_audit/console_raffle.py
msgid "That status change isn't allowed from the current state."
msgstr "Essa mudança de status não é permitida a partir do estado atual."

#: apps/admin_audit/console_raffle.py
msgid "Templates can only be applied to a draft/scheduled contest."
msgstr "Modelos só podem ser aplicados a um concurso em rascunho/agendado."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Applied the “%(key)s” template."
msgstr "Modelo “%(key)s” aplicado."

#: apps/admin_audit/console_raffle.py
msgid "Unknown template."
msgstr "Modelo desconhecido."

#: apps/admin_audit/console_raffle.py
msgid "Prize saved."
msgstr "Prêmio salvo."

#: apps/admin_audit/console_raffle.py
msgid "Prize removed."
msgstr "Prêmio removido."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "“%(source)s” source saved."
msgstr "Fonte “%(source)s” salva."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Granted %(amount)s tickets to %(who)s."
msgstr "%(amount)s bilhetes concedidos a %(who)s."

#: apps/admin_audit/console_raffle.py
msgid "Entry reversed (a correcting row was appended)."
msgstr "Lançamento revertido (uma linha de correção foi anexada)."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Entry marked %(status)s."
msgstr "Lançamento marcado como %(status)s."

#: apps/admin_audit/console_raffle.py
msgid "Couldn't change that entry."
msgstr "Não foi possível alterar esse lançamento."

#: apps/admin_audit/console_raffle.py
msgid ""
" Only the top 200 pilots by tickets were considered — run again for more."
msgstr ""
" Apenas os 200 principais pilotos por bilhetes foram considerados — execute "
"novamente para mais."

#: apps/admin_audit/console_raffle.py
msgid "Enrolment outreach is turned off in the notification console."
msgstr "A divulgação de inscrição está desativada no console de notificações."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid ""
"Sent %(sent)s enrolment nudge(s); skipped %(skipped)s (already nudged, opted"
" out, now enrolled, or no linked account).%(capped)s"
msgstr ""
"Enviado(s) %(sent)s lembrete(s) de inscrição; %(skipped)s ignorado(s) (já "
"lembrado, optou por sair, agora inscrito ou sem conta vinculada).%(capped)s"

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "No new pilots to nudge (skipped %(skipped)s).%(capped)s"
msgstr "Nenhum piloto novo para lembrar (%(skipped)s ignorado(s)).%(capped)s"

#: apps/admin_audit/console_raffle.py
msgid "Contest closed — the ledger is frozen."
msgstr "Concurso encerrado — o livro-razão está congelado."

#: apps/admin_audit/console_raffle.py
