msgid "Reward rule removed."
msgstr "Правило награды удалено."

#: apps/admin_audit/console_mentorship.py
msgid "Badge saved."
msgstr "Значок сохранён."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the badge — check the values."
msgstr "Не удалось сохранить значок — проверьте значения."

#: apps/admin_audit/console_mentorship.py
msgid "Badge removed."
msgstr "Значок удалён."

#: apps/admin_audit/console_mentorship.py
msgid "Mentor application updated."
msgstr "Заявка наставника обновлена."

#: apps/admin_audit/console_mentorship.py
msgid "Cadet application updated."
msgstr "Заявка кадета обновлена."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't activate — the mentor may be at capacity."
msgstr ""
"Не удалось активировать — возможно, наставник достиг предела нагрузки."

#: apps/admin_audit/console_mentorship.py
msgid "Pairing updated."
msgstr "Пара обновлена."

#: apps/admin_audit/console_mentorship.py
msgid "Those two already have an open pairing."
msgstr "У этих двоих уже есть открытая пара."

#: apps/admin_audit/console_mentorship.py
msgid "Pairing created."
msgstr "Пара создана."

#: apps/admin_audit/console_mentorship.py
#, python-format
