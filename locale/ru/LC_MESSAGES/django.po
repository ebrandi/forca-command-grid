msgstr "Сгенерировано %(count)s предложений."

#: apps/admin_audit/console_mentorship.py
msgid "You can't decide your own reward — another officer must."
msgstr ""
"Вы не можете решать по собственной награде — это должен сделать другой "
"officer."

#: apps/admin_audit/console_mentorship.py
msgid "Reward updated."
msgstr "Награда обновлена."

#: apps/admin_audit/console_mentorship.py
msgid "You can't pay out your own reward — another officer must."
msgstr ""
"Вы не можете выплатить собственную награду — это должен сделать другой "
"officer."

#: apps/admin_audit/console_mentorship.py
msgid "Marked paid."
msgstr "Отмечено как выплачено."

#: apps/admin_audit/console_mentorship.py
msgid "That reward isn't ready to pay."
msgstr "Эта награда ещё не готова к выплате."

#: apps/admin_audit/console_mentorship.py apps/admin_audit/console_raffle.py
