msgid "Please correct the errors below."
msgstr "Пожалуйста, исправьте ошибки ниже."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” removed."
msgstr "Ранг «%(name)s» удалён."

#: apps/admin_audit/console_combat.py
msgid "Reward settings saved."
msgstr "Настройки наград сохранены."

#: apps/admin_audit/console_combat.py
#, python-format
msgid ""
"Rewards enabled. Baseline snapshotted for %(n)d pilot(s) — only ranks "
"reached from now on will create rewards."
msgstr ""
"Награды включены. Сохранён базовый снимок для %(n)d пилота(ов) — награды "
"будут создаваться только для рангов, достигнутых с этого момента."

#: apps/admin_audit/console_combat.py
msgid "Rewards disabled. No new reward events will be created."
msgstr "Награды отключены. Новые события наград создаваться не будут."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Baseline re-snapshotted for %(n)d pilot(s)."
msgstr "Базовый снимок пересоздан для %(n)d пилота(ов)."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward scan complete — %(n)d new reward event(s) created."
msgstr "Сканирование наград завершено — создано %(n)d новых событий наград."

#: apps/admin_audit/console_combat.py apps/buyback/views.py
#: apps/logistics/views.py apps/stockpile/views.py apps/store/views.py
msgid "Unknown action."
msgstr "Неизвестное действие."

#: apps/admin_audit/console_combat.py
msgid "Only a Director can mark a reward paid."
msgstr "Только Директор может отметить награду как выплаченную."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward %(action)s — %(character)s · %(rank)s."
msgstr "Награда %(action)s — %(character)s · %(rank)s."

#: apps/admin_audit/console_command_intel.py
#, python-format
msgid "%(domain)s reset to defaults."
msgstr "%(domain)s сброшено до значений по умолчанию."

#: apps/admin_audit/console_command_intel.py
msgid "Provider & model settings saved."
msgstr "Настройки провайдера и модели сохранены."

#: apps/admin_audit/console_command_intel.py
msgid "Critical ratio"
msgstr "Критическое соотношение"

#: apps/admin_audit/console_command_intel.py
msgid "Headroom/demand at or below this colours a constraint critical."
msgstr ""
"Запас/спрос на этом уровне или ниже окрашивает ограничение как критическое."

#: apps/admin_audit/console_command_intel.py
msgid "High ratio"
msgstr "Высокое соотношение"

#: apps/admin_audit/console_command_intel.py
msgid "Above critical, at or below this colours it high."
msgstr "Выше критического: на этом уровне или ниже окрашивается как высокое."

#: apps/admin_audit/console_command_intel.py
msgid "Watch ratio"
msgstr "Соотношение для наблюдения"

#: apps/admin_audit/console_command_intel.py
msgid "Above high, at or below this colours it watch."
msgstr "Выше высокого: на этом уровне или ниже окрашивается как наблюдение."

#: apps/admin_audit/console_command_intel.py
msgid "Constraints & thresholds saved."
msgstr "Ограничения и пороги сохранены."

#: apps/admin_audit/console_command_intel.py
msgid "Classification settings saved."
msgstr "Настройки классификации сохранены."

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Corporation Internal"
msgstr "Внутри корпорации"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "High Command"
msgstr "Высшее командование"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Director — Eyes Only"
msgstr "Только для Директора"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Alliance Command"
msgstr "Командование альянса"

#: apps/admin_audit/console_command_intel.py
msgid "Notification & delivery settings saved."
msgstr "Настройки уведомлений и доставки сохранены."

#: apps/admin_audit/console_command_intel.py
msgid "Autonomous proposal settings saved."
msgstr "Настройки автономных предложений сохранены."

#: apps/admin_audit/console_command_intel.py
msgid "Auto-AAR settings saved."
msgstr "Настройки Auto-AAR сохранены."

#: apps/admin_audit/console_corporation.py
msgid "Low-fuel warning must be between 1 and 30 days."
msgstr "Предупреждение о низком уровне топлива должно быть от 1 до 30 дней."

#: apps/admin_audit/console_corporation.py
msgid "ADM floor must be between 1.0 and 6.0."
msgstr "Минимальный ADM должен быть от 1.0 до 6.0."

#: apps/admin_audit/console_corporation.py
msgid "Structure-alert thresholds saved."
msgstr "Пороги оповещений о структурах сохранены."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import rejected: %(error)s"
msgstr "Импорт отклонён: %(error)s"

#: apps/admin_audit/console_doctrine_xml.py
msgid "XML import applied."
msgstr "Импорт XML применён."

#: apps/admin_audit/console_doctrine_xml.py
msgid "Enter a whole number."
msgstr "Введите целое число."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Limit set to %(clamped)s (values are kept within 1–%(ceiling)s)."
msgstr ""
"Лимит установлен на %(clamped)s (значения удерживаются в пределах "
"1–%(ceiling)s)."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import limit set to %(clamped)s fittings."
msgstr "Лимит импорта установлен на %(clamped)s фиттингов."

