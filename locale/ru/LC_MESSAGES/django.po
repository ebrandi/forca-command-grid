msgstr "Настройки промышленности и экономики сохранены."

#: apps/admin_audit/console_mentorship.py
msgid "Mentorship Program settings saved."
msgstr "Настройки программы наставничества сохранены."

#: apps/admin_audit/console_mentorship.py
msgid "Cohort saved."
msgstr "Когорта сохранена."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the cohort — check the values."
msgstr "Не удалось сохранить когорту — проверьте значения."

#: apps/admin_audit/console_mentorship.py
msgid "Cohort removed."
msgstr "Когорта удалена."

#: apps/admin_audit/console_mentorship.py
msgid "Track saved."
msgstr "Трек сохранён."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the track — check the values."
msgstr "Не удалось сохранить трек — проверьте значения."

#: apps/admin_audit/console_mentorship.py
msgid "Track removed."
msgstr "Трек удалён."

#: apps/admin_audit/console_mentorship.py
msgid "Track cloned (as a draft)."
msgstr "Трек клонирован (как черновик)."

#: apps/admin_audit/console_mentorship.py
msgid ""
"Criteria must be a JSON object, e.g. {\"type\": \"skill_min\", "
"\"skill_type_id\": 3300, \"level\": 3}."
msgstr ""
"Критерии должны быть JSON-объектом, например {\"type\": \"skill_min\", "
"\"skill_type_id\": 3300, \"level\": 3}."

#: apps/admin_audit/console_mentorship.py
msgid "Field exercise saved."
msgstr "Полевое учение сохранено."

