msgstr "Сохранить учётные данные"

#: templates/admin_audit/console/comms_access/settings.html
#, python-format
msgid "Set the callback URL to <code>%(callback)s</code> in the Discord app."
msgstr "Укажите в приложении Discord callback URL <code>%(callback)s</code>."

#: templates/admin_audit/console/comms_access/settings.html
msgid "Feature enabled"
msgstr "Функция включена"

#: templates/admin_audit/console/comms_access/settings.html
msgid "Global dry-run (preview only)"
msgstr "Глобальный пробный запуск (только предпросмотр)"

#: templates/admin_audit/console/comms_access/settings.html
msgid "Revoke grace (minutes)"
msgstr "Отсрочка отзыва (минуты)"

#: templates/admin_audit/console/comms_access/settings.html
#: templates/admin_audit/console/pingboard/settings.html
msgid "Save general"
msgstr "Сохранить общие"

#: templates/admin_audit/console/comms_access/settings.html
msgid "Platforms"
msgstr "Платформы"

#: templates/admin_audit/console/comms_access/settings.html
msgid "Armed"
msgstr "Активно"

#: templates/admin_audit/console/comms_access/settings.html
msgid "Kick on total loss"
msgstr "Исключать при полной потере доступа"

#: templates/admin_audit/console/comms_access/settings.html
msgid "platform id"
msgstr "id платформы"

#: templates/admin_audit/console/comms_access/settings.html
msgid "Save platforms"
msgstr "Сохранить платформы"

#: templates/admin_audit/console/comms_access/settings.html
msgid ""
"Discord is the first supported platform (5.1). Slack &amp; Mumble are\n"
"  designed and reserved — arming them has no effect until their providers "
"ship."
