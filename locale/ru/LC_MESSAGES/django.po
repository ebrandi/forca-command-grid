#: apps/navigation/jump_service.py
#, python-format
msgid "System %(id)s"
msgstr "Система %(id)s"

#: apps/navigation/jump_service.py
#, python-format
msgid "%(count)s low/null system(s) on the gate leg: %(systems)s"
msgstr "Систем low/null на участке по гейтам: %(count)s — %(systems)s"

#: apps/navigation/jump_service.py
#, python-format
msgid "(%(origin)s and %(dest)s are high-sec.)"
msgstr "(%(origin)s и %(dest)s — high-sec.)"

#: apps/navigation/jump_service.py
#, python-format
msgid "(%(system)s is high-sec.)"
msgstr "(%(system)s — high-sec.)"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Waypoint %(systems)s is high-sec — a cyno can't be lit there. Waypoints must "
"be low-sec or null-sec."
msgstr ""
"Путевая точка %(systems)s — high-sec: там нельзя зажечь cyno. Путевые точки "
"должны быть в low-sec или null-sec."

#: apps/navigation/jump_service.py
msgid ""
"No jump route within range — try a longer-range hull/JDC, fewer avoided "
"systems/waypoints, or drop ‘dockable only’."
msgstr ""
"Нет прыжкового маршрута в пределах дальности — попробуйте корпус/JDC с "
"большей дальностью, меньше исключённых систем/путевых точек или снимите "
"«только со стыковкой»."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"No low-sec exit near %(dest)s is reachable by jump from %(origin)s. Try a "
"longer-range hull/JDC, a different origin, or add a waypoint."
msgstr ""
"Ни один выход в low-sec рядом с %(dest)s недостижим прыжком из %(origin)s. "
"Попробуйте корпус/JDC с большей дальностью, другую точку отправления или "
"добавьте путевую точку."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"No low-sec exit near %(dest)s is reachable by jump from %(origin)s with "
"these filters. Try a longer-range hull/JDC, fewer avoided systems/waypoints, "
"or dropping ‘dockable only’."
msgstr ""
"С этими фильтрами ни один low-sec выход рядом с %(dest)s недостижим прыжком "
"из %(origin)s. Попробуйте корпус/JDC с большей дальностью, меньше "
"исключённых систем/путевых точек или снимите «только со стыковкой»."

#: apps/navigation/jump_service.py
#, python-format
msgid "Jump: %(origin)s → %(exit)s (low-sec exit)"
msgstr "Прыжок: %(origin)s → %(exit)s (low-sec выход)"

#: apps/navigation/jump_service.py
#, python-format
msgid "Gate: %(exit)s → %(dest)s (high-sec destination)"
msgstr "Гейты: %(exit)s → %(dest)s (high-sec назначение)"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"%(exit)s (%(security)s) is your low-sec exit — light a cyno or use a beacon "
"there, then take %(jumps)s gate(s) to %(dest)s."
msgstr ""
"%(exit)s (%(security)s) — ваш low-sec выход: зажгите там cyno или "
"используйте маяк, затем пройдите %(jumps)s гейт(ов) до %(dest)s."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"No low-sec staging system near %(origin)s can jump to %(dest)s. Try a longer-"
"range hull/JDC or a different destination."
msgstr ""
"Ни одна low-sec система подскока рядом с %(origin)s не может прыгнуть в "
"%(dest)s. Попробуйте корпус/JDC с большей дальностью или другую точку "
"назначения."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"No low-sec staging system near %(origin)s can jump to %(dest)s with these "
"filters. Try a longer-range hull/JDC, fewer avoided systems/waypoints, or "
"dropping ‘dockable only’."
msgstr ""
"С этими фильтрами ни одна low-sec система подскока рядом с %(origin)s не "
"может прыгнуть в %(dest)s. Попробуйте корпус/JDC с большей дальностью, "
"меньше исключённых систем/путевых точек или снимите «только со стыковкой»."

#: apps/navigation/jump_service.py
#, python-format
msgid "Gate: %(origin)s (high-sec) → %(entry)s"
msgstr "Гейты: %(origin)s (high-sec) → %(entry)s"

#: apps/navigation/jump_service.py
#, python-format
msgid "Jump: %(entry)s → %(dest)s"
msgstr "Прыжок: %(entry)s → %(dest)s"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Gate out of %(origin)s to %(entry)s (%(security)s), light a cyno there, then "
"jump."
msgstr ""
"Выйдите по гейтам из %(origin)s в %(entry)s (%(security)s), зажгите там cyno "
"и прыгайте."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Couldn't find a low-sec entry near %(origin)s that can jump to a low-sec "
"exit near %(dest)s. The high-sec pockets may be too far apart for this "
"hull's range."
msgstr ""
"Не удалось найти low-sec вход рядом с %(origin)s, из которого можно прыгнуть "
"в low-sec выход рядом с %(dest)s. Эти high-sec карманы, вероятно, слишком "
"далеко друг от друга для дальности этого корпуса."

#: apps/navigation/jump_service.py
msgid "No jump route between the chosen entry and exit systems."
msgstr "Нет маршрута прыжков между выбранными системами входа и выхода."

#: apps/navigation/jump_service.py
#, python-format
msgid "Jump: %(entry)s → %(exit)s"
msgstr "Прыжок: %(entry)s → %(exit)s"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Two gate legs: out of %(origin)s to %(entry)s, and from %(exit)s into "
"%(dest)s. Fuel covers the jump between them only."
msgstr ""
"Два участка по гейтам: из %(origin)s в %(entry)s и из %(exit)s в %(dest)s. "
"Топливо учитывается только на прыжок между ними."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Range %(range)s ly (%(ship)s, base %(base)s ly × JDC %(jdc)s). JDC affects "
"range only."
msgstr ""
"Дальность %(range)s св. лет (%(ship)s, база %(base)s св. лет × JDC %(jdc)s). "
"JDC влияет только на дальность."

#: apps/navigation/jump_service.py
#, python-format
msgid "Fuel %(base)s %(isotope)s/ly base, −10%%/level JFC (JFC %(jfc)s)."
msgstr ""
"Топливо: база %(base)s %(isotope)s/св. год, −10%%/уровень JFC (JFC %(jfc)s)."

#: apps/navigation/jump_service.py
#, python-format
msgid "Jump Freighters skill saves a further −10%%/level (JF %(jf)s)."
msgstr "Навык Jump Freighters экономит ещё −10%%/уровень (JF %(jf)s)."

#: apps/navigation/jump_service.py
#, python-format
msgid "%(rigs)s× Jump Drive Economizer rig fitted."
msgstr "Установлено ригов Jump Drive Economizer: %(rigs)s×."

#: apps/navigation/jump_service.py
msgid ""
"Fuel is rounded up per jump (never under-fuel) and covers jump legs only — "
"gate legs burn no isotopes."
msgstr ""
"Топливо округляется вверх на каждый прыжок (недолива не будет) и учитывается "
"только для прыжковых участков — на гейтах изотопы не тратятся."

#: apps/navigation/jump_service.py
#, python-format
msgid "Includes a %(pct)s%% fuel safety margin."
msgstr "Включает запас топлива %(pct)s%%."

#: apps/navigation/jump_service.py
msgid "No market price for the fuel isotope — ISK cost unavailable."
msgstr "Нет рыночной цены на топливные изотопы — стоимость в ISK недоступна."

