msgstr "Настройки защиты от злоупотреблений сохранены."

#: apps/admin_audit/console_pingboard.py
msgid "Calendar settings saved."
msgstr "Настройки календаря сохранены."

#: apps/admin_audit/console_pingboard.py
msgid "Channel added."
msgstr "Канал добавлен."

#: apps/admin_audit/console_pingboard.py
msgid "Channel enabled."
msgstr "Канал включён."

#: apps/admin_audit/console_pingboard.py
msgid "Channel disabled."
msgstr "Канал отключён."

#: apps/admin_audit/console_pingboard.py
msgid "Channel deleted."
msgstr "Канал удалён."

#: apps/admin_audit/console_pingboard.py
#, python-format
