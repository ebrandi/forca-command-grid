#: apps/planetary/recommend.py
#, python-format
msgid "An extraction planet self-refining into %(name)s (%(tier)s)"
msgstr "Добывающая планета с переработкой на месте в %(name)s (%(tier)s)"

#: apps/planetary/recommend.py
#, python-format
msgid "A factory planet buying inputs to make %(name)s (%(tier)s)"
msgstr ""
"Заводская планета, закупающая входы для производства %(name)s (%(tier)s)"

#: apps/planetary/recommend.py
#, python-format
msgid "nets about %(isk)s ISK/day per planet at current prices"
msgstr "даёт чистыми около %(isk)s ISK/день с планеты по текущим ценам"

#: apps/planetary/recommend.py
