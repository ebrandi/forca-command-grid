msgid_plural "%(accounts)s departed accounts"
msgstr[0] "%(accounts)s ушедший аккаунт"
msgstr[1] "%(accounts)s ушедших аккаунта"
msgstr[2] "%(accounts)s ушедших аккаунтов"

