#: apps/pingboard/messages.py
msgid "Milestone unlocked: First kill!"
msgstr "Новая веха: первое убийство!"

#: apps/pingboard/messages.py
msgid "Congratulations on your first corp killmail! Welcome to the fight."
msgstr "Поздравляем с первым корповым killmail! Добро пожаловать в бой."

#: apps/pingboard/messages.py
msgid "Milestone unlocked: First solo kill!"
msgstr "Новая веха: первое соло-убийство!"

#: apps/pingboard/messages.py
msgid "Your first solo kill — you took one down all on your own. Nice work."
msgstr ""
"Ваше первое соло-убийство — вы уничтожили цель в одиночку. Отличная работа."

#: apps/pingboard/messages.py
msgid "Milestone unlocked: First final blow!"
msgstr "Новая веха: первый финальный удар!"

#: apps/pingboard/messages.py
msgid "You landed your first final blow. The killing shot is yours."
msgstr "Вы нанесли свой первый финальный удар. Добивающий выстрел за вами."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Combat rank achieved: {rank_name}"
msgstr "Получен боевой ранг: {rank_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Congratulations — you've reached the rank of {rank_name} ({kill_count} "
"lifetime kills recorded). Ranks update from the nightly combat rollup, so "
"this can reflect kills from the last day or two rather than the exact moment."
msgstr ""
"Поздравляем — вы достигли ранга {rank_name} (всего засчитано убийств: "
"{kill_count}). Ранги обновляются по ночной боевой сводке, поэтому данные "
"могут отражать убийства за последние день-два, а не текущий момент."

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Congratulations — you've reached the rank of {rank_name} ({kill_count} "
"lifetime kills recorded). A rank reward is pending leadership approval. "
"Ranks update from the nightly combat rollup, so this can reflect kills from "
"the last day or two rather than the exact moment."
msgstr ""
"Поздравляем — вы достигли ранга {rank_name} (всего засчитано убийств: "
"{kill_count}). Награда за ранг ожидает одобрения руководства. Ранги "
"обновляются по ночной боевой сводке, поэтому данные могут отражать убийства "
"за последние день-два, а не текущий момент."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Watchlist tripwire: {entity_name}"
msgstr "Сигнал из списка наблюдения: {entity_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"⚠ Watched {entity_type} **{entity_name}** ({watchlist_name}) was on a "
"killmail in {system_name} ~{minutes}m ago. Risk indicator, not a guarantee — "
"verify before acting."
msgstr ""
"⚠ Отслеживаемый объект — {entity_type} **{entity_name}** ({watchlist_name}) "
"— засветился на killmail в системе {system_name} ~{minutes} мин назад. Это "
"индикатор риска, а не гарантия — проверьте, прежде чем действовать."

