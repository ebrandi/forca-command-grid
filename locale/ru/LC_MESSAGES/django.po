msgstr "Магазин корпорации"

#: apps/admin_audit/console.py
msgid "Service & feature availability updated."
msgstr "Доступность сервисов & функций обновлена."

#: apps/admin_audit/console.py
msgid "Data-retention policy saved."
msgstr "Политика хранения данных сохранена."

#: apps/admin_audit/console.py
msgid "Couldn't read that expiry date."
msgstr "Не удалось прочитать эту дату окончания."

#: apps/admin_audit/console.py
msgid "Expiry must be in the future — leave it blank for a permanent grant."
msgstr ""
"Дата окончания должна быть в будущем — оставьте поле пустым для бессрочного "
"доступа."

#: apps/admin_audit/console.py
msgid "That role can't be managed here."
msgstr "Этой ролью нельзя управлять здесь."

#: apps/admin_audit/console.py
#, python-format
msgid "A %(role)s grant for that pilot is already awaiting approval."
msgstr "Предоставление роли %(role)s этому пилоту уже ожидает подтверждения."

#: apps/admin_audit/console.py
#, python-format
msgid "%(role)s grant requested — a second director must approve it."
msgstr ""
"Запрошено предоставление роли %(role)s — его должен подтвердить второй "
"директор."

#: apps/admin_audit/console.py
msgid "Can't remove the last Director — promote someone else first."
msgstr ""
"Нельзя удалить последнего Директора — сначала назначьте кого-то другого."

#: apps/admin_audit/console.py
#, python-format
msgid "%(role)s %(action)s for %(name)s."
msgstr "%(role)s %(action)s для %(name)s."

#: apps/admin_audit/console.py
msgid "You can't approve your own role request — another director must."
msgstr ""
"Нельзя подтвердить собственный запрос роли — это должен сделать другой "
"директор."

#: apps/admin_audit/console.py
#, python-format
msgid "%(role)s grant %(outcome)s for %(name)s."
msgstr "Предоставление роли %(role)s %(outcome)s для %(name)s."

#: apps/admin_audit/console.py apps/admin_audit/console_doctrine_xml.py
msgid "Enter a whole number."
msgstr "Введите целое число."

#: apps/admin_audit/console.py
#, python-format
msgid "Page size set to %(clamped)s (kept within %(min)s–%(max)s)."
msgstr ""
"Размер страницы установлен на %(clamped)s (в пределах %(min)s–%(max)s)."

#: apps/admin_audit/console.py
#, python-format
msgid "Page size set to %(clamped)s per page."
msgstr "Размер страницы установлен: %(clamped)s на страницу."

#: apps/admin_audit/console.py
msgid "Give the doctrine a name."
msgstr "Укажите название doctrine."

#: apps/admin_audit/console.py
#, python-format
msgid "Doctrine “%(name)s” created — add a fit below."
msgstr "Doctrine «%(name)s» создана — добавьте fit ниже."

#: apps/admin_audit/console.py
msgid "Doctrine updated."
msgstr "Doctrine обновлена."

#: apps/admin_audit/console.py
msgid "Doctrine deleted."
msgstr "Doctrine удалена."

#: apps/admin_audit/console.py
#, python-format
msgid "Couldn't parse the EFT: %(error)s"
msgstr "Не удалось разобрать EFT: %(error)s"

#: apps/admin_audit/console.py
#, python-format
msgid "Unknown ship “%(ship)s” — check the EFT header."
msgstr "Неизвестный корабль «%(ship)s» — проверьте заголовок EFT."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"Fit “%(name)s” added (%(count)s skill requirements derived). Unresolved "
"lines: %(lines)s."
msgstr ""
"Fit «%(name)s» добавлен (%(count)s требований к навыкам определено). "
"Нераспознанные строки: %(lines)s."

#: apps/admin_audit/console.py
#, python-format
msgid "Fit “%(name)s” added (%(count)s skill requirements derived)."
msgstr "Fit «%(name)s» добавлен (%(count)s требований к навыкам определено)."

#: apps/admin_audit/console.py
msgid "Fit removed."
msgstr "Fit удалён."

#: apps/admin_audit/console.py
msgid "Pick a valid requirement type."
msgstr "Выберите допустимый тип требования."

#: apps/admin_audit/console.py
msgid "A note needs some text."
msgstr "Заметка должна содержать текст."

#: apps/admin_audit/console.py
msgid "This requirement needs a type id (or record it as a note)."
msgstr "Для этого требования нужен type id (или запишите его как заметку)."

#: apps/admin_audit/console.py
msgid "Requirement added."
msgstr "Требование добавлено."

#: apps/admin_audit/console.py
msgid "Requirement removed."
msgstr "Требование удалено."

#: apps/admin_audit/console.py
msgid "Tick at least one fit to import."
msgstr "Отметьте хотя бы один fit для импорта."

#: apps/admin_audit/console.py
#, python-format
msgid "Imported %(count)d fit as new doctrines under IMPORTED."
msgid_plural "Imported %(count)d fits as new doctrines under IMPORTED."
msgstr[0] "Импортирован %(count)d фит как новые doctrines в раздел IMPORTED."
msgstr[1] "Импортировано %(count)d фита как новые doctrines в раздел IMPORTED."
msgstr[2] ""
"Импортировано %(count)d фитов как новые doctrines в раздел IMPORTED."

#: apps/admin_audit/console.py
#, python-format
msgid "Already in the library (identical name and fit) — skipped: %(names)s."
msgstr "Уже в библиотеке (совпадают название и fit) — пропущено: %(names)s."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"A doctrine with this name already exists but with a different fit — rename "
"it and import again: %(names)s."
msgstr ""
"Doctrine с таким названием уже существует, но с другим fit — переименуйте и "
"импортируйте снова: %(names)s."

#: apps/admin_audit/console.py
msgid "Nothing imported — the selected fits couldn't be read."
msgstr "Ничего не импортировано — не удалось прочитать выбранные fits."

#: apps/admin_audit/console.py
#, python-format
msgid "Couldn't parse the fit: %(error)s"
msgstr "Не удалось разобрать fit: %(error)s"

#: apps/admin_audit/console.py
#, python-format
msgid "Unknown ship “%(ship)s” — check the first line."
msgstr "Неизвестный корабль «%(ship)s» — проверьте первую строку."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"Doctrine “%(name)s” created from killmail (%(count)s skills derived). "
"Unresolved: %(lines)s."
msgstr ""
"Doctrine «%(name)s» создана из killmail (%(count)s навыков определено). Не "
"распознано: %(lines)s."

#: apps/admin_audit/console.py
#, python-format
msgid "Doctrine “%(name)s” created from killmail (%(count)s skills derived)."
msgstr ""
"Doctrine «%(name)s» создана из killmail (%(count)s навыков определено)."

#: apps/admin_audit/console.py
#, python-format
msgid "Category “%(label)s” added."
msgstr "Категория «%(label)s» добавлена."

#: apps/admin_audit/console.py
msgid "Manual — pilot checks it off"
msgstr "Вручную — пилот отмечает выполнение"

#: apps/admin_audit/console.py
msgid "Auto — a character is linked"
msgstr "Авто — привязан персонаж"

#: apps/admin_audit/console.py
msgid "Auto — verified corp member"
msgstr "Авто — подтверждённый участник корпорации"

#: apps/admin_audit/console.py
msgid "Auto — skills imported"
msgstr "Авто — навыки импортированы"

#: apps/admin_audit/console.py
msgid "Auto — ESI scopes granted"
msgstr "Авто — предоставлены области доступа ESI"

#: apps/admin_audit/console.py
msgid "Auto — skill trained to level"
msgstr "Авто — навык прокачан до уровня"

#: apps/admin_audit/console.py
msgid "Auto — can fly a specific doctrine"
msgstr "Авто — может летать на конкретной doctrine"

#: apps/admin_audit/console.py
msgid "Auto — can fly ANY active doctrine"
msgstr "Авто — может летать на ЛЮБОЙ активной doctrine"

#: apps/admin_audit/console.py apps/campaigns/views.py
msgid "A milestone needs a title."
msgstr "У вехи должен быть заголовок."

#: apps/admin_audit/console.py
msgid "Pick the doctrine this milestone checks."
msgstr "Выберите doctrine, которую проверяет эта веха."

#: apps/admin_audit/console.py
msgid "That doctrine no longer exists."
msgstr "Этой doctrine больше не существует."

#: apps/admin_audit/console.py
msgid "Skill milestones need a skill type id and a level (1–5)."
msgstr "Для вех по навыкам нужны type id навыка и уровень (1–5)."

#: apps/admin_audit/console.py
msgid "List at least one ESI scope (comma-separated)."
msgstr "Укажите хотя бы одну область доступа ESI (через запятую)."

#: apps/admin_audit/console.py
msgid "That milestone no longer exists."
msgstr "Этой вехи больше не существует."

#: apps/admin_audit/console.py
#, python-format
msgid "Milestone “%(title)s” saved."
msgstr "Веха «%(title)s» сохранена."

#: apps/admin_audit/console.py
msgid "Milestone removed — pilots' progress rows went with it."
msgstr "Веха удалена — вместе с ней удалены записи о прогрессе пилотов."

#: apps/admin_audit/console.py
#, python-format
msgid "Glossary term “%(term)s” saved."
msgstr "Термин глоссария «%(term)s» сохранён."

#: apps/admin_audit/console.py
msgid "Both term and definition are required."
msgstr "Требуются и термин, и определение."

#: apps/admin_audit/console.py
msgid "Glossary term removed."
msgstr "Термин глоссария удалён."

#: apps/admin_audit/console.py
msgid "Recommendation engine"
msgstr "Механизм рекомендаций"

#: apps/admin_audit/console.py
msgid "Market history refresh"
msgstr "Обновление истории рынка"

#: apps/admin_audit/console.py
msgid "Corp asset sync"
msgstr "Синхронизация активов корпорации"

#: apps/admin_audit/console.py
msgid "Personal asset sync"
msgstr "Синхронизация личных активов"

#: apps/admin_audit/console.py
msgid "Killmail discovery"
msgstr "Обнаружение killmail"

#: apps/admin_audit/console.py
msgid "Member skill sync"
msgstr "Синхронизация навыков участников"

#: apps/admin_audit/console.py
msgid "Capsuleer Path reconcile"
msgstr "Сверка Capsuleer Path"

#: apps/admin_audit/console.py
msgid "Unknown maintenance action."
msgstr "Неизвестное действие обслуживания."

#: apps/admin_audit/console.py
#, python-format
msgid "%(label)s queued — results appear under Integrations as they finish."
msgstr ""
"%(label)s поставлено в очередь — результаты появятся в разделе «Интеграции» "
"по мере готовности."

#: apps/admin_audit/console.py
msgid "Contribution weights updated."
msgstr "Веса вкладов обновлены."

#: apps/admin_audit/console_access.py
msgid "Enter a valid alliance id."
msgstr "Введите корректный ID альянса."

#: apps/admin_audit/console_access.py
msgid "Partner alliance saved."
msgstr "Альянс-партнёр сохранён."

#: apps/admin_audit/console_access.py
msgid "Partner alliance removed."
msgstr "Альянс-партнёр удалён."

#: apps/admin_audit/console_access.py
msgid "Enter a valid corporation id."
msgstr "Введите корректный ID корпорации."

#: apps/admin_audit/console_access.py
msgid "Friendly corporation saved."
msgstr "Дружественная корпорация сохранена."

#: apps/admin_audit/console_access.py
msgid "Friendly corporation removed."
msgstr "Дружественная корпорация удалена."

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings reset to defaults."
msgstr "Настройки Capsuleer Path сброшены до значений по умолчанию."

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings saved."
msgstr "Настройки Capsuleer Path сохранены."

#: apps/admin_audit/console_combat.py
msgid "A rank title can't be empty."
msgstr "Название ранга не может быть пустым."

#: apps/admin_audit/console_combat.py
msgid "Reward amount can't be negative."
msgstr "Размер награды не может быть отрицательным."

#: apps/admin_audit/console_combat.py
msgid "Another rank already uses this threshold for this metric."
msgstr "Другой ранг уже использует этот порог для этой метрики."

#: apps/admin_audit/console_combat.py
msgid ""
"Rewards apply to the all-time PvP kills track only — the support-role tracks "
"are recognition-only."
msgstr ""
"Награды применяются только к треку PvP-убийств за всё время — треки "
"вспомогательных ролей предназначены только для признания заслуг."

#: apps/admin_audit/console_combat.py
msgid "Choose a reward type, or untick “grants reward”."
msgstr "Выберите тип награды или снимите отметку «выдаёт награду»."

#: apps/admin_audit/console_combat.py
msgid "An item reward needs an EVE type id."
msgstr "Для награды в виде предмета нужен EVE type id."

#: apps/admin_audit/console_combat.py
msgid "An ISK/PLEX reward needs a positive amount."
msgstr "Для награды ISK/PLEX нужна положительная сумма."

#: apps/admin_audit/console_combat.py
msgid "Must be zero or positive."
msgstr "Должно быть нулём или положительным числом."

#: apps/admin_audit/console_combat.py
msgid "Can't exceed 100%."
msgstr "Не может превышать 100%."

#: apps/admin_audit/console_combat.py
msgid "Newbro settings saved."
msgstr "Настройки Newbro сохранены."

#: apps/admin_audit/console_combat.py
msgid "Please correct the newbro settings."
msgstr "Пожалуйста, исправьте настройки newbro."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” saved."
msgstr "Ранг «%(name)s» сохранён."

#: apps/admin_audit/console_combat.py apps/admin_audit/console_corporation.py
#: apps/admin_audit/console_industry.py apps/admin_audit/console_mentorship.py
#: apps/admin_audit/console_navigation.py apps/admin_audit/console_pingboard.py
#: apps/admin_audit/console_planetary.py apps/admin_audit/console_raffle.py
msgid "Please correct the errors below."
msgstr "Пожалуйста, исправьте ошибки ниже."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” removed."
msgstr "Ранг «%(name)s» удалён."

#: apps/admin_audit/console_combat.py
msgid "Reward settings saved."
msgstr "Настройки наград сохранены."

#: apps/admin_audit/console_combat.py
#, python-format
msgid ""
"Rewards enabled. Baseline snapshotted for %(n)d pilot(s) — only ranks "
"reached from now on will create rewards."
msgstr ""
"Награды включены. Сохранён базовый снимок для %(n)d пилота(ов) — награды "
"будут создаваться только для рангов, достигнутых с этого момента."

#: apps/admin_audit/console_combat.py
msgid "Rewards disabled. No new reward events will be created."
msgstr "Награды отключены. Новые события наград создаваться не будут."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Baseline re-snapshotted for %(n)d pilot(s)."
msgstr "Базовый снимок пересоздан для %(n)d пилота(ов)."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward scan complete — %(n)d new reward event(s) created."
msgstr "Сканирование наград завершено — создано %(n)d новых событий наград."

#: apps/admin_audit/console_combat.py apps/buyback/views.py
#: apps/capsuleer/views.py apps/logistics/views.py apps/stockpile/views.py
#: apps/store/views.py apps/store/views_inventory.py
msgid "Unknown action."
msgstr "Неизвестное действие."

#: apps/admin_audit/console_combat.py
msgid "Only a Director can mark a reward paid."
msgstr "Только Директор может отметить награду как выплаченную."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward %(action)s — %(character)s · %(rank)s."
msgstr "Награда %(action)s — %(character)s · %(rank)s."

#: apps/admin_audit/console_command_intel.py
#: apps/admin_audit/console_readiness.py
#, python-format
msgid "%(domain)s reset to defaults."
msgstr "%(domain)s сброшено до значений по умолчанию."

#: apps/admin_audit/console_command_intel.py
msgid "Provider & model settings saved."
msgstr "Настройки провайдера и модели сохранены."

#: apps/admin_audit/console_command_intel.py
msgid "Critical ratio"
msgstr "Критическое соотношение"

#: apps/admin_audit/console_command_intel.py
msgid "Headroom/demand at or below this colours a constraint critical."
msgstr ""
"Запас/спрос на этом уровне или ниже окрашивает ограничение как критическое."

#: apps/admin_audit/console_command_intel.py
msgid "High ratio"
msgstr "Высокое соотношение"

#: apps/admin_audit/console_command_intel.py
msgid "Above critical, at or below this colours it high."
msgstr "Выше критического: на этом уровне или ниже окрашивается как высокое."

#: apps/admin_audit/console_command_intel.py
msgid "Watch ratio"
msgstr "Соотношение для наблюдения"

#: apps/admin_audit/console_command_intel.py
msgid "Above high, at or below this colours it watch."
msgstr "Выше высокого: на этом уровне или ниже окрашивается как наблюдение."

#: apps/admin_audit/console_command_intel.py
msgid "Constraints & thresholds saved."
msgstr "Ограничения и пороги сохранены."

#: apps/admin_audit/console_command_intel.py
msgid "Classification settings saved."
msgstr "Настройки классификации сохранены."

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Corporation Internal"
msgstr "Внутри корпорации"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "High Command"
msgstr "Высшее командование"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Director — Eyes Only"
msgstr "Только для Директора"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Alliance Command"
msgstr "Командование альянса"

#: apps/admin_audit/console_command_intel.py
msgid "Notification & delivery settings saved."
msgstr "Настройки уведомлений и доставки сохранены."

#: apps/admin_audit/console_command_intel.py
msgid "Autonomous proposal settings saved."
msgstr "Настройки автономных предложений сохранены."

#: apps/admin_audit/console_command_intel.py
msgid "Auto-AAR settings saved."
msgstr "Настройки Auto-AAR сохранены."

#: apps/admin_audit/console_comms_access.py
msgid "Discord credentials saved."
msgstr "Учётные данные Discord сохранены."

#: apps/admin_audit/console_comms_access.py
msgid "Unknown settings section."
msgstr "Неизвестный раздел настроек."

#: apps/admin_audit/console_comms_access.py
msgid "Settings saved."
msgstr "Настройки сохранены."

#: apps/admin_audit/console_comms_access.py
msgid "Platform, entitlement and target are required."
msgstr "Требуются платформа, право доступа и цель."

#: apps/admin_audit/console_comms_access.py
