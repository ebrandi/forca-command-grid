msgstr "Приватно (только я)"

#: apps/navigation/models.py apps/planetary/models.py
#: templates/navigation/jump_planner.html templates/navigation/jump_routes.html
msgid "Shared with leadership"
msgstr "Доступно руководству"

#: apps/navigation/route_mode.py templates/navigation/jump_planner.html
msgid "Gate route"
msgstr "Маршрут по гейтам"

#: apps/navigation/route_mode.py
msgid "Jump route"
msgstr "Маршрут прыжков"

#: apps/navigation/route_mode.py
msgid "Black Ops jump"
msgstr "Прыжок Black Ops"

#: apps/navigation/route_mode.py
msgid "Jump + gate (high-sec exit)"
msgstr "Прыжок + гейты (выход в high-sec)"

#: apps/navigation/route_mode.py
msgid "Gate + jump (high-sec start)"
msgstr "Гейты + прыжок (старт в high-sec)"

#: apps/navigation/route_mode.py
msgid "Gate + jump + gate"
msgstr "Гейты + прыжок + гейты"

#: apps/navigation/route_mode.py
msgid "Invalid for this hull"
msgstr "Недопустимо для этого корпуса"

#: apps/navigation/route_mode.py
msgid "Unsupported"
msgstr "Не поддерживается"

#: apps/navigation/route_mode.py
msgid "This hull has no jump drive — a normal stargate route."
msgstr "У этого корпуса нет прыжкового двигателя — обычный маршрут по гейтам."

#: apps/navigation/route_mode.py
#, python-format
msgid "A %(ship)s can't reach a %(band)s system by stargate."
msgstr "%(ship)s не может добраться до системы %(band)s по гейтам."

#: apps/navigation/route_mode.py
#, python-format
msgid "Black Ops jump via %(cyno)s — covert legs, reduced jump fatigue."
msgstr ""
"Прыжок Black Ops через %(cyno)s — скрытные участки, пониженная прыжковая "
"усталость."

#: apps/navigation/route_mode.py
#, python-format
msgid "Direct jump-drive route via %(cyno)s."
msgstr "Прямой маршрут на прыжковом двигателе через %(cyno)s."

#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't enter high-sec (no stargate access and no cyno in high-"
"sec), so neither the high-sec origin nor the high-sec destination can be "
"reached. Choose a low-sec or null-sec system."
msgstr ""
"%(ship)s не может войти в high-sec (нет доступа к гейтам и нельзя зажечь "
"cyno в high-sec), поэтому недостижимы ни high-sec точка отправления, ни high-"
"sec точка назначения. Выберите систему в low-sec или null-sec."

#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't enter high-sec (no stargate access and no cyno in high-"
"sec), so the high-sec destination can't be reached. Choose a low-sec or null-"
"sec system."
msgstr ""
"%(ship)s не может войти в high-sec (нет доступа к гейтам и нельзя зажечь "
"cyno в high-sec), поэтому high-sec точка назначения недостижима. Выберите "
"систему в low-sec или null-sec."

#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't enter high-sec (no stargate access and no cyno in high-"
"sec), so the high-sec origin can't be reached. Choose a low-sec or null-sec "
"system."
msgstr ""
"%(ship)s не может войти в high-sec (нет доступа к гейтам и нельзя зажечь "
"cyno в high-sec), поэтому high-sec точка отправления недостижима. Выберите "
"систему в low-sec или null-sec."

#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't cyno into or out of high-sec: gate out of the high-sec "
"origin to a low-sec entry, jump, then gate to the high-sec destination."
msgstr ""
"%(ship)s не может использовать cyno для входа в high-sec или выхода из него: "
"выйдите по гейтам из high-sec точки отправления в low-sec вход, прыгните, "
"затем идите по гейтам до high-sec точки назначения."

#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't cyno directly into high-sec: jump to a low-sec exit near "
"the destination, then take stargates the rest of the way."
msgstr ""
"%(ship)s не может прыгнуть по cyno прямо в high-sec: прыгните в low-sec "
"выход рядом с точкой назначения, а остаток пути пройдите по гейтам."

#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't light a cyno in high-sec: gate out of the high-sec origin "
"to a low-sec staging system, then jump from there."
msgstr ""
"%(ship)s не может зажечь cyno в high-sec: выйдите по гейтам из high-sec "
"точки отправления в low-sec систему подскока и прыгайте оттуда."

#: apps/navigation/views.py
msgid "Grant it on the ESI Scopes page."
msgstr "Выдайте это на странице ESI Scopes."

#: apps/navigation/views.py
msgid "Pick two different systems for the bridge."
msgstr "Выберите две разные системы для bridge."

#: apps/navigation/views.py
#, python-format
msgid "Jump bridge %(a)s ⇄ %(b)s saved."
msgstr "Jump bridge %(a)s ⇄ %(b)s сохранён."

#: apps/navigation/views.py
msgid "Jump bridge removed."
msgstr "Jump bridge удалён."

#: apps/navigation/views.py
msgid "Pick both systems from the list."
msgstr "Выберите обе системы из списка."

#: apps/navigation/views.py
msgid "The jump planner is currently disabled by leadership."
msgstr "Jump planner сейчас отключён руководством."

#: apps/navigation/views.py
msgid "That system has no coordinates."
msgstr "У этой системы нет координат."

#: apps/navigation/views.py
msgid "Saved routes are turned off."
msgstr "Сохранённые маршруты отключены."

#: apps/navigation/views.py
msgid "Plan a route first, then save it."
msgstr "Сначала проложите маршрут, затем сохраните его."

#: apps/navigation/views.py
#, python-format
msgid "Saved route “%(name)s”."
msgstr "Маршрут «%(name)s» сохранён."

#: apps/navigation/views.py
msgid "You can't open that route."
msgstr "Вы не можете открыть этот маршрут."

#: apps/navigation/views.py
msgid "Route removed."
msgstr "Маршрут удалён."

#: apps/navigation/views.py
msgid "You can't remove that route."
msgstr "Вы не можете удалить этот маршрут."

#: apps/navigation/views.py
#, python-format
msgid "You can watch at most %(n)d routes at once — turn one off first."
msgstr ""
"Одновременно можно отслеживать не более %(n)d маршрутов — сначала отключите "
"один."

#: apps/navigation/views.py
#, python-format
msgid ""
"Camp/incursion watch on for “%(name)s”. You'll be DMed when a threat appears "
"on it."
msgstr ""
"Отслеживание camp/incursion включено для «%(name)s». Вам придёт DM, когда на "
"нём появится угроза."

#: apps/navigation/views.py
#, python-format
msgid "Camp/incursion watch off for “%(name)s”."
msgstr "Отслеживание camp/incursion выключено для «%(name)s»."

#: apps/onboarding/milestones_i18n.py
msgid "Link your EVE character"
msgstr "Привяжите свой EVE-персонаж"

#: apps/onboarding/milestones_i18n.py
#: templates/admin_audit/console/content.html
msgid "Register on alliance voice comms"
msgstr "Зарегистрироваться в голосовой связи альянса"

#: apps/onboarding/milestones_i18n.py
msgid "Grant the corp tools your ESI scopes"
msgstr "Выдайте корп-инструментам свои ESI scopes"

#: apps/onboarding/milestones_i18n.py
msgid "Import your skills"
msgstr "Импортируйте свои скиллы"

#: apps/onboarding/milestones_i18n.py
msgid "Train into your first doctrine ship"
msgstr "Прокачайтесь на свой первый doctrine-корабль"

#: apps/onboarding/milestones_i18n.py
msgid "Move your gear to staging"
msgstr "Перевезите своё снаряжение на staging"

#: apps/onboarding/milestones_i18n.py
msgid "Fly your first fleet"
msgstr "Слетайте в свой первый fleet"

#: apps/onboarding/milestones_i18n.py
msgid "Start your first income stream"
msgstr "Запустите свой первый источник дохода"

#: apps/onboarding/milestones_i18n.py
msgid ""
"Log in with EVE SSO so the Grid knows who you are — and link every alt you "
"fly, they all count."
msgstr ""
"Войдите через EVE SSO, чтобы Grid знал, кто вы, — и привяжите каждого alt, "
"на котором летаете, они все учитываются."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Comms are mandatory for fleets — you don't need to talk, just listen. Grab "
"the invite from your recruiter and set your comms name to your main "
"character's."
msgstr ""
"Comms обязательны для флотов — говорить необязательно, достаточно слушать. "
"Возьмите инвайт у рекрутера и укажите в comms имя вашего основного персонажа "
"(main)."

#: apps/onboarding/milestones_i18n.py
msgid ""
"The Grid can only help with what it can see. Grant the optional scopes "
"(assets, market, planets) on the ESI Scopes page — one click per character."
msgstr ""
"Grid может помочь только с тем, что видит. Выдайте необязательные scopes "
"(assets, market, planets) на странице ESI Scopes — один клик на каждого "
"персонажа."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Share your skill sheet so every 'can I fly this?' answer on this site is "
"about YOU. One click — it keeps itself fresh afterwards."
msgstr ""
"Поделитесь своим skill sheet, чтобы каждый ответ 'смогу ли я на этом "
"летать?' на этом сайте был про ВАС. Один клик — дальше он обновляется сам."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Being able to fly what the FC calls for is your single biggest contribution. "
"Pick the starter doctrine and follow its training plan."
msgstr ""
"Умение летать на том, что требует FC, — ваш самый большой вклад. Выберите "
"стартовый doctrine и следуйте его плану прокачки."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Set your home station to staging, move your doctrine ships there, and keep a "
"cheap travel ship at each end. Use the freight service instead of hauling it "
"yourself."
msgstr ""
"Задайте home station на staging, перевезите туда свои doctrine-корабли и "
"держите на каждом конце дешёвый перегонный корабль. Пользуйтесь freight-"
"сервисом вместо того, чтобы возить самому."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Watch the ops board and x up. Nobody expects anything from you on fleet one "
"— undocking with us IS the milestone."
msgstr ""
"Следите за ops board и пишите x up. На первом fleet от вас никто ничего не "
"ждёт — сам undock вместе с нами и есть та самая веха."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Ratting, corp mining fleets, or PI — pick one and get ISK flowing. Sell loot "
"and ore to the corp buyback: zero hauling risk, paid today."
msgstr ""
"Ratting, корпоративные mining-флоты или PI — выберите что-то одно и "
"запустите поток ISK. Продавайте loot и руду в корпоративный buyback: "
"никакого риска hauling, платят сразу."

#: apps/onboarding/milestones_i18n.py
msgid ""
"EVE space comes in security bands. Highsec: NPC police (CONCORD) punish "
"attackers. Lowsec: no police, but no warp-stopping bubbles either. Nullsec — "
"where we live: no police at all, player alliances own the space, and "
"anything goes. More risk, better rewards, real friends."
msgstr ""
"Космос EVE делится на зоны безопасности. Highsec: NPC-полиция (CONCORD) "
"карает атакующих. Lowsec: полиции нет, но нет и bubbles, глушащих warp. "
"Nullsec — где мы и живём: полиции нет вообще, космосом владеют альянсы "
"игроков, и здесь дозволено всё. Больше риска, лучше награда, настоящие "
"друзья."

#: apps/onboarding/milestones_i18n.py
msgid ""
"A standard ship fitting published by leadership — the exact hull, modules, "
"and ammo the corp wants you to fly so the whole fleet works together. Fly "
"the doctrine fit as written; it's also what makes your loss SRP-eligible."
msgstr ""
"Стандартный fitting корабля, опубликованный руководством, — конкретный hull, "
"modules и ammo, на которых корпорация хочет вас видеть, чтобы весь fleet "
"работал слаженно. Летайте на doctrine fit точно как указано; именно это "
"делает ваш loss пригодным для SRP."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Logistics ships — the fleet's healers. Logi pilots repair the shields or "
"armor of fleetmates who broadcast for help. Flying logi is one of the most "
"valued roles a newer pilot can learn."
msgstr ""
"Logistics-корабли — лекари fleet. Пилоты logi восстанавливают щиты или броню "
"сокомандников, которые сделали broadcast о помощи. Полёты на logi — одна из "
"самых ценных ролей для начинающего пилота."

#: apps/onboarding/milestones_i18n.py
msgid ""
"EVE's currency (InterStellar Kredits). Everything — ships, ammo, services — "
"is priced in ISK, usually quoted in millions ('m') or billions ('b'). Losing "
"a ship really means losing its ISK cost, which is why cheap, replaceable "
"ships are king."
msgstr ""
"Валюта EVE (InterStellar Kredits). Всё — корабли, ammo, услуги — оценивается "
"в ISK, обычно в миллионах ('m') или миллиардах ('b'). Потерять корабль на "
"деле значит потерять его стоимость в ISK — поэтому дешёвые, легко заменяемые "
"корабли рулят."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Fleet Commander — the pilot leading the fleet and calling every move on "
"voice comms. Their word is law mid-fight: when they say 'check check' or "
"'clear comms', stop chatting so orders can be heard, and put questions in "
"fleet text chat instead of on comms."
msgstr ""
"Fleet Commander — пилот, который ведёт fleet и командует каждым манёвром в "
"голосовых comms. Его слово — закон в бою: когда он говорит 'check check' или "
"'clear comms', прекратите болтать, чтобы приказы было слышно, и задавайте "
"вопросы в текстовом чате fleet, а не в comms."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Typing 'x' in fleet or corp chat to volunteer — for a fleet spot, a specific "
"ship, or a job ('x up if you can fly logi'). It simply means 'count me in'."
msgstr ""
"Написать 'x' в чате fleet или корпорации, чтобы записаться — на место во "
"fleet, на конкретный корабль или на задачу ('x up, если умеешь летать на "
"logi'). Проще говоря, это значит 'я в деле'."

#: apps/onboarding/milestones_i18n.py
msgid ""
"The designated pilot the whole fleet physically follows in combat — you set "
"your ship to orbit or keep-at-range on them and let them do the flying. This "
"keeps the fleet in one tight, controlled ball while you focus on targets and "
"broadcasts."
msgstr ""
"Назначенный пилот, за которым в бою физически следует весь fleet — вы "
"ставите свой корабль на orbit или keep-at-range к нему и позволяете ему "
"вести. Так fleet держится одним плотным, управляемым ball, пока вы "
"сосредоточены на целях и broadcasts."

#: apps/onboarding/milestones_i18n.py
msgid ""
"To point your ship at a destination and build up speed without actually "
"warping — an aligned ship enters warp almost instantly when the order comes. "
"'Align to the sun' means turn toward it and wait; do not warp until the FC "
"says so."
msgstr ""
"Направить корабль к точке назначения и набрать скорость, фактически не уходя "
"в warp — выровненный (aligned) корабль входит в warp почти мгновенно по "
"команде. 'Align to the sun' значит развернуться к солнцу и ждать; не уходите "
"в warp, пока FC не скажет."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Warping to exactly 0 km from your destination instead of landing at a "
"distance, so you can jump a gate or dock the moment you arrive. 'Gate, gate, "
"warp to zero' means warp straight onto the gate and jump as soon as you land."
msgstr ""
"Варп точно на 0 km до пункта назначения, а не приземление на расстоянии, "
"чтобы вы могли сразу же прыгнуть в гейт или пристыковаться в момент "
"прибытия. Фраза «Gate, gate, warp to zero» означает варп прямо на гейт и "
"прыжок сразу после приземления."

#: apps/onboarding/milestones_i18n.py
msgid ""
"One-click alerts sent through the fleet window that every fleet member sees. "
"The one that saves your life: broadcast for shield or armor the instant you "
"start taking damage, so the logi pilots know exactly who to heal."
msgstr ""
"Оповещения в один клик, отправляемые через окно fleet, которые видит каждый "
"его член. То самое, что спасает жизнь: делайте broadcast на shield или armor "
"в тот же миг, когда начали получать урон, чтобы пилоты logi точно знали, "
"кого хилить."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Intel-channel shorthand for 'no hostiles here'. Alliance intel channels run "
"on quick calls like 'X-7 free' or 'status?', answered with 'free' (clear) or "
"the names of hostile pilots in the system — check them before you travel. "
"Other groups say 'clr' or 'clear' — same meaning."
msgstr ""
"Сокращение в intel-канале для 'здесь нет врагов'. Intel-каналы альянса "
"работают на коротких репликах вроде 'X-7 free' или 'status?', на которые "
"отвечают 'free' (чисто) или именами вражеских пилотов в системе — проверяйте "
"их перед вылетом. Другие группы говорят 'clr' или 'clear' — смысл тот же."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Calling a bigger allied group for backup when a fight is too large to handle "
"alone — named after Batman's emergency hotline. 'They batphoned' means the "
"enemy rang up heavy friends, and the fight is about to get much bigger."
msgstr ""
"Вызов более крупной союзной группы на подмогу, когда бой слишком велик, "
"чтобы справиться в одиночку — назван в честь экстренной линии Бэтмена. 'They "
"batphoned' значит, что враг позвал тяжёлых друзей, и бой вот-вот станет "
"намного крупнее."

#: apps/onboarding/milestones_i18n.py
msgid ""
"The directional scanner — a free, instant scan that lists ships and "
"structures within about 14 AU of your position. Spamming d-scan while you're "
"in space is one of the core survival habits in EVE: it shows most threats "
"before they land on you — but not cloaked ships or Combat Recon cruisers, "
"which are invisible to d-scan, so a clear scan is never a promise."
msgstr ""
"Направленный сканер (directional scanner) — бесплатное мгновенное "
"сканирование, показывающее корабли и структуры примерно в 14 AU от вас. "
"Спамить d-scan, находясь в космосе, — одна из ключевых привычек выживания в "
"EVE: он показывает большинство угроз до того, как они окажутся рядом — но не "
"cloaked-корабли и не Combat Recon cruisers, которые для d-scan невидимы, так "
"что чистый скан — никогда не гарантия."

#: apps/onboarding/milestones_i18n.py
msgid ""
"A bookmark out in empty space, away from planets, gates, and anything "
"warpable, where you can sit while hostiles sweep the system. A related trick "
"is the insta-undock: a bookmark lined up with a station's exit so you can "
"warp away the second you undock, before campers can lock you. A safe spot "
"hides you — it doesn't make you invincible: hostiles with combat scanner "
"probes can find you in a minute or two, so keep hitting d-scan (probes show "
"up on it) and keep moving between safes."
msgstr ""
"Bookmark в пустом космосе, вдали от планет, gates и всего, во что можно уйти "
"в warp, где можно пересидеть, пока враги прочёсывают систему. Смежный приём "
"— insta-undock: bookmark, выровненный с выходом станции, чтобы уйти в warp в "
"ту же секунду, как выходишь из дока (undock), пока campers не успели вас "
"захватить. Safe spot прячет вас, но не делает неуязвимым: враги с combat "
"scanner probes найдут вас за минуту-другую, так что жмите d-scan (probes на "
"нём видны) и перемещайтесь между safe-спотами."

#: apps/onboarding/milestones_i18n.py
msgid ""
"If your ship is destroyed you're left floating in your pod (escape capsule); "
"lose that too and you've been podded — you wake up in a fresh clone at your "
"home station. Podding destroys any implants (skill- and stat-boosting plugs "
"in your head), so keep your home station set somewhere useful and don't take "
"an expensive head into big fights."
msgstr ""
"Если ваш корабль уничтожен, вы остаётесь в своём pod (спасательной капсуле); "
"потеряете и её — вас заподдили (podded): вы очнётесь в свежем клоне на своей "
"home station. Podding уничтожает все импланты (вставки в голове, повышающие "
"скиллы и характеристики), так что держите home station в удобном месте и не "
"берите дорогую голову в крупные бои."

#: apps/onboarding/milestones_i18n.py
msgid ""
"A group of hostiles parked at a stargate, waiting to kill whatever jumps "
"through — in nullsec usually with bubbles so you can't just warp off. Check "
"the intel channels before traveling alone; most newbro losses happen at "
"camps."
msgstr ""
"Группа врагов, засевшая у stargate и убивающая всех, кто прыгает через него, "
"— в nullsec обычно с bubbles, чтобы вы не могли просто уйти в warp. "
"Проверяйте intel-каналы перед одиночным перелётом; большинство потерь у "
"newbro случается на camps."

#: apps/onboarding/milestones_i18n.py
msgid ""
"A warp disruption bubble — a large sphere that stops everyone inside it from "
"warping and drags passing warps to its edge. Bubbles don't work in high- or "
"low-security space — you'll meet them in nullsec, wormholes, and Pochven. "
"They come from interdictor ships ('dictors') or anchorable deployables; "
"they're the teeth of every nullsec gate camp."
msgstr ""
"Warp disruption bubble — большая сфера, которая не даёт уйти в warp всем, "
"кто внутри, и стягивает пролетающие warp к своему краю. Bubbles не работают "
"в high- и low-security космосе — вы встретите их в nullsec, wormholes и "
"Pochven. Их ставят interdictor-корабли ('dictors') или заякориваемые "
"(anchorable) устройства; это зубы любого nullsec gate camp."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Time dilation — when a massive battle overloads the server, EVE deliberately "
"slows time in that system, sometimes to a tenth of normal speed, so it can "
"process everything. Everything moves in slow motion for everyone equally; "
"it's normal, so stay calm and follow orders."
msgstr ""
"Time dilation — когда масштабный бой перегружает сервер, EVE намеренно "
"замедляет время в этой системе, иногда до десятой доли обычной скорости, "
"чтобы успеть всё обработать. Всё движется как в замедленной съёмке, "
"одинаково для всех; это нормально, так что сохраняйте спокойствие и "
"выполняйте приказы."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Catching hostile ships so they can't warp away — a tackler pins a target in "
"place with a warp scrambler or disruptor ('scram' or 'point') while the "
"fleet kills it. It's one of the highest-impact jobs a newer pilot can fly: "
"nothing dies if nothing is tackled."
msgstr ""
"Захват вражеских кораблей, чтобы они не могли уйти в warp — tackler "
"удерживает цель на месте с помощью warp scrambler или disruptor ('scram' или "
"'point'), пока fleet её уничтожает. Это одна из самых важных ролей для "
"начинающего пилота: ничего не умирает, если ничего не взято в tackle."

#: apps/onboarding/milestones_i18n.py
msgid ""
"A cynosural field — a bright beacon a ship lights in space that lets capital "
"ships (and some others) jump directly to it from light-years away, skipping "
"gates entirely. Cynos power both our logistics, like jump freighters, and "
"ambushes (see Hotdrop)."
msgstr ""
"Cynosural field — яркий маяк, который корабль зажигает в космосе и который "
"позволяет capital-кораблям (и некоторым другим) прыгать прямо к нему за "
"много световых лет, полностью минуя gates. Cynos обеспечивают и нашу "
"логистику, вроде jump freighters, и засады (см. Hotdrop)."

#: apps/onboarding/milestones_i18n.py
msgid ""
"When hostiles light a cyno on your position and heavy ships pour in on top "
"of you with no warning. It's why you never ignore a lone unknown pilot while "
"ratting — they may be the beacon for an entire fleet."
msgstr ""
"Когда враги зажигают cyno на вашей позиции и тяжёлые корабли без "
"предупреждения сваливаются вам на голову. Вот почему нельзя игнорировать "
"одинокого незнакомого пилота во время ratting — он может оказаться маяком "
"для целого fleet."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Killing a target with overwhelming, unfair force — most famously suicide "
"ganking in high-security space, where attackers happily let the NPC police "
"(CONCORD) destroy their cheap ships because your cargo is worth more. Never "
"haul more than you can afford to lose."
msgstr ""
"Убийство цели подавляющей, нечестной силой — самый известный пример suicide "
"gank в high-security космосе, где атакующие охотно позволяют NPC-полиции "
"(CONCORD) уничтожить свои дешёвые корабли, потому что ваш cargo стоит "
"дороже. Никогда не берите в haul больше, чем можете позволить себе потерять."

#: apps/onboarding/milestones_i18n.py
msgid ""
"When someone turns their guns on their own corpmates, usually an infiltrator "
"who joined just to betray — named after an infamous player who did exactly "
"that. It's why corps vet applicants, and why you should report suspicious "
"behavior to leadership."
msgstr ""
"Когда кто-то направляет оружие на собственных сокорповцев, обычно "
"внедрившийся, вступивший лишь чтобы предать — назван в честь печально "
"известного игрока, поступившего именно так. Вот почему корпорации проверяют "
"кандидатов и почему о подозрительном поведении нужно сообщать руководству."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Killing NPC pirates ('rats') in our space for bounty ISK — nullsec's bread-"
"and-butter income, also called krabbing. Bounties arrive in 20-minute "
"payouts, so pilots measure income in 'ticks' ('40m ticks' means 40 million "
"ISK per payout)."
msgstr ""
"Убийство NPC-пиратов ('rats') в нашем космосе ради bounty в ISK — хлеб "
"насущный nullsec, также называется krabbing. Bounty приходит выплатами "
"каждые 20 минут, поэтому пилоты меряют доход в 'ticks' ('40m ticks' значит "
"40 миллионов ISK за выплату)."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Planetary Industry — setting up automated extractors and factories on "
"planets for semi-passive income. It takes a few clicks a day and can be "
"managed from anywhere, making it a popular first income stream for new "
"nullsec pilots."
msgstr ""
"Planetary Industry — установка автоматических экстракторов и фабрик на "
"планетах ради полупассивного дохода. Требует пары кликов в день и "
"управляется откуда угодно, что делает её популярным первым источником дохода "
"для новых пилотов nullsec."

#: apps/onboarding/milestones_i18n.py
msgid ""
"An item CCP sells for real money that players can also buy and sell for ISK "
"on the in-game market; redeeming 500 of them grants a month of Omega (full "
"subscription) time. In other words, a healthy in-game income can pay for "
"your game time."
msgstr ""
"Предмет, который CCP продаёт за реальные деньги и который игроки также могут "
"покупать и продавать за ISK на внутриигровом рынке (market); обменяв 500 "
"таких, вы получаете месяц Omega (полной подписки). Иными словами, хороший "
"внутриигровой доход может оплачивать ваше игровое время."

#: apps/onboarding/milestones_i18n.py
msgid ""
"EVE's biggest trade hub — a high-security system (specifically the famous "
"Jita 4-4 station) where nearly everything in the game is bought and sold. "
"'Jita price' is the standard reference price, and our hauling services exist "
"to move goods between Jita and home."
msgstr ""
"Крупнейший торговый хаб EVE — high-security система (а именно знаменитая "
"станция Jita 4-4), где покупается и продаётся почти всё в игре. 'Jita price' "
"— стандартная опорная цена, а наши hauling-сервисы существуют, чтобы возить "
"товары между Jita и домом."

#: apps/onboarding/milestones_i18n.py
msgid ""
"EVE's built-in system for player-to-player deals: handing over items, "
"hauling jobs, or ship sales. Corp doctrine ships and buyback payouts usually "
"arrive as contracts — and since scamming is a legal part of EVE, always read "
"a contract carefully before accepting."
msgstr ""
"Встроенная в EVE система сделок между игроками: передача предметов, заказы "
"на перевозку или продажа кораблей. Корабли корпоративной doctrine и выплаты "
"по buyback обычно приходят как контракты — а поскольку мошенничество в EVE "
"легально, всегда внимательно читайте контракт перед принятием."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Jump Freighter — a huge cargo ship that jumps across light-years to a cyno "
"beacon instead of taking gates. The alliance JF service hauls your stuff "
"between Jita and our staging system for a small fee, so you never have to "
"fly a defenseless hauler through hostile space."
msgstr ""
"Jump Freighter — огромный грузовой корабль, который прыгает на световые годы "
"к cyno-маяку вместо использования гейтов. Сервис JF альянса перевозит ваши "
"вещи между Jita и нашей staging-системой за небольшую плату, так что вам "
"никогда не придётся вести беззащитный hauler через враждебное пространство."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Ship Replacement Program — lose a doctrine ship on an official fleet and the "
"corp or alliance pays you back. File your loss (usually a killmail link — "
"EVE's automatic record of a ship loss, copyable from the in-game combat log "
"or our killboard) after the op; SRP is why you can commit to fights without "
"fearing the ISK loss."
msgstr ""
"Ship Replacement Program — потеряете doctrine-корабль в официальном флоте, и "
"корпорация или альянс компенсируют его. Подайте заявку на потерю (обычно "
"ссылка на killmail — автоматическая запись EVE о потере корабля, которую "
"можно скопировать из внутриигрового боевого лога или с нашего killboard) "
"после опа; SRP — это то, что позволяет ввязываться в бои, не боясь потери "
"ISK."

#: apps/onboarding/milestones_i18n.py
msgid ""
"A corp service that buys your ore, loot, and salvage at a posted percentage "
"of market value, paid on the spot. You skip the hauling and selling; the "
"corp handles the logistics and keeps a small cut for the trouble."
msgstr ""
"Корпоративный сервис, который покупает вашу руду, лут и сальваж по "
"объявленному проценту от рыночной стоимости с оплатой на месте. Вы "
"избавляетесь от перевозки и продажи; корпорация берёт на себя логистику и "
"оставляет себе небольшую долю за хлопоты."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Friend-or-foe labels set by standings your leaders configure: blues are "
"allies — including coalition partners, other alliances we're teamed up with "
"— and reds are hostiles. The colors show in local chat and on your overview; "
"never shoot a blue. Anyone with no standings (a 'neutral') is NOT a friend — "
"most nullsec groups, ours included, fly NBSI: Not Blue? Shoot It. Report "
"neutrals in intel."
msgstr ""
"Метки «свой-чужой», задаваемые standings, которые настраивают ваши лидеры: "
"blues — союзники, включая партнёров по коалиции, другие альянсы, с которыми "
"мы объединились, — а reds враждебны. Цвета отображаются в local-чате и в "
"вашем overview; никогда не стреляйте по blue. Любой без standings "
"(«нейтрал») НЕ друг — большинство nullsec-групп, включая нашу, летают по "
"NBSI: Not Blue? Shoot It (не blue? стреляй). Сообщайте о нейтралах в intel."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Short for sovereignty — an alliance's official ownership of nullsec systems, "
"which unlocks upgrades like better ratting and mining. Our sov is the space "
"we live in and what enemies attack, so defending it is the point of many "
"fleets."
msgstr ""
"Сокращение от sovereignty — официальное владение альянса системами nullsec, "
"которое открывает улучшения вроде лучшего ratting и майнинга. Наш sov — это "
"пространство, в котором мы живём, и то, что атакуют враги, поэтому его "
"защита — цель многих флотов."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Call To Arms — the highest-priority fleet ping (an alert on Discord/comms "
"telling everyone to log in); if you can log in, you're expected to show up. "
"You'll also hear 'strat op' (a planned strategic operation) and 'home "
"defense' (drop everything, our space is under attack) — these fleets are "
"almost always SRP-covered."
msgstr ""
"Call To Arms — пинг флота высшего приоритета (оповещение в Discord/comms, "
"зовущее всех залогиниться); если можете залогиниться — обязаны явиться. Вы "
"также услышите «strat op» (запланированная стратегическая операция) и «home "
"defense» (бросай всё, наше пространство атакуют) — эти флоты почти всегда "
"покрываются SRP."

#: apps/onboarding/milestones_i18n.py
msgid ""
"The system and structure the alliance designates as its military home — keep "
"your doctrine ships and a clone there, because that's where fleets form. "
"When the alliance temporarily relocates staging into a war zone, that's "
"called a deployment."
msgstr ""
"Система и структура, которую альянс назначает своим военным домом, — держите "
"там свои doctrine-корабли и клон, потому что именно там собираются флоты. "
"Когда альянс временно переносит staging в зону боевых действий, это "
"называется deployment."

#: apps/onboarding/milestones_i18n.py
msgid ""
"Opsec (operational security) means keeping fleet times, pings, and plans "
"inside the alliance — assume enemy spies ('spais') are reading anything "
"public, because in EVE they really are. Never repost pings, fleet locations, "
"or intel outside official channels."
msgstr ""
"Opsec (operational security) означает держать время флотов, пинги и планы "
"внутри альянса — считайте, что вражеские шпионы («spais») читают всё "
"публичное, потому что в EVE так и есть. Никогда не публикуйте повторно "
"пинги, местоположения флотов или intel за пределами официальных каналов."

#: apps/onboarding/milestones_i18n.py
msgid ""
"A little text salute — the 'o' is a head, the '7' a saluting arm. Pilots use "
"it as hello, goodbye, and a sign of respect; you'll see a wall of 'o7' in "
"fleet chat at the end of every op."
msgstr ""
"Небольшой текстовый салют — «o» это голова, «7» — рука в приветствии. Пилоты "
"используют его как «привет», «пока» и знак уважения; в конце каждого опа вы "
"увидите стену из «o7» в чате флота."

#: apps/onboarding/milestones_i18n.py
msgid "Safe spot"
msgstr "Сейфспот"

#: apps/onboarding/milestones_i18n.py apps/operations/models.py
msgid "Gate camp"
msgstr "Gate camp"

#: apps/onboarding/models.py templates/_nav.html
#: templates/admin_audit/console/members.html
msgid "Account"
msgstr "Аккаунт"

#: apps/onboarding/models.py
msgid "To do"
msgstr "К выполнению"

#: apps/onboarding/views.py
msgid "Get connected"
msgstr "Подключитесь"

#: apps/onboarding/views.py
msgid ""
"Link your characters and plug into corp comms — this is how we find you and "
"how the Grid briefs you."
msgstr ""
"Привяжите своих персонажей и подключитесь к каналам связи корпорации — так "
"мы вас находим и так Grid держит вас в курсе."

#: apps/onboarding/views.py
msgid "Show us your skills"
msgstr "Покажите нам свои навыки"

#: apps/onboarding/views.py
msgid ""
"Share your skill sheet so every tool here can answer 'can I fly this?' "
"honestly."
msgstr ""
"Поделитесь своим листом навыков, чтобы каждый инструмент здесь мог честно "
"ответить 'могу ли я летать на этом?'."

#: apps/onboarding/views.py
msgid "Get combat-ready"
msgstr "Подготовьтесь к бою"

#: apps/onboarding/views.py
msgid ""
"Train into a corp doctrine ship. Flying what the FC calls for is the single "
"biggest thing you can do."
msgstr ""
"Обучитесь корпоративному doctrine-кораблю. Летать на том, что требует FC — "
"это самое важное, что вы можете сделать."

#: apps/onboarding/views.py
msgid "Live here"
msgstr "Живите здесь"

#: apps/onboarding/views.py
msgid ""
"Move in, undock with us, and start earning — nullsec pays the pilots who "
"show up."
msgstr ""
"Переезжайте, вылетайте со станции вместе с нами и начинайте зарабатывать — "
"nullsec платит пилотам, которые появляются."

#: apps/operations/models.py apps/pingboard/models.py
msgid "PvP fleet"
msgstr "PvP-флот"

#: apps/operations/models.py apps/pingboard/models.py
msgid "Roaming gang"
msgstr "Roaming-банда"

#: apps/operations/models.py
msgid "Ratting fleet"
msgstr "Ratting-флот"

#: apps/operations/models.py apps/pingboard/models.py
msgid "Mining operation"
msgstr "Операция по добыче"

#: apps/operations/models.py
msgid "Transport / logistics"
msgstr "Транспорт / логистика"

#: apps/operations/models.py
msgid "War preparation"
msgstr "Подготовка к войне"

#: apps/operations/models.py apps/pingboard/models.py
msgid "Home defence"
msgstr "Оборона дома"

#: apps/operations/models.py apps/pingboard/models.py
msgid "Structure timer"
msgstr "Таймер структуры"

#: apps/operations/models.py
msgid "Doctrine rollout"
msgstr "Внедрение doctrine"

#: apps/operations/models.py
msgid "Industrial campaign"
msgstr "Индустриальная кампания"

#: apps/operations/models.py
msgid "Cancelled (manual)"
msgstr "Отменено (вручную)"

#: apps/operations/models.py
msgid "Cancelled — too few sign-ups"
msgstr "Отменено — слишком мало записавшихся"

#: apps/operations/models.py
msgid "Alliance SRP"
