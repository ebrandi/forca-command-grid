msgstr "Только для участников корпорации"

#: apps/admin_audit/console.py
msgid "Corp & alliance members"
msgstr "Участники корпорации & альянса"

#: apps/admin_audit/console.py
msgid "Public — anyone"
msgstr "Публично — для всех"

