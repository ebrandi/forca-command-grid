msgstr "Канал «%(label)s» сохранён и готов к отправке."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Channel “%(label)s” saved, but not operational yet: %(why)s"
msgstr "Канал «%(label)s» сохранён, но пока не работает: %(why)s"

#: apps/admin_audit/console_pingboard.py
msgid "no provider implementation for this channel kind"
msgstr "нет реализации провайдера для этого типа канала"

#: apps/admin_audit/console_pingboard.py
msgid "could not verify configuration"
msgstr "не удалось проверить конфигурацию"

#: apps/admin_audit/console_pingboard.py
msgid "No provider implementation for this channel."
msgstr "Нет реализации провайдера для этого канала."

#: apps/admin_audit/console_pingboard.py
msgid ""
"Can't send a test EVE-mail — your account has no linked character to receive"
" it. Link a character, or just send a real alert (delivery to the corp works"
" independently)."
msgstr ""
"Не удалось отправить тестовое EVE-mail — к вашему аккаунту не привязан "
"персонаж для его получения. Привяжите персонажа или просто отправьте "
"реальное оповещение (доставка в корпорацию работает независимо)."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Test mail sent to %(recipient)s — check your in-game inbox."
msgstr ""
"Тестовое письмо отправлено %(recipient)s — проверьте свой внутриигровой "
"почтовый ящик."

#: apps/admin_audit/console_pingboard.py
msgid "your character"
msgstr "ваш персонаж"

#: apps/admin_audit/console_pingboard.py
msgid "Test message sent."
msgstr "Тестовое сообщение отправлено."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Test failed: %(error)s"
msgstr "Тест не пройден: %(error)s"

#: apps/admin_audit/console_pingboard.py
msgid "unknown error"
msgstr "неизвестная ошибка"

#: apps/admin_audit/console_pingboard.py
msgid "— none (use title/body below) —"
msgstr "— нет (используйте заголовок/текст ниже) —"

#: apps/admin_audit/console_pingboard.py
msgid "Condition must be a JSON object, e.g. {\"amount_gt\": 1000000000}."
msgstr "Условие должно быть JSON-объектом, например {\"amount_gt\": 1000000000}."

#: apps/admin_audit/console_pingboard.py
msgid "Audience must be a JSON object, e.g. {\"kind\": \"officer\"}."
msgstr "Аудитория должна быть JSON-объектом, например {\"kind\": \"officer\"}."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Unknown audience kind %(kind)r. Use one of: %(kinds)s."
msgstr "Неизвестный тип аудитории %(kind)r. Используйте один из: %(kinds)s."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Audience role must be one of: %(roles)s."
msgstr "Роль аудитории должна быть одной из: %(roles)s."

#: apps/admin_audit/console_pingboard.py
msgid "Window must be at least 1 minute."
msgstr "Окно должно быть не менее 1 минуты."

#: apps/admin_audit/console_pingboard.py
msgid "Cooldown can't be negative."
msgstr "Время ожидания не может быть отрицательным."

#: apps/admin_audit/console_pingboard.py
msgid "Max per window can't be negative (0 = unlimited)."
msgstr "Максимум за окно не может быть отрицательным (0 = без ограничений)."

#: apps/admin_audit/console_pingboard.py
msgid "Channels must be a JSON list of channel keys, e.g. [\"in_app\", \"discord\"]."
msgstr ""
"Каналы должны быть JSON-списком ключей каналов, например [\"in_app\", "
"\"discord\"]."

#: apps/admin_audit/console_pingboard.py
msgid "Rule updated."
msgstr "Правило обновлено."

#: apps/admin_audit/console_pingboard.py
msgid "Rule created (disabled)."
msgstr "Правило создано (отключено)."

#: apps/admin_audit/console_pingboard.py
msgid "Rule enabled."
msgstr "Правило включено."

#: apps/admin_audit/console_pingboard.py
msgid "Rule disabled."
msgstr "Правило отключено."

#: apps/admin_audit/console_pingboard.py
msgid "Rule deleted."
msgstr "Правило удалено."

#: apps/admin_audit/console_pingboard.py
msgid "Template created."
msgstr "Шаблон создан."

#: apps/admin_audit/console_pingboard.py
msgid "Template enabled."
msgstr "Шаблон включён."

#: apps/admin_audit/console_pingboard.py
msgid "Template disabled."
msgstr "Шаблон отключён."

#: apps/admin_audit/console_pingboard.py
msgid "Template deleted."
msgstr "Шаблон удалён."

#: apps/admin_audit/console_planetary.py
msgid "Planetary Industry settings saved."
msgstr "Настройки Planetary Industry сохранены."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Contest “%(name)s” created as a draft."
msgstr "Конкурс «%(name)s» создан как черновик."

#: apps/admin_audit/console_raffle.py
msgid "Raffle settings saved."
msgstr "Настройки розыгрыша сохранены."

#: apps/admin_audit/console_raffle.py
msgid ""
"This contest has started accruing tickets (or is closed) — its schedule and "
"rules are locked; only the text/display fields were saved."
msgstr ""
"Этот конкурс уже начал накапливать билеты (или закрыт) — его расписание и "
"правила заблокированы; сохранены только текстовые/отображаемые поля."

#: apps/admin_audit/console_raffle.py
msgid "Contest updated."
msgstr "Конкурс обновлён."

#: apps/admin_audit/console_raffle.py
msgid "Only a Director can cancel a contest."
msgstr "Только Директор может отменить конкурс."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Contest moved to %(status)s."
