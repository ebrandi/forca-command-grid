"Hallazgos de preparación de flota que cruzan una regla de alerta configurada "
"(dirigidos al responsable)."

#: apps/pingboard/notifications.py
msgid "Beat readiness.evaluate_alerts, over open findings."
msgstr "Beat readiness.evaluate_alerts, sobre los hallazgos abiertos."

#: apps/pingboard/notifications.py
msgid "Weekly readiness report"
msgstr "Informe semanal de preparación"

#: apps/pingboard/notifications.py
msgid ""
"The weekly executive readiness digest — index, biggest movers, top risks."
msgstr ""
"El resumen ejecutivo semanal de preparación — índice, mayores variaciones, "
"principales riesgos."

#: apps/pingboard/notifications.py
msgid "Beat readiness.weekly_report (weekly)."
msgstr "Beat readiness.weekly_report (semanal)."

#: apps/pingboard/notifications.py
msgid "Daily leadership briefing"
