#: templates/navigation/roaming.html templates/readiness/dimension.html
msgid "Score"
msgstr "Puntuación"

#: templates/navigation/roaming.html
msgid ""
"Score = NPC kills ÷ (1 + 2 × recent ship kills). Red ship-kill counts mean "
"the field is already contested. Data is CCP's public hourly feed; mining "
"can't be measured directly, so quiet systems with high NPC kills are the "
"best mining/ratting bets."
msgstr ""
"Puntuación = bajas de NPC ÷ (1 + 2 × bajas de naves recientes). Los "
"recuentos de bajas de naves en rojo significan que el campo ya está "
"disputado. Los datos son el feed público horario de CCP; la minería no se "
"puede medir directamente, así que los sistemas tranquilos con muchas bajas "
"de NPC son las mejores apuestas de minería/ratting."

#: templates/navigation/roaming.html
#, python-format
msgid ""
"No ratting activity reported in %(region)s right now. Try another region or "
"security band — the feed updates hourly."
msgstr ""
"No se reporta actividad de ratting en %(region)s ahora mismo. Prueba con "
"otra región o banda de seguridad — el feed se actualiza cada hora."

#: templates/navigation/roaming.html
msgid ""
"No ratting activity reported right now. Try another region or security band "
"— the feed updates hourly."
msgstr ""
"No se reporta actividad de ratting ahora mismo. Prueba con otra región o "
"banda de seguridad — el feed se actualiza cada hora."

