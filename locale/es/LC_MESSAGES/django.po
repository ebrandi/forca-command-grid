msgstr "Alerta suprimida (duplicada o limitada por frecuencia)."

#: apps/pingboard/views.py
#, python-format
msgid "Alert '%(title)s' created (%(status)s)."
msgstr "Alerta '%(title)s' creada (%(status)s)."

#: apps/pingboard/views.py
