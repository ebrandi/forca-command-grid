#: apps/pingboard/messages.py
msgid "Milestone unlocked: First kill!"
msgstr "Hito desbloqueado: ¡primer kill!"

#: apps/pingboard/messages.py
msgid "Congratulations on your first corp killmail! Welcome to the fight."
msgstr ""
"¡Enhorabuena por tu primer killmail con la corp! Bienvenido a la pelea."

#: apps/pingboard/messages.py
msgid "Milestone unlocked: First solo kill!"
msgstr "Hito desbloqueado: ¡primer kill en solitario!"

#: apps/pingboard/messages.py
msgid "Your first solo kill — you took one down all on your own. Nice work."
msgstr "Tu primer kill en solitario — lo derribaste tú solo. Buen trabajo."

#: apps/pingboard/messages.py
msgid "Milestone unlocked: First final blow!"
msgstr "Hito desbloqueado: ¡primer golpe final!"

#: apps/pingboard/messages.py
msgid "You landed your first final blow. The killing shot is yours."
msgstr "Has dado tu primer golpe final. El disparo definitivo es tuyo."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Combat rank achieved: {rank_name}"
msgstr "Rango de combate alcanzado: {rank_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Congratulations — you've reached the rank of {rank_name} ({kill_count} "
"lifetime kills recorded). Ranks update from the nightly combat rollup, so "
"this can reflect kills from the last day or two rather than the exact moment."
msgstr ""
"Enhorabuena — has alcanzado el rango de {rank_name} ({kill_count} kills "
"totales registrados). Los rangos se actualizan con el resumen de combate "
"nocturno, así que esto puede reflejar kills de hace uno o dos días y no el "
"momento exacto."

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Congratulations — you've reached the rank of {rank_name} ({kill_count} "
"lifetime kills recorded). A rank reward is pending leadership approval. "
"Ranks update from the nightly combat rollup, so this can reflect kills from "
"the last day or two rather than the exact moment."
msgstr ""
"Enhorabuena — has alcanzado el rango de {rank_name} ({kill_count} kills "
"totales registrados). Hay una recompensa de rango pendiente de aprobación "
"por la dirección. Los rangos se actualizan con el resumen de combate "
"nocturno, así que esto puede reflejar kills de hace uno o dos días y no el "
"momento exacto."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Watchlist tripwire: {entity_name}"
msgstr "Alarma de la lista de vigilancia: {entity_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"⚠ Watched {entity_type} **{entity_name}** ({watchlist_name}) was on a "
"killmail in {system_name} ~{minutes}m ago. Risk indicator, not a guarantee — "
"verify before acting."
msgstr ""
"⚠ En vigilancia — {entity_type}: **{entity_name}** ({watchlist_name}) "
"apareció en un killmail en {system_name} hace ~{minutes} min. Es un "
"indicador de riesgo, no una garantía: verifica antes de actuar."

#: apps/pingboard/messages.py
msgid "Order update: Claimed"
msgstr "Pedido actualizado: Reclamado"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "{ship_name} was claimed — a member is fulfilling it."
msgstr ""
"Se ha reclamado tu pedido de {ship_name}: un miembro se está encargando de "
"él."

#: apps/pingboard/messages.py
msgid "Order update: Deposit paid"
msgstr "Pedido actualizado: Depósito pagado"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Deposit received for {ship_name}."
msgstr "Depósito recibido para {ship_name}."

#: apps/pingboard/messages.py
msgid "Order update: In production"
msgstr "Pedido actualizado: En producción"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "{ship_name} is in production."
msgstr "{ship_name} está en producción."

#: apps/pingboard/messages.py
msgid "Order update: Ready"
msgstr "Pedido actualizado: Listo"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "{ship_name} is ready — coordinate pickup."
msgstr "Tu pedido de {ship_name} está listo: coordina la recogida."

#: apps/pingboard/messages.py
msgid "Order update: Delivered"
msgstr "Pedido actualizado: Entregado"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "{ship_name} was delivered. Fly safe!"
msgstr "Se ha entregado {ship_name}. ¡Buen vuelo!"

#: apps/pingboard/messages.py
msgid "Order update: Cancelled"
msgstr "Pedido actualizado: Cancelado"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Your order for {ship_name} was cancelled."
msgstr "Tu pedido de {ship_name} ha sido cancelado."

#: apps/pingboard/messages.py
msgid "Order update: New delivery estimate"
msgstr "Pedido actualizado: Nueva estimación de entrega"

#: apps/pingboard/messages.py
#, python-brace-format
