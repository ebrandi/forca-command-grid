msgstr "Canales fallidos vueltos a poner en cola."

#: apps/pingboard/views.py
msgid "Alert cancelled."
msgstr "Alerta cancelada."

#: apps/pingboard/views.py
msgid "Alert approved and queued."
msgstr "Alerta aprobada y puesta en cola."

#: apps/pingboard/views.py
msgid "Alert is not awaiting approval."
msgstr "La alerta no está esperando aprobación."

#: apps/pingboard/views.py
msgid "A valid start time is required."
msgstr "Se requiere una hora de inicio válida."

#: apps/pingboard/views.py
msgid "A structure timer needs a name."
msgstr "Un timer de estructura necesita un nombre."

#: apps/pingboard/views.py
msgid "Structure timer added — it'll appear on the calendar shortly."
msgstr "Timer de estructura añadido — aparecerá en el calendario en breve."

#: apps/pingboard/views.py
msgid "Structure timer added — it's on the calendar and the timers board."
msgstr ""
"Timer de estructura añadido — está en el calendario y en el tablero de "
"timers."

#: apps/pingboard/views.py
msgid "Calendar event created."
msgstr "Evento de calendario creado."

#: apps/pingboard/views.py
msgid "Event cancelled."
msgstr "Evento cancelado."

#: apps/pingboard/views.py
#, python-format
msgid "Reminder scheduled %(minutes)d min before."
msgstr "Recordatorio programado %(minutes)d min antes."

#: apps/pingboard/views.py
msgid "Unknown channel."
msgstr "Canal desconocido."

#: apps/pingboard/views.py
msgid "Notification preferences saved."
msgstr "Preferencias de notificación guardadas."

#: apps/pingboard/views.py
msgid "Open the Telegram deep link below and press Start to verify."
msgstr "Abre el deep link de Telegram de abajo y pulsa Start para verificar."

#: apps/pingboard/views.py
#, python-format
msgid "Verification code: %(code)s — confirm it below once received."
msgstr "Código de verificación: %(code)s — confírmalo abajo una vez recibido."

#: apps/pingboard/views.py
msgid "Channel verified."
msgstr "Canal verificado."

#: apps/pingboard/views.py
