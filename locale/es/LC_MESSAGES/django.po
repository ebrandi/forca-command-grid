#: templates/admin_audit/console/retention_settings.html
msgid ""
"How long each class of data is kept before the nightly\n"
"    housekeeping job prunes it, and what happens to a member's data when "
"they leave. These drive the\n"
"    daily retention task."
msgstr ""
"Cuánto tiempo se conserva cada clase de datos antes de que la tarea nocturna "
"de\n"
"    mantenimiento la depure, y qué ocurre con los datos de un miembro cuando "
"se va. Esto rige la\n"
"    tarea diaria de retención."

#: templates/admin_audit/console/retention_settings.html
msgid "Pruned nightly."
msgstr "Se depura cada noche."

#: templates/admin_audit/console/retention_settings.html
msgid "Stored — enforcement not yet wired."
msgstr "Almacenado — la aplicación aún no está conectada."

#: templates/admin_audit/console/retention_settings.html
msgid "Keep for (days)"
msgstr "Conservar durante (días)"

#: templates/admin_audit/console/retention_settings.html
