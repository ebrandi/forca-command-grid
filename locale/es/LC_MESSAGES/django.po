#: apps/admin_audit/console.py
msgid "Service & feature availability updated."
msgstr "Disponibilidad de servicios & funciones actualizada."

#: apps/admin_audit/console.py
msgid "Data-retention policy saved."
msgstr "Política de retención de datos guardada."

#: apps/admin_audit/console.py
msgid "Couldn't read that expiry date."
msgstr "No se pudo leer esa fecha de caducidad."

#: apps/admin_audit/console.py
msgid "Expiry must be in the future — leave it blank for a permanent grant."
msgstr ""
"La caducidad debe estar en el futuro — déjala en blanco para una concesión "
"permanente."

#: apps/admin_audit/console.py
msgid "That role can't be managed here."
msgstr "Ese rol no se puede gestionar aquí."

#: apps/admin_audit/console.py
#, python-format
msgid "A %(role)s grant for that pilot is already awaiting approval."
msgstr ""
"Ya hay una concesión de %(role)s para ese piloto pendiente de aprobación."

#: apps/admin_audit/console.py
#, python-format
msgid "%(role)s grant requested — a second director must approve it."
msgstr "Concesión de %(role)s solicitada — un segundo director debe aprobarla."

#: apps/admin_audit/console.py
msgid "Can't remove the last Director — promote someone else first."
msgstr "No se puede quitar al último Director — asciende antes a otra persona."

#: apps/admin_audit/console.py
#, python-format
msgid "%(role)s %(action)s for %(name)s."
msgstr "%(role)s %(action)s para %(name)s."

#: apps/admin_audit/console.py
msgid "You can't approve your own role request — another director must."
msgstr ""
"No puedes aprobar tu propia solicitud de rol — debe hacerlo otro director."

#: apps/admin_audit/console.py
#, python-format
msgid "%(role)s grant %(outcome)s for %(name)s."
msgstr "Concesión de %(role)s %(outcome)s para %(name)s."

#: apps/admin_audit/console.py apps/admin_audit/console_doctrine_xml.py
msgid "Enter a whole number."
msgstr "Introduce un número entero."

#: apps/admin_audit/console.py
#, python-format
msgid "Page size set to %(clamped)s (kept within %(min)s–%(max)s)."
msgstr "Tamaño de página fijado en %(clamped)s (dentro de %(min)s–%(max)s)."

#: apps/admin_audit/console.py
#, python-format
msgid "Page size set to %(clamped)s per page."
msgstr "Tamaño de página fijado en %(clamped)s por página."

#: apps/admin_audit/console.py
msgid "Give the doctrine a name."
msgstr "Dale un nombre a la doctrine."

#: apps/admin_audit/console.py
#, python-format
msgid "Doctrine “%(name)s” created — add a fit below."
msgstr "Doctrine “%(name)s” creada — añade un fit abajo."

#: apps/admin_audit/console.py
msgid "Doctrine updated."
msgstr "Doctrine actualizada."

#: apps/admin_audit/console.py
msgid "Doctrine deleted."
msgstr "Doctrine eliminada."

#: apps/admin_audit/console.py
#, python-format
msgid "Couldn't parse the EFT: %(error)s"
msgstr "No se pudo procesar el EFT: %(error)s"

#: apps/admin_audit/console.py
#, python-format
msgid "Unknown ship “%(ship)s” — check the EFT header."
msgstr "Nave desconocida “%(ship)s” — revisa la cabecera del EFT."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"Fit “%(name)s” added (%(count)s skill requirements derived). Unresolved "
"lines: %(lines)s."
msgstr ""
"Fit “%(name)s” añadido (%(count)s requisitos de skill derivados). Líneas sin "
"resolver: %(lines)s."

#: apps/admin_audit/console.py
#, python-format
msgid "Fit “%(name)s” added (%(count)s skill requirements derived)."
msgstr "Fit “%(name)s” añadido (%(count)s requisitos de skill derivados)."

#: apps/admin_audit/console.py
msgid "Fit removed."
msgstr "Fit eliminado."

#: apps/admin_audit/console.py
msgid "Pick a valid requirement type."
msgstr "Elige un tipo de requisito válido."

#: apps/admin_audit/console.py
msgid "A note needs some text."
msgstr "Una nota necesita algo de texto."

#: apps/admin_audit/console.py
msgid "This requirement needs a type id (or record it as a note)."
msgstr "Este requisito necesita un type id (o regístralo como nota)."

#: apps/admin_audit/console.py
msgid "Requirement added."
msgstr "Requisito añadido."

#: apps/admin_audit/console.py
msgid "Requirement removed."
msgstr "Requisito eliminado."

#: apps/admin_audit/console.py
msgid "Tick at least one fit to import."
msgstr "Marca al menos un fit para importar."

#: apps/admin_audit/console.py
#, python-format
msgid "Imported %(count)d fit as new doctrines under IMPORTED."
msgid_plural "Imported %(count)d fits as new doctrines under IMPORTED."
msgstr[0] "Se importó %(count)d fit como nuevas doctrines en IMPORTED."
msgstr[1] "Se importaron %(count)d fits como nuevas doctrines en IMPORTED."

#: apps/admin_audit/console.py
#, python-format
msgid "Already in the library (identical name and fit) — skipped: %(names)s."
msgstr "Ya está en la biblioteca (mismo nombre y fit) — omitido: %(names)s."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"A doctrine with this name already exists but with a different fit — rename "
"it and import again: %(names)s."
msgstr ""
"Ya existe una doctrine con este nombre pero con un fit distinto — renómbrala "
"e impórtala de nuevo: %(names)s."

#: apps/admin_audit/console.py
msgid "Nothing imported — the selected fits couldn't be read."
msgstr "No se importó nada — no se pudieron leer los fits seleccionados."

#: apps/admin_audit/console.py
#, python-format
msgid "Couldn't parse the fit: %(error)s"
msgstr "No se pudo procesar el fit: %(error)s"

#: apps/admin_audit/console.py
#, python-format
msgid "Unknown ship “%(ship)s” — check the first line."
msgstr "Nave desconocida “%(ship)s” — revisa la primera línea."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"Doctrine “%(name)s” created from killmail (%(count)s skills derived). "
"Unresolved: %(lines)s."
msgstr ""
"Doctrine “%(name)s” creada a partir del killmail (%(count)s skills "
"derivados). Sin resolver: %(lines)s."

#: apps/admin_audit/console.py
#, python-format
msgid "Doctrine “%(name)s” created from killmail (%(count)s skills derived)."
msgstr ""
"Doctrine “%(name)s” creada a partir del killmail (%(count)s skills "
"derivados)."

#: apps/admin_audit/console.py
#, python-format
msgid "Category “%(label)s” added."
msgstr "Categoría “%(label)s” añadida."

#: apps/admin_audit/console.py
msgid "Manual — pilot checks it off"
msgstr "Manual — el piloto lo marca"

#: apps/admin_audit/console.py
msgid "Auto — a character is linked"
msgstr "Auto — hay un personaje vinculado"

#: apps/admin_audit/console.py
msgid "Auto — verified corp member"
msgstr "Auto — miembro verificado de la corporación"

#: apps/admin_audit/console.py
msgid "Auto — skills imported"
msgstr "Auto — skills importados"

#: apps/admin_audit/console.py
msgid "Auto — ESI scopes granted"
msgstr "Auto — scopes ESI concedidos"

#: apps/admin_audit/console.py
msgid "Auto — skill trained to level"
msgstr "Auto — skill entrenado a un nivel"

#: apps/admin_audit/console.py
msgid "Auto — can fly a specific doctrine"
msgstr "Auto — puede volar una doctrine específica"

#: apps/admin_audit/console.py
msgid "Auto — can fly ANY active doctrine"
msgstr "Auto — puede volar CUALQUIER doctrine activa"

#: apps/admin_audit/console.py apps/campaigns/views.py
msgid "A milestone needs a title."
msgstr "Un hito necesita un título."

#: apps/admin_audit/console.py
msgid "Pick the doctrine this milestone checks."
msgstr "Elige la doctrine que comprueba este hito."

#: apps/admin_audit/console.py
msgid "That doctrine no longer exists."
msgstr "Esa doctrine ya no existe."

#: apps/admin_audit/console.py
msgid "Skill milestones need a skill type id and a level (1–5)."
msgstr "Los hitos de skill necesitan un skill type id y un nivel (1–5)."

#: apps/admin_audit/console.py
msgid "List at least one ESI scope (comma-separated)."
msgstr "Indica al menos un scope ESI (separados por comas)."

#: apps/admin_audit/console.py
msgid "That milestone no longer exists."
msgstr "Ese hito ya no existe."

#: apps/admin_audit/console.py
#, python-format
msgid "Milestone “%(title)s” saved."
msgstr "Hito “%(title)s” guardado."

#: apps/admin_audit/console.py
msgid "Milestone removed — pilots' progress rows went with it."
msgstr ""
"Hito eliminado — las filas de progreso de los pilotos se eliminaron con él."

#: apps/admin_audit/console.py
#, python-format
msgid "Glossary term “%(term)s” saved."
msgstr "Término del glosario “%(term)s” guardado."

#: apps/admin_audit/console.py
msgid "Both term and definition are required."
msgstr "Se requieren tanto el término como la definición."

#: apps/admin_audit/console.py
msgid "Glossary term removed."
msgstr "Término del glosario eliminado."

#: apps/admin_audit/console.py
msgid "Recommendation engine"
msgstr "Motor de recomendaciones"

#: apps/admin_audit/console.py
msgid "Market history refresh"
msgstr "Actualización del historial de mercado"

#: apps/admin_audit/console.py
msgid "Corp asset sync"
msgstr "Sincronización de activos de la corporación"

#: apps/admin_audit/console.py
msgid "Personal asset sync"
msgstr "Sincronización de activos personales"

#: apps/admin_audit/console.py
msgid "Killmail discovery"
msgstr "Descubrimiento de killmails"

#: apps/admin_audit/console.py
msgid "Member skill sync"
msgstr "Sincronización de skills de miembros"

#: apps/admin_audit/console.py
msgid "Capsuleer Path reconcile"
msgstr "Reconciliación de Capsuleer Path"

#: apps/admin_audit/console.py
msgid "Unknown maintenance action."
msgstr "Acción de mantenimiento desconocida."

#: apps/admin_audit/console.py
#, python-format
msgid "%(label)s queued — results appear under Integrations as they finish."
msgstr ""
"%(label)s en cola — los resultados aparecen en Integraciones a medida que "
"terminan."

#: apps/admin_audit/console.py
msgid "Contribution weights updated."
msgstr "Pesos de contribución actualizados."

#: apps/admin_audit/console_access.py
msgid "Enter a valid alliance id."
msgstr "Introduce un ID de alianza válido."

#: apps/admin_audit/console_access.py
msgid "Partner alliance saved."
msgstr "Alianza asociada guardada."

#: apps/admin_audit/console_access.py
msgid "Partner alliance removed."
msgstr "Alianza asociada eliminada."

#: apps/admin_audit/console_access.py
msgid "Enter a valid corporation id."
msgstr "Introduce un ID de corporación válido."

#: apps/admin_audit/console_access.py
msgid "Friendly corporation saved."
msgstr "Corporación amiga guardada."

#: apps/admin_audit/console_access.py
msgid "Friendly corporation removed."
msgstr "Corporación amiga eliminada."

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings reset to defaults."
msgstr "Ajustes de Capsuleer Path restablecidos a los valores predeterminados."

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings saved."
msgstr "Ajustes de Capsuleer Path guardados."

#: apps/admin_audit/console_combat.py
msgid "A rank title can't be empty."
msgstr "El título de un rango no puede estar vacío."

#: apps/admin_audit/console_combat.py
msgid "Reward amount can't be negative."
msgstr "El importe de la recompensa no puede ser negativo."

#: apps/admin_audit/console_combat.py
msgid "Another rank already uses this threshold for this metric."
msgstr "Otro rango ya usa este umbral para esta métrica."

#: apps/admin_audit/console_combat.py
msgid ""
"Rewards apply to the all-time PvP kills track only — the support-role tracks "
"are recognition-only."
msgstr ""
"Las recompensas se aplican solo a la clasificación de kills de PvP de todos "
"los tiempos — las clasificaciones de roles de apoyo son solo de "
"reconocimiento."

#: apps/admin_audit/console_combat.py
msgid "Choose a reward type, or untick “grants reward”."
msgstr "Elige un tipo de recompensa o desmarca “otorga recompensa”."

#: apps/admin_audit/console_combat.py
msgid "An item reward needs an EVE type id."
msgstr "Una recompensa de objeto necesita un EVE type id."

#: apps/admin_audit/console_combat.py
msgid "An ISK/PLEX reward needs a positive amount."
msgstr "Una recompensa de ISK/PLEX necesita un importe positivo."

#: apps/admin_audit/console_combat.py
msgid "Must be zero or positive."
msgstr "Debe ser cero o positivo."

#: apps/admin_audit/console_combat.py
msgid "Can't exceed 100%."
msgstr "No puede superar el 100%."

#: apps/admin_audit/console_combat.py
msgid "Newbro settings saved."
msgstr "Ajustes de newbro guardados."

#: apps/admin_audit/console_combat.py
msgid "Please correct the newbro settings."
msgstr "Corrige los ajustes de newbro."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” saved."
msgstr "Rango “%(name)s” guardado."

#: apps/admin_audit/console_combat.py apps/admin_audit/console_corporation.py
#: apps/admin_audit/console_industry.py apps/admin_audit/console_mentorship.py
#: apps/admin_audit/console_navigation.py apps/admin_audit/console_pingboard.py
#: apps/admin_audit/console_planetary.py apps/admin_audit/console_raffle.py
msgid "Please correct the errors below."
msgstr "Corrige los errores de abajo."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” removed."
msgstr "Rango “%(name)s” eliminado."

#: apps/admin_audit/console_combat.py
msgid "Reward settings saved."
msgstr "Ajustes de recompensas guardados."

#: apps/admin_audit/console_combat.py
#, python-format
msgid ""
"Rewards enabled. Baseline snapshotted for %(n)d pilot(s) — only ranks "
"reached from now on will create rewards."
msgstr ""
"Recompensas activadas. Se tomó una instantánea de referencia para %(n)d "
"piloto(s) — solo los rangos alcanzados a partir de ahora generarán "
"recompensas."

#: apps/admin_audit/console_combat.py
msgid "Rewards disabled. No new reward events will be created."
msgstr "Recompensas desactivadas. No se crearán nuevos eventos de recompensa."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Baseline re-snapshotted for %(n)d pilot(s)."
msgstr "Instantánea de referencia rehecha para %(n)d piloto(s)."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward scan complete — %(n)d new reward event(s) created."
msgstr ""
"Análisis de recompensas completado — %(n)d nuevo(s) evento(s) de recompensa "
"creado(s)."

#: apps/admin_audit/console_combat.py apps/buyback/views.py
#: apps/capsuleer/views.py apps/logistics/views.py apps/stockpile/views.py
#: apps/store/views.py apps/store/views_inventory.py
msgid "Unknown action."
msgstr "Acción desconocida."

#: apps/admin_audit/console_combat.py
