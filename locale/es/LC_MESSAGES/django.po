#: apps/admin_audit/console_corporation.py
msgid "Low-fuel warning must be between 1 and 30 days."
msgstr "La advertencia de combustible bajo debe estar entre 1 y 30 días."

#: apps/admin_audit/console_corporation.py
msgid "ADM floor must be between 1.0 and 6.0."
msgstr "El mínimo de ADM debe estar entre 1.0 y 6.0."

#: apps/admin_audit/console_corporation.py
msgid "Structure-alert thresholds saved."
msgstr "Umbrales de alerta de estructura guardados."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import rejected: %(error)s"
msgstr "Importación rechazada: %(error)s"

#: apps/admin_audit/console_doctrine_xml.py
msgid "XML import applied."
msgstr "Importación XML aplicada."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Limit set to %(clamped)s (values are kept within 1–%(ceiling)s)."
msgstr ""
"Límite establecido en %(clamped)s (los valores se mantienen entre 1–"
"%(ceiling)s)."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import limit set to %(clamped)s fittings."
msgstr "Límite de importación establecido en %(clamped)s fittings."

#: apps/admin_audit/console_i18n.py
msgid ""
"Official CCP game-data names (ships, modules, systems) are not localised yet "
"— they will be integrated at the SDE display seam (Phase 4)."
msgstr ""
"Los nombres oficiales de datos de juego de CCP (naves, módulos, sistemas) "
"aún no están localizados — se integrarán en el punto de visualización del "
"SDE (Fase 4)."

#: apps/admin_audit/console_i18n.py
#, python-format
msgid "Ignored unknown locale(s): %(codes)s."
msgstr "Se ignoraron configuraciones regionales desconocidas: %(codes)s."

#: apps/admin_audit/console_i18n.py
msgid "Localisation settings saved."
msgstr "Ajustes de localización guardados."

#: apps/admin_audit/console_industry.py
msgid "Industry & Economy settings saved."
msgstr "Ajustes de industria y economía guardados."

#: apps/admin_audit/console_mentorship.py
