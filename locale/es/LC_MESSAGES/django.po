"autorizarlo."

#: apps/skills/views.py
#, python-format
msgid "%(character)s can already fly %(doctrine)s — no plan needed."
msgstr "%(character)s ya puede volar %(doctrine)s — no hace falta plan."

#: apps/skills/views.py
#, python-format
msgid "Plan built: %(count)d skills toward %(doctrine)s."
msgstr "Plan creado: %(count)d habilidades hacia %(doctrine)s."

#: apps/skills/views.py
msgid "Skill removed from the plan."
msgstr "Habilidad eliminada del plan."

#: apps/skills/views.py
msgid "Plan deleted."
msgstr "Plan eliminado."

#: apps/srp/forms.py
msgid "Insurance fraction must be between 0 and 1."
msgstr "La fracción del seguro debe estar entre 0 y 1."

#: apps/srp/forms.py
msgid "Cap can't be negative."
msgstr "El tope no puede ser negativo."

#: apps/srp/forms.py
msgid "Default op length must be at least 1 minute."
msgstr ""
"La duración predeterminada de la operación debe ser de al menos 1 minuto."

#: apps/srp/forms.py templates/srp/settings.html
msgid "Any doctrine (catch-all)"
msgstr "Cualquier doctrine (comodín)"

#: apps/srp/forms.py
msgid "Amount can't be negative."
msgstr "El importe no puede ser negativo."

#: apps/srp/models.py
msgid ""
"Lose a doctrine ship on a fleet op and the corp helps you replace it. Submit "
"a claim from your eligible losses below and an officer reviews it."
msgstr ""
"Si pierdes una nave de doctrine en una op de flota, la corp te ayuda a "
"reemplazarla. Envía una solicitud desde tus pérdidas elegibles de abajo y un "
"oficial la revisa."

#: apps/srp/models.py
msgid "Replacement ship & fit"
msgstr "Nave y fit de reemplazo"

#: apps/srp/models.py
msgid "ISK — full loss value"
msgstr "ISK — valor total de la pérdida"

#: apps/srp/models.py
msgid "ISK — top up official insurance"
msgstr "ISK — complementar el seguro oficial"

#: apps/srp/models.py
msgid "Actual loss (hull + destroyed modules)"
msgstr "Pérdida real (hull + módulos destruidos)"

#: apps/srp/models.py
msgid "Doctrine fit value"
msgstr "Valor del fit de la doctrine"

#: apps/srp/models.py
msgid "Hull only"
msgstr "Solo hull"

#: apps/srp/models.py
msgid "Only losses flying an active doctrine hull are eligible."
msgstr ""
"Solo son elegibles las pérdidas volando un hull de una doctrine activa."

#: apps/srp/models.py
msgid "Also cover capsule (pod) losses."
msgstr "Cubrir también las pérdidas de cápsula (pod)."

#: apps/srp/models.py
msgid "Only cover losses during a sanctioned fleet op's window."
msgstr ""
"Cubrir solo las pérdidas durante la ventana de una operación de flota "
"autorizada."

#: apps/srp/models.py
msgid ""
"Minutes of grace added before and after an op window (form-up / travel)."
msgstr ""
"Minutos de gracia añadidos antes y después de la ventana de una operación "
"(formación / viaje)."

#: apps/srp/models.py
msgid "Assumed op length when an operation has no explicit duration."
msgstr ""
"Duración de operación asumida cuando una operación no tiene duración "
"explícita."

#: apps/srp/models.py
msgid ""
"Also require the pilot's recorded attendance (PAP) on that op, not just the "
"window."
msgstr ""
"Requerir también la asistencia registrada del piloto (PAP) en esa operación, "
"no solo la ventana."

#: apps/srp/models.py
msgid "Full fit"
msgstr "Fit completo"

#: apps/srp/models.py
msgid "Fixed cap"
msgstr "Tope fijo"

#: apps/srp/models.py
msgid "Denied"
msgstr "Denegado"

#: apps/srp/models.py
msgid "e.g. 2026-06"
msgstr "p. ej. 2026-06"

#: apps/srp/services.py
msgid "SRP is currently paused by leadership."
msgstr "La dirección tiene el SRP pausado ahora mismo."

#: apps/srp/services.py
msgid "Not a corp loss."
msgstr "No es una pérdida de la corp."

#: apps/srp/services.py
msgid "Pod losses aren't covered."
msgstr "Las pérdidas de pod no están cubiertas."

#: apps/srp/services.py
msgid "Loss isn't an active doctrine hull."
msgstr "La pérdida no es un hull de una doctrine activa."

#: apps/srp/services.py
msgid "No active SRP rule."
msgstr "No hay ninguna regla de SRP activa."

#: apps/srp/services.py
msgid "Loss wasn't on a sanctioned fleet op."
msgstr "La pérdida no ocurrió en una op de flota sancionada."

#: apps/srp/views.py
#, python-format
msgid "SRP claim submitted: %(amount)s ISK pending review."
msgstr "Solicitud de SRP enviada: %(amount)s ISK pendiente de revisión."

#: apps/srp/views.py
msgid "That loss isn't eligible, or a claim already exists."
msgstr "Esa pérdida no es elegible, o ya existe una solicitud."

#: apps/srp/views.py
#, python-format
msgid "Approved %(count)d claim(s)."
msgstr "%(count)d solicitud(es) aprobada(s)."

#: apps/srp/views.py
#, python-format
msgid "Skipped %(count)d of your own — another officer must review those."
msgstr "Se omitieron %(count)d de las tuyas — otro oficial debe revisarlas."

#: apps/srp/views.py
#, python-format
msgid "Nothing to approve — %(count)d were your own claims."
msgstr "Nada que aprobar — %(count)d eran tus propias solicitudes."

#: apps/srp/views.py
msgid "Nothing to approve."
msgstr "Nada que aprobar."

#: apps/srp/views.py
#, python-format
msgid "Settled %(count)d claim(s) against “%(ref)s”."
msgstr "%(count)d solicitud(es) liquidada(s) contra “%(ref)s”."

#: apps/srp/views.py
#, python-format
msgid "Settled %(count)d claim(s)."
msgstr "%(count)d solicitud(es) liquidada(s)."

#: apps/srp/views.py
#, python-format
msgid "Skipped %(count)d of your own."
msgstr "Se omitieron %(count)d de las tuyas."

#: apps/srp/views.py
#, python-format
msgid "No approved claims to settle — %(count)d were your own."
msgstr "No hay solicitudes aprobadas que liquidar — %(count)d eran tuyas."

#: apps/srp/views.py
msgid "No approved claims to settle."
msgstr "No hay solicitudes aprobadas que liquidar."

#: apps/srp/views.py
msgid "Enter a valid period (YYYY-MM) and a non-negative amount."
msgstr "Introduce un periodo válido (YYYY-MM) y una cantidad no negativa."

#: apps/srp/views.py
#, python-format
msgid "Budget for %(period)s set to %(amount)s ISK."
msgstr "Presupuesto para %(period)s fijado en %(amount)s ISK."

#: apps/srp/views.py
msgid "You can't decide your own SRP claim — another officer must review it."
msgstr ""
"No puedes decidir tu propia solicitud de SRP — otro oficial debe revisarla."

#: apps/srp/views.py
msgid "That claim is no longer awaiting a decision."
msgstr "Esa solicitud ya no está pendiente de decisión."

#: apps/srp/views.py
msgid "Claim approved."
msgstr "Solicitud aprobada."

#: apps/srp/views.py
msgid "Claim denied."
msgstr "Solicitud denegada."

#: apps/srp/views.py
msgid "You can't pay out your own SRP claim — another officer must."
msgstr ""
"No puedes pagar tu propia solicitud de SRP — debe hacerlo otro oficial."

#: apps/srp/views.py
msgid "That claim isn't approved and awaiting payment."
msgstr "Esa solicitud no está aprobada y pendiente de pago."

#: apps/srp/views.py
msgid "SRP programme updated."
msgstr "Programa de SRP actualizado."

#: apps/srp/views.py
msgid "SRP rule added."
msgstr "Regla de SRP añadida."

#: apps/srp/views.py
msgid "Couldn't add that rule — check the values."
msgstr "No se pudo añadir esa regla — revisa los valores."

#: apps/srp/views.py
msgid "SRP rule removed."
msgstr "Regla de SRP eliminada."

#: apps/sso/linking.py
msgid "ESI authorisation healthy"
msgstr "Autorización de ESI al día"

#: apps/sso/linking.py
msgid "ESI authorisation required"
msgstr "Autorización de ESI requerida"

#: apps/sso/linking.py
msgid "Missing ESI permissions"
msgstr "Permisos de ESI faltantes"

#: apps/sso/linking.py
msgid "This pilot's ESI authorisation is current. Nothing to do."
msgstr ""
"La autorización de ESI de este piloto está al día. No hay nada que hacer."

#: apps/sso/linking.py
msgid ""
"This pilot's EVE authorisation has expired or been revoked. You can still "
"switch to them, but their ESI data cannot refresh until you reauthorise."
msgstr ""
"La autorización de EVE de este piloto ha caducado o ha sido revocada. Aún "
"puedes cambiar a este piloto, pero sus datos de ESI no se actualizarán hasta "
"que lo reautorices."

#: apps/sso/linking.py
msgid ""
"This pilot has not granted every permission FORCA Command Grid asks for. "
"Some pages will be incomplete until you reauthorise."
msgstr ""
"Este piloto no ha concedido todos los permisos que FORCA Command Grid "
"solicita. Algunas páginas estarán incompletas hasta que lo reautorices."

#: apps/sso/scopes.py
msgid "Track my assets"
msgstr "Seguir mis activos"

#: apps/sso/scopes.py
msgid ""
"Show your own assets and where they sit across stations and structures in "
"the stockpile views."
msgstr ""
"Muestra tus propios activos y dónde están repartidos entre estaciones y "
"estructuras en las vistas de acopio."

#: apps/sso/scopes.py
msgid "My industry jobs + blueprints"
msgstr "Mis trabajos de industria + blueprints"

#: apps/sso/scopes.py
msgid ""
"Read your own running industry jobs and owned blueprints, so the Industry "
"Center can track your personal production and match it to your plans."
msgstr ""
"Lee tus trabajos de industria en curso y los blueprints que posees, para que "
"el Centro de Industria pueda seguir tu producción personal y cruzarla con "
"tus planes."

#: apps/sso/scopes.py
msgid "Freight location search"
msgstr "Búsqueda de ubicaciones de flete"

#: apps/sso/scopes.py
msgid ""
"Search the player structures you can dock at when booking a courier "
"contract, so a pickup or drop-off resolves to the exact station."
msgstr ""
"Busca las estructuras de jugador en las que puedes atracar al reservar un "
"contrato de mensajería, para que la recogida o la entrega se resuelvan a la "
"estación exacta."

#: apps/sso/scopes.py
msgid "Verify my hauls"
msgstr "Verificar mis transportes"

#: apps/sso/scopes.py
msgid ""
"Read your own contracts so the freight service can confirm a courier job you "
"delivered actually completed in-game and credit you for it."
msgstr ""
"Lee tus propios contratos para que el servicio de flete pueda confirmar en "
"el juego que el contrato de mensajería que entregaste se completó de verdad "
"y abonártelo."

#: apps/sso/scopes.py
msgid "Verify corp hauls"
msgstr "Verificar los transportes de la corp"

#: apps/sso/scopes.py
msgid ""
"Read corp contracts to auto-verify every hauler's courier delivery in-game "
"before crediting it — no per-pilot grant needed."
msgstr ""
"Lee los contratos de la corp para verificar automáticamente en el juego la "
"entrega de mensajería de cada transportista antes de abonarla — sin "
"necesidad de un permiso por piloto."

#: apps/sso/scopes.py templates/_pilot_identity.html
#: templates/admin_audit/console/recovery.html
#: templates/corporation/finance.html templates/identity/dashboard.html
#: templates/impersonation/log.html
msgid "Director"
msgstr "Director"

#: apps/sso/scopes.py
msgid ""
"Import the corporation's assets to power the stockpile and supply views."
msgstr ""
"Importa los activos de la corporación para alimentar las vistas de acopio y "
"suministro."

#: apps/sso/scopes.py
msgid "Member tracking"
msgstr "Seguimiento de miembros"

#: apps/sso/scopes.py
msgid ""
"Import the corp roster with each member's location, ship and last login for "
"the readiness and roster tools."
msgstr ""
"Importa la lista de miembros de la corp con la ubicación, la nave y el "
"último acceso de cada uno para las herramientas de preparación y de "
"plantilla."

#: apps/sso/scopes.py
msgid "Corp wallet"
msgstr "Cartera de la corp"

#: apps/sso/scopes.py
msgid "Import corp wallet balances and the journal for the finance page."
msgstr ""
"Importa los saldos de la cartera de la corp y el diario para la página de "
"finanzas."

#: apps/sso/scopes.py
msgid "Accountant or Director"
msgstr "Accountant o Director"

#: apps/sso/scopes.py
msgid "Corp standings"
msgstr "Standings de la corp"

#: apps/sso/scopes.py
msgid ""
"Import corp contacts to drive the member-facing blue/red standings board."
msgstr ""
"Importa los contactos de la corp para alimentar el tablón de standings "
"azules/rojos que ven los miembros."

#: apps/sso/scopes.py
msgid ""
"List the corp's Ansiblex jump bridges and cyno beacons to auto-build the "
"jump map and route planner."
msgstr ""
"Lista los Ansiblex jump bridges y las balizas de cyno de la corp para "
"construir automáticamente el mapa de saltos y el planificador de rutas."

#: apps/sso/scopes.py
msgid "Director or Station Manager"
msgstr "Director o Station Manager"

#: apps/sso/scopes.py
msgid "Structure monitoring"
msgstr "Monitorización de estructuras"

#: apps/sso/scopes.py
msgid ""
"Monitor every corp structure — fuel remaining, online/low-power state and "
"reinforcement timers — so nothing runs dry or comes out of reinforcement "
"unwatched."
msgstr ""
"Monitoriza todas las estructuras de la corp — combustible restante, estado "
"online/low-power y timers de refuerzo — para que ninguna se quede sin "
"combustible ni salga de refuerzo sin vigilancia."

#: apps/sso/scopes.py templates/corporation/extractions.html
msgid "Moon extractions"
msgstr "Extracciones de lunas"

#: apps/sso/scopes.py
msgid "Import scheduled moon extractions for the extraction calendar."
msgstr ""
"Importa las extracciones lunares programadas para el calendario de "
"extracciones."

#: apps/sso/scopes.py
msgid "Station Manager or Director"
msgstr "Station Manager o Director"

#: apps/sso/scopes.py
msgid "Corp blueprints + jobs"
msgstr "Blueprints + trabajos de la corp"

#: apps/sso/scopes.py
msgid ""
"Import the corp's owned blueprints (ME/TE) and running industry jobs so "
"blueprint coverage and build-or-buy reflect what the corp actually owns and "
"has in production."
msgstr ""
"Importa los blueprints que posee la corp (ME/TE) y los trabajos de industria "
"en curso, para que la cobertura de blueprints y el fabricar-o-comprar "
"reflejen lo que la corp realmente tiene y está produciendo."

#: apps/sso/scopes.py
msgid "Director or Factory Manager"
msgstr "Director o Factory Manager"

#: apps/sso/scopes.py
msgid "Notification relay"
msgstr "Retransmisión de notificaciones"

#: apps/sso/scopes.py
msgid ""
"Relay in-game notifications — structure attacks, war declarations, "
"sovereignty and moon pops — to the site and Discord."
msgstr ""
"Retransmite al sitio y a Discord las notificaciones del juego: ataques a "
"estructuras, declaraciones de guerra, soberanía y detonaciones de lunas."

#: apps/sso/scopes.py
msgid "Director or role-holder"
msgstr "Director o titular del rol"

#: apps/sso/scopes.py
msgid "Mail relay"
msgstr "Retransmisión de correo"

#: apps/sso/scopes.py
msgid ""
"Relay your corp/alliance mailing-list mail to Discord, so announcements "
"reach members who don't check in-game mail. Grant from the character "
"subscribed to the lists."
msgstr ""
"Retransmite a Discord el correo de las listas de la corp/alianza, para que "
"los anuncios lleguen a los miembros que no revisan el correo del juego. "
"Concédelo desde el personaje suscrito a las listas."

#: apps/sso/scopes.py
msgid "Readiness mail sender"
msgstr "Remitente del correo de preparación"

#: apps/sso/scopes.py
msgid ""
"Let the platform send readiness alert e-mails in-game from this character. "
"Grant from the director you select as the readiness mail sender on the Admin "
"Console → Readiness → Alerts page."
msgstr ""
"Permite que la plataforma envíe EVE-mails de alerta de preparación desde "
"este personaje. Concédelo desde el director que elijas como remitente del "
"correo de preparación en la página Consola de administración → Preparación → "
"Alertas."

#: apps/sso/scopes.py
msgid "Pingboard mail sender"
msgstr "Remitente del correo de Pingboard"

#: apps/sso/scopes.py
msgid ""
"Let Pingboard send corp alerts in-game from this character. Grant from the "
"director you select as the Pingboard EVE-mail sender on the Admin Console → "
"Pingboard → Channels page."
msgstr ""
"Permite que Pingboard envíe alertas de la corp dentro del juego desde este "
"personaje. Concédelo desde el director que elijas como remitente de EVE-mail "
"de Pingboard en la página Consola de administración → Pingboard → Canales."

#: apps/sso/scopes.py
msgid "Fleet tracking"
msgstr "Seguimiento de flota"

#: apps/sso/scopes.py
msgid ""
"Let an FC pull the live fleet roster to auto-record everyone's participation "
"(PAP) for an operation — no manual sign-in. Grant from the character that "
"boss-fleets."
msgstr ""
"Permite que un FC obtenga la lista en vivo de la flota para registrar "
"automáticamente la participación (PAP) de todos en una operación, sin "
"fichaje manual. Concédelo desde el personaje que hace de boss de la flota."

#: apps/sso/scopes.py
msgid "Mentorship session check-in"
msgstr "Registro de asistencia a la sesión de mentoría"

#: apps/sso/scopes.py
msgid ""
"Optional: let the Mentorship Program confirm you were online and in the "
"session's system during a scheduled mentoring session — the only way to "
"corroborate 'we flew together', since EVE keeps no history of it. Off by "
"default, polled only during a session you booked, and never stored beyond "
"the check."
msgstr ""
"Opcional: permite que el Programa de mentoría confirme que estabas conectado "
"y en el sistema de la sesión durante una sesión de mentoría programada; es "
"la única forma de corroborar el “volamos juntos”, ya que EVE no guarda "
"historial de ello. Desactivado por defecto, se consulta solo durante una "
"sesión que hayas reservado y nunca se almacena más allá de la comprobación."

#: apps/sso/scopes.py templates/admin_audit/console/import_fits.html
msgid "Import saved fits"
msgstr "Importar fits guardados"

#: apps/sso/scopes.py
msgid ""
"Read your own saved ship fittings so you can import them as corp doctrines "
"(ESI has no corp-fittings endpoint, so doctrines are seeded from a "
"director's personal fits)."
msgstr ""
"Lee tus propios fittings de nave guardados para que puedas importarlos como "
"doctrines de la corp (ESI no tiene un endpoint de fittings de corp, así que "
"las doctrines se siembran a partir de los fits personales de un director)."

#: apps/sso/scopes.py
msgid "Import PI colonies"
msgstr "Importar colonias de PI"

#: apps/sso/scopes.py
msgid ""
"Optional: let the Planetary Industry planner import your live colonies so it "
"can show your real layouts, flag issues (idle extractors, missing routes) "
"and estimate your current output. EVE only refreshes this when you open the "
"colony in the client, so imports can be stale — the planner always says when."
msgstr ""
"Opcional: permite que el planificador de industria planetaria importe tus "
"colonias en vivo para mostrar tus diseños reales, señalar problemas "
"(extractores parados, rutas ausentes) y estimar tu producción actual. EVE "
"solo actualiza estos datos cuando abres la colonia en el cliente, así que "
"las importaciones pueden estar desactualizadas; el planificador siempre te "
"indica cuándo."

#: apps/sso/views.py
msgid "Not available while viewing as another pilot."
msgstr "No disponible mientras ves como otro piloto."

#: apps/sso/views.py
#, python-format
msgid "SSO error: %(error)s"
msgstr "Error de SSO: %(error)s"

#: apps/sso/views.py
msgid "Invalid OAuth state."
msgstr "Estado de OAuth no válido."

#: apps/sso/views.py
msgid "Missing authorization code."
msgstr "Falta el código de autorización."

#: apps/sso/views.py
msgid "Authentication failed."
msgstr "La autenticación falló."

#: apps/sso/views.py
msgid "This EVE character is already linked to another account."
msgstr "Este personaje de EVE ya está vinculado a otra cuenta."

#: apps/sso/views.py
msgid ""
"This EVE character's ownership has changed since it was linked. For security "
"it cannot sign in until an officer detaches it."
msgstr ""
"La propiedad de este personaje de EVE ha cambiado desde que se vinculó. Por "
"seguridad no puede iniciar sesión hasta que un oficial lo desvincule."

#: apps/sso/views.py
msgid "This pilot-linking request is no longer valid. Please start again."
msgstr ""
"Esta solicitud de vinculación de piloto ya no es válida. Vuelve a empezar."

#: apps/sso/views.py
#, python-format
msgid ""
"%(pilot)s is already linked to a different FORCA Command Grid account. An "
"officer must detach it before it can be linked here."
msgstr ""
"%(pilot)s ya está vinculado a otra cuenta de FORCA Command Grid. Un oficial "
"debe desvincularlo antes de que pueda vincularse aquí."

#: apps/sso/views.py
msgid ""
"This pilot's EVE ownership has changed since it was linked. For security an "
"officer must detach it before it can be used again."
msgstr ""
"La propiedad de este piloto en EVE ha cambiado desde que se vinculó. Por "
"seguridad, un oficial debe desvincularlo antes de que pueda volver a usarse."

#: apps/sso/views.py
#, python-format
msgid "%(pilot)s has been reauthorised."
msgstr "%(pilot)s ha sido reautorizado."

#: apps/sso/views.py
#, python-format
msgid "%(pilot)s is now linked to your account."
msgstr "%(pilot)s ahora está vinculado a tu cuenta."

#: apps/sso/views.py
#, python-format
msgid ""
"You authorised %(pilot)s, which is not the pilot you selected. That pilot is "
"now linked; the pilot you meant to reauthorise still needs attention."
msgstr ""
"Autorizaste a %(pilot)s, que no es el piloto que seleccionaste. Ese piloto "
"ha quedado vinculado; el piloto que querías reautorizar sigue necesitando "
"atención."

#: apps/sso/views.py
msgid "Could not re-check your access just now — try again shortly."
msgstr ""
"No se pudo volver a comprobar tu acceso ahora mismo — inténtalo de nuevo en "
"breve."

#: apps/sso/views.py
msgid "A full CCP re-check is running in the background."
msgstr ""
"Se está ejecutando en segundo plano una recomprobación completa con CCP."

#: apps/sso/views.py
#, python-format
msgid ""
"%(n)d scope(s) are no longer granted and have been marked inactive.%(deep)s"
msgstr ""
"Ya no se conceden %(n)d scope(s) y se han marcado como inactivos.%(deep)s"

#: apps/sso/views.py
#, python-format
msgid "%(n)d scope(s) reconciled.%(deep)s"
msgstr "%(n)d scope(s) reconciliados.%(deep)s"

#: apps/sso/views.py
#, python-format
msgid "Your access is in sync.%(deep)s"
msgstr "Tu acceso está sincronizado.%(deep)s"

#: apps/sso/views.py
msgid "Not your character."
msgstr "No es tu personaje."

#: apps/stockpile/assets.py
msgid ""
"No Director has granted corp-asset access yet. A CEO/Director must re-"
"authorise with the corp-assets scope."
msgstr ""
"Ningún Director ha concedido acceso a los activos de la corp todavía. Un CEO/"
"Director debe volver a autorizar con el scope corp-assets."

#: apps/stockpile/assets.py
#, python-format
msgid "Could not read corp assets: %(error)s"
msgstr "No se pudieron leer los activos de la corp: %(error)s"

#: apps/stockpile/assets.py
#, python-format
msgid ""
"Imported %(types)s asset stacks across %(locations)s locations from "
"%(character)s."
msgstr ""
"Importadas %(types)s pilas de activos en %(locations)s ubicaciones desde "
"%(character)s."

#: apps/stockpile/assets.py
msgid "Grant personal-asset access first (ESI Scopes → Track my assets)."
msgstr ""
"Concede primero acceso a los activos personales (ESI Scopes → Track my "
"assets)."

#: apps/stockpile/assets.py
#, python-format
msgid "Could not read your assets: %(error)s"
msgstr "No se pudieron leer tus activos: %(error)s"

#: apps/stockpile/assets.py
#, python-format
msgid "Imported %(types)s asset stacks across %(locations)s locations."
msgstr "Importadas %(types)s pilas de activos en %(locations)s ubicaciones."

#: apps/stockpile/assets.py templates/stockpile/assets.html
msgid "Unknown location"
msgstr "Ubicación desconocida"

#: apps/stockpile/assets.py
#, python-format
