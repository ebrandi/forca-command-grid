#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Director — Eyes Only"
msgstr "Director — Solo para sus ojos"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Alliance Command"
msgstr "Mando de la alianza"

#: apps/admin_audit/console_command_intel.py
msgid "Notification & delivery settings saved."
msgstr "Ajustes de notificación y entrega guardados."

#: apps/admin_audit/console_command_intel.py
msgid "Autonomous proposal settings saved."
msgstr "Ajustes de propuestas autónomas guardados."

#: apps/admin_audit/console_command_intel.py
msgid "Auto-AAR settings saved."
msgstr "Ajustes de Auto-AAR guardados."

#: apps/admin_audit/console_comms_access.py
msgid "Discord credentials saved."
msgstr "Credenciales de Discord guardadas."

#: apps/admin_audit/console_comms_access.py
