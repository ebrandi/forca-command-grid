msgstr "Ajustes de proveedor y modelo guardados."

#: apps/admin_audit/console_command_intel.py
msgid "Critical ratio"
msgstr "Ratio crítico"

#: apps/admin_audit/console_command_intel.py
msgid "Headroom/demand at or below this colours a constraint critical."
msgstr ""
"Un margen/demanda igual o por debajo de este valor colorea una restricción "
"como crítica."

#: apps/admin_audit/console_command_intel.py
msgid "High ratio"
msgstr "Ratio alto"

#: apps/admin_audit/console_command_intel.py
msgid "Above critical, at or below this colours it high."
msgstr ""
"Por encima de crítico, igual o por debajo de este valor lo colorea como alto."

#: apps/admin_audit/console_command_intel.py
msgid "Watch ratio"
msgstr "Ratio de vigilancia"

#: apps/admin_audit/console_command_intel.py
msgid "Above high, at or below this colours it watch."
msgstr ""
"Por encima de alto, igual o por debajo de este valor lo colorea como "
"vigilancia."

