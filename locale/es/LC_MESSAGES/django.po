#: apps/navigation/jump_service.py
#, python-format
msgid "System %(id)s"
msgstr "Sistema %(id)s"

#: apps/navigation/jump_service.py
#, python-format
msgid "%(count)s low/null system(s) on the gate leg: %(systems)s"
msgstr "%(count)s sistema(s) low/null en el tramo por gate: %(systems)s"

#: apps/navigation/jump_service.py
#, python-format
msgid "(%(origin)s and %(dest)s are high-sec.)"
msgstr "(%(origin)s y %(dest)s son high-sec.)"

#: apps/navigation/jump_service.py
#, python-format
msgid "(%(system)s is high-sec.)"
msgstr "(%(system)s es high-sec.)"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Waypoint %(systems)s is high-sec — a cyno can't be lit there. Waypoints must "
"be low-sec or null-sec."
msgstr ""
"El punto de ruta %(systems)s es high-sec — allí no se puede encender un "
"cyno. Los puntos de ruta deben ser low-sec o null-sec."

#: apps/navigation/jump_service.py
msgid ""
"No jump route within range — try a longer-range hull/JDC, fewer avoided "
"systems/waypoints, or drop ‘dockable only’."
msgstr ""
"No hay ruta de salto dentro de alcance — prueba con un casco/JDC de mayor "
"alcance, con menos sistemas/puntos de ruta evitados, o desactiva ‘solo "
"acoplables’."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"No low-sec exit near %(dest)s is reachable by jump from %(origin)s. Try a "
"longer-range hull/JDC, a different origin, or add a waypoint."
msgstr ""
"Ninguna salida en low-sec cerca de %(dest)s es alcanzable por salto desde "
"%(origin)s. Prueba con un casco/JDC de mayor alcance, con otro origen, o "
"añade un punto de ruta."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"No low-sec exit near %(dest)s is reachable by jump from %(origin)s with "
"these filters. Try a longer-range hull/JDC, fewer avoided systems/waypoints, "
"or dropping ‘dockable only’."
msgstr ""
"No hay ninguna salida low-sec cerca de %(dest)s alcanzable por salto desde "
"%(origin)s con estos filtros. Prueba con un casco/JDC de mayor alcance, con "
"menos sistemas/puntos de ruta evitados, o desactiva ‘solo acoplables’."

#: apps/navigation/jump_service.py
#, python-format
msgid "Jump: %(origin)s → %(exit)s (low-sec exit)"
msgstr "Salto: %(origin)s → %(exit)s (salida low-sec)"

#: apps/navigation/jump_service.py
#, python-format
msgid "Gate: %(exit)s → %(dest)s (high-sec destination)"
msgstr "Gate: %(exit)s → %(dest)s (destino high-sec)"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"%(exit)s (%(security)s) is your low-sec exit — light a cyno or use a beacon "
"there, then take %(jumps)s gate(s) to %(dest)s."
msgstr ""
"%(exit)s (%(security)s) es tu salida low-sec — enciende un cyno o usa un "
"beacon allí, y luego haz %(jumps)s salto(s) por gate hasta %(dest)s."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"No low-sec staging system near %(origin)s can jump to %(dest)s. Try a longer-"
"range hull/JDC or a different destination."
msgstr ""
"Ningún sistema de staging low-sec cerca de %(origin)s puede saltar a "
"%(dest)s. Prueba con un casco/JDC de mayor alcance o con otro destino."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"No low-sec staging system near %(origin)s can jump to %(dest)s with these "
"filters. Try a longer-range hull/JDC, fewer avoided systems/waypoints, or "
"dropping ‘dockable only’."
msgstr ""
"Ningún sistema de staging low-sec cerca de %(origin)s puede saltar a "
"%(dest)s con estos filtros. Prueba con un casco/JDC de mayor alcance, con "
"menos sistemas/puntos de ruta evitados, o desactiva ‘solo acoplables’."

#: apps/navigation/jump_service.py
#, python-format
msgid "Gate: %(origin)s (high-sec) → %(entry)s"
msgstr "Gate: %(origin)s (high-sec) → %(entry)s"

#: apps/navigation/jump_service.py
#, python-format
msgid "Jump: %(entry)s → %(dest)s"
msgstr "Salto: %(entry)s → %(dest)s"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Gate out of %(origin)s to %(entry)s (%(security)s), light a cyno there, then "
"jump."
msgstr ""
"Sal por gate de %(origin)s hacia %(entry)s (%(security)s), enciende un cyno "
"allí y luego salta."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Couldn't find a low-sec entry near %(origin)s that can jump to a low-sec "
"exit near %(dest)s. The high-sec pockets may be too far apart for this "
"hull's range."
msgstr ""
"No se encontró una entrada low-sec cerca de %(origin)s que pueda saltar a "
"una salida low-sec cerca de %(dest)s. Puede que las bolsas de high-sec estén "
"demasiado separadas para el alcance de este casco."

#: apps/navigation/jump_service.py
msgid "No jump route between the chosen entry and exit systems."
msgstr "No hay ruta de salto entre los sistemas de entrada y salida elegidos."

#: apps/navigation/jump_service.py
#, python-format
msgid "Jump: %(entry)s → %(exit)s"
msgstr "Salto: %(entry)s → %(exit)s"

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Two gate legs: out of %(origin)s to %(entry)s, and from %(exit)s into "
"%(dest)s. Fuel covers the jump between them only."
msgstr ""
"Dos tramos por gate: de %(origin)s a %(entry)s, y de %(exit)s a %(dest)s. El "
"combustible cubre solo el salto entre ambos."

#: apps/navigation/jump_service.py
#, python-format
msgid ""
"Range %(range)s ly (%(ship)s, base %(base)s ly × JDC %(jdc)s). JDC affects "
"range only."
msgstr ""
"Alcance %(range)s ly (%(ship)s, base %(base)s ly × JDC %(jdc)s). JDC solo "
"afecta al alcance."

#: apps/navigation/jump_service.py
#, python-format
msgid "Fuel %(base)s %(isotope)s/ly base, −10%%/level JFC (JFC %(jfc)s)."
msgstr ""
"Combustible %(base)s %(isotope)s/ly base, −10%%/nivel de JFC (JFC %(jfc)s)."

#: apps/navigation/jump_service.py
#, python-format
msgid "Jump Freighters skill saves a further −10%%/level (JF %(jf)s)."
msgstr "La habilidad Jump Freighters ahorra otro −10%%/nivel (JF %(jf)s)."

#: apps/navigation/jump_service.py
#, python-format
msgid "%(rigs)s× Jump Drive Economizer rig fitted."
msgstr "%(rigs)s× rig Jump Drive Economizer montado."

#: apps/navigation/jump_service.py
msgid ""
"Fuel is rounded up per jump (never under-fuel) and covers jump legs only — "
"gate legs burn no isotopes."
msgstr ""
"El combustible se redondea hacia arriba en cada salto (nunca se queda corto) "
"y cubre solo los tramos de salto — los tramos por gate no consumen isótopos."

#: apps/navigation/jump_service.py
#, python-format
msgid "Includes a %(pct)s%% fuel safety margin."
msgstr "Incluye un margen de seguridad de combustible del %(pct)s%%."

#: apps/navigation/jump_service.py
msgid "No market price for the fuel isotope — ISK cost unavailable."
msgstr ""
"Sin precio de mercado para el isótopo de combustible — coste en ISK no "
"disponible."

