msgstr "Sección de ajustes desconocida."

#: apps/admin_audit/console_comms_access.py
msgid "Settings saved."
msgstr "Ajustes guardados."

#: apps/admin_audit/console_comms_access.py
msgid "Platform, entitlement and target are required."
msgstr "La plataforma, el derecho y el destino son obligatorios."

#: apps/admin_audit/console_comms_access.py
msgid "A mapping for that platform + entitlement + target already exists."
msgstr "Ya existe una asignación para esa plataforma + derecho + destino."

