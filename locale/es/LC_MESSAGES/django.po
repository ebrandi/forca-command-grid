msgstr "Jump bridge eliminado."

#: apps/navigation/views.py
msgid "Pick both systems from the list."
msgstr "Elige ambos sistemas de la lista."

#: apps/navigation/views.py
msgid "The jump planner is currently disabled by leadership."
msgstr ""
"El planificador de saltos está desactivado por el liderazgo ahora mismo."

#: apps/navigation/views.py
msgid "That system has no coordinates."
msgstr "Ese sistema no tiene coordenadas."

#: apps/navigation/views.py
msgid "Saved routes are turned off."
msgstr "Las rutas guardadas están desactivadas."

#: apps/navigation/views.py
msgid "Plan a route first, then save it."
msgstr "Planifica una ruta primero y luego guárdala."

#: apps/navigation/views.py
#, python-format
msgid "Saved route “%(name)s”."
msgstr "Ruta “%(name)s” guardada."

#: apps/navigation/views.py
