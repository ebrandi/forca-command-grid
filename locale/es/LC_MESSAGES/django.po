msgstr "La entrega estimada de {ship_name} es ahora {eta_date}."

#: apps/pingboard/messages.py
msgid "Order update: Stock reserved"
msgstr "Pedido actualizado: Stock reservado"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"{quantity}× {ship_name} from a new delivery is now reserved for your order."
msgstr ""
"Se ha reservado para tu pedido {quantity}× {ship_name} de una nueva entrega."

#: apps/pingboard/messages.py
msgid "Order update: Reservation released"
msgstr "Pedido actualizado: Reserva liberada"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Your reserved {ship_name} was released after waiting unclaimed; the order is "
"now backordered."
msgstr ""
"Tu {ship_name} reservado se liberó tras esperar sin ser reclamado; el pedido "
"ha pasado a encargo."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Back in stock: {ship_name}"
msgstr "De nuevo en stock: {ship_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "{ship_name} can be ordered on the Shipyard again."
msgstr "{ship_name} ya se puede volver a pedir en el Astillero."

#: apps/pingboard/messages.py
msgid "Shipyard restock built"
msgstr "Reposición del Astillero fabricada"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Production for {fit_name} finished. Assemble and fit the ships, then record "
"the receipt on the Shipyard inventory console to release waiting backorders."
msgstr ""
"La producción de {fit_name} ha terminado. Ensambla las naves y aplícales el "
"fit, y luego registra la recepción en la consola de inventario del Astillero "
"para liberar los encargos en espera."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Re-authorise {character_name}: corp data ingestion stopped"
msgstr ""
"Reautoriza {character_name}: la ingesta de datos de la corp se ha detenido"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"The ESI token for {character_name} that authorises corp data ingestion "
"({scopes}) has stopped working — it was revoked or failed to refresh past "
"the retry limit. Re-authorise it on the ESI scopes page (/auth/scopes/) to "
"resume ingestion; corp {scopes} pages will show stale data until then."
msgstr ""
"El token ESI de {character_name} que autoriza la ingesta de datos de la corp "
"({scopes}) ha dejado de funcionar: fue revocado o no pudo renovarse tras "
"agotar los reintentos. Reautorízalo en la página de scopes ESI (/auth/"
"scopes/) para reanudar la ingesta; hasta entonces, las páginas de {scopes} "
"de la corp mostrarán datos desactualizados."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Your skill queue is empty — {character_name}"
msgstr "Tu cola de entrenamiento está vacía — {character_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"{character_name}'s training queue has run dry, so it's not earning SP. Queue "
"your next skills in the EVE client (the Skills page has a plan you can paste "
"in). This is based on the last skill sync, so ignore it if you just queued "
"something."
msgstr ""
"La cola de entrenamiento de {character_name} se ha vaciado, así que no está "
"generando SP. Encola tus próximas habilidades en el cliente de EVE (la "
"página de Habilidades tiene un plan que puedes pegar). Esto se basa en la "
"última sincronización de habilidades, así que ignóralo si acabas de encolar "
"algo."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Milestone reached: «{milestone_title}»"
msgstr "Hito alcanzado: «{milestone_title}»"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Milestone «{milestone_title}» on your goal «{goal_title}» is done. {link}"
msgstr ""
"El hito «{milestone_title}» de tu objetivo «{goal_title}» está completado. "
"{link}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Goal completed: «{goal_title}»"
msgstr "Objetivo completado: «{goal_title}»"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "You completed your career goal «{goal_title}». {link}"
msgstr "Has completado tu objetivo de carrera «{goal_title}». {link}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Review nudge: «{goal_title}»"
msgstr "Recordatorio de revisión: «{goal_title}»"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"It's been a while since you looked at «{goal_title}» ({review_month}). A two-"
"minute review keeps the plan honest — nothing changes if you don't. {link}"
msgstr ""
"Hace tiempo que no miras «{goal_title}» ({review_month}). Una revisión de "
"dos minutos mantiene el plan honesto: si no lo haces, nada cambia. {link}"

#: apps/pingboard/messages.py
msgid "New Capsuleer Path suggestions"
msgstr "Nuevas sugerencias de Capsuleer Path"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"You have {count} new Capsuleer Path suggestion waiting. Open your path to "
"see them. {link}"
msgstr ""
"Tienes {count} sugerencia nueva de Capsuleer Path esperando. Abre tu "
"Capsuleer Path para verla. {link}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"You have {count} new Capsuleer Path suggestions waiting. Open your path to "
"see them. {link}"
msgstr ""
"Tienes {count} sugerencias nuevas de Capsuleer Path esperando. Abre tu "
"Capsuleer Path para verlas. {link}"

#: apps/pingboard/messages.py
msgid "PI colony needs attention"
msgstr "Una colonia PI requiere atención"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Your PI colony on a {planet_type} in {system_name} needs attention: {details}"
msgstr ""
"Tu colonia PI en un planeta {planet_type} de {system_name} requiere "
"atención: {details}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Route watch: {route_name}"
msgstr "Vigilancia de ruta: {route_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"⚠ Route **{route_name}** ({origin_system} → {destination_system}) — "
"{threat_count} watched system(s) flagged (endpoints & waypoints only):\n"
"{details}\n"
"Risk indicator, not a guarantee — this doesn't cover every gate hop. Scout "
"before you undock."
msgstr ""
"⚠ Ruta **{route_name}** ({origin_system} → {destination_system}): "
"{threat_count} sistema(s) vigilado(s) marcado(s) (solo extremos y "
"waypoints):\n"
"{details}\n"
"Es un indicador de riesgo, no una garantía: no cubre todos los saltos de "
"puerta. Manda un scout antes de desatracar."

#: apps/pingboard/messages.py
msgid "Haul deadline approaching"
msgstr "Se acerca la fecha límite del transporte"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Your haul {origin_system} → {destination_system} is due in about {minutes} "
"min. Deliver it and mark the contract complete to get paid."
msgstr ""
"Tu transporte {origin_system} → {destination_system} vence en unos {minutes} "
"min. Entrégalo y marca el contrato como completado para cobrar."

#: apps/pingboard/messages.py
msgid "Haul overdue — released to the pool"
msgstr "Transporte vencido: devuelto a la bolsa común"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"The haul {origin_system} → {destination_system} passed its deadline and was "
"returned to the pool for another hauler."
msgstr ""
"El transporte {origin_system} → {destination_system} superó su fecha límite "
"y se devolvió a la bolsa común para otro transportista."

#: apps/pingboard/messages.py
msgid "Your haul was released"
msgstr "Tu transporte se ha devuelto a la bolsa común"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Your haul {origin_system} → {destination_system} passed its deadline and was "
"released back to the pool."
msgstr ""
"Tu transporte {origin_system} → {destination_system} superó su fecha límite "
"y se devolvió a la bolsa común."

#: apps/pingboard/messages.py
msgid "Moon chunk arriving soon"
msgstr "El fragmento lunar llega pronto"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"The moon chunk at {structure_name} is ready to fracture in about {hours}h — "
"form up to mine it before it decays."
msgstr ""
"El fragmento lunar en {structure_name} estará listo para fracturar en unas "
"{hours} h: monta una flota para minarlo antes de que se degrade."

#: apps/pingboard/messages.py
msgid "Corp infrastructure alert"
msgstr "Alerta de infraestructura de la corp"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Corp infrastructure needs attention:\n"
"\n"
"{details}\n"
"\n"
"Refuel the low structures and shore up the soft-ADM systems. This digest "
"fires once per distinct set and resets when everything is back above "
"threshold."
msgstr ""
"La infraestructura de la corp requiere atención:\n"
"\n"
"{details}\n"
"\n"
"Reposta las estructuras con poco combustible y refuerza los sistemas con ADM "
"bajo. Este resumen se envía una vez por cada conjunto distinto y se reinicia "
"cuando todo vuelve a estar por encima del umbral."

#: apps/pingboard/messages.py
msgid "SRP needs attention"
msgstr "El SRP requiere atención"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"SRP is breaching its service level:\n"
"\n"
"{details}\n"
"\n"
"Review the SRP queue and clear/decide the oldest claims. This digest fires "
"once per distinct breach set and resets when SRP is back within SLA."
msgstr ""
"El SRP está incumpliendo su nivel de servicio:\n"
"\n"
"{details}\n"
"\n"
"Revisa la cola de SRP y resuelve las solicitudes más antiguas. Este resumen "
"se envía una vez por cada conjunto distinto de incumplimientos y se reinicia "
"cuando el SRP vuelve a estar dentro del SLA."

#: apps/pingboard/messages.py
msgid "Integration health degraded"
msgstr "Estado de las integraciones degradado"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"FORCA integration health has degraded:\n"
"\n"
"{details}\n"
"\n"
"Open the Admin Console → Health page for the full picture. This alert fires "
"once per distinct problem set and resets automatically once healthy."
msgstr ""
"El estado de las integraciones de FORCA se ha degradado:\n"
"\n"
"{details}\n"
"\n"
"Abre la Consola de administración → Estado para ver el panorama completo. "
"Esta alerta se envía una vez por cada conjunto distinto de problemas y se "
"reinicia automáticamente al recuperarse."

#: apps/pingboard/messages.py
msgid "Role grant awaiting approval"
msgstr "Concesión de rol pendiente de aprobación"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"{actor_name} requested a {role_name} grant for {pilot_name}. A different "
"director must approve it in the Members console."
msgstr ""
"{actor_name} ha solicitado conceder el rol {role_name} a {pilot_name}. Debe "
"aprobarlo otro director distinto en la consola de Miembros."

#: apps/pingboard/messages.py
msgid "Mentorship pairing"
msgstr "Emparejamiento de mentoría"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"{mentee_name} has requested you as their mentor. Respond on your mentorship "
"dashboard."
msgstr ""
"{mentee_name} te ha solicitado como mentor. Responde en tu panel de mentoría."

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
