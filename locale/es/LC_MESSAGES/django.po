msgstr "Las alertas %(priority)s requieren el rol %(role)s."

#: apps/pingboard/services.py
#, python-format
msgid "Corp-wide announcements require the %(role)s role."
msgstr "Los anuncios a toda la corporación requieren el rol %(role)s."

#: apps/pingboard/services.py
msgid "Urgent and emergency alerts require a reason."
msgstr "Las alertas urgentes y de emergencia requieren un motivo."

#: apps/pingboard/services.py
msgid "Urgent/emergency alerts require two-step confirmation."
msgstr ""
"Las alertas urgentes/de emergencia requieren confirmación en dos pasos."

#: apps/pingboard/services.py
#, python-format
msgid ""
"This alert reaches %(count)s pilots; large-audience confirmation is required."
msgstr ""
"Esta alerta llega a %(count)s pilotos; se requiere la confirmación de "
"audiencia amplia."

#: apps/pingboard/services.py
#, python-format
msgid "Missing required template variables: %(variables)s"
msgstr "Faltan variables de plantilla obligatorias: %(variables)s"

#: apps/pingboard/views.py
