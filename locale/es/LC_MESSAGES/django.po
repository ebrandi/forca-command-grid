#: apps/planetary/static_data.py
msgid "The all-rounder. Great first planet."
msgstr "El todoterreno. Un gran primer planeta."

#: apps/planetary/static_data.py
msgid ""
"Balanced and forgiving — food, industrial and electronics feedstock. If "
"you're new, start here."
msgstr ""
"Equilibrado e indulgente — materia prima para alimentos, industria y "
"electrónica. Si eres nuevo, empieza aquí."

#: apps/planetary/static_data.py
msgid "Robotics & electronics feedstock."
msgstr "Materia prima para robótica y electrónica."

#: apps/planetary/static_data.py
msgid ""
"Reliable all-rounder rich in metals and organics. Backbone of most "
"electronics and robotics chains."
msgstr ""
"Todoterreno fiable rico en metales y orgánicos. La columna vertebral de la "
"mayoría de cadenas de electrónica y robótica."

#: apps/planetary/static_data.py
msgid "Construction metals & heavy industry."
msgstr "Metales de construcción e industria pesada."

#: apps/planetary/static_data.py
msgid ""
"Metals and magma — the source of construction materials and many high-end "
"refined commodities."
msgstr ""
"Metales y magma — la fuente de materiales de construcción y muchos productos "
"refinados de gama alta."

#: apps/planetary/static_data.py
msgid "High-end electronics & metals."
msgstr "Electrónica y metales de gama alta."

#: apps/planetary/static_data.py
msgid ""
"Harsh but valuable: heavy metals and non-CS crystals that feed advanced "
"electronics and superconductors."
msgstr ""
"Duro pero valioso: metales pesados y cristales no-CS que alimentan la "
"electrónica avanzada y los superconductores."

#: apps/planetary/static_data.py
msgid "Coolant, life-support & fuels."
msgstr "Refrigerante, soporte vital y combustibles."

#: apps/planetary/static_data.py
msgid ""
"Cold storage of gases, water and microorganisms — coolant, oxygen and "
"biotech chains start here."
msgstr ""
"Almacenamiento en frío de gases, agua y microorganismos — las cadenas de "
"refrigerante, oxígeno y biotecnología empiezan aquí."

#: apps/planetary/static_data.py
msgid "Fuels, oxidisers & industrials."
msgstr "Combustibles, oxidantes & industriales."

#: apps/planetary/static_data.py
msgid ""
"The only source of Reactive Gas. Gas planets drive oxidising compounds, "
"oxygen and fuel chains."
msgstr ""
"La única fuente de Reactive Gas. Los planetas gaseosos impulsan compuestos "
"oxidantes, oxígeno y cadenas de combustible."

#: apps/planetary/static_data.py
msgid "Biotech & strong food chains."
msgstr "Biotecnología & cadenas alimentarias sólidas."

#: apps/planetary/static_data.py
msgid ""
"Water-rich and organic — the best planet for biomass, proteins and the "
"biotech P3/P4 lines."
msgstr ""
"Rico en agua y orgánico — el mejor planeta para biomasa, proteínas y las "
"líneas biotecnológicas P3/P4."

#: apps/planetary/static_data.py
msgid "Electronics feedstock (plasmoids)."
msgstr "Materia prima para electrónica (plasmoids)."

#: apps/planetary/static_data.py
msgid ""
"Electrically charged: plasmoids, ionic solutions and noble gas for the "
"electronics and superconductor chains."
msgstr ""
"Cargado eléctricamente: plasmoids, ionic solutions y noble gas para las "
"cadenas de electrónica y superconductores."

#: apps/planetary/static_data.py
msgid "Extraction planet"
msgstr "Planeta de extracción"

#: apps/planetary/static_data.py
msgid ""
"Pull one or two raw P0 resources and refine them on-site into P1 (or "
"straight P2 if you have the feedstock)."
msgstr ""
"Extrae uno o dos recursos brutos P0 y refínalos allí mismo hasta P1 (o "
"directamente a P2 si tienes los insumos)."

#: apps/planetary/static_data.py
msgid "1× Command Center (sets your power/CPU budget — upgrade it fully)."
msgstr ""
"1× Command Center (define tu presupuesto de energía/CPU: mejóralo al máximo)."

#: apps/planetary/static_data.py
msgid ""
"1× Extractor Control Unit per resource, with as many extractor heads as CPU/"
"PG allows (more heads = more yield, but shorter reach)."
msgstr ""
"1× Extractor Control Unit por recurso, con tantos cabezales extractores como "
"permita la CPU/PG (más cabezales = más rendimiento, pero menos alcance)."

#: apps/planetary/static_data.py
msgid ""
"Basic Industry Facilities to convert P0 → P1 (each does 3,000 P0 → 20 P1 "
"every 30 min)."
msgstr ""
"Basic Industry Facilities para convertir P0 → P1 (cada una hace 3.000 P0 → "
"20 P1 cada 30 min)."

#: apps/planetary/static_data.py
msgid "1× Launchpad as the export point and buffer storage."
msgstr "1× Launchpad como punto de exportación y almacenamiento intermedio."

#: apps/planetary/static_data.py
msgid ""
"Route extractor output → storage/launchpad → factories → launchpad. Keep the "
"extracted P0 flowing into the BIFs and the finished P1 to the launchpad for "
"export."
msgstr ""
"Rutea la salida del extractor → almacenamiento/launchpad → fábricas → "
"launchpad. Mantén el P0 extraído fluyendo hacia las BIF y el P1 terminado "
"hacia el launchpad para exportarlo."

#: apps/planetary/static_data.py
msgid "Export P1 (or P2) via the customs office. Import nothing."
msgstr "Exporta P1 (o P2) por la aduana. No importes nada."

#: apps/planetary/static_data.py
msgid ""
"Import cheaper lower-tier materials and refine them up a tier. No extraction "
"— pure manufacturing throughput."
msgstr ""
"Importa materiales baratos de nivel inferior y refínalos un nivel más "
"arriba. Sin extracción: puro rendimiento de fabricación."

#: apps/planetary/static_data.py
msgid "1× Command Center (upgrade fully for CPU/PG)."
msgstr "1× Command Center (mejóralo al máximo para CPU/PG)."

#: apps/planetary/static_data.py
msgid "1× Launchpad to receive imports and hold exports."
msgstr ""
"1× Launchpad para recibir las importaciones y almacenar las exportaciones."

#: apps/planetary/static_data.py
msgid ""
"As many Advanced Industry Facilities as your power/CPU allows (each does "
"40+40 input → 5 output every hour for P2)."
msgstr ""
"Tantas Advanced Industry Facilities como permita tu energía/CPU (cada una "
"hace 40+40 de entrada → 5 de salida cada hora para P2)."

#: apps/planetary/static_data.py
msgid "Storage facilities to buffer inputs between imports."
msgstr ""
"Instalaciones de almacenamiento para amortiguar los insumos entre "
"importaciones."

#: apps/planetary/static_data.py
msgid ""
"Import inputs to the launchpad → route to each factory → route finished "
"goods back to the launchpad."
msgstr ""
"Importa los insumos al launchpad → rutéalos a cada fábrica → devuelve los "
"productos terminados al launchpad."

#: apps/planetary/static_data.py
msgid "Import the P1/P2 inputs; export the higher-tier product."
msgstr "Importa los insumos P1/P2; exporta el producto de nivel superior."

#: apps/planetary/static_data.py
msgid "Storage / staging planet"
msgstr "Planeta de almacenamiento / staging"

#: apps/planetary/static_data.py
msgid ""
"A buffer or consolidation point. Rare for most pilots — usually a launchpad "
"on another planet does the job."
msgstr ""
"Un punto de amortiguación o consolidación. Poco habitual para la mayoría de "
"pilotos: normalmente un launchpad en otro planeta ya cumple esa función."

#: apps/planetary/static_data.py
msgid "1× Command Center"
msgstr "1× Command Center"

#: apps/planetary/static_data.py
msgid "1× Launchpad"
msgstr "1× Launchpad"

#: apps/planetary/static_data.py
msgid "Storage facilities as needed."
msgstr "Instalaciones de almacenamiento según haga falta."

#: apps/planetary/static_data.py
msgid "Consolidate goods here before a single haul out."
msgstr "Consolida aquí las mercancías antes de un único transporte de salida."

#: apps/planetary/static_data.py
msgid "Export in bulk on your haul day."
msgstr "Exporta todo de golpe el día de transporte."

#: apps/planetary/static_data.py
msgid "Not upgrading the Command Center"
msgstr "No mejorar el Command Center"

#: apps/planetary/static_data.py
msgid ""
"Your Command Center level sets your entire CPU/PG budget. Upgrade it to "
"level 5 before you place facilities, or you'll run out of power halfway "
"through."
msgstr ""
"El nivel de tu Command Center define todo tu presupuesto de CPU/PG. Mejóralo "
"a nivel 5 antes de colocar instalaciones o te quedarás sin energía a medio "
"camino."

#: apps/planetary/static_data.py
msgid "Routing errors"
msgstr "Errores de rutas"

#: apps/planetary/static_data.py
msgid ""
"A facility with no inbound route sits idle; a route to the wrong storage "
"stalls the chain. Follow every product from extractor → factory → launchpad."
msgstr ""
"Una instalación sin ruta de entrada se queda parada; una ruta al "
"almacenamiento equivocado atasca la cadena. Sigue cada producto desde el "
"extractor → la fábrica → el launchpad."

#: apps/planetary/static_data.py
msgid "Too many extractor heads"
msgstr "Demasiados cabezales de extracción"

#: apps/planetary/static_data.py
msgid ""
"More heads raise yield but shorten the extraction radius and cost CPU/PG. "
"Balance heads against the program length you actually want to run."
msgstr ""
"Más cabezales aumentan el rendimiento, pero reducen el radio de extracción y "
"consumen CPU/PG. Equilibra los cabezales con la duración de programa que "
"realmente quieres ejecutar."

#: apps/planetary/static_data.py
msgid "Insufficient storage"
msgstr "Almacenamiento insuficiente"

#: apps/planetary/static_data.py
msgid ""
"If a launchpad or storage fills up, upstream facilities stop. Size storage "
"for the time between your resets."
msgstr ""
"Si un launchpad o un almacén se llena, las instalaciones anteriores se "
"detienen. Dimensiona el almacenamiento según el tiempo entre tus reinicios."

#: apps/planetary/static_data.py
msgid "Wrong schematic"
msgstr "Esquema incorrecto"

#: apps/planetary/static_data.py
msgid ""
"Setting a factory to the wrong schematic wastes materials. Double-check "
"inputs match what you're actually routing in."
msgstr ""
"Poner el esquema equivocado en una fábrica desperdicia materiales. Comprueba "
"que los insumos coincidan con lo que realmente estás enrutando."

#: apps/planetary/static_data.py
msgid "Overbuilding factories"
msgstr "Construir fábricas de más"

#: apps/planetary/static_data.py
msgid ""
"Ten factories starved of feedstock earn less than three that run "
"continuously. Match factory count to your extraction rate."
msgstr ""
"Diez fábricas sin materia prima rinden menos que tres funcionando sin parar. "
"Ajusta el número de fábricas a tu ritmo de extracción."

#: apps/planetary/static_data.py
msgid "Ignoring customs (POCO) tax"
msgstr "Ignorar el impuesto de aduana (POCO)"

#: apps/planetary/static_data.py
msgid ""
"Export/import tax at the customs office is charged on every launch. In "
"hostile space it can dwarf your margin — factor it in before you commit."
msgstr ""
"El impuesto de exportación/importación de la aduana se cobra en cada "
"lanzamiento. En espacio hostil puede superar de largo tu margen: tenlo en "
"cuenta antes de comprometerte."

#: apps/planetary/static_data.py
msgid "Train Command Center Upgrades to unlock the planet tiers you need."
msgstr ""
"Entrena la habilidad Command Center Upgrades para desbloquear los niveles de "
"planeta que necesitas."

#: apps/planetary/static_data.py
msgid "Buy and deploy a Command Center on each planet, then upgrade it fully."
msgstr ""
"Compra y despliega un Command Center en cada planeta y mejóralo al máximo."

#: apps/planetary/static_data.py
msgid "On extraction planets: place the ECU, add heads, and start a program."
msgstr ""
"En los planetas de extracción: coloca la ECU, añade cabezales e inicia un "
"programa."

#: apps/planetary/static_data.py
msgid "Place your factories and set the correct schematic on each."
msgstr "Coloca tus fábricas y asigna el esquema correcto a cada una."

#: apps/planetary/static_data.py
msgid "Wire the routes: extractor → storage → factory → launchpad."
msgstr "Conecta las rutas: extractor → almacenamiento → fábrica → launchpad."

#: apps/planetary/static_data.py
msgid "Confirm the customs office tax for your space and your standings."
msgstr "Confirma el impuesto de la aduana para tu espacio y tus standings."

#: apps/planetary/static_data.py
msgid "Set a reset cadence that matches your extractor program length."
msgstr ""
"Fija una cadencia de reinicio acorde con la duración de tu programa de "
"extracción."

#: apps/planetary/static_data.py
msgid "Haul exports to your chosen market hub (or hand to corp buyback)."
msgstr ""
"Transporta las exportaciones al hub de mercado que elijas (o entrégalas al "
"buyback de la corp)."

#: apps/planetary/views.py
msgid "Missing planets"
msgstr "Faltan planetas"

#: apps/planetary/views.py
msgid "Not costed"
msgstr "Sin costear"

#: apps/planetary/views.py
msgid "Missing prices"
msgstr "Faltan precios"

#: apps/planetary/views.py
msgid "Unprofitable"
msgstr "No rentable"

#: apps/planetary/views.py
msgid "Profitable"
msgstr "Rentable"

#: apps/planetary/views.py
msgid "The Planetary Industry planner is currently disabled by leadership."
msgstr ""
"El planificador de Planetary Industry está deshabilitado por el liderazgo en "
"este momento."

#: apps/planetary/views.py
msgid "Add at least one planet — that's what the plan is built around."
msgstr ""
"Añade al menos un planeta — es la base sobre la que se construye el plan."

#: apps/planetary/views.py
msgid "Each factory planet needs a product to build — pick one."
msgstr "Cada planeta fábrica necesita un producto que construir — elige uno."

#: apps/planetary/views.py
#, python-format
msgid "Plan “%(name)s” created — here's your setup and profit estimate."
msgstr ""
"Plan “%(name)s” creado — aquí tienes tu configuración y estimación de "
"beneficio."

#: apps/planetary/views.py
msgid "Plan updated and re-costed."
msgstr "Plan actualizado y recosteado."

#: apps/planetary/views.py
msgid "Keep at least one planet on the plan."
msgstr "Mantén al menos un planeta en el plan."

#: apps/planetary/views.py
msgid "Re-costed with the latest market prices."
msgstr "Recosteado con los últimos precios de mercado."

#: apps/planetary/views.py
#, python-format
msgid "Duplicated as “%(name)s”."
msgstr "Duplicado como “%(name)s”."

#: apps/planetary/views.py
#, python-format
msgid "Status set to %(status)s."
msgstr "Estado establecido a %(status)s."

#: apps/planetary/views.py
#, python-format
msgid "“%(name)s” archived. Delete again to remove it permanently."
msgstr ""
"“%(name)s” archivado. Elimínalo de nuevo para borrarlo permanentemente."

#: apps/planetary/views.py
#, python-format
msgid "“%(name)s” permanently deleted."
msgstr "“%(name)s” eliminado permanentemente."

#: apps/planetary/views.py
msgid "A colony sync is already running — give it a minute before retrying."
msgstr ""
"Ya hay una sincronización de colonias en curso — dale un minuto antes de "
"reintentar."

#: apps/planetary/views.py
#, python-format
msgid "Colony sync queued for %(count)s pilot(s) — refresh in a minute."
msgstr ""
"Sincronización de colonias en cola para %(count)s piloto(s) — actualiza en "
"un minuto."

#: apps/planetary/views.py
msgid "Grant the Planetary Industry scope first, then sync your colonies."
msgstr ""
"Concede primero el scope de Planetary Industry y luego sincroniza tus "
"colonias."

#: apps/raffle/contest_templates.py
msgid "1st prize"
msgstr "1.er premio"

#: apps/raffle/contest_templates.py
msgid "2nd prize"
msgstr "2.º premio"

#: apps/raffle/contest_templates.py
msgid "3rd prize"
msgstr "3.er premio"

#: apps/raffle/contest_templates.py
msgid "4th prize"
msgstr "4.º premio"

#: apps/raffle/contest_templates.py
msgid "5th prize"
msgstr "5.º premio"

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "PVP activity raffle"
msgstr "Sorteo por actividad PVP"

#: apps/raffle/contest_templates.py
msgid ""
"Reward everyone who undocks and gets on kills. Solo 100 · final blow 10 · "
"participation 1."
msgstr ""
"Recompensa a todo el que desatraque y entre en kills. Solo 100 · golpe final "
"10 · participación 1."

#: apps/raffle/contest_templates.py
msgid "Get pilots on more kills."
msgstr "Haz que los pilotos participen en más derribos."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Solo kill challenge"
msgstr "Desafío de kills en solitario"

#: apps/raffle/contest_templates.py
msgid ""
"Heavily reward solo PvP prowess — solo kills are worth 10× a normal kill."
msgstr ""
"Recompensa con fuerza la destreza en PvP en solitario: los kills en "
"solitario valen 10× un kill normal."

#: apps/raffle/contest_templates.py
msgid "Crown the corp's best solo hunter."
msgstr "Corona al mejor cazador en solitario de la corp."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Home defence contest"
msgstr "Concurso de defensa local"

#: apps/raffle/contest_templates.py
msgid ""
"Reward kills defending home space. Set the home region/systems in the PVP "
"filters."
msgstr ""
"Recompensa los kills en defensa del espacio propio. Define la región/"
"sistemas de origen en los filtros de PVP."

#: apps/raffle/contest_templates.py
msgid "Defend home — kills in our space earn tickets."
msgstr "Defiende el hogar: los derribos en nuestro espacio otorgan boletos."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Mining month"
msgstr "Mes de la minería"

#: apps/raffle/contest_templates.py
msgid "Reward ore mined from the corp mining ledger (X tickets per m³)."
msgstr ""
"Recompensa el mineral extraído según el registro de minería de la corp (X "
"boletos por m³)."

#: apps/raffle/contest_templates.py
msgid "Fill the ore hangar — mine to earn tickets."
msgstr "Llena el hangar de mineral: mina para ganar boletos."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Industry production drive"
msgstr "Campaña de producción industrial"

#: apps/raffle/contest_templates.py
msgid ""
"Recognise builders. Industry has no reliable per-pilot feed, so awards are "
"officer-approved."
msgstr ""
"Reconoce a los constructores. La industria no tiene un feed fiable por "
"piloto, así que los premios los aprueba un oficial."

#: apps/raffle/contest_templates.py
msgid "Keep the production lines running."
msgstr "Mantén las líneas de producción en marcha."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Logistics support campaign"
msgstr "Campaña de apoyo logístico"

#: apps/raffle/contest_templates.py
msgid "Reward haulers for delivered courier contracts (officer-approved)."
msgstr ""
"Recompensa a los transportistas por los contratos de mensajería entregados "
"(aprobado por un oficial)."

#: apps/raffle/contest_templates.py
msgid "Keep the supply lines moving."
msgstr "Mantén las líneas de suministro en movimiento."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Newbro support contest"
msgstr "Concurso de apoyo a newbros"

#: apps/raffle/contest_templates.py
msgid "Reward mentors and helpers. Mentorship completions + leadership grants."
msgstr ""
"Recompensa a mentores y ayudantes. Mentorías completadas + concesiones de "
"liderazgo."

#: apps/raffle/contest_templates.py
msgid "Help new pilots get flying."
msgstr "Ayuda a los pilotos nuevos a empezar a volar."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Alliance deployment raffle"
msgstr "Sorteo de despliegue de la alianza"

#: apps/raffle/contest_templates.py
msgid ""
"PVP + fleet attendance during a deployment. Admits alliance / friendly "
"pilots."
msgstr ""
"PVP + asistencia a flotas durante un despliegue. Admite pilotos de la "
"alianza y aliados."

#: apps/raffle/contest_templates.py
msgid "Show up and fight the deployment."
msgstr "Preséntate y combate en el despliegue."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "Mixed activity engagement"
msgstr "Participación por actividad mixta"

#: apps/raffle/contest_templates.py
msgid ""
"A bit of everything — PVP, mining, fleet attendance and leadership grants."
msgstr ""
"Un poco de todo: PVP, minería, asistencia a flotas y concesiones de "
"liderazgo."

#: apps/raffle/contest_templates.py
msgid "Reward any way of contributing to the corp."
msgstr "Recompensa cualquier forma de contribuir a la corp."

#: apps/raffle/contest_templates.py
#: templates/admin_audit/console/raffle_detail.html
msgid "ESI adoption campaign"
msgstr "Campaña de adopción de ESI"

#: apps/raffle/contest_templates.py
msgid ""
"Drive app enrolment — everyone who connects ESI and flies earns; big CTA on "
"the dashboard."
msgstr ""
"Impulsa el registro en la app: todo el que conecte ESI y vuele gana; CTA "
"destacado en el panel."

#: apps/raffle/contest_templates.py
msgid "Get the whole corp enrolled in FORCA Command Grid."
msgstr "Consigue que toda la corp se inscriba en FORCA Command Grid."

#: apps/raffle/draw.py
msgid "draw not completed / seed not revealed"
msgstr "sorteo no completado / semilla no revelada"

#: apps/raffle/draw.py
msgid "no eligible tickets"
msgstr "sin boletos elegibles"

#: apps/raffle/eligibility.py
msgid "This pilot has no FORCA Command Grid account."
msgstr "Este piloto no tiene cuenta de FORCA Command Grid."

