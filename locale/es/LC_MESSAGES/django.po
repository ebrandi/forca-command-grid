#: apps/campaigns/services.py
msgid "This status change is not allowed from the campaign's current state."
msgstr ""
"Este cambio de estado no está permitido desde el estado actual de la campaña."

#: apps/campaigns/services.py
msgid ""
"Complete or fail a campaign through the close-out flow, not a direct status "
"change."
msgstr ""
"Completa o marca como fallida una campaña mediante el flujo de cierre, no "
"con un cambio de estado directo."

#: apps/campaigns/services.py
msgid "A reason is required for this status change."
msgstr "Se requiere un motivo para este cambio de estado."

#: apps/campaigns/services.py
msgid ""
"All mandatory objectives must be resolved and verified before completing, or "
"a director must supply an override reason."
msgstr ""
"Todos los objetivos obligatorios deben estar resueltos y verificados antes "
"de completar, o un director debe proporcionar un motivo de anulación."

#: apps/campaigns/services.py
msgid "The target end date must be in the future to start the campaign."
msgstr ""
"La fecha de finalización prevista debe estar en el futuro para iniciar la "
"campaña."

#: apps/campaigns/services.py
msgid "Set the desired outcome before proposing the campaign."
msgstr "Define el resultado deseado antes de proponer la campaña."

#: apps/campaigns/services.py
msgid "Add at least one objective before proposing the campaign."
msgstr "Añade al menos un objetivo antes de proponer la campaña."

#: apps/campaigns/services.py apps/campaigns/views.py
msgid "The target end date cannot be before the start date."
msgstr "La fecha de fin objetivo no puede ser anterior a la de inicio."

#: apps/campaigns/services.py
msgid "A note is required when entering a value manually."
msgstr "Se requiere una nota al introducir un valor manualmente."

#: apps/campaigns/services.py
msgid "The value must be a number."
msgstr "El valor debe ser un número."

#: apps/campaigns/services.py
msgid "Objectives become blocked only through a linked issue."
msgstr "Los objetivos solo se bloquean mediante una incidencia vinculada."

#: apps/campaigns/services.py
msgid "A reason is required to drop an objective."
msgstr "Se requiere un motivo para descartar un objetivo."

#: apps/campaigns/services.py
msgid "Resolve the blocking issue before changing this objective's status."
msgstr ""
"Resuelve la incidencia que lo bloquea antes de cambiar el estado de este "
"objetivo."

#: apps/campaigns/services.py
msgid "That objective status change is not allowed."
msgstr "Ese cambio de estado del objetivo no está permitido."

#: apps/campaigns/services.py
msgid "Only a met objective can be verified."
msgstr "Solo se puede verificar un objetivo cumplido."

#: apps/campaigns/services.py
msgid ""
"You cannot verify this objective — officer rank is required and the verifier "
"must differ from the pilot who claimed it."
msgstr ""
"No puedes verificar este objetivo: se requiere rango de oficial y el "
"verificador debe ser distinto del piloto que lo reclamó."

#: apps/campaigns/services.py
#, python-format
msgid "Linked to campaign objective “%(title)s”."
msgstr "Vinculado al objetivo de campaña “%(title)s”."

#: apps/campaigns/services.py
msgid "Campaign follow-up task"
msgstr "Tarea de seguimiento de campaña"

#: apps/campaigns/services.py
msgid ""
"A campaign follow-up task is assigned to you — open Campaign Command for "
"details."
msgstr ""
"Se te ha asignado una tarea de seguimiento de campaña: abre Comando de "
"Campaña para ver los detalles."

#: apps/campaigns/services.py
msgid "Manual progress can only be set on a manual-progress campaign."
msgstr ""
"El progreso manual solo puede establecerse en una campaña de progreso manual."

#: apps/campaigns/services.py
msgid "A note is required when setting progress manually."
msgstr "Se requiere una nota al establecer el progreso manualmente."

#: apps/campaigns/services.py
msgid "Progress must be a whole number between 0 and 100."
msgstr "El progreso debe ser un número entero entre 0 y 100."

#: apps/campaigns/services.py
msgid "A dependency's source cannot be external."
msgstr "El origen de una dependencia no puede ser externo."

#: apps/campaigns/services.py
msgid "An external dependency needs a note describing it."
msgstr "Una dependencia externa necesita una nota que la describa."

#: apps/campaigns/services.py
msgid "A dependency cannot point at itself."
msgstr "Una dependencia no puede apuntar a sí misma."

#: apps/campaigns/services.py
msgid "The dependency's source must be part of this campaign."
msgstr "El origen de la dependencia debe formar parte de esta campaña."

#: apps/campaigns/services.py
msgid ""
"The blocking target must be an item of this campaign or a campaign you can "
"view."
msgstr ""
"El objetivo bloqueante debe ser un elemento de esta campaña o de una campaña "
"que puedas ver."

#: apps/campaigns/services.py
msgid "This dependency would create a cycle."
msgstr "Esta dependencia crearía un ciclo."

#: apps/campaigns/services.py
msgid "This dependency chain is too deep to add safely."
msgstr ""
"Esta cadena de dependencias es demasiado profunda para añadirla de forma "
"segura."

#: apps/campaigns/services.py
msgid "An issue needs a description."
msgstr "Una incidencia necesita una descripción."

#: apps/campaigns/services.py
msgid "You can't raise a blocking issue against an already-resolved objective."
msgstr ""
"No puedes plantear una incidencia bloqueante contra un objetivo ya resuelto."

#: apps/campaigns/services.py
msgid "A reason is required to escalate an issue."
msgstr "Se requiere un motivo para escalar una incidencia."

#: apps/campaigns/services.py
msgid "A resolved issue cannot be escalated."
msgstr "Una incidencia resuelta no puede escalarse."

#: apps/campaigns/services.py
msgid "Resolution notes are required to resolve an issue."
msgstr "Se requieren notas de resolución para resolver una incidencia."

#: apps/campaigns/services.py
msgid ""
"Finish or drop this lane's objectives before marking the workstream done."
msgstr ""
"Termina o descarta los objetivos de esta línea antes de marcar el flujo de "
"trabajo como completado."

#: apps/campaigns/services.py
msgid "Unknown milestone status."
msgstr "Estado de hito desconocido."

#: apps/campaigns/services.py
msgid "That milestone status change is not allowed."
msgstr "Ese cambio de estado del hito no está permitido."

#: apps/campaigns/services.py
msgid ""
"Someone other than the pilot who marked this milestone ready must approve it."
msgstr ""
"Debe aprobarlo alguien distinto del piloto que marcó este hito como listo."

#: apps/campaigns/services.py
msgid "A milestone can only be marked missed after its due date has passed."
msgstr ""
"Un hito solo puede marcarse como incumplido después de que haya pasado su "
"fecha límite."

#: apps/campaigns/services.py
msgid "A reason is required to resolve a dependency by hand."
msgstr "Se requiere un motivo para resolver una dependencia manualmente."

#: apps/campaigns/services.py
msgid "Choose a valid operation to link."
msgstr "Elige una operación válida para vincular."

#: apps/campaigns/services.py
#, python-format
msgid "Help: %(title)s"
msgstr "Ayuda: %(title)s"

#: apps/campaigns/services.py
msgid "A template needs a name to derive its key from."
msgstr "Una plantilla necesita un nombre del que derivar su clave."

#: apps/campaigns/services.py
msgid "A template with that key already exists — choose a different name."
msgstr "Ya existe una plantilla con esa clave: elige un nombre diferente."

#: apps/campaigns/services.py
msgid "A reason is required to record recognition."
msgstr "Se requiere un motivo para registrar un reconocimiento."

#: apps/campaigns/services.py
msgid "Recognition needs a pilot to recognise."
msgstr "El reconocimiento necesita un piloto al que reconocer."

#: apps/campaigns/services.py
msgid ""
"You can't record recognition for your own account unless you are a director."
msgstr ""
"No puedes registrar un reconocimiento para tu propia cuenta a menos que seas "
"director."

#: apps/campaigns/services.py
msgid ""
"Points come from completed campaign-linked tasks (leadership-weighted) plus "
"any manual recognition awards. Manual awards show their reason and who gave "
"them."
msgstr ""
"Los puntos provienen de tareas completadas vinculadas a campañas (ponderadas "
"por liderazgo) más cualquier premio de reconocimiento manual. Los premios "
"manuales muestran su motivo y quién los otorgó."

#: apps/campaigns/services.py
msgid ""
"Counts are completed campaign-linked tasks credited to each pilot, plus any "
"manual recognition. Manual awards show their reason and who gave them."
msgstr ""
"Los recuentos son tareas completadas vinculadas a campañas atribuidas a cada "
"piloto, más cualquier reconocimiento manual. Los premios manuales muestran "
"su motivo y quién los otorgó."

#: apps/campaigns/services.py
msgid "Choose a final status of completed, failed or cancelled."
msgstr "Elige un estado final de completado, fallido o cancelado."

#: apps/campaigns/services.py
msgid "Only an active campaign can be closed — resume a paused campaign first."
msgstr ""
"Solo puede cerrarse una campaña activa: reanuda primero una campaña en pausa."

#: apps/campaigns/services.py
msgid "Record an outcome summary before closing."
msgstr "Registra un resumen del resultado antes de cerrar."

#: apps/campaigns/services.py
msgid "Lessons learned are required when completing or failing a campaign."
msgstr ""
"Se requieren lecciones aprendidas al completar o dar por fallida una campaña."

#: apps/campaigns/services.py
#, python-format
msgid ""
"Resolve every objective to met, missed or dropped before closing "
"(unresolved: %(ids)s)."
msgstr ""
"Resuelve cada objetivo como cumplido, incumplido o descartado antes de "
"cerrar (sin resolver: %(ids)s)."

#: apps/campaigns/services.py
msgid "Enter a valid spent figure."
msgstr "Introduce una cifra de gasto válida."

#: apps/campaigns/services.py
msgid "Spent ISK cannot be negative."
msgstr "El ISK gastado no puede ser negativo."

#: apps/campaigns/services.py
#, python-format
msgid "Follow-up: %(title)s"
msgstr "Seguimiento: %(title)s"

#: apps/campaigns/templates_i18n.py
msgid "Establish Armour Battleship Deployment Readiness"
msgstr "Establecer la preparación de despliegue de battleships de armor"

#: apps/campaigns/templates_i18n.py
msgid ""
"The reference deployment-readiness campaign: qualify pilots into the armour "
"battleship doctrine, stage fitted hulls and consumables, secure an SRP "
"reserve, prove the logistics route and finish with a live readiness "
"exercise. Fill in the doctrine, stockpile, wallet and operation selections "
"after creating — every id is left blank on purpose."
msgstr ""
"La campaña de referencia para la preparación de un despliegue: cualifica a "
"los pilotos en la doctrine de battleships de armor, posiciona en el staging "
"los cascos fiteados y los consumibles, asegura una reserva de SRP, valida la "
"ruta logística y termina con un ejercicio de preparación en vivo. Rellena "
"las selecciones de doctrine, acopio, cartera y operación después de crearla "
"— todos los ids se dejan en blanco a propósito."

#: apps/campaigns/templates_i18n.py
msgid "Stand up an armour battleship fleet in the new staging within 30 days."
msgstr ""
"Poner en pie una flota de battleships de armor en el nuevo staging en 30 "
"días."

#: apps/campaigns/templates_i18n.py
msgid ""
"A credible armour battleship fleet in staging is the deterrent this "
"deployment turns on — pilots trained, hulls fitted and staged, SRP funded, "
"and the supply route proven before we commit."
msgstr ""
"Una flota creíble de battleships de armor en el staging es la disuasión "
"sobre la que gira este despliegue: pilotos entrenados, cascos fiteados y "
"posicionados, SRP financiado y la ruta de suministro probada antes de "
"comprometernos."

#: apps/campaigns/templates_i18n.py
msgid ""
"An armour battleship fleet that can undock at strength from the new staging, "
"with trained pilots, staged replacements, a funded SRP reserve and a "
"validated logistics route."
msgstr ""
"Una flota de battleships de armor capaz de undockear con efectivos "
"suficientes desde el nuevo staging, con pilotos entrenados, reemplazos "
"posicionados, una reserva de SRP financiada y una ruta logística validada."

#: apps/campaigns/templates_i18n.py
msgid ""
"35 mainline + 12 logistics pilots qualified; 50 mainline and 15 logistics "
"hulls fitted and staged; 30 replacement hulls and 5 fleets' consumables "
"stocked; ≥3 FCs across TZs; route validated; SRP reserve funded; final "
"readiness exercise passed."
msgstr ""
"35 pilotos de línea principal + 12 de logística cualificados; 50 cascos de "
"línea principal y 15 de logística fiteados y posicionados; 30 cascos de "
"reemplazo y consumibles para 5 flotas en stock; ≥3 FCs repartidos por TZs; "
"ruta validada; reserva de SRP financiada; ejercicio final de preparación "
"superado."

#: apps/campaigns/templates_i18n.py
msgid ""
"Deployment date reached without a fleet that can field mainline + logistics "
"at strength, or with no funded SRP reserve / no proven supply route."
msgstr ""
"Llega la fecha del despliegue sin una flota capaz de desplegar línea "
"principal + logística con efectivos suficientes, o sin una reserva de SRP "
"financiada / sin una ruta de suministro probada."

#: apps/campaigns/templates_i18n.py
msgid "Doctrine & fitting"
msgstr "Doctrine y fiteo"

#: apps/campaigns/templates_i18n.py
msgid "Agree, approve and publish the armour battleship doctrine and fits."
msgstr ""
"Acordar, aprobar y publicar la doctrine de battleships de armor y sus fits."

#: apps/campaigns/templates_i18n.py
msgid "Qualify pilots into the doctrine and run training fleets."
msgstr ""
"Cualificar a los pilotos en la doctrine y realizar flotas de entrenamiento."

#: apps/campaigns/templates_i18n.py apps/erp/models.py apps/industry/calc.py
#: apps/industry/models.py
msgid "Manufacturing"
msgstr "Fabricación"

#: apps/campaigns/templates_i18n.py
msgid "Build and fit the mainline, logistics and replacement hulls."
msgstr ""
"Construir y fitear los cascos de línea principal, de logística y de "
"reemplazo."

#: apps/campaigns/templates_i18n.py
msgid "Procurement"
msgstr "Aprovisionamiento"

#: apps/campaigns/templates_i18n.py
msgid "Source ammunition, consumables and modules for the fleets."
msgstr "Conseguir munición, consumibles y módulos para las flotas."

#: apps/campaigns/templates_i18n.py
msgid "Validate the route and move staged assets before the deadline."
msgstr ""
"Validar la ruta y mover los activos al staging antes de la fecha límite."

#: apps/campaigns/templates_i18n.py
msgid "Finance & SRP"
msgstr "Finanzas y SRP"

#: apps/campaigns/templates_i18n.py
msgid "Fund and hold the agreed SRP reserve for the deployment."
msgstr "Financiar y mantener la reserva de SRP acordada para el despliegue."

#: apps/campaigns/templates_i18n.py
msgid "FC coverage"
msgstr "Cobertura de FC"

#: apps/campaigns/templates_i18n.py
msgid "Ensure qualified fleet commanders across the covered timezones."
msgstr ""
"Asegurar comandantes de flota cualificados en todas las zonas horarias "
"cubiertas."

#: apps/campaigns/templates_i18n.py
msgid "Communications"
msgstr "Comunicaciones"

#: apps/campaigns/templates_i18n.py
msgid "Brief the corp, publish the schedule and keep pilots informed."
msgstr ""
"Informar a la corp, publicar el calendario y mantener a los pilotos al día."

#: apps/campaigns/templates_i18n.py
msgid "Final validation"
msgstr "Validación final"

#: apps/campaigns/templates_i18n.py
msgid "Run the final readiness exercise and sign the fleet off."
msgstr ""
"Realizar el ejercicio final de preparación y dar el visto bueno a la flota."

#: apps/campaigns/templates_i18n.py
msgid "Qualify 35 mainline doctrine pilots"
msgstr "Cualificar a 35 pilotos de la doctrine de línea principal"

#: apps/campaigns/templates_i18n.py
msgid ""
"Pilots flying the mainline armour battleship fit. Set the doctrine to "
"measure after creating the campaign."
msgstr ""
"Pilotos capaces de volar el fit de battleship de armor de línea principal. "
"Elige la doctrine a medir después de crear la campaña."

#: apps/campaigns/templates_i18n.py
msgctxt "objective unit"
msgid "pilots"
msgstr "pilotos"

#: apps/campaigns/templates_i18n.py
msgid "Qualify 12 logistics pilots"
msgstr "Cualificar a 12 pilotos de logística"

#: apps/campaigns/templates_i18n.py
msgid ""
"Pilots flying the fleet logistics fit. Set the logistics doctrine to measure "
"after creating the campaign."
msgstr ""
"Pilotos capaces de volar el fit de logística de flota. Elige la doctrine de "
"logística a medir después de crear la campaña."

#: apps/campaigns/templates_i18n.py
msgid "Stage 50 fitted mainline hulls"
msgstr "Posicionar en staging 50 cascos de línea principal fiteados"

#: apps/campaigns/templates_i18n.py
msgid ""
"Fitted mainline hulls on hand in the staging structure. Point this at the "
"staging stockpile and hull type after creating."
msgstr ""
"Cascos de línea principal fiteados disponibles en la estructura de staging. "
"Apunta esto al acopio del staging y al tipo de casco después de crear."

#: apps/campaigns/templates_i18n.py
msgctxt "objective unit"
msgid "ships"
msgstr "naves"

#: apps/campaigns/templates_i18n.py
msgid "Stage 15 fitted logistics hulls"
msgstr "Posicionar en staging 15 cascos de logística fiteados"

#: apps/campaigns/templates_i18n.py
msgid ""
"Fitted logistics hulls on hand in staging. Point this at the staging "
"stockpile and logistics hull type after creating."
msgstr ""
"Cascos de logística fiteados disponibles en el staging. Apunta esto al "
"acopio del staging y al tipo de casco de logística después de crear."

#: apps/campaigns/templates_i18n.py
msgid "Build 30 replacement hulls"
msgstr "Construir 30 cascos de reemplazo"

#: apps/campaigns/templates_i18n.py
msgid ""
"Spare hulls held against losses. Point this at the replacement stockpile "
"after creating."
msgstr ""
"Cascos de repuesto guardados para cubrir pérdidas. Apunta esto al acopio de "
"reemplazos después de crear."

#: apps/campaigns/templates_i18n.py
msgctxt "objective unit"
msgid "hulls"
msgstr "cascos"

#: apps/campaigns/templates_i18n.py
msgid "Stock ammunition & consumables for 5 fleets"
msgstr "Almacenar munición y consumibles para 5 flotas"

#: apps/campaigns/templates_i18n.py
msgid ""
"Ammo, charges and consumables sufficient for five fleet outings. Point this "
