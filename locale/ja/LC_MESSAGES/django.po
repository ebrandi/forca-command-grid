#: apps/planetary/recommend.py
#, python-format
msgid "An extraction planet self-refining into %(name)s (%(tier)s)"
msgstr "自前で精製して %(name)s（%(tier)s）を作る採取惑星"

#: apps/planetary/recommend.py
#, python-format
msgid "A factory planet buying inputs to make %(name)s (%(tier)s)"
msgstr "材料を買って %(name)s（%(tier)s）を作るファクトリー惑星"

#: apps/planetary/recommend.py
#, python-format
msgid "nets about %(isk)s ISK/day per planet at current prices"
msgstr "現在価格で惑星 1 つあたり 1 日約 %(isk)s ISK の純益"

#: apps/planetary/recommend.py
#, python-format
msgid "and you already have the planets for it (%(planets)s)"
msgstr "しかも必要な惑星をすでに持っています（%(planets)s）"

#: apps/planetary/recommend.py
#, python-format
