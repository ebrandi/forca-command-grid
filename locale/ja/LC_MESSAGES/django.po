#, python-format
msgid "%(where)s: missing params key(s): %(keys)s."
msgstr "%(where)s: 不足しているパラメータキー: %(keys)s。"

#: apps/capsuleer/params.py
#, python-format
msgid "%(name)s must be a positive integer."
msgstr "%(name)s は正の整数である必要があります。"

#: apps/capsuleer/params.py
msgid "skill_target.skills must be a list of 1-25 entries."
msgstr "skill_target.skills は 1〜25 件のリストである必要があります。"

#: apps/capsuleer/params.py
msgid "skill_target.skills entries take only type_id and level."
msgstr "skill_target.skills の各エントリは type_id と level のみを取ります。"

#: apps/capsuleer/params.py
msgid "skill_target.skills[].level must be an int in 1-5."
msgstr "skill_target.skills[].level は 1〜5 の整数である必要があります。"

#: apps/capsuleer/params.py
msgid "doctrine_ready.resolver must be 'category' or 'key'."
msgstr ""
"doctrine_ready.resolver は 'category' または 'key' である必要があります。"

#: apps/capsuleer/params.py
msgid "doctrine_ready.unresolved must be a boolean."
msgstr "doctrine_ready.unresolved はブール値である必要があります。"

#: apps/capsuleer/params.py
msgid "doctrine_ready.tier must be 'viable' or 'optimal'."
msgstr ""
"doctrine_ready.tier は 'viable' または 'optimal' である必要があります。"

#: apps/capsuleer/params.py
msgid "ship_owned.type_ids must be a non-empty list."
msgstr "ship_owned.type_ids は空でないリストである必要があります。"

#: apps/capsuleer/params.py
msgid "ship_owned.require_fitted must be a boolean."
msgstr "ship_owned.require_fitted はブール値である必要があります。"

#: apps/capsuleer/params.py
msgid "contribution.baseline_count is system-managed, not author-supplied."
msgstr ""
"contribution.baseline_count はシステム管理であり、作成者が指定するものではあ"
"りません。"

#: apps/capsuleer/params.py
msgid "contribution.kinds must be a non-empty list of strings."
msgstr "contribution.kinds は空でない文字列のリストである必要があります。"

#: apps/capsuleer/params.py
msgid "combat_first.milestone_key must be a non-empty string."
msgstr "combat_first.milestone_key は空でない文字列である必要があります。"

#: apps/capsuleer/params.py
msgid "practical.instructions must be a string of at most 500 chars."
msgstr "practical.instructions は最大 500 文字の文字列である必要があります。"

#: apps/capsuleer/params.py
msgid "practical.evidence_hint must be a string of at most 200 chars."
msgstr "practical.evidence_hint は最大 200 文字の文字列である必要があります。"

#: apps/capsuleer/params.py
msgid "practical.link must be a string of at most 200 chars."
msgstr "practical.link は最大 200 文字の文字列である必要があります。"

#: apps/capsuleer/params.py
#, python-format
msgid "Unknown verification mode: %(value)s."
msgstr "不明な検証モード: %(value)s。"

#: apps/capsuleer/params.py
#, python-format
msgid "'%(kind)s' milestones cannot use automatic verification."
msgstr "'%(kind)s' のマイルストーンは自動検証を使用できません。"

#: apps/capsuleer/params.py
#, python-format
msgid "Unknown milestone kind: %(value)s."
msgstr "不明なマイルストーンの種類: %(value)s。"

