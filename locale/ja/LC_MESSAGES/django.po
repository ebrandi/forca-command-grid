#: apps/admin_audit/console.py
#, python-format
msgid "Imported %(count)d fit as new doctrines under IMPORTED."
msgid_plural "Imported %(count)d fits as new doctrines under IMPORTED."
msgstr[0] "%(count)d 件の fit を IMPORTED 配下の新しい doctrine としてインポートしました。"

#: apps/admin_audit/console_access.py
msgid "Enter a valid alliance id."
msgstr "有効なアライアンス ID を入力してください。"

#: apps/admin_audit/console_access.py
msgid "Partner alliance saved."
msgstr "パートナーアライアンスを保存しました。"

#: apps/admin_audit/console_access.py
msgid "Partner alliance removed."
msgstr "パートナーアライアンスを削除しました。"

#: apps/admin_audit/console_access.py
msgid "Enter a valid corporation id."
msgstr "有効なコーポレーション ID を入力してください。"

#: apps/admin_audit/console_access.py
msgid "Friendly corporation saved."
msgstr "フレンドリーコーポレーションを保存しました。"

#: apps/admin_audit/console_access.py
msgid "Friendly corporation removed."
msgstr "フレンドリーコーポレーションを削除しました。"

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings reset to defaults."
msgstr "Capsuleer Path の設定をデフォルトにリセットしました。"

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings saved."
msgstr "Capsuleer Path の設定を保存しました。"

#: apps/admin_audit/console_combat.py
msgid "A rank title can't be empty."
msgstr "ランクのタイトルは空にできません。"

#: apps/admin_audit/console_combat.py
msgid "Reward amount can't be negative."
msgstr "報酬額を負の値にすることはできません。"

#: apps/admin_audit/console_combat.py
msgid "Another rank already uses this threshold for this metric."
msgstr "別のランクがこのメトリクスで既にこのしきい値を使用しています。"

#: apps/admin_audit/console_combat.py
msgid ""
"Rewards apply to the all-time PvP kills track only — the support-role tracks"
" are recognition-only."
msgstr "報酬は通算 PvP キル数トラックにのみ適用されます — サポートロールのトラックは表彰専用です。"

#: apps/admin_audit/console_combat.py
msgid "Choose a reward type, or untick “grants reward”."
msgstr "報酬タイプを選択するか、“報酬を付与” のチェックを外してください。"

#: apps/admin_audit/console_combat.py
msgid "An item reward needs an EVE type id."
msgstr "アイテム報酬には EVE type ID が必要です。"

#: apps/admin_audit/console_combat.py
msgid "An ISK/PLEX reward needs a positive amount."
msgstr "ISK/PLEX 報酬には正の金額が必要です。"

#: apps/admin_audit/console_combat.py
msgid "Must be zero or positive."
msgstr "0 以上でなければなりません。"

#: apps/admin_audit/console_combat.py
msgid "Can't exceed 100%."
msgstr "100% を超えることはできません。"

#: apps/admin_audit/console_combat.py
msgid "Newbro settings saved."
msgstr "Newbro の設定を保存しました。"

#: apps/admin_audit/console_combat.py
msgid "Please correct the newbro settings."
msgstr "newbro の設定を修正してください。"

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” saved."
msgstr "ランク “%(name)s” を保存しました。"

#: apps/admin_audit/console_combat.py apps/admin_audit/console_corporation.py
#: apps/admin_audit/console_industry.py apps/admin_audit/console_mentorship.py
#: apps/admin_audit/console_navigation.py
#: apps/admin_audit/console_pingboard.py apps/admin_audit/console_planetary.py
#: apps/admin_audit/console_raffle.py
msgid "Please correct the errors below."
msgstr "以下のエラーを修正してください。"

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” removed."
msgstr "ランク “%(name)s” を削除しました。"

#: apps/admin_audit/console_combat.py
msgid "Reward settings saved."
msgstr "報酬設定を保存しました。"

#: apps/admin_audit/console_combat.py
#, python-format
msgid ""
"Rewards enabled. Baseline snapshotted for %(n)d pilot(s) — only ranks "
"reached from now on will create rewards."
msgstr "報酬を有効にしました。%(n)d 人のパイロットのベースラインをスナップショットしました — 今後到達したランクのみが報酬を生成します。"

#: apps/admin_audit/console_combat.py
msgid "Rewards disabled. No new reward events will be created."
msgstr "報酬を無効にしました。新しい報酬イベントは作成されません。"

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Baseline re-snapshotted for %(n)d pilot(s)."
msgstr "%(n)d 人のパイロットのベースラインを再スナップショットしました。"

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward scan complete — %(n)d new reward event(s) created."
msgstr "報酬スキャンが完了しました — %(n)d 件の新しい報酬イベントを作成しました。"

#: apps/admin_audit/console_combat.py apps/buyback/views.py
#: apps/logistics/views.py apps/stockpile/views.py apps/store/views.py
msgid "Unknown action."
msgstr "不明なアクションです。"

#: apps/admin_audit/console_combat.py
msgid "Only a Director can mark a reward paid."
msgstr "報酬を支払い済みにマークできるのは Director のみです。"

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward %(action)s — %(character)s · %(rank)s."
msgstr "報酬 %(action)s — %(character)s · %(rank)s。"

#: apps/admin_audit/console_command_intel.py
#, python-format
msgid "%(domain)s reset to defaults."
msgstr "%(domain)s をデフォルトにリセットしました。"

#: apps/admin_audit/console_command_intel.py
msgid "Provider & model settings saved."
msgstr "プロバイダーとモデルの設定を保存しました。"

#: apps/admin_audit/console_command_intel.py
msgid "Critical ratio"
msgstr "クリティカル比率"

#: apps/admin_audit/console_command_intel.py
msgid "Headroom/demand at or below this colours a constraint critical."
msgstr "この値以下の余裕/需要は制約を「クリティカル」として色付けします。"

#: apps/admin_audit/console_command_intel.py
msgid "High ratio"
msgstr "高比率"

#: apps/admin_audit/console_command_intel.py
msgid "Above critical, at or below this colours it high."
msgstr "「クリティカル」より上で、この値以下では「高」として色付けします。"

#: apps/admin_audit/console_command_intel.py
msgid "Watch ratio"
msgstr "監視比率"

#: apps/admin_audit/console_command_intel.py
msgid "Above high, at or below this colours it watch."
msgstr "「高」より上で、この値以下では「監視」として色付けします。"

#: apps/admin_audit/console_command_intel.py
msgid "Constraints & thresholds saved."
msgstr "制約としきい値を保存しました。"

#: apps/admin_audit/console_command_intel.py
msgid "Classification settings saved."
msgstr "分類設定を保存しました。"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Corporation Internal"
msgstr "コーポレーション内部"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "High Command"
msgstr "上級司令部"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Director — Eyes Only"
msgstr "Director — 閲覧限定"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Alliance Command"
msgstr "アライアンス司令部"

#: apps/admin_audit/console_command_intel.py
msgid "Notification & delivery settings saved."
msgstr "通知と配信の設定を保存しました。"

#: apps/admin_audit/console_command_intel.py
msgid "Autonomous proposal settings saved."
msgstr "自律提案の設定を保存しました。"

#: apps/admin_audit/console_command_intel.py
msgid "Auto-AAR settings saved."
msgstr "Auto-AAR の設定を保存しました。"

#: apps/admin_audit/console_corporation.py
msgid "Low-fuel warning must be between 1 and 30 days."
msgstr "低燃料警告は 1〜30 日の間でなければなりません。"

#: apps/admin_audit/console_corporation.py
msgid "ADM floor must be between 1.0 and 6.0."
msgstr "ADM の下限は 1.0〜6.0 の間でなければなりません。"

#: apps/admin_audit/console_corporation.py
msgid "Structure-alert thresholds saved."
msgstr "ストラクチャアラートのしきい値を保存しました。"

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import rejected: %(error)s"
msgstr "インポートが拒否されました: %(error)s"

#: apps/admin_audit/console_doctrine_xml.py
msgid "XML import applied."
msgstr "XML インポートを適用しました。"

#: apps/admin_audit/console_doctrine_xml.py
msgid "Enter a whole number."
msgstr "整数を入力してください。"

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Limit set to %(clamped)s (values are kept within 1–%(ceiling)s)."
msgstr "上限を %(clamped)s に設定しました（値は 1–%(ceiling)s の範囲に収められます）。"

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import limit set to %(clamped)s fittings."
msgstr "インポート上限を %(clamped)s fittings に設定しました。"

