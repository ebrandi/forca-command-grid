#: templates/admin_audit/console/pingboard/channel_form.html
msgid "#alerts or C0123ABCD"
msgstr "#alerts または C0123ABCD"

#: templates/admin_audit/console/pingboard/channel_form.html
msgid ""
"Used when the workspace bot token is set in the environment. Ignored in "
