msgstr "— EVE-mail 無効 —"

#: templates/admin_audit/console/readiness/alerts.html
msgid "(scope not granted)"
msgstr "（スコープ未付与）"

#: templates/admin_audit/console/readiness/alerts.html
msgid "Save sender"
msgstr "送信者を保存"

#: templates/admin_audit/console/readiness/alerts.html
#, python-format
