#: apps/capsuleer/params.py
#, python-format
msgid "%(where)s params must be an object."
msgstr "%(where)s のパラメータはオブジェクトである必要があります。"

#: apps/capsuleer/params.py
#, python-format
msgid "%(where)s: unexpected params key(s): %(keys)s."
msgstr "%(where)s: 予期しないパラメータキー: %(keys)s。"

