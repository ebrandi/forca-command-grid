msgstr "État OAuth invalide."

#: apps/sso/views.py
msgid "Missing authorization code."
msgstr "Code d'autorisation manquant."

#: apps/sso/views.py
msgid "Authentication failed."
msgstr "Échec de l'authentification."

#: apps/sso/views.py
msgid "This EVE character is already linked to another account."
msgstr "Ce personnage EVE est déjà lié à un autre compte."

#: apps/sso/views.py
msgid ""
"This EVE character's ownership has changed since it was linked. For security"
" it cannot sign in until an officer detaches it."
msgstr ""
"La propriété de ce personnage EVE a changé depuis sa liaison. Pour des "
"raisons de sécurité, il ne peut pas se connecter tant qu'un officer ne l'a "
"pas détaché."

#: apps/sso/views.py
msgid "Could not re-check your access just now — try again shortly."
msgstr ""
"Impossible de revérifier votre accès pour le moment — réessayez sous peu."

#: apps/sso/views.py
msgid "A full CCP re-check is running in the background."
msgstr "Une revérification complète CCP est en cours en arrière-plan."

#: apps/sso/views.py
#, python-format
