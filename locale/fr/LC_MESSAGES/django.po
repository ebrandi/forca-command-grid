#: apps/sso/scopes.py
#| msgid "Sync my assets"
msgid "Track my assets"
msgstr "Suivre mes actifs"

#: apps/sso/scopes.py
msgid ""
"Show your own assets and where they sit across stations and structures in "
"the stockpile views."
msgstr ""
"Affiche vos propres actifs et leur emplacement dans les stations et les "
"structures, dans les vues de stock."

#: apps/sso/scopes.py
msgid "My industry jobs + blueprints"
msgstr "Mes jobs d'industrie + blueprints"

#: apps/sso/scopes.py
msgid ""
"Read your own running industry jobs and owned blueprints, so the Industry "
"Center can track your personal production and match it to your plans."
msgstr ""
"Lit vos jobs d'industrie en cours et les blueprints que vous possédez, pour "
"que le Centre industriel suive votre production personnelle et la rapproche "
"de vos plans."

#: apps/sso/scopes.py
#| msgid "Market locations"
msgid "Freight location search"
msgstr "Recherche de lieux de fret"

#: apps/sso/scopes.py
msgid ""
"Search the player structures you can dock at when booking a courier "
"contract, so a pickup or drop-off resolves to the exact station."
msgstr ""
"Recherche les structures joueur où vous pouvez vous amarrer lors de la "
"réservation d'un contrat de courrier, pour que l'enlèvement ou la livraison "
"pointe vers la station exacte."

#: apps/sso/scopes.py
msgid "Verify my hauls"
msgstr "Vérifier mes transports"

#: apps/sso/scopes.py
msgid ""
"Read your own contracts so the freight service can confirm a courier job you"
" delivered actually completed in-game and credit you for it."
msgstr ""
"Lit vos propres contrats pour que le service de fret confirme in-game qu'un "
"contrat de courrier que vous avez livré est bien terminé, et vous le "
"crédite."

#: apps/sso/scopes.py
msgid "Verify corp hauls"
msgstr "Vérifier les transports de la corp"

#: apps/sso/scopes.py
msgid ""
"Read corp contracts to auto-verify every hauler's courier delivery in-game "
"before crediting it — no per-pilot grant needed."
msgstr ""
"Lit les contrats de la corp pour vérifier automatiquement in-game la "
"livraison de chaque transporteur avant de la créditer — aucune autorisation "
"par pilote nécessaire."

#: apps/sso/scopes.py templates/_user_block.html
#: templates/corporation/finance.html templates/identity/dashboard.html
#: templates/impersonation/log.html
msgid "Director"
msgstr "Directeur"

#: apps/sso/scopes.py
msgid ""
"Import the corporation's assets to power the stockpile and supply views."
msgstr ""
"Importe les actifs de la corporation pour alimenter les vues de stock et "
"d'approvisionnement."

#: apps/sso/scopes.py
#| msgid "Member roster"
msgid "Member tracking"
msgstr "Suivi des membres"

#: apps/sso/scopes.py
msgid ""
"Import the corp roster with each member's location, ship and last login for "
"the readiness and roster tools."
msgstr ""
"Importe la liste des membres de la corp avec, pour chacun, la localisation, "
"le vaisseau et la dernière connexion, pour les outils de préparation et de "
"liste des membres."

#: apps/sso/scopes.py
#| msgid "Corp assets"
msgid "Corp wallet"
msgstr "Portefeuille de la corp"

#: apps/sso/scopes.py
msgid "Import corp wallet balances and the journal for the finance page."
msgstr ""
"Importe les soldes du portefeuille de la corp et le journal pour la page "
"finances."

#: apps/sso/scopes.py
#| msgid "Account recovery"
msgid "Accountant or Director"
msgstr "Comptable ou Directeur"

#: apps/sso/scopes.py
#| msgid "Corp stats"
msgid "Corp standings"
msgstr "Réputations de la corp"

#: apps/sso/scopes.py
msgid ""
"Import corp contacts to drive the member-facing blue/red standings board."
msgstr ""
"Importe les contacts de la corp pour alimenter le tableau des réputations "
"bleu/rouge visible par les membres."

#: apps/sso/scopes.py
msgid ""
"List the corp's Ansiblex jump bridges and cyno beacons to auto-build the "
"jump map and route planner."
msgstr ""
"Liste les jump bridges Ansiblex et les balises cyno de la corp pour "
"construire automatiquement la carte des sauts et le planificateur "
"d'itinéraire."

#: apps/sso/scopes.py
msgid "Director or Station Manager"
msgstr "Directeur ou Station Manager"

#: apps/sso/scopes.py
#| msgid "Structure timer"
msgid "Structure monitoring"
msgstr "Surveillance des structures"

#: apps/sso/scopes.py
msgid ""
"Monitor every corp structure — fuel remaining, online/low-power state and "
"reinforcement timers — so nothing runs dry or comes out of reinforcement "
"unwatched."
msgstr ""
"Surveille chaque structure de la corp — carburant restant, état online/low-"
"power et timers de reinforcement — pour qu'aucune ne tombe en panne sèche ni"
" ne sorte de reinforcement sans surveillance."

#: apps/sso/scopes.py templates/corporation/extractions.html
msgid "Moon extractions"
msgstr "Extractions de lune"

#: apps/sso/scopes.py
msgid "Import scheduled moon extractions for the extraction calendar."
msgstr ""
"Importe les extractions de lune planifiées pour le calendrier d'extraction."

#: apps/sso/scopes.py
#| msgid "Veteran Mentor Directory"
msgid "Station Manager or Director"
msgstr "Station Manager ou Directeur"

#: apps/sso/scopes.py
#| msgid "Corporation blueprint"
msgid "Corp blueprints + jobs"
msgstr "Blueprints + jobs de la corp"

#: apps/sso/scopes.py
msgid ""
"Import the corp's owned blueprints (ME/TE) and running industry jobs so "
"blueprint coverage and build-or-buy reflect what the corp actually owns and "
"has in production."
msgstr ""
"Importe les blueprints détenus par la corp (ME/TE) et les jobs d'industrie "
"en cours, pour que la couverture des blueprints et l'arbitrage fabriquer-ou-"
"acheter reflètent ce que la corp possède et produit réellement."

#: apps/sso/scopes.py
#| msgid "Director no longer authorised"
msgid "Director or Factory Manager"
msgstr "Directeur ou Factory Manager"

#: apps/sso/scopes.py
#| msgid "Notifications"
msgid "Notification relay"
msgstr "Relais de notifications"

#: apps/sso/scopes.py
#| msgid ""
#| "Relayed ESI notifications — structure attacks, war declarations, sovereignty"
#| " and moon extractions — pulled from a role-holder's token. Fresh red alerts "
#| "also go to Discord."
msgid ""
"Relay in-game notifications — structure attacks, war declarations, "
"sovereignty and moon pops — to the site and Discord."
msgstr ""
"Relaie les notifications en jeu — attaques de structure, déclarations de "
"guerre, souveraineté et extractions de lune — vers le site et Discord."

#: apps/sso/scopes.py
#| msgid "Director no longer authorised"
msgid "Director or role-holder"
msgstr "Directeur ou détenteur du rôle"

#: apps/sso/scopes.py
#| msgid "Corp mail relay"
msgid "Mail relay"
msgstr "Relais de mail"

#: apps/sso/scopes.py
msgid ""
"Relay your corp/alliance mailing-list mail to Discord, so announcements "
"reach members who don't check in-game mail. Grant from the character "
"subscribed to the lists."
msgstr ""
"Relaie les mails des mailing-lists de la corp/alliance vers Discord, pour "
"que les annonces atteignent les membres qui ne consultent pas leur mail en "
"jeu. À accorder depuis le personnage abonné aux listes."

#: apps/sso/scopes.py
#| msgid "Readiness index"
msgid "Readiness mail sender"
msgstr "Expéditeur des mails de préparation"

#: apps/sso/scopes.py
msgid ""
"Let the platform send readiness alert e-mails in-game from this character. "
"Grant from the director you select as the readiness mail sender on the Admin"
" Console → Readiness → Alerts page."
msgstr ""
"Permet à la plateforme d'envoyer les e-mails d'alerte de préparation en jeu "
"depuis ce personnage. À accorder depuis le directeur que vous désignez comme"
" expéditeur des mails de préparation sur la page Console d'administration → "
"Préparation → Alertes."

#: apps/sso/scopes.py
#| msgid "Pingboard calendar →"
msgid "Pingboard mail sender"
msgstr "Expéditeur des EVE-mails Pingboard"

#: apps/sso/scopes.py
msgid ""
"Let Pingboard send corp alerts in-game from this character. Grant from the "
"director you select as the Pingboard EVE-mail sender on the Admin Console → "
"Pingboard → Channels page."
msgstr ""
"Permet à Pingboard d'envoyer les alertes de la corp en jeu depuis ce "
"personnage. À accorder depuis le directeur que vous désignez comme "
"expéditeur des EVE-mails Pingboard sur la page Console d'administration → "
"Pingboard → Canaux."

#: apps/sso/scopes.py
#| msgid "Fleet operation"
msgid "Fleet tracking"
msgstr "Suivi de flotte"

#: apps/sso/scopes.py
msgid ""
"Let an FC pull the live fleet roster to auto-record everyone's participation"
" (PAP) for an operation — no manual sign-in. Grant from the character that "
"boss-fleets."
msgstr ""
"Permet à un FC de récupérer la composition de flotte en direct pour "
"enregistrer automatiquement la participation (PAP) de chacun à une opération"
" — sans pointage manuel. À accorder depuis le personnage qui est boss de "
"flotte."

#: apps/sso/scopes.py
#| msgid "A mentorship session is confirmed"
msgid "Mentorship session check-in"
msgstr "Pointage de session de mentorat"

#: apps/sso/scopes.py
msgid ""
"Optional: let the Mentorship Program confirm you were online and in the "
"session's system during a scheduled mentoring session — the only way to "
"corroborate 'we flew together', since EVE keeps no history of it. Off by "
"default, polled only during a session you booked, and never stored beyond "
"the check."
msgstr ""
"Optionnel : permet au programme de mentorat de confirmer que vous étiez en "
"ligne et dans le système de la session pendant une session de mentorat "
"programmée — le seul moyen de corroborer « nous avons volé ensemble », "
"puisque EVE n'en conserve aucun historique. Désactivé par défaut, interrogé "
"uniquement pendant une session que vous avez réservée, et jamais conservé "
"au-delà de la vérification."

#: apps/sso/scopes.py
#| msgid "Imported"
msgid "Import saved fits"
msgstr "Importer les fits enregistrés"

#: apps/sso/scopes.py
msgid ""
"Read your own saved ship fittings so you can import them as corp doctrines "
"(ESI has no corp-fittings endpoint, so doctrines are seeded from a "
"director's personal fits)."
msgstr ""
"Lit vos propres fittings enregistrés pour que vous puissiez les importer "
"comme doctrines de la corp (ESI n'expose aucun endpoint de fittings de corp "
": les doctrines sont donc initialisées à partir des fits personnels d'un "
"directeur)."

#: apps/sso/scopes.py
#| msgid "Import per cycle:"
msgid "Import PI colonies"
msgstr "Importer les colonies PI"

#: apps/sso/scopes.py
msgid ""
"Optional: let the Planetary Industry planner import your live colonies so it"
" can show your real layouts, flag issues (idle extractors, missing routes) "
"and estimate your current output. EVE only refreshes this when you open the "
"colony in the client, so imports can be stale — the planner always says "
"when."
msgstr ""
"Optionnel : permet au planificateur Planetary Industry d'importer vos "
"colonies en direct pour afficher vos dispositions réelles, signaler les "
"problèmes (extracteurs à l'arrêt, routes manquantes) et estimer votre "
"production actuelle. EVE ne rafraîchit ces données que lorsque vous ouvrez "
"la colonie dans le client : les imports peuvent donc être obsolètes — le "
"planificateur indique toujours la date."

#: apps/sso/views.py
msgid "Not available while viewing as another pilot."
msgstr "Non disponible lors de la consultation en tant qu'un autre pilote."

#: apps/sso/views.py
#, python-format
msgid "SSO error: %(error)s"
msgstr "Erreur SSO : %(error)s"

