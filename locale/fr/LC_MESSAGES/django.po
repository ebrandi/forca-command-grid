#: apps/pingboard/messages.py
msgid "Milestone unlocked: First kill!"
msgstr "Jalon débloqué : premier kill !"

#: apps/pingboard/messages.py
msgid "Congratulations on your first corp killmail! Welcome to the fight."
msgstr ""
"Félicitations pour votre premier killmail en corp ! Bienvenue au combat."

#: apps/pingboard/messages.py
msgid "Milestone unlocked: First solo kill!"
msgstr "Jalon débloqué : premier kill solo !"

#: apps/pingboard/messages.py
msgid "Your first solo kill — you took one down all on your own. Nice work."
msgstr ""
"Votre premier kill solo — vous en avez abattu un tout seul. Beau travail."

#: apps/pingboard/messages.py
msgid "Milestone unlocked: First final blow!"
msgstr "Jalon débloqué : premier coup de grâce !"

#: apps/pingboard/messages.py
msgid "You landed your first final blow. The killing shot is yours."
msgstr ""
"Vous avez porté votre premier coup de grâce. Le tir fatal est le vôtre."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Combat rank achieved: {rank_name}"
msgstr "Rang de combat atteint : {rank_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Congratulations — you've reached the rank of {rank_name} ({kill_count} "
"lifetime kills recorded). Ranks update from the nightly combat rollup, so "
"this can reflect kills from the last day or two rather than the exact moment."
msgstr ""
"Félicitations — vous avez atteint le rang de {rank_name} ({kill_count} kills "
"enregistrés au total). Les rangs sont mis à jour par le bilan de combat "
"nocturne : ce chiffre peut donc refléter des kills d'il y a un ou deux jours "
"plutôt que l'instant exact."

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Congratulations — you've reached the rank of {rank_name} ({kill_count} "
"lifetime kills recorded). A rank reward is pending leadership approval. "
"Ranks update from the nightly combat rollup, so this can reflect kills from "
"the last day or two rather than the exact moment."
msgstr ""
"Félicitations — vous avez atteint le rang de {rank_name} ({kill_count} kills "
"enregistrés au total). Une récompense de rang est en attente d'approbation "
"du commandement. Les rangs sont mis à jour par le bilan de combat nocturne : "
"ce chiffre peut donc refléter des kills d'il y a un ou deux jours plutôt que "
"l'instant exact."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Watchlist tripwire: {entity_name}"
msgstr "Alerte watchlist : {entity_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"⚠ Watched {entity_type} **{entity_name}** ({watchlist_name}) was on a "
"killmail in {system_name} ~{minutes}m ago. Risk indicator, not a guarantee — "
"verify before acting."
msgstr ""
"⚠ Sur watchlist — {entity_type} **{entity_name}** ({watchlist_name}) : "
"repéré sur un killmail dans {system_name} il y a ~{minutes} min. Indicateur "
"de risque, pas une garantie — vérifiez avant d'agir."

#: apps/pingboard/messages.py
msgid "Order update: Claimed"
msgstr "Commande mise à jour : Réclamée"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "{ship_name} was claimed — a member is fulfilling it."
msgstr "{ship_name} a été réclamé — un membre s'en occupe."

#: apps/pingboard/messages.py
msgid "Order update: Deposit paid"
msgstr "Commande mise à jour : Acompte payé"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Deposit received for {ship_name}."
msgstr "Acompte reçu pour {ship_name}."

#: apps/pingboard/messages.py
msgid "Order update: In production"
msgstr "Commande mise à jour : En production"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "{ship_name} is in production."
msgstr "{ship_name} est en production."

#: apps/pingboard/messages.py
msgid "Order update: Ready"
msgstr "Commande mise à jour : Prête"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "{ship_name} is ready — coordinate pickup."
msgstr "{ship_name} est prêt — organisez la récupération."

#: apps/pingboard/messages.py
msgid "Order update: Delivered"
msgstr "Commande mise à jour : Livrée"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "{ship_name} was delivered. Fly safe!"
msgstr "{ship_name} a été livré. Bon vol !"

#: apps/pingboard/messages.py
msgid "Order update: Cancelled"
msgstr "Commande mise à jour : Annulée"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Your order for {ship_name} was cancelled."
msgstr "Votre commande de {ship_name} a été annulée."

#: apps/pingboard/messages.py
msgid "Order update: New delivery estimate"
msgstr "Commande mise à jour : Nouvelle estimation de livraison"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "The estimated delivery for {ship_name} is now {eta_date}."
msgstr "La livraison estimée pour {ship_name} est désormais le {eta_date}."

#: apps/pingboard/messages.py
msgid "Order update: Stock reserved"
msgstr "Commande mise à jour : Stock réservé"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"{quantity}× {ship_name} from a new delivery is now reserved for your order."
msgstr ""
"{quantity}× {ship_name} d'une nouvelle livraison est désormais réservé pour "
"votre commande."

#: apps/pingboard/messages.py
msgid "Order update: Reservation released"
msgstr "Commande mise à jour : Réservation libérée"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Your reserved {ship_name} was released after waiting unclaimed; the order is "
"now backordered."
msgstr ""
"Votre {ship_name} réservé a été libéré après être resté non réclamé ; la "
"commande est désormais différée."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Back in stock: {ship_name}"
msgstr "De retour en stock : {ship_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid "{ship_name} can be ordered on the Shipyard again."
msgstr "{ship_name} peut de nouveau être commandé sur le Chantier naval."

#: apps/pingboard/messages.py
msgid "Shipyard restock built"
msgstr "Réapprovisionnement du Chantier naval construit"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Production for {fit_name} finished. Assemble and fit the ships, then record "
"the receipt on the Shipyard inventory console to release waiting backorders."
msgstr ""
"La production de {fit_name} est terminée. Assemblez les vaisseaux et montez "
"le fit, puis enregistrez la réception sur la console d'inventaire du "
"Chantier naval pour libérer les commandes différées en attente."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Re-authorise {character_name}: corp data ingestion stopped"
msgstr ""
"Réautorisez {character_name} : l'ingestion des données corp est arrêtée"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"The ESI token for {character_name} that authorises corp data ingestion "
"({scopes}) has stopped working — it was revoked or failed to refresh past "
"the retry limit. Re-authorise it on the ESI scopes page (/auth/scopes/) to "
"resume ingestion; corp {scopes} pages will show stale data until then."
msgstr ""
"Le token ESI de {character_name} qui autorise l'ingestion des données corp "
"({scopes}) a cessé de fonctionner — il a été révoqué ou n'a pas pu être "
"rafraîchi au-delà de la limite de tentatives. Réautorisez-le sur la page des "
"scopes ESI (/auth/scopes/) pour reprendre l'ingestion ; d'ici là, les pages "
"corp {scopes} afficheront des données obsolètes."

#: apps/pingboard/messages.py
#, python-brace-format
msgid "Your skill queue is empty — {character_name}"
msgstr "Votre file de compétences est vide — {character_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"{character_name}'s training queue has run dry, so it's not earning SP. Queue "
"your next skills in the EVE client (the Skills page has a plan you can paste "
"in). This is based on the last skill sync, so ignore it if you just queued "
"something."
msgstr ""
"La file d'entraînement de {character_name} est vide : ce personnage ne gagne "
"plus de SP. Mettez vos prochaines compétences en file dans le client EVE (la "
"page Compétences propose un plan à copier-coller). Ceci se base sur la "
"dernière synchro de compétences : ignorez ce message si vous venez d'en "
"mettre une en file."

