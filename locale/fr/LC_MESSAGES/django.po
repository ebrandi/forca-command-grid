#: apps/capsuleer/messages.py
#, python-format
msgid ""
"You are about %(levels)s skill level(s) — roughly %(days)s day(s) of "
"training — from flying %(doctrine)s, which your goal «%(goal)s» targets. "
"Based on your skills as of %(as_of)s."
