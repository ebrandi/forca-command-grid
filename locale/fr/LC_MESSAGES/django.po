msgid "Can't remove the last Director — promote someone else first."
msgstr ""
"Impossible de retirer le dernier directeur — promouvez d'abord quelqu'un "
"d'autre."

#: apps/admin_audit/console.py
#, python-format
msgid "%(role)s %(action)s for %(name)s."
msgstr "%(role)s %(action)s pour %(name)s."

