#: templates/admin_audit/console/readiness/responsibilities.html
#: templates/admin_audit/console/readiness/srp.html
#, python-format
msgid "config v%(version)s"
msgstr "config v%(version)s"

#: templates/admin_audit/console/command_intel/autonomous.html
#: templates/admin_audit/console/command_intel/notifications.html
#, python-format
msgid "last by %(by)s"
msgstr "dernier par %(by)s"

#: templates/admin_audit/console/command_intel/autonomous.html
msgid "Calibration — what would be proposed for now"
msgstr "Calibration — ce qui serait proposé à ce stade"

#: templates/admin_audit/console/command_intel/autonomous.html
msgid ""
"No measured outcomes yet — nothing is trusted, so autonomous proposal stays "
"silent even when armed. Trust accrues as accepted COAs complete and their "
"outcomes are measured."
msgstr ""
"Aucun résultat mesuré pour l'instant — rien n'est jugé fiable, la "
"proposition autonome reste donc silencieuse même armée. La confiance "
"s'accumule à mesure que les COA acceptés s'achèvent et que leurs résultats "
"sont mesurés."

#: templates/admin_audit/console/command_intel/autonomous.html
#, python-format
msgid "spread %(spread)s"
msgstr "dispersion %(spread)s"

#: templates/admin_audit/console/command_intel/autonomous.html
msgid "▲ trusted"
msgstr "▲ fiable"

#: templates/admin_audit/console/command_intel/autonomous.html
msgid "○ not yet"
msgstr "○ pas encore"

#: templates/admin_audit/console/command_intel/classification.html
#: templates/admin_audit/console/hub.html
msgid "Classification"
msgstr "Classification"

#: templates/admin_audit/console/command_intel/classification.html
msgid ""
"Set the default report classification and the tier → minimum-role map that "
"gates who can read each tier. A <span class=\"text-cyan\">design floor</"
"span> is enforced server-side — a tier can be tightened but never loosened "
"below its built-in minimum."
msgstr ""
"Définissez la classification par défaut des rapports et la table niveau → "
"rôle minimum qui régit qui peut lire chaque niveau. Un <span class=\"text-"
"cyan\">plancher de conception</span> est appliqué côté serveur — un niveau "
"peut être renforcé, jamais assoupli en deçà de son minimum intégré."

#: templates/admin_audit/console/command_intel/classification.html
msgid "Default classification"
msgstr "Classification par défaut"

#: templates/admin_audit/console/command_intel/classification.html
msgid "The tier a report falls back to when its template specifies none."
msgstr ""
"Le niveau attribué par défaut à un rapport lorsque son modèle n'en précise "
"aucun."

#: templates/admin_audit/console/command_intel/classification.html
msgid "Tier → minimum role"
msgstr "Niveau → rôle minimum"

#: templates/admin_audit/console/command_intel/classification.html
msgid ""
"Restores the default classification and every tier floor to the shipped "
"defaults."
msgstr ""
"Rétablit la classification par défaut et chaque plancher de niveau aux "
"valeurs par défaut livrées."

#: templates/admin_audit/console/command_intel/constraints.html
#: templates/admin_audit/console/hub.html
msgid "Constraints &amp; thresholds"
msgstr "Contraintes &amp; seuils"

#: templates/admin_audit/console/command_intel/constraints.html
msgid ""
"Tune the global severity ratios, demand baselines and which constraint "
"providers run. A threshold change re-colours severities on the <span "
"class=\"text-cyan\">next snapshot</span> with no deploy. A net-new provider "
"stays disabled until you enable it here."
msgstr ""
"Réglez les ratios de gravité globaux, les références de demande et les "
"fournisseurs de contraintes actifs. Un changement de seuil recolore les "
"gravités au <span class=\"text-cyan\">prochain instantané</span>, sans "
"déploiement. Un fournisseur nouvellement ajouté reste désactivé tant que "
"vous ne l'activez pas ici."

#: templates/admin_audit/console/command_intel/constraints.html
msgid "Global severity ratios"
msgstr "Ratios de gravité globaux"

#: templates/admin_audit/console/command_intel/constraints.html
msgid "Constraint providers"
msgstr "Fournisseurs de contraintes"

#: templates/admin_audit/console/command_intel/constraints.html
msgid "No constraint providers are registered."
msgstr "Aucun fournisseur de contraintes n'est enregistré."

#: templates/admin_audit/console/command_intel/constraints.html
msgid "Demand targets"
msgstr "Cibles de demande"

#: templates/admin_audit/console/command_intel/constraints.html
msgid ""
"One per line as <code class=\"text-faint\">key value</code> — e.g. <code "
"class=\"text-faint\">doctrine:ferox-fleet 22</code>. Leave empty to seed "
"demand from data."
msgstr ""
"Un par ligne, au format <code class=\"text-faint\">clé valeur</code> — p. "
"ex. <code class=\"text-faint\">doctrine:ferox-fleet 22</code>. Laissez vide "
"pour initialiser la demande à partir des données."

#: templates/admin_audit/console/command_intel/constraints.html
msgid ""
"Restores every ratio, provider flag and demand target to the shipped "
"defaults."
msgstr ""
"Rétablit chaque ratio, indicateur de fournisseur et cible de demande aux "
"valeurs par défaut livrées."

#: templates/admin_audit/console/command_intel/notifications.html
msgid ""
"Command Intelligence · Scheduled reports &amp; delivery · [FORCA] Command "
"Grid"
msgstr ""
"Renseignement de commandement · Rapports planifiés &amp; distribution · "
"[FORCA] Command Grid"

#: templates/admin_audit/console/command_intel/notifications.html
#: templates/admin_audit/console/hub.html
msgid "Scheduled reports &amp; delivery"
msgstr "Rapports planifiés &amp; distribution"

#: templates/admin_audit/console/command_intel/notifications.html
msgid ""
"The weekly briefing generates in the background; delivery is <span "
"class=\"text-cyan\">classification-aware</span> and ships <span class=\"text-"
"gold\">disarmed</span> — a director-eyes-only report can never be broadcast "
"to a corp-wide Discord channel (the server refuses that pairing). Nothing "
"leaves the server until you arm a channel and configure its target below."
msgstr ""
"Le briefing hebdomadaire est généré en arrière-plan ; la distribution <span "
"class=\"text-cyan\">tient compte de la classification</span> et est livrée "
"<span class=\"text-gold\">désarmée</span> — un rapport réservé aux "
"directeurs ne peut jamais être diffusé sur un canal Discord ouvert à toute "
"la corp (le serveur refuse cet appariement). Rien ne quitte le serveur tant "
"que vous n'avez pas armé un canal et configuré sa cible ci-dessous."

#: templates/admin_audit/console/command_intel/notifications.html
msgid ""
"LLM enabled — scheduled briefings are narrated. (Without a key they still "
"generate a deterministic report.)"
msgstr ""
"LLM activé — les briefings planifiés sont rédigés. (Sans clé, ils génèrent "
"tout de même un rapport déterministe.)"

#: templates/admin_audit/console/command_intel/notifications.html
msgid ""
"LLM disabled — scheduled briefings still generate the deterministic "
"constraint picture."
msgstr ""
"LLM désactivé — les briefings planifiés génèrent malgré tout le tableau "
"déterministe des contraintes."

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Scheduled generation"
msgstr "Génération planifiée"

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Generate a weekly briefing"
msgstr "Générer un briefing hebdomadaire"

#: templates/admin_audit/console/command_intel/notifications.html
msgid ""
"Monday 12:00 UTC. Deduped against a recent run so a retried beat never "
"double-spends tokens."
msgstr ""
"Lundi 12:00 UTC. Dédupliqué par rapport à une exécution récente afin qu'un "
"beat relancé ne consomme jamais deux fois les tokens."

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Only announce when binding at/above"
msgstr "N'annoncer que si la contrainte atteint ou dépasse"

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Suppress delivery of a quiet report with no meaningful constraint."
msgstr ""
"Supprime la distribution d'un rapport calme, sans contrainte significative."

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Discord (broadcast)"
msgstr "Discord (diffusion)"

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Arm Discord delivery"
msgstr "Armer la distribution Discord"

#: templates/admin_audit/console/command_intel/notifications.html
msgid ""
"Posts a classification-safe summary to every active Discord webhook "
"(configured under In-game Alerts)."
msgstr ""
"Publie un résumé conforme à la classification sur chaque webhook Discord "
"actif (configuré sous Alertes en jeu)."

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Broadcast these classifications"
msgstr "Diffuser ces classifications"

#: templates/admin_audit/console/command_intel/notifications.html
msgid ""
"Only corp-shareable tiers can be broadcast; director/alliance tiers are "
"never offered here."
msgstr ""
"Seuls les niveaux partageables avec la corp peuvent être diffusés ; les "
"niveaux directeur/alliance ne sont jamais proposés ici."

#: templates/admin_audit/console/command_intel/notifications.html
msgid "EVE-mail (targeted to leadership)"
msgstr "EVE-mail (ciblé sur le commandement)"

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Arm EVE-mail delivery"
msgstr "Armer la distribution EVE-mail"

#: templates/admin_audit/console/command_intel/notifications.html
msgid ""
"Sends an in-game mail to the mains behind the owner tags below. Needs a "
"sender character with the <code class=\"text-faint\">esi-mail.send_mail.v1</"
"code> scope."
msgstr ""
"Envoie un mail en jeu aux mains derrière les tags de responsable ci-dessous. "
"Nécessite un personnage expéditeur disposant du scope <code class=\"text-"
"faint\">esi-mail.send_mail.v1</code>."

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Mail these classifications"
msgstr "Envoyer un mail pour ces classifications"

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Targeted mail may carry the sensitive tiers (it is not a broadcast)."
msgstr ""
"Un mail ciblé peut transporter les niveaux sensibles (ce n'est pas une "
"diffusion générale)."

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Sender character id"
msgstr "ID du personnage expéditeur"

#: templates/admin_audit/console/command_intel/notifications.html
msgid ""
"A corp character that granted the mail-send scope. Leave blank to disable."
msgstr ""
"Un personnage de la corp ayant accordé le scope d'envoi de mail. Laissez "
"vide pour désactiver."

#: templates/admin_audit/console/command_intel/notifications.html
msgid "Recipient owner tags"
msgstr "Tags de responsable destinataires"

#: templates/admin_audit/console/command_intel/notifications.html
msgid ""
"Space- or comma-separated (e.g. <code class=\"text-"
"faint\">strategic_director</code>). Their mains receive the mail."
msgstr ""
"Séparés par des espaces ou des virgules (p. ex. <code class=\"text-"
"faint\">strategic_director</code>). Leurs mains reçoivent le mail."

#: templates/admin_audit/console/command_intel/provider.html
msgid "Command Intelligence · Provider &amp; model · [FORCA] Command Grid"
msgstr "Command Intelligence · Fournisseur &amp; modèle · [FORCA] Command Grid"

#: templates/admin_audit/console/command_intel/provider.html
#: templates/admin_audit/console/hub.html
msgid "Provider &amp; model"
msgstr "Fournisseur &amp; modèle"

#: templates/admin_audit/console/command_intel/provider.html
msgid ""
"Pick the runtime model name, output sizing, budgets and call discipline. The "
"<span class=\"text-cyan\">API key</span> lives in the environment and is "
"never shown, edited or stored here — only its presence flips the subsystem "
"on."
msgstr ""
"Choisissez le nom du modèle d'exécution, la taille des sorties, les budgets "
"et la discipline d'appels. La <span class=\"text-cyan\">clé API</span> "
"réside dans l'environnement : elle n'est jamais affichée, modifiée ni "
"stockée ici — seule sa présence active le sous-système."

#: templates/admin_audit/console/command_intel/provider.html
msgid "Enabled — an <code class=\"text-faint\">LLM_API_KEY</code> is present."
msgstr ""
"Activé — une <code class=\"text-faint\">LLM_API_KEY</code> est présente."

#: templates/admin_audit/console/command_intel/provider.html
msgid ""
"Disabled — set <code class=\"text-faint\">LLM_API_KEY</code> in the "
"environment to enable Command Intelligence."
msgstr ""
"Désactivé — définissez <code class=\"text-faint\">LLM_API_KEY</code> dans "
"l'environnement pour activer Command Intelligence."

#: templates/admin_audit/console/command_intel/provider.html
msgid "Model name"
msgstr "Nom du modèle"

#: templates/admin_audit/console/command_intel/provider.html
msgid ""
"The runtime model — overrides the env default (e.g. <code class=\"text-"
"faint\">MiniMax-M2.7</code> or <code class=\"text-faint\">MiniMax-M3</code>)."
msgstr ""
"Le modèle d'exécution — remplace la valeur par défaut de l'environnement (p. "
"ex. <code class=\"text-faint\">MiniMax-M2.7</code> ou <code class=\"text-"
"faint\">MiniMax-M3</code>)."

#: templates/admin_audit/console/command_intel/provider.html
msgid "Max output tokens"
msgstr "Tokens de sortie max"

#: templates/admin_audit/console/command_intel/provider.html
msgid ""
"Sized for reasoning plus the answer; raise on a length cut-off. Range 256–"
"65536."
msgstr ""
"Dimensionné pour le raisonnement plus la réponse ; augmentez en cas de "
"troncature. Plage 256–65536."

#: templates/admin_audit/console/command_intel/provider.html
msgid "Temperature"
msgstr "Température"

#: templates/admin_audit/console/command_intel/provider.html
msgid "Sampling temperature, 0–1. Lower is more deterministic."
msgstr "Température d'échantillonnage, 0–1. Plus bas est plus déterministe."

#: templates/admin_audit/console/command_intel/provider.html
msgid "Token budget per report"
msgstr "Budget de tokens par rapport"

#: templates/admin_audit/console/command_intel/provider.html
msgid "Hard cap on prompt + completion tokens for a single report."
msgstr "Plafond strict de tokens (prompt + complétion) pour un seul rapport."

#: templates/admin_audit/console/command_intel/provider.html
msgid "Monthly token ceiling"
msgstr "Plafond mensuel de tokens"

#: templates/admin_audit/console/command_intel/provider.html
msgid "Safety cap on total tokens spent across all reports in a month."
msgstr ""
"Plafond de sécurité sur le total des tokens dépensés pour l'ensemble des "
"rapports d'un mois."

#: templates/admin_audit/console/command_intel/provider.html
msgid "Rate limit / hour"
msgstr "Limite de débit / heure"

#: templates/admin_audit/console/command_intel/provider.html
msgid "Reports per hour — backs the breaker counter."
msgstr "Rapports par heure — alimente le compteur du disjoncteur."

#: templates/admin_audit/console/command_intel/provider.html
msgid "Repair attempts"
msgstr "Tentatives de réparation"

#: templates/admin_audit/console/command_intel/provider.html
msgid "Schema / grounding re-prompts on invalid structured output. Range 0–5."
msgstr ""
"Relances de prompt (schéma / ancrage) en cas de sortie structurée invalide. "
"Plage 0–5."

#: templates/admin_audit/console/command_intel/provider.html
msgid ""
"Restores the model, budgets and call discipline to the shipped defaults."
msgstr ""
"Rétablit le modèle, les budgets et la discipline d'appels aux valeurs par "
"défaut livrées."

