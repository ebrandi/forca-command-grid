msgstr "Impossible de lire les actifs de la corp : %(error)s"

#: apps/stockpile/assets.py
#, python-format
msgid ""
"Imported %(types)s asset stacks across %(locations)s locations from "
"%(character)s."
msgstr ""
"%(types)s lots d'actifs importés sur %(locations)s emplacements depuis "
