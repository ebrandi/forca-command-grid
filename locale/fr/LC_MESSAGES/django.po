msgstr ""
"Vous ne pouvez pas payer votre propre demande SRP — un autre officier doit "
"le faire."

#: apps/srp/views.py
msgid "That claim isn't approved and awaiting payment."
msgstr "Cette demande n'est pas approuvée et en attente de paiement."

