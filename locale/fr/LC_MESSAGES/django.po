#, python-format
msgid "Already in the library (identical name and fit) — skipped: %(names)s."
msgstr ""
"Déjà dans la bibliothèque (nom et fit identiques) — ignoré : %(names)s."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"A doctrine with this name already exists but with a different fit — rename "
"it and import again: %(names)s."
msgstr ""
"Une doctrine portant ce nom existe déjà mais avec un fit différent — "
"renommez-la et réimportez : %(names)s."

#: apps/admin_audit/console.py
msgid "Nothing imported — the selected fits couldn't be read."
msgstr "Rien n'a été importé — impossible de lire les fits sélectionnés."

#: apps/admin_audit/console.py
#, python-format
msgid "Couldn't parse the fit: %(error)s"
msgstr "Impossible d'analyser le fit : %(error)s"

#: apps/admin_audit/console.py
#, python-format
msgid "Unknown ship “%(ship)s” — check the first line."
msgstr "Vaisseau inconnu « %(ship)s » — vérifiez la première ligne."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"Doctrine “%(name)s” created from killmail (%(count)s skills derived). "
"Unresolved: %(lines)s."
msgstr ""
"Doctrine « %(name)s » créée à partir du killmail (%(count)s compétences "
"dérivées). Non résolu : %(lines)s."

#: apps/admin_audit/console.py
#, python-format
msgid "Doctrine “%(name)s” created from killmail (%(count)s skills derived)."
msgstr ""
"Doctrine « %(name)s » créée à partir du killmail (%(count)s compétences "
"dérivées)."

#: apps/admin_audit/console.py
#, python-format
msgid "Category “%(label)s” added."
msgstr "Catégorie « %(label)s » ajoutée."

#: apps/admin_audit/console.py
msgid "Manual — pilot checks it off"
msgstr "Manuel — le pilote le coche"

#: apps/admin_audit/console.py
msgid "Auto — a character is linked"
msgstr "Auto — un personnage est lié"

#: apps/admin_audit/console.py
msgid "Auto — verified corp member"
msgstr "Auto — membre du corp vérifié"

#: apps/admin_audit/console.py
msgid "Auto — skills imported"
msgstr "Auto — compétences importées"

#: apps/admin_audit/console.py
msgid "Auto — ESI scopes granted"
msgstr "Auto — scopes ESI accordés"

#: apps/admin_audit/console.py
msgid "Auto — skill trained to level"
msgstr "Auto — compétence entraînée au niveau"

#: apps/admin_audit/console.py
msgid "Auto — can fly a specific doctrine"
msgstr "Auto — peut piloter une doctrine spécifique"

#: apps/admin_audit/console.py
msgid "Auto — can fly ANY active doctrine"
msgstr "Auto — peut piloter N'IMPORTE QUELLE doctrine active"

#: apps/admin_audit/console.py apps/campaigns/views.py
msgid "A milestone needs a title."
msgstr "Un jalon a besoin d'un titre."

#: apps/admin_audit/console.py
msgid "Pick the doctrine this milestone checks."
msgstr "Choisissez la doctrine que ce jalon vérifie."

#: apps/admin_audit/console.py
msgid "That doctrine no longer exists."
msgstr "Cette doctrine n'existe plus."

#: apps/admin_audit/console.py
msgid "Skill milestones need a skill type id and a level (1–5)."
msgstr ""
"Les jalons de compétence nécessitent un identifiant de type de compétence et "
"un niveau (1–5)."

