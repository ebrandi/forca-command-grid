"Full walkthrough: <span class=\"font-mono text-cyan\">handbooks/"
"administrator-handbook/console-overview.md</span>"
msgstr ""
"Guide complet : <span class=\"font-mono text-cyan\">handbooks/administrator-"
"handbook/console-overview.md</span>"

