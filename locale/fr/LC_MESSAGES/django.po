#: apps/navigation/views.py
#, python-format
msgid ""
"Camp/incursion watch on for “%(name)s”. You'll be DMed when a threat appears "
"on it."
msgstr ""
"Surveillance camp/incursion activée pour « %(name)s ». Vous recevrez un DM "
"lorsqu'une menace y apparaît."

#: apps/navigation/views.py
#, python-format
