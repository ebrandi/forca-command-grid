#: apps/admin_audit/console.py
#, python-format
msgid "Imported %(count)d fit as new doctrines under IMPORTED."
msgid_plural "Imported %(count)d fits as new doctrines under IMPORTED."
msgstr[0] "%(count)d fit importé comme nouvelle doctrine sous IMPORTED."
msgstr[1] "%(count)d fits importés comme nouvelles doctrines sous IMPORTED."

#: apps/admin_audit/console_access.py
msgid "Enter a valid alliance id."
msgstr "Saisissez un id d'alliance valide."

#: apps/admin_audit/console_access.py
msgid "Partner alliance saved."
msgstr "Alliance partenaire enregistrée."

#: apps/admin_audit/console_access.py
msgid "Partner alliance removed."
msgstr "Alliance partenaire supprimée."

#: apps/admin_audit/console_access.py
msgid "Enter a valid corporation id."
msgstr "Saisissez un id de corporation valide."

#: apps/admin_audit/console_access.py
msgid "Friendly corporation saved."
msgstr "Corporation amie enregistrée."

#: apps/admin_audit/console_access.py
msgid "Friendly corporation removed."
msgstr "Corporation amie supprimée."

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings reset to defaults."
msgstr "Paramètres Capsuleer Path réinitialisés aux valeurs par défaut."

#: apps/admin_audit/console_capsuleer.py
msgid "Capsuleer Path settings saved."
msgstr "Paramètres Capsuleer Path enregistrés."

#: apps/admin_audit/console_combat.py
msgid "A rank title can't be empty."
msgstr "Un titre de rang ne peut pas être vide."

#: apps/admin_audit/console_combat.py
msgid "Reward amount can't be negative."
msgstr "Le montant de la récompense ne peut pas être négatif."

#: apps/admin_audit/console_combat.py
msgid "Another rank already uses this threshold for this metric."
msgstr "Un autre rang utilise déjà ce seuil pour cette métrique."

#: apps/admin_audit/console_combat.py
msgid ""
"Rewards apply to the all-time PvP kills track only — the support-role tracks"
" are recognition-only."
msgstr ""
"Les récompenses s'appliquent uniquement au parcours des kills PvP de tous "
"les temps — les parcours de rôle de soutien servent uniquement à la "
"reconnaissance."

#: apps/admin_audit/console_combat.py
msgid "Choose a reward type, or untick “grants reward”."
msgstr ""
"Choisissez un type de récompense, ou décochez “accorde une récompense”."

#: apps/admin_audit/console_combat.py
msgid "An item reward needs an EVE type id."
msgstr "Une récompense en objet nécessite un EVE type id."

#: apps/admin_audit/console_combat.py
msgid "An ISK/PLEX reward needs a positive amount."
msgstr "Une récompense en ISK/PLEX nécessite un montant positif."

#: apps/admin_audit/console_combat.py
msgid "Must be zero or positive."
msgstr "Doit être zéro ou positif."

#: apps/admin_audit/console_combat.py
msgid "Can't exceed 100%."
msgstr "Ne peut pas dépasser 100 %."

#: apps/admin_audit/console_combat.py
msgid "Newbro settings saved."
msgstr "Paramètres Newbro enregistrés."

#: apps/admin_audit/console_combat.py
msgid "Please correct the newbro settings."
msgstr "Veuillez corriger les paramètres newbro."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” saved."
msgstr "Rang “%(name)s” enregistré."

#: apps/admin_audit/console_combat.py apps/admin_audit/console_corporation.py
#: apps/admin_audit/console_industry.py apps/admin_audit/console_mentorship.py
#: apps/admin_audit/console_navigation.py
#: apps/admin_audit/console_pingboard.py apps/admin_audit/console_planetary.py
#: apps/admin_audit/console_raffle.py
msgid "Please correct the errors below."
msgstr "Veuillez corriger les erreurs ci-dessous."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Rank “%(name)s” removed."
msgstr "Rang “%(name)s” supprimé."

#: apps/admin_audit/console_combat.py
msgid "Reward settings saved."
msgstr "Paramètres de récompense enregistrés."

#: apps/admin_audit/console_combat.py
#, python-format
msgid ""
"Rewards enabled. Baseline snapshotted for %(n)d pilot(s) — only ranks "
"reached from now on will create rewards."
msgstr ""
"Récompenses activées. Instantané de référence pris pour %(n)d pilote(s) — "
"seuls les rangs atteints à partir de maintenant créeront des récompenses."

#: apps/admin_audit/console_combat.py
msgid "Rewards disabled. No new reward events will be created."
msgstr ""
"Récompenses désactivées. Aucun nouvel événement de récompense ne sera créé."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Baseline re-snapshotted for %(n)d pilot(s)."
msgstr "Nouvel instantané de référence pris pour %(n)d pilote(s)."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward scan complete — %(n)d new reward event(s) created."
msgstr ""
"Analyse des récompenses terminée — %(n)d nouveau(x) événement(s) de "
"récompense créé(s)."

#: apps/admin_audit/console_combat.py apps/buyback/views.py
#: apps/logistics/views.py apps/stockpile/views.py apps/store/views.py
msgid "Unknown action."
msgstr "Action inconnue."

#: apps/admin_audit/console_combat.py
msgid "Only a Director can mark a reward paid."
msgstr "Seul un Directeur peut marquer une récompense comme payée."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward %(action)s — %(character)s · %(rank)s."
msgstr "Récompense %(action)s — %(character)s · %(rank)s."

#: apps/admin_audit/console_command_intel.py
#, python-format
msgid "%(domain)s reset to defaults."
msgstr "%(domain)s réinitialisé aux valeurs par défaut."

#: apps/admin_audit/console_command_intel.py
msgid "Provider & model settings saved."
msgstr "Paramètres de fournisseur et de modèle enregistrés."

#: apps/admin_audit/console_command_intel.py
msgid "Critical ratio"
msgstr "Ratio critique"

#: apps/admin_audit/console_command_intel.py
msgid "Headroom/demand at or below this colours a constraint critical."
msgstr ""
"Une marge/demande égale ou inférieure à ce seuil colore une contrainte en "
"critique."

#: apps/admin_audit/console_command_intel.py
msgid "High ratio"
msgstr "Ratio élevé"

#: apps/admin_audit/console_command_intel.py
msgid "Above critical, at or below this colours it high."
msgstr ""
"Au-dessus de critique, une valeur égale ou inférieure à ce seuil la colore "
"en élevé."

#: apps/admin_audit/console_command_intel.py
msgid "Watch ratio"
msgstr "Ratio de surveillance"

#: apps/admin_audit/console_command_intel.py
msgid "Above high, at or below this colours it watch."
msgstr ""
"Au-dessus d'élevé, une valeur égale ou inférieure à ce seuil la colore en "
"surveillance."

#: apps/admin_audit/console_command_intel.py
msgid "Constraints & thresholds saved."
msgstr "Contraintes et seuils enregistrés."

#: apps/admin_audit/console_command_intel.py
msgid "Classification settings saved."
msgstr "Paramètres de classification enregistrés."

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Corporation Internal"
msgstr "Interne à la corporation"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "High Command"
msgstr "Haut commandement"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Director — Eyes Only"
msgstr "Directeur — pour ses yeux uniquement"

#: apps/admin_audit/console_command_intel.py apps/command_intel/models.py
msgid "Alliance Command"
msgstr "Commandement de l'alliance"

#: apps/admin_audit/console_command_intel.py
msgid "Notification & delivery settings saved."
msgstr "Paramètres de notification et d'acheminement enregistrés."

#: apps/admin_audit/console_command_intel.py
msgid "Autonomous proposal settings saved."
msgstr "Paramètres de proposition autonome enregistrés."

#: apps/admin_audit/console_command_intel.py
msgid "Auto-AAR settings saved."
msgstr "Paramètres Auto-AAR enregistrés."

#: apps/admin_audit/console_corporation.py
msgid "Low-fuel warning must be between 1 and 30 days."
msgstr "L'alerte de carburant bas doit être comprise entre 1 et 30 jours."

#: apps/admin_audit/console_corporation.py
msgid "ADM floor must be between 1.0 and 6.0."
msgstr "Le plancher ADM doit être compris entre 1.0 et 6.0."

#: apps/admin_audit/console_corporation.py
msgid "Structure-alert thresholds saved."
msgstr "Seuils d'alerte de structure enregistrés."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import rejected: %(error)s"
msgstr "Import rejeté : %(error)s"

#: apps/admin_audit/console_doctrine_xml.py
msgid "XML import applied."
msgstr "Import XML appliqué."

#: apps/admin_audit/console_doctrine_xml.py
msgid "Enter a whole number."
msgstr "Saisissez un nombre entier."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Limit set to %(clamped)s (values are kept within 1–%(ceiling)s)."
msgstr ""
"Limite définie à %(clamped)s (les valeurs restent comprises entre 1 et "
"%(ceiling)s)."

#: apps/admin_audit/console_doctrine_xml.py
#, python-format
msgid "Import limit set to %(clamped)s fittings."
msgstr "Limite d'import définie à %(clamped)s fittings."

#: apps/admin_audit/console_industry.py
msgid "Industry & Economy settings saved."
msgstr "Paramètres Industrie et Économie enregistrés."

#: apps/admin_audit/console_mentorship.py
msgid "Mentorship Program settings saved."
msgstr "Paramètres du programme de mentorat enregistrés."

#: apps/admin_audit/console_mentorship.py
msgid "Cohort saved."
msgstr "Cohorte enregistrée."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the cohort — check the values."
msgstr "Impossible d'enregistrer la cohorte — vérifiez les valeurs."

#: apps/admin_audit/console_mentorship.py
msgid "Cohort removed."
msgstr "Cohorte supprimée."

#: apps/admin_audit/console_mentorship.py
msgid "Track saved."
msgstr "Parcours enregistré."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the track — check the values."
msgstr "Impossible d'enregistrer le parcours — vérifiez les valeurs."

#: apps/admin_audit/console_mentorship.py
msgid "Track removed."
msgstr "Parcours supprimé."

#: apps/admin_audit/console_mentorship.py
msgid "Track cloned (as a draft)."
msgstr "Parcours cloné (en brouillon)."

#: apps/admin_audit/console_mentorship.py
msgid ""
"Criteria must be a JSON object, e.g. {\"type\": \"skill_min\", "
"\"skill_type_id\": 3300, \"level\": 3}."
msgstr ""
"Les critères doivent être un objet JSON, par ex. {\"type\": \"skill_min\", "
"\"skill_type_id\": 3300, \"level\": 3}."

#: apps/admin_audit/console_mentorship.py
msgid "Field exercise saved."
msgstr "Exercice de terrain enregistré."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the exercise — check the values."
msgstr "Impossible d'enregistrer l'exercice — vérifiez les valeurs."

#: apps/admin_audit/console_mentorship.py
msgid "Field exercise removed."
msgstr "Exercice de terrain supprimé."

#: apps/admin_audit/console_mentorship.py
msgid "Reward rule saved."
msgstr "Règle de récompense enregistrée."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the reward rule — check the values."
msgstr ""
"Impossible d'enregistrer la règle de récompense — vérifiez les valeurs."

#: apps/admin_audit/console_mentorship.py
msgid "Reward rule removed."
msgstr "Règle de récompense supprimée."

#: apps/admin_audit/console_mentorship.py
msgid "Badge saved."
msgstr "Badge enregistré."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't save the badge — check the values."
msgstr "Impossible d'enregistrer le badge — vérifiez les valeurs."

#: apps/admin_audit/console_mentorship.py
msgid "Badge removed."
msgstr "Badge supprimé."

#: apps/admin_audit/console_mentorship.py
msgid "Mentor application updated."
msgstr "Candidature de mentor mise à jour."

#: apps/admin_audit/console_mentorship.py
msgid "Cadet application updated."
msgstr "Candidature de cadet mise à jour."

#: apps/admin_audit/console_mentorship.py
msgid "Couldn't activate — the mentor may be at capacity."
msgstr "Impossible d'activer — le mentor est peut-être à pleine capacité."

#: apps/admin_audit/console_mentorship.py
msgid "Pairing updated."
msgstr "Binôme mis à jour."

#: apps/admin_audit/console_mentorship.py
msgid "Those two already have an open pairing."
msgstr "Ces deux-là ont déjà un binôme ouvert."

#: apps/admin_audit/console_mentorship.py
msgid "Pairing created."
msgstr "Binôme créé."

#: apps/admin_audit/console_mentorship.py
#, python-format
msgid "Generated %(count)s suggestion(s)."
msgstr "%(count)s suggestion(s) générée(s)."

#: apps/admin_audit/console_mentorship.py
msgid "You can't decide your own reward — another officer must."
msgstr ""
"Vous ne pouvez pas décider de votre propre récompense — un autre officier "
"doit le faire."

#: apps/admin_audit/console_mentorship.py
msgid "Reward updated."
msgstr "Récompense mise à jour."

#: apps/admin_audit/console_mentorship.py
msgid "You can't pay out your own reward — another officer must."
msgstr ""
"Vous ne pouvez pas verser votre propre récompense — un autre officier doit "
"le faire."

#: apps/admin_audit/console_mentorship.py
msgid "Marked paid."
msgstr "Marquée comme payée."

#: apps/admin_audit/console_mentorship.py
msgid "That reward isn't ready to pay."
msgstr "Cette récompense n'est pas prête à être payée."

#: apps/admin_audit/console_mentorship.py apps/admin_audit/console_raffle.py
msgid "Flag resolved."
msgstr "Signalement résolu."

#: apps/admin_audit/console_navigation.py
msgid "Safety margin must be between 0 and 100%."
msgstr "La marge de sécurité doit être comprise entre 0 et 100 %."

#: apps/admin_audit/console_navigation.py
msgid "Jump Planner settings saved."
msgstr "Paramètres du Jump Planner enregistrés."

#: apps/admin_audit/console_notifications.py
msgid "Unknown form."
msgstr "Formulaire inconnu."

#: apps/admin_audit/console_notifications.py
msgid "Leadership distribution saved."
msgstr "Répartition du leadership enregistrée."

#: apps/admin_audit/console_notifications.py
msgid "Notification settings saved."
msgstr "Paramètres de notification enregistrés."

#: apps/admin_audit/console_pingboard.py
msgid "General settings saved."
msgstr "Paramètres généraux enregistrés."

#: apps/admin_audit/console_pingboard.py
msgid "Anti-abuse settings saved."
msgstr "Paramètres anti-abus enregistrés."

#: apps/admin_audit/console_pingboard.py
msgid "Calendar settings saved."
msgstr "Paramètres du calendrier enregistrés."

#: apps/admin_audit/console_pingboard.py
msgid "Channel added."
msgstr "Canal ajouté."

#: apps/admin_audit/console_pingboard.py
msgid "Channel enabled."
msgstr "Canal activé."

#: apps/admin_audit/console_pingboard.py
msgid "Channel disabled."
msgstr "Canal désactivé."

#: apps/admin_audit/console_pingboard.py
msgid "Channel deleted."
msgstr "Canal supprimé."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Channel “%(label)s” saved and ready to send."
msgstr "Canal “%(label)s” enregistré et prêt à envoyer."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Channel “%(label)s” saved, but not operational yet: %(why)s"
msgstr "Canal “%(label)s” enregistré, mais pas encore opérationnel : %(why)s"

#: apps/admin_audit/console_pingboard.py
msgid "no provider implementation for this channel kind"
msgstr "aucune implémentation de fournisseur pour ce type de canal"

#: apps/admin_audit/console_pingboard.py
msgid "could not verify configuration"
msgstr "impossible de vérifier la configuration"

#: apps/admin_audit/console_pingboard.py
msgid "No provider implementation for this channel."
msgstr "Aucune implémentation de fournisseur pour ce canal."

#: apps/admin_audit/console_pingboard.py
msgid ""
"Can't send a test EVE-mail — your account has no linked character to receive"
" it. Link a character, or just send a real alert (delivery to the corp works"
" independently)."
msgstr ""
"Impossible d'envoyer un EVE-mail de test — votre compte n'a aucun personnage"
" lié pour le recevoir. Liez un personnage, ou envoyez simplement une vraie "
"alerte (l'acheminement vers la corp fonctionne indépendamment)."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Test mail sent to %(recipient)s — check your in-game inbox."
msgstr ""
"Mail de test envoyé à %(recipient)s — vérifiez votre boîte de réception en "
"jeu."

#: apps/admin_audit/console_pingboard.py
msgid "your character"
msgstr "votre personnage"

#: apps/admin_audit/console_pingboard.py
msgid "Test message sent."
msgstr "Message de test envoyé."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Test failed: %(error)s"
msgstr "Échec du test : %(error)s"

#: apps/admin_audit/console_pingboard.py
msgid "unknown error"
msgstr "erreur inconnue"

#: apps/admin_audit/console_pingboard.py
msgid "— none (use title/body below) —"
msgstr "— aucun (utilisez le titre/corps ci-dessous) —"

#: apps/admin_audit/console_pingboard.py
msgid "Condition must be a JSON object, e.g. {\"amount_gt\": 1000000000}."
msgstr ""
"La condition doit être un objet JSON, par ex. {\"amount_gt\": 1000000000}."

#: apps/admin_audit/console_pingboard.py
msgid "Audience must be a JSON object, e.g. {\"kind\": \"officer\"}."
msgstr "L'audience doit être un objet JSON, par ex. {\"kind\": \"officer\"}."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Unknown audience kind %(kind)r. Use one of: %(kinds)s."
msgstr "Type d'audience inconnu %(kind)r. Utilisez l'un de : %(kinds)s."

#: apps/admin_audit/console_pingboard.py
#, python-format
msgid "Audience role must be one of: %(roles)s."
msgstr "Le rôle d'audience doit être l'un de : %(roles)s."

#: apps/admin_audit/console_pingboard.py
msgid "Window must be at least 1 minute."
msgstr "La fenêtre doit être d'au moins 1 minute."

#: apps/admin_audit/console_pingboard.py
msgid "Cooldown can't be negative."
msgstr "Le délai de recharge ne peut pas être négatif."

#: apps/admin_audit/console_pingboard.py
msgid "Max per window can't be negative (0 = unlimited)."
msgstr "Le maximum par fenêtre ne peut pas être négatif (0 = illimité)."

#: apps/admin_audit/console_pingboard.py
msgid "Channels must be a JSON list of channel keys, e.g. [\"in_app\", \"discord\"]."
msgstr ""
"Les canaux doivent être une liste JSON de clés de canal, par ex. "
"[\"in_app\", \"discord\"]."

#: apps/admin_audit/console_pingboard.py
msgid "Rule updated."
msgstr "Règle mise à jour."

#: apps/admin_audit/console_pingboard.py
msgid "Rule created (disabled)."
msgstr "Règle créée (désactivée)."

#: apps/admin_audit/console_pingboard.py
msgid "Rule enabled."
msgstr "Règle activée."

#: apps/admin_audit/console_pingboard.py
msgid "Rule disabled."
msgstr "Règle désactivée."

#: apps/admin_audit/console_pingboard.py
msgid "Rule deleted."
msgstr "Règle supprimée."

#: apps/admin_audit/console_pingboard.py
msgid "Template created."
msgstr "Modèle créé."

#: apps/admin_audit/console_pingboard.py
msgid "Template enabled."
msgstr "Modèle activé."

#: apps/admin_audit/console_pingboard.py
msgid "Template disabled."
msgstr "Modèle désactivé."

#: apps/admin_audit/console_pingboard.py
msgid "Template deleted."
msgstr "Modèle supprimé."

#: apps/admin_audit/console_planetary.py
msgid "Planetary Industry settings saved."
msgstr "Paramètres Planetary Industry enregistrés."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Contest “%(name)s” created as a draft."
msgstr "Concours “%(name)s” créé en brouillon."

#: apps/admin_audit/console_raffle.py
msgid "Raffle settings saved."
msgstr "Paramètres de tombola enregistrés."

#: apps/admin_audit/console_raffle.py
msgid ""
"This contest has started accruing tickets (or is closed) — its schedule and "
"rules are locked; only the text/display fields were saved."
msgstr ""
"Ce concours a commencé à accumuler des tickets (ou est clôturé) — son "
"calendrier et ses règles sont verrouillés ; seuls les champs de "
"texte/d'affichage ont été enregistrés."

#: apps/admin_audit/console_raffle.py
msgid "Contest updated."
msgstr "Concours mis à jour."

#: apps/admin_audit/console_raffle.py
msgid "Only a Director can cancel a contest."
msgstr "Seul un Directeur peut annuler un concours."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Contest moved to %(status)s."
msgstr "Concours passé à %(status)s."

#: apps/admin_audit/console_raffle.py
msgid "That status change isn't allowed from the current state."
msgstr "Ce changement de statut n'est pas autorisé depuis l'état actuel."

#: apps/admin_audit/console_raffle.py
msgid "Templates can only be applied to a draft/scheduled contest."
msgstr ""
"Les modèles ne peuvent être appliqués qu'à un concours en "
"brouillon/planifié."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Applied the “%(key)s” template."
msgstr "Modèle “%(key)s” appliqué."

#: apps/admin_audit/console_raffle.py
msgid "Unknown template."
msgstr "Modèle inconnu."

#: apps/admin_audit/console_raffle.py
msgid "Prize saved."
msgstr "Lot enregistré."

#: apps/admin_audit/console_raffle.py
msgid "Prize removed."
msgstr "Lot supprimé."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "“%(source)s” source saved."
msgstr "Source “%(source)s” enregistrée."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Granted %(amount)s tickets to %(who)s."
msgstr "%(amount)s tickets accordés à %(who)s."

#: apps/admin_audit/console_raffle.py
msgid "Entry reversed (a correcting row was appended)."
msgstr "Écriture annulée (une ligne de correction a été ajoutée)."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid "Entry marked %(status)s."
msgstr "Écriture marquée %(status)s."

#: apps/admin_audit/console_raffle.py
msgid "Couldn't change that entry."
msgstr "Impossible de modifier cette écriture."

#: apps/admin_audit/console_raffle.py
msgid ""
" Only the top 200 pilots by tickets were considered — run again for more."
msgstr ""
" Seuls les 200 meilleurs pilotes par tickets ont été pris en compte — "
"relancez pour en avoir plus."

#: apps/admin_audit/console_raffle.py
msgid "Enrolment outreach is turned off in the notification console."
msgstr ""
"La relance d'inscription est désactivée dans la console de notifications."

#: apps/admin_audit/console_raffle.py
#, python-format
msgid ""
"Sent %(sent)s enrolment nudge(s); skipped %(skipped)s (already nudged, opted"
" out, now enrolled, or no linked account).%(capped)s"
msgstr ""
