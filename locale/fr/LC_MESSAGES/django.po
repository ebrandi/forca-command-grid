#, python-format
msgid "Doctrine “%(name)s” created — add a fit below."
msgstr "Doctrine « %(name)s » créée — ajoutez un fit ci-dessous."

#: apps/admin_audit/console.py
msgid "Doctrine updated."
msgstr "Doctrine mise à jour."

#: apps/admin_audit/console.py
msgid "Doctrine deleted."
msgstr "Doctrine supprimée."

#: apps/admin_audit/console.py
#, python-format
msgid "Couldn't parse the EFT: %(error)s"
msgstr "Impossible d'analyser l'EFT : %(error)s"

