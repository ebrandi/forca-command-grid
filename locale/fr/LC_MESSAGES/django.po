msgid "You can't approve your own role request — another director must."
msgstr ""
"Vous ne pouvez pas approuver votre propre demande de rôle — un autre "
"directeur doit le faire."

#: apps/admin_audit/console.py
#, python-format
msgid "%(role)s grant %(outcome)s for %(name)s."
msgstr "Attribution %(role)s %(outcome)s pour %(name)s."

#: apps/admin_audit/console.py apps/admin_audit/console_doctrine_xml.py
msgid "Enter a whole number."
msgstr "Saisissez un nombre entier."

#: apps/admin_audit/console.py
#, python-format
msgid "Page size set to %(clamped)s (kept within %(min)s–%(max)s)."
msgstr ""
"Taille de page réglée sur %(clamped)s (maintenue entre %(min)s et %(max)s)."

#: apps/admin_audit/console.py
#, python-format
msgid "Page size set to %(clamped)s per page."
msgstr "Taille de page réglée sur %(clamped)s par page."

#: apps/admin_audit/console.py
msgid "Give the doctrine a name."
msgstr "Donnez un nom à la doctrine."

