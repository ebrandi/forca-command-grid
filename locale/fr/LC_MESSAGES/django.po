#: apps/pingboard/messages.py
#, python-brace-format
msgid "Route watch: {route_name}"
msgstr "Surveillance de route : {route_name}"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"⚠ Route **{route_name}** ({origin_system} → {destination_system}) — "
"{threat_count} watched system(s) flagged (endpoints & waypoints only):\n"
"{details}\n"
"Risk indicator, not a guarantee — this doesn't cover every gate hop. Scout "
"before you undock."
msgstr ""
"⚠ Route **{route_name}** ({origin_system} → {destination_system}) — "
"{threat_count} système(s) surveillé(s) signalé(s) (extrémités et waypoints "
"uniquement) :\n"
"{details}\n"
"Indicateur de risque, pas une garantie — tous les sauts de gate ne sont pas "
"couverts. Envoyez un scout avant de sortir de station."

#: apps/pingboard/messages.py
msgid "Haul deadline approaching"
msgstr "Échéance de transport imminente"

#: apps/pingboard/messages.py
#, python-brace-format
