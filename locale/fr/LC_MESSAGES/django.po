#, python-format
msgid ""
"Fit “%(name)s” added (%(count)s skill requirements derived). Unresolved "
"lines: %(lines)s."
msgstr ""
"Fit « %(name)s » ajouté (%(count)s prérequis de compétence dérivés). Lignes "
"non résolues : %(lines)s."

#: apps/admin_audit/console.py
#, python-format
msgid "Fit “%(name)s” added (%(count)s skill requirements derived)."
msgstr "Fit « %(name)s » ajouté (%(count)s prérequis de compétence dérivés)."

#: apps/admin_audit/console.py
msgid "Fit removed."
msgstr "Fit supprimé."

#: apps/admin_audit/console.py
msgid "Pick a valid requirement type."
msgstr "Choisissez un type de prérequis valide."

#: apps/admin_audit/console.py
msgid "A note needs some text."
msgstr "Une note doit contenir du texte."

#: apps/admin_audit/console.py
msgid "This requirement needs a type id (or record it as a note)."
msgstr ""
"Ce prérequis nécessite un identifiant de type (ou enregistrez-le comme note)."

#: apps/admin_audit/console.py
msgid "Requirement added."
msgstr "Prérequis ajouté."

#: apps/admin_audit/console.py
msgid "Requirement removed."
msgstr "Prérequis supprimé."

#: apps/admin_audit/console.py
msgid "Tick at least one fit to import."
msgstr "Cochez au moins un fit à importer."

#: apps/admin_audit/console.py
#, python-format
msgid "Imported %(count)d fit as new doctrines under IMPORTED."
msgid_plural "Imported %(count)d fits as new doctrines under IMPORTED."
msgstr[0] "%(count)d fit importé comme nouvelle doctrine sous IMPORTED."
msgstr[1] "%(count)d fits importés comme nouvelles doctrines sous IMPORTED."

