#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't enter high-sec (no stargate access and no cyno in high-"
"sec), so neither the high-sec origin nor the high-sec destination can be "
"reached. Choose a low-sec or null-sec system."
msgstr ""
"Un %(ship)s ne peut pas entrer en high-sec (pas d'accès stargate et pas de "
"cyno en high-sec) : ni l'origine high-sec ni la destination high-sec ne sont "
"atteignables. Choisissez un système low-sec ou null-sec."

#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't enter high-sec (no stargate access and no cyno in high-"
"sec), so the high-sec destination can't be reached. Choose a low-sec or null-"
"sec system."
msgstr ""
"Un %(ship)s ne peut pas entrer en high-sec (pas d'accès stargate et pas de "
"cyno en high-sec) : la destination high-sec n'est donc pas atteignable. "
"Choisissez un système low-sec ou null-sec."

#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't enter high-sec (no stargate access and no cyno in high-"
"sec), so the high-sec origin can't be reached. Choose a low-sec or null-sec "
"system."
msgstr ""
"Un %(ship)s ne peut pas entrer en high-sec (pas d'accès stargate et pas de "
"cyno en high-sec) : l'origine high-sec n'est donc pas atteignable. "
"Choisissez un système low-sec ou null-sec."

#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't cyno into or out of high-sec: gate out of the high-sec "
"origin to a low-sec entry, jump, then gate to the high-sec destination."
msgstr ""
"Un %(ship)s ne peut pas cyno vers ou depuis le high-sec : sortez de "
"l'origine high-sec par les gates jusqu'à une entrée low-sec, sautez, puis "
"prenez les gates jusqu'à la destination high-sec."

#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't cyno directly into high-sec: jump to a low-sec exit near "
"the destination, then take stargates the rest of the way."
msgstr ""
"Un %(ship)s ne peut pas cyno directement en high-sec : sautez vers une "
"sortie low-sec près de la destination, puis prenez les stargates pour le "
"reste du trajet."

#: apps/navigation/route_mode.py
#, python-format
msgid ""
"A %(ship)s can't light a cyno in high-sec: gate out of the high-sec origin "
"to a low-sec staging system, then jump from there."
msgstr ""
"Un %(ship)s ne peut pas allumer de cyno en high-sec : sortez de l'origine "
"high-sec par les gates jusqu'à un système de staging low-sec, puis sautez "
"depuis là."

