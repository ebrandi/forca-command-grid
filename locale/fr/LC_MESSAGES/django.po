msgstr ""
"Seul un mentor actif d'un objectif partagé avec le mentor peut l'avaliser."

#: apps/capsuleer/services.py
msgid "Only an officer can endorse an officers-shared goal milestone."
msgstr ""
"Seul un officier peut avaliser le jalon d'un objectif partagé avec les "
"officiers."

#: apps/capsuleer/services.py
msgid "This milestone does not take endorsements."
msgstr "Ce jalon n'accepte pas d'avals."

#: apps/capsuleer/services.py
msgid "The milestone is already complete; the owner must reopen it."
msgstr "Le jalon est déjà terminé ; le propriétaire doit le rouvrir."

#: apps/capsuleer/services.py
msgid "Only the goal owner can create a corp task."
msgstr ""
"Seul le propriétaire de l'objectif peut créer une tâche de corporation."

#: apps/capsuleer/services.py
msgid "Only an open step can become a corp task."
msgstr "Seule une étape ouverte peut devenir une tâche de corporation."

#: apps/capsuleer/services.py
msgid "The corp task board is not enabled."
msgstr "Le tableau des tâches de corporation n'est pas activé."

#: apps/capsuleer/services.py
