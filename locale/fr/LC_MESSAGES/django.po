#, python-format
msgid ""
"Cannot compute max %(doctrine)s fleet: %(missing)s missing from the doctrine "
"slice."
msgstr ""
"Impossible de calculer la flotte %(doctrine)s max : %(missing)s manquant "
"dans la tranche doctrine."

#: apps/command_intel/messages.py
#, python-format
msgid ""
"%(structure)s runs out of fuel in %(days)s day(s) — the soonest of %(count)s "
"low-fuel structure(s); watch margin is %(watch)s days."
msgstr ""
"%(structure)s tombe en panne de carburant dans %(days)s jour(s) — la plus "
"proche parmi %(count)s structure(s) à carburant bas ; la marge de "
"surveillance est de %(watch)s jours."

#: apps/command_intel/messages.py
msgid "No structures are running low on fuel."
msgstr "Aucune structure n'est à court de carburant."

#: apps/command_intel/messages.py
msgid "Cannot compute fuel runway: infrastructure slice has no structure data."
msgstr ""
"Impossible de calculer l'autonomie en carburant : la tranche infrastructure "
"ne contient aucune donnée de structure."

#: apps/command_intel/messages.py
msgid "Cannot compute fuel runway: no structure reported fuel_days_left."
msgstr ""
"Impossible de calculer l'autonomie en carburant : aucune structure n'a "
"remonté fuel_days_left."

#: apps/command_intel/messages.py
#, python-format
msgid ""
"%(days)s days of runway at the current burn (%(balance)s balance ÷ %(burn)s/"
"day net outflow); target is %(target)s days."
msgstr ""
"%(days)s jours d'autonomie au rythme de dépense actuel (solde %(balance)s ÷ "
"sortie nette de %(burn)s/jour) ; la cible est de %(target)s jours."

#: apps/command_intel/messages.py
msgid "30-day net cashflow is positive — no ISK runway constraint."
msgstr ""
"Le flux de trésorerie net sur 30 jours est positif — aucune contrainte "
"d'autonomie en ISK."

#: apps/command_intel/messages.py
msgid "Cannot compute ISK runway: wallet balance or 30-day net missing."
msgstr ""
"Impossible de calculer l'autonomie en ISK : solde du portefeuille ou net sur "
"30 jours manquant."

#: apps/command_intel/messages.py
#, python-format
msgid ""
"SRP can sustain %(months)s month(s) of payouts: (%(budget)s budget − "
"%(liability)s open liability) ÷ %(spent)s period spend; target is %(target)s "
"month(s)."
msgstr ""
"Le SRP peut couvrir %(months)s mois de versements : (budget %(budget)s − "
"engagements ouverts %(liability)s) ÷ dépense sur la période %(spent)s ; la "
"cible est de %(target)s mois."

#: apps/command_intel/messages.py
msgid ""
"Cannot compute SRP solvency: budget, open liability or period spend missing."
msgstr ""
"Impossible de calculer la solvabilité SRP : budget, engagements ouverts ou "
"dépense de la période manquants."

