msgid ""
"Comma-separated PI product names the corp wants pilots to make (e.g. "
"Coolant, Mechanical Parts, Robotics). They get a badge in the "
"recommendations."
msgstr ""
"Noms de produits PI (séparés par des virgules) que la corp veut voir "
"fabriquer par les pilotes (p. ex. Coolant, Mechanical Parts, Robotics). Ils "
"obtiennent un badge dans les recommandations."

#: apps/planetary/forms.py
msgid "e.g. lowsec staging, home constellation"
msgstr "p. ex. staging lowsec, constellation d'attache"

#: apps/planetary/forms.py
