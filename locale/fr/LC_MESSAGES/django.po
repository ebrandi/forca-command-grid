"%(n)d scope(s) are no longer granted and have been marked inactive.%(deep)s"
msgstr ""
"%(n)d scope(s) ne sont plus accordés et ont été marqués comme "
"inactifs.%(deep)s"

#: apps/sso/views.py
#, python-format
msgid "%(n)d scope(s) reconciled.%(deep)s"
msgstr "%(n)d scope(s) réconciliés.%(deep)s"

#: apps/sso/views.py
#, python-format
msgid "Your access is in sync.%(deep)s"
msgstr "Votre accès est synchronisé.%(deep)s"

#: apps/sso/views.py
msgid "Not your character."
msgstr "Ce n'est pas votre personnage."

#: apps/stockpile/assets.py
msgid ""
"No Director has granted corp-asset access yet. A CEO/Director must re-"
"authorise with the corp-assets scope."
msgstr ""
"Aucun Director n'a encore accordé l'accès aux actifs de la corp. Un "
"CEO/Director doit ré-autoriser avec le scope corp-assets."

#: apps/stockpile/assets.py
#, python-format
