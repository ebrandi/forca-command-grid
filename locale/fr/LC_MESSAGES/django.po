#, python-format
msgid ""
"Max %(doctrine)s fleet = %(binding)s pilots, limited by %(factor)s "
"(%(flyable)s qualified, %(hulls)s hulls staged) (no demand target set)."
msgstr ""
"Flotte %(doctrine)s max = %(binding)s pilotes, limitée par %(factor)s "
"(%(flyable)s qualifiés, %(hulls)s hulls au staging) (aucune cible de demande "
"définie)."

