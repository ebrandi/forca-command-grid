msgstr "Résultats pour « %(query)s »"

#: templates/admin_audit/console/recovery.html
msgid "Linked to"
msgstr "Lié à"

#: templates/admin_audit/console/recovery.html
msgid "Owner hash"
msgstr "Hash de propriétaire"

#: templates/admin_audit/console/recovery.html
msgid "Tokens"
msgstr "Jetons"

#: templates/admin_audit/console/recovery.html
msgid "Detach"
msgstr "Détacher"

#: templates/admin_audit/console/recovery.html
msgid "— unlinked"
msgstr "— délié"

#: templates/admin_audit/console/recovery.html
msgid "present"
msgstr "présent"

#: templates/admin_audit/console/recovery.html
msgid "Director-linked — a Director must detach."
msgstr "Lié à un Directeur — seul un Directeur peut le détacher."

#: templates/admin_audit/console/recovery.html
#, python-format
