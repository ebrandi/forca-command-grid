#: apps/capsuleer/params.py
#, python-format
msgid "%(name)s must be a positive integer."
msgstr "%(name)s doit être un entier positif."

#: apps/capsuleer/params.py
msgid "skill_target.skills must be a list of 1-25 entries."
msgstr "skill_target.skills doit être une liste de 1 à 25 entrées."

#: apps/capsuleer/params.py
msgid "skill_target.skills entries take only type_id and level."
msgstr "Les entrées de skill_target.skills n'acceptent que type_id et level."

#: apps/capsuleer/params.py
msgid "skill_target.skills[].level must be an int in 1-5."
msgstr "skill_target.skills[].level doit être un entier de 1 à 5."

#: apps/capsuleer/params.py
msgid "doctrine_ready.resolver must be 'category' or 'key'."
msgstr "doctrine_ready.resolver doit être 'category' ou 'key'."

#: apps/capsuleer/params.py
msgid "doctrine_ready.unresolved must be a boolean."
msgstr "doctrine_ready.unresolved doit être un booléen."

#: apps/capsuleer/params.py
msgid "doctrine_ready.tier must be 'viable' or 'optimal'."
msgstr "doctrine_ready.tier doit être 'viable' ou 'optimal'."

#: apps/capsuleer/params.py
msgid "ship_owned.type_ids must be a non-empty list."
msgstr "ship_owned.type_ids doit être une liste non vide."

#: apps/capsuleer/params.py
msgid "ship_owned.require_fitted must be a boolean."
msgstr "ship_owned.require_fitted doit être un booléen."

#: apps/capsuleer/params.py
msgid "contribution.baseline_count is system-managed, not author-supplied."
msgstr ""
"contribution.baseline_count est géré par le système, non fourni par l'auteur."

#: apps/capsuleer/params.py
msgid "contribution.kinds must be a non-empty list of strings."
msgstr "contribution.kinds doit être une liste non vide de chaînes."

#: apps/capsuleer/params.py
msgid "combat_first.milestone_key must be a non-empty string."
msgstr "combat_first.milestone_key doit être une chaîne non vide."

#: apps/capsuleer/params.py
msgid "practical.instructions must be a string of at most 500 chars."
msgstr "practical.instructions doit être une chaîne d'au plus 500 caractères."

#: apps/capsuleer/params.py
msgid "practical.evidence_hint must be a string of at most 200 chars."
msgstr "practical.evidence_hint doit être une chaîne d'au plus 200 caractères."

#: apps/capsuleer/params.py
msgid "practical.link must be a string of at most 200 chars."
msgstr "practical.link doit être une chaîne d'au plus 200 caractères."

