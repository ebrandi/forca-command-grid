msgstr ""
"Vous ne pouvez pas attribuer de tickets de tombola à votre propre compte."

#: apps/raffle/services.py
#, python-format
msgid ""
"%(reason)s Ask them to enrol in FORCA Command Grid and connect their ESI "
"token first."
msgstr ""
"%(reason)s Demandez-leur de s'inscrire d'abord à FORCA Command Grid et de "
"connecter leur token ESI."

