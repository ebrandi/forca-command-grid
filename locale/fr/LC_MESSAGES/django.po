#: apps/srp/models.py
msgid ""
"Lose a doctrine ship on a fleet op and the corp helps you replace it. Submit "
"a claim from your eligible losses below and an officer reviews it."
msgstr ""
"Perdez un vaisseau de doctrine lors d'une op de flotte et la corp vous aide "
"à le remplacer. Soumettez une demande à partir de vos pertes éligibles ci-"
"dessous et un officier l'examinera."

#: apps/srp/models.py
msgid "Replacement ship & fit"
msgstr "Vaisseau & fit de remplacement"

#: apps/srp/models.py
msgid "ISK — full loss value"
msgstr "ISK — valeur totale de la perte"

#: apps/srp/models.py
msgid "ISK — top up official insurance"
msgstr "ISK — complément de l'assurance officielle"

#: apps/srp/models.py
msgid "Actual loss (hull + destroyed modules)"
msgstr "Perte réelle (hull + modules détruits)"

#: apps/srp/models.py
