#: apps/capsuleer/services.py
msgid "A goal needs a title."
msgstr "목표에는 제목이 필요합니다."

#: apps/capsuleer/services.py
#, python-format
msgid "Unknown goal type: %(value)s."
msgstr "알 수 없는 목표 유형: %(value)s."

#: apps/capsuleer/services.py
msgid "A new goal starts as considering or active."
msgstr "새 목표는 검토 중 또는 활성 상태로 시작합니다."

#: apps/capsuleer/services.py
#, python-format
msgid "Unknown priority: %(value)s."
msgstr "알 수 없는 우선순위: %(value)s."

#: apps/capsuleer/services.py
#, python-format
msgid "Unknown pace: %(value)s."
msgstr "알 수 없는 진행 속도: %(value)s."

#: apps/capsuleer/services.py
msgid "That character does not belong to you."
msgstr "해당 캐릭터는 당신의 것이 아닙니다."

#: apps/capsuleer/services.py
msgid "Budget cannot be negative."
msgstr "예산은 음수일 수 없습니다."

#: apps/capsuleer/services.py
#, python-format
msgid "Unknown visibility: %(value)s."
msgstr "알 수 없는 공개 범위: %(value)s."

#: apps/capsuleer/services.py
#, python-format
msgid ""
"You already have %(max)d active goals — archive one before adding another."
msgstr "이미 활성 목표가 %(max)d개 있습니다 — 새로 추가하기 전에 하나를 보관하세요."

#: apps/capsuleer/services.py
#, python-format
msgid "Unknown status: %(value)s."
msgstr "알 수 없는 상태: %(value)s."

#: apps/capsuleer/services.py
msgid "Only the goal owner can change its status."
msgstr "목표 소유자만 상태를 변경할 수 있습니다."

#: apps/capsuleer/services.py
msgid "That status change is not allowed from the goal's current state."
msgstr "목표의 현재 상태에서는 해당 상태 변경이 허용되지 않습니다."

#: apps/capsuleer/services.py
msgid ""
"Complete a goal when its required milestones are done, or supply an override"
" reason."
msgstr "필수 마일스톤이 완료되면 목표를 완료하거나, 재정의 사유를 입력하세요."

#: apps/capsuleer/services.py
msgid "Only the goal owner can change its visibility."
msgstr "목표 소유자만 공개 범위를 변경할 수 있습니다."

#: apps/capsuleer/services.py
msgid "Only the goal owner can edit its milestones."
msgstr "목표 소유자만 마일스톤을 편집할 수 있습니다."

#: apps/capsuleer/services.py
msgid ""
"This goal is finished — reopen it before changing its milestones or steps."
msgstr "이 목표는 완료되었습니다 — 마일스톤이나 단계를 변경하려면 먼저 다시 여세요."

#: apps/capsuleer/services.py
#, python-format
msgid "A goal cannot hold more than %(max)d milestones."
msgstr "목표는 마일스톤을 %(max)d개 넘게 가질 수 없습니다."

#: apps/capsuleer/services.py
msgid "Unskip this milestone before completing it."
msgstr "완료하기 전에 이 마일스톤의 건너뛰기를 해제하세요."

#: apps/capsuleer/services.py
msgid "Automatic milestones are credited by verification, not by hand."
msgstr "자동 마일스톤은 수동이 아닌 검증으로 인정됩니다."

#: apps/capsuleer/services.py
msgid "This milestone needs a matching endorsement before completion."
msgstr "이 마일스톤은 완료 전에 일치하는 보증이 필요합니다."

#: apps/capsuleer/services.py
msgid "Automatically credited milestones cannot be reopened."
msgstr "자동으로 인정된 마일스톤은 다시 열 수 없습니다."

#: apps/capsuleer/services.py
msgid "That milestone is not part of this goal."
msgstr "해당 마일스톤은 이 목표의 일부가 아닙니다."

#: apps/capsuleer/services.py
msgid "You cannot endorse your own milestone."
msgstr "자신의 마일스톤은 보증할 수 없습니다."

#: apps/capsuleer/services.py
msgid "Only an active mentor of a mentor-shared goal can endorse this."
msgstr "멘토 공유 목표의 활성 멘토만 이를 보증할 수 있습니다."

#: apps/capsuleer/services.py
msgid "Only an officer can endorse an officers-shared goal milestone."
msgstr "장교만 장교 공유 목표 마일스톤을 보증할 수 있습니다."

#: apps/capsuleer/services.py
msgid "This milestone does not take endorsements."
msgstr "이 마일스톤은 보증을 받지 않습니다."

#: apps/capsuleer/services.py
msgid "The milestone is already complete; the owner must reopen it."
msgstr "마일스톤이 이미 완료되었습니다. 소유자가 다시 열어야 합니다."

#: apps/capsuleer/services.py
