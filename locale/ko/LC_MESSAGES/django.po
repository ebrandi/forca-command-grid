msgstr ""
"화물 묶음 {origin_system} → {destination_system} 의 ETA 가 {eta_date} 로 늦춰졌습니다."

#: apps/pingboard/messages.py
msgid "Moon chunk arriving soon"
msgstr "달 청크 도착 임박"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"The moon chunk at {structure_name} is ready to fracture in about {hours}h — "
