msgstr "{ship_name} 주문이 확보되었습니다 — 멤버가 처리 중입니다."

#: apps/pingboard/messages.py
msgid "Order update: Deposit paid"
msgstr "주문 업데이트: 보증금 지불됨"

#: apps/pingboard/messages.py
