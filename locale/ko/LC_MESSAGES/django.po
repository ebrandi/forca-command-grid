msgid "Ticket accrual opens."
msgstr "티켓 적립 시작."

#: apps/raffle/models.py
msgid "Ticket accrual closes."
msgstr "티켓 적립 종료."

#: apps/raffle/models.py
msgid "Winners are drawn."
msgstr "당첨자가 추첨됩니다."

#: apps/raffle/models.py
msgid "Only pilots enrolled in FORCA earn tickets (strongly recommended)."
msgstr "FORCA에 등록된 파일럿만 티켓을 적립합니다 (강력 권장)."

