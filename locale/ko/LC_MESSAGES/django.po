msgstr "디렉터만 보상을 지급 완료로 표시할 수 있습니다."

#: apps/admin_audit/console_combat.py
#, python-format
msgid "Reward %(action)s — %(character)s · %(rank)s."
msgstr "보상 %(action)s — %(character)s · %(rank)s."

