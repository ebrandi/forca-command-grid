#: apps/capsuleer/params.py
#, python-format
msgid "%(where)s params must be an object."
msgstr "%(where)s의 params는 객체여야 합니다."

#: apps/capsuleer/params.py
#, python-format
msgid "%(where)s: unexpected params key(s): %(keys)s."
msgstr "%(where)s: 예기치 않은 params 키: %(keys)s."

#: apps/capsuleer/params.py
#, python-format
msgid "%(where)s: missing params key(s): %(keys)s."
msgstr "%(where)s: 누락된 params 키: %(keys)s."

#: apps/capsuleer/params.py
#, python-format
msgid "%(name)s must be a positive integer."
msgstr "%(name)s은(는) 양의 정수여야 합니다."

#: apps/capsuleer/params.py
msgid "skill_target.skills must be a list of 1-25 entries."
msgstr "skill_target.skills는 1~25개 항목의 리스트여야 합니다."

#: apps/capsuleer/params.py
msgid "skill_target.skills entries take only type_id and level."
msgstr "skill_target.skills 항목은 type_id와 level만 사용합니다."

#: apps/capsuleer/params.py
msgid "skill_target.skills[].level must be an int in 1-5."
msgstr "skill_target.skills[].level은 1~5 사이의 정수여야 합니다."

#: apps/capsuleer/params.py
msgid "doctrine_ready.resolver must be 'category' or 'key'."
msgstr "doctrine_ready.resolver는 'category' 또는 'key'여야 합니다."

#: apps/capsuleer/params.py
msgid "doctrine_ready.unresolved must be a boolean."
msgstr "doctrine_ready.unresolved는 불리언이어야 합니다."

#: apps/capsuleer/params.py
msgid "doctrine_ready.tier must be 'viable' or 'optimal'."
msgstr "doctrine_ready.tier는 'viable' 또는 'optimal'이어야 합니다."

#: apps/capsuleer/params.py
msgid "ship_owned.type_ids must be a non-empty list."
msgstr "ship_owned.type_ids는 비어 있지 않은 리스트여야 합니다."

#: apps/capsuleer/params.py
msgid "ship_owned.require_fitted must be a boolean."
msgstr "ship_owned.require_fitted는 불리언이어야 합니다."

#: apps/capsuleer/params.py
msgid "contribution.baseline_count is system-managed, not author-supplied."
msgstr "contribution.baseline_count는 시스템이 관리하며, 작성자가 지정할 수 없습니다."

#: apps/capsuleer/params.py
msgid "contribution.kinds must be a non-empty list of strings."
msgstr "contribution.kinds는 비어 있지 않은 문자열 리스트여야 합니다."

#: apps/capsuleer/params.py
msgid "combat_first.milestone_key must be a non-empty string."
msgstr "combat_first.milestone_key는 비어 있지 않은 문자열이어야 합니다."

#: apps/capsuleer/params.py
msgid "practical.instructions must be a string of at most 500 chars."
msgstr "practical.instructions는 최대 500자의 문자열이어야 합니다."

#: apps/capsuleer/params.py
msgid "practical.evidence_hint must be a string of at most 200 chars."
msgstr "practical.evidence_hint는 최대 200자의 문자열이어야 합니다."

#: apps/capsuleer/params.py
msgid "practical.link must be a string of at most 200 chars."
msgstr "practical.link는 최대 200자의 문자열이어야 합니다."

#: apps/capsuleer/params.py
#, python-format
msgid "Unknown verification mode: %(value)s."
msgstr "알 수 없는 검증 모드: %(value)s."

#: apps/capsuleer/params.py
#, python-format
msgid "'%(kind)s' milestones cannot use automatic verification."
msgstr "'%(kind)s' 마일스톤은 자동 검증을 사용할 수 없습니다."

#: apps/capsuleer/params.py
#, python-format
msgid "Unknown milestone kind: %(value)s."
msgstr "알 수 없는 마일스톤 종류: %(value)s."

