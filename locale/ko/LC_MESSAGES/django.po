msgstr "미정"

#: apps/operations/models.py
msgid "Too few sign-ups"
msgstr "신청자 부족"

#: apps/operations/models.py
msgid "Doctrine composition not met"
msgstr "doctrine 구성 미충족"

#: apps/operations/models.py
msgid "Cancelled by organiser"
msgstr "주최자에 의해 취소됨"

