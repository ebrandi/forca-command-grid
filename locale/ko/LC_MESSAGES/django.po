#: templates/admin_audit/console/pingboard/channel_form.html
msgid ""
"Discord → <span class=\"text-ink\">Server Settings → Integrations → Webhooks"
" → New Webhook</span>. Pick the target channel, <span class=\"text-"
"ink\">Copy Webhook URL</span>, and paste it above."
msgstr ""
