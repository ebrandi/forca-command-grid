msgstr "EFT를 파싱할 수 없습니다: %(error)s"

#: apps/admin_audit/console.py
#, python-format
msgid "Unknown ship “%(ship)s” — check the EFT header."
msgstr "알 수 없는 함선 “%(ship)s” — EFT 헤더를 확인하세요."

#: apps/admin_audit/console.py
#, python-format
msgid ""
"Fit “%(name)s” added (%(count)s skill requirements derived). Unresolved "
"lines: %(lines)s."
msgstr ""
"Fit “%(name)s”이(가) 추가되었습니다 (%(count)s개의 스킬 요구사항 도출됨). 해결되지 않은 줄: %(lines)s."

#: apps/admin_audit/console.py
#, python-format
msgid "Fit “%(name)s” added (%(count)s skill requirements derived)."
msgstr "Fit “%(name)s”이(가) 추가되었습니다 (%(count)s개의 스킬 요구사항 도출됨)."

#: apps/admin_audit/console.py
msgid "Fit removed."
msgstr "Fit이(가) 제거되었습니다."

#: apps/admin_audit/console.py
msgid "Pick a valid requirement type."
msgstr "유효한 요구사항 유형을 선택하세요."

