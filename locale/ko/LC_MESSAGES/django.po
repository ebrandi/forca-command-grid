#: apps/pingboard/messages.py
msgid "Freight batch delayed"
msgstr "화물 묶음 지연"

#: apps/pingboard/messages.py
#, python-brace-format
msgid ""
"Freight batch {origin_system} → {destination_system} slipped its ETA to "
