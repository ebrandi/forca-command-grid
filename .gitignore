# ─────────────────────────────────────────────────────────────
/data/
*.sqlite
*.sqlite3
*.db.gz
*.zip

# ─────────────────────────────────────────────────────────────
#  Database dumps & editor leftovers — the classic accidental commit
# ─────────────────────────────────────────────────────────────
*.sql
*.sql.gz
*.dump
*.bak
*.backup
*.orig
*.rej
*.pid

# ─────────────────────────────────────────────────────────────
#  OS
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Generated at package/deploy time — the deployed commit hash for the footer.
.git-commit

# ─────────────────────────────────────────────────────────────
#  Deployment — local operational artifacts (never commit)
# ─────────────────────────────────────────────────────────────
# Database dumps written by scripts/backup.sh
/backups/
# TLS material (keys already covered by *.key/*.pem; also exclude the cert + dir)
/certs/
*.crt
# Local EVE image mirror if bind-mounted instead of a named volume
/eveimg/

# Local AI/agent tooling state
.omc/
.claude/

# Generated by `make sbom`
sbom.cdx.json

# Written by scripts/rollback.sh
.rollback-from

# ─────────────────────────────────────────────────────────────
#  Localisation
# ─────────────────────────────────────────────────────────────
# Compiled gettext catalogues — build artifacts compiled from the tracked .po
# sources into the image / by CI (docs/i18n/design/11-catalogue-maintenance.md).
# The .po files under locale/ ARE tracked.
*.mo
# Scratch dir for the machine-translation drafting pipeline (not source).
.i18n_work/

# Temporary documentation
docs/
